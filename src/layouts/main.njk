{% import "macros/i18n.njk" as i18n with context %}
{% import "macros/seo.njk" as seo %}

<!DOCTYPE html>
<html lang="{{ lang }}" dir="ltr" class="scroll-smooth i18n-loading">
  <head>
    {{ seo.render_tags(page, global) }}

    {% block resource_hints %}
      <link rel="preload" href="/assets/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous">
      {{ clientI18nScript | safe }}
    {% endblock %}

    <style>
      /* State 1: Saat Loading - Mencegah Fluktuasi Skor LCP */
      html.i18n-loading [data-i18n] {
        color: transparent !important;
        background-color: rgba(255,255,255,0.05);
        border-radius: 4px;
        opacity: 1 !important;
        visibility: visible !important;
        transition: none !important;
      }

      /* State 2: Saat Atribut Berubah */
      html.i18n-loading [data-i18n-attr] {
        color: inherit !important;
        background-color: transparent !important;
      }

      /* State 3: Saat Ready */
      html.i18n-ready [data-i18n] {
        color: inherit;
        background-color: transparent;
        transition: color 0.2s ease, background-color 0.2s ease;
      }

      /* UPDATE: Tambahkan font-family khusus untuk karakter Asia (JP/CN) jika diperlukan */
      @font-face {
        font-family: 'Inter';
        font-display: swap;
      }

      /* UPDATE: Tambahkan CSS agar transisi RTL smooth */
      [dir="rtl"] {
        text-align: right;
      }

      ::-webkit-scrollbar {
        width: 10px;
      }
      ::-webkit-scrollbar-track {
        background: #020617;
      }
      ::-webkit-scrollbar-thumb {
        background: #1e293b;
        border-radius: 5px;
        border: 2px solid #020617;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #334155;
      }

      [x-cloak] {
        display: none !important;
      }
    </style>

    {% block extra_head %}{% endblock %}
  </head>

  <body class="min-h-screen bg-slate-950 text-slate-200 antialiased font-sans selection:bg-violet-500/30 selection:text-violet-200" data-page="{{ page_id }}">

    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(15,23,42,0)_0%,rgba(2,6,23,1)_100%)]"></div>
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-violet-600/10 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-fuchsia-600/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 3s;"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_80%)]"></div>
    </div>

    {% include "navbar.njk" %}

    <main id="main-content" class="relative z-10 flex flex-col">
      {% block content %}{% endblock %}
    </main>

    {% include "footer.njk" %}

    <script>
      (() => {
        const defaultLng = "{{ lang }}";
        const savedLng = localStorage.getItem('i18nextLng') || defaultLng;
        const htmlEl = document.documentElement;

        // Deteksi RTL via Intl API
        let textDirection = 'ltr';
        try {
          const localeObj = new Intl.Locale(savedLng);
          if (typeof localeObj.getTextInfo === 'function') {
            textDirection = localeObj
              .getTextInfo()
              .direction;
          }
        } catch (e) {}

        htmlEl.setAttribute('dir', textDirection);
        htmlEl.setAttribute('lang', savedLng);

        if (savedLng === defaultLng || !window.__I18N_DATA__ || !window.__I18N_DATA__[savedLng]) {
          htmlEl
            .classList
            .replace('i18n-loading', 'i18n-ready');
          return;
        }

        const dict = window.__I18N_DATA__[savedLng];
        const pageId = window.__PAGE_ID__;

        const getTranslatedText = (rawKey) => {
          const parts = rawKey.split(':');
          if (parts.length < 2) 
            return rawKey;
          
          const ns = parts[0];
          const keyPath = parts[1];
          let sourceObj = null;

          if (ns === 'common') 
            sourceObj = dict.common;
          else if (ns === pageId) 
            sourceObj = dict.page;
          else if (ns.startsWith('components/')) {
            sourceObj = dict.comp[ns.split('/')[1]];
          }

          if (!sourceObj) 
            return rawKey;
          
          return keyPath
            .split('.')
            .reduce((prev, curr) => {
              return prev && prev[curr] !== undefined
                ? prev[curr]
                : undefined;
            }, sourceObj) || rawKey;
        };

        // Helper untuk parse variabel {{var}}
        const applyVars = (text, varsAttr) => {
          if (!varsAttr) 
            return text;
          try {
            const varsObj = JSON.parse(varsAttr);
            let newText = text;
            for (const k in varsObj) {
              newText = newText
                .split('{{' + k + '}}')
                .join(varsObj[k]);
            }
            return newText;
          } catch (e) {
            return text;
          }
        };

        // 1. Eksekusi Teks
        document
          .querySelectorAll('[data-i18n]')
          .forEach((el) => {
            const rawKey = el.getAttribute('data-i18n');
            const varsAttr = el.getAttribute('data-i18n-vars');
            el.innerHTML = applyVars(getTranslatedText(rawKey), varsAttr);
          });

        // 2. Eksekusi Atribut
        document
          .querySelectorAll('[data-i18n-attr]')
          .forEach((el) => {
            const attrConfig = el.getAttribute('data-i18n-attr');
            const firstColonIdx = attrConfig.indexOf(':');

            if (firstColonIdx > -1) {
              const attrName = attrConfig.slice(0, firstColonIdx);
              const rawKey = attrConfig.slice(firstColonIdx + 1);
              const varsAttr = el.getAttribute('data-i18n-vars');

              const translated = applyVars(getTranslatedText(rawKey), varsAttr);
              el.setAttribute(attrName, translated);
            }
          });

        htmlEl
          .classList
          .replace('i18n-loading', 'i18n-ready');
      })();
    </script>
    {% block scripts %}{% endblock %}
  </body>
</html>