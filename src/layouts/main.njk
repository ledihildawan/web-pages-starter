{% import "macros/i18n.njk" as i18n with context %}
{% import "macros/seo.njk" as seo %}

<!DOCTYPE html>
<html lang="{{ lang }}" dir="ltr" class="scroll-smooth i18n-loading selection:bg-violet-500/30 selection:text-violet-200">
  <head>
    {{ seo.render_tags(page, global) }}

    {% block resource_hints %}
      <link rel="preload" href="/assets/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous">
      {{ clientI18nScript | safe }}
    {% endblock %}

    {% block extra_head %}{% endblock %}
  </head>

  <body class="min-block-screen bg-slate-950 text-slate-200 antialiased font-sans" data-page="{{ page_id }}">

    {# --- GLOBAL BACKGROUND AMBIENCE (Logical v4.2.1) --- #}
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none gpu-boost">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(15,23,42,0)_0%,rgba(2,6,23,1)_100%)]"></div>
      
      {# Aura Top-Start (Akan otomatis pindah kiri/kanan sesuai bahasa) #}
      <div class="absolute -inset-bs-[10%] -inset-s-[10%] inline-1/2 block-1/2 bg-violet-600/10 rounded-full blur-[120px] animate-pulse"></div>
      
      {# Aura Bottom-End #}
      <div class="absolute -inset-be-[10%] -inset-e-[10%] inline-1/2 block-1/2 bg-fuchsia-600/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 3s;"></div>
      
      {# Grid Mask #}
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_80%)]"></div>
    </div>

    {% include "navbar.njk" %}

    <main id="main-content" class="relative z-10 flex flex-col min-block-screen">
      {% block content %}{% endblock %}
    </main>

    {% include "footer.njk" %}

    {# --- INLINE i18n HYDRATION SCRIPT --- #}
    <script>
      (() => {
        const defaultLng = "{{ lang }}";
        const savedLng = localStorage.getItem('i18nextLng') || defaultLng;
        const htmlEl = document.documentElement;

        // Deteksi Arah Teks Berdasarkan Region Lengkap (misal: en-US, ar-SA)
        const getDirection = (lng) => {
          try {
            const locale = new Intl.Locale(lng);
            // v4.2.1 menyukai deteksi otomatis via Intl
            if (locale.getTextInfo) return locale.getTextInfo().direction;
            if (locale.maximize().language === 'ar') return 'rtl';
          } catch (e) {
            if (lng.startsWith('ar')) return 'rtl';
          }
          return 'ltr';
        };

        const direction = getDirection(savedLng);
        htmlEl.setAttribute('dir', direction);
        htmlEl.setAttribute('lang', savedLng);

        // Jika data belum siap atau bahasa default, langsung tampilkan
        if (savedLng === defaultLng || !window.__I18N_DATA__ || !window.__I18N_DATA__[savedLng]) {
          htmlEl.classList.replace('i18n-loading', 'i18n-ready');
          return;
        }

        const dict = window.__I18N_DATA__[savedLng];
        const pageId = window.__PAGE_ID__;

        const getTranslatedText = (rawKey) => {
          const parts = rawKey.split(':');
          if (parts.length < 2) return rawKey;
          
          const ns = parts[0];
          const keyPath = parts[1];
          let sourceObj = null;

          if (ns === 'common') sourceObj = dict.common;
          else if (ns === pageId) sourceObj = dict.page;
          else if (ns.startsWith('components/')) {
            const compName = ns.split('/')[1];
            sourceObj = dict.comp ? dict.comp[compName] : null;
          }

          if (!sourceObj) return rawKey;
          
          return keyPath.split('.').reduce((prev, curr) => {
            return prev && prev[curr] !== undefined ? prev[curr] : undefined;
          }, sourceObj) || rawKey;
        };

        const applyVars = (text, varsAttr) => {
          if (!varsAttr) return text;
          try {
            const varsObj = JSON.parse(varsAttr);
            let newText = text;
            for (const k in varsObj) {
              newText = newText.split('{{' + k + '}}').join(varsObj[k]);
            }
            return newText;
          } catch (e) { return text; }
        };

        // Batch DOM Updates untuk Performa LCP
        requestAnimationFrame(() => {
          // 1. Translasi Teks
          document.querySelectorAll('[data-i18n]').forEach((el) => {
            const rawKey = el.getAttribute('data-i18n');
            const varsAttr = el.getAttribute('data-i18n-vars');
            const translated = getTranslatedText(rawKey);
            el.innerHTML = applyVars(translated, varsAttr);
          });

          // 2. Translasi Atribut
          document.querySelectorAll('[data-i18n-attr]').forEach((el) => {
            const attrConfig = el.getAttribute('data-i18n-attr');
            const colonIdx = attrConfig.indexOf(':');
            if (colonIdx > -1) {
              const attrName = attrConfig.slice(0, colonIdx);
              const rawKey = attrConfig.slice(colonIdx + 1);
              const varsAttr = el.getAttribute('data-i18n-vars');
              el.setAttribute(attrName, applyVars(getTranslatedText(rawKey), varsAttr));
            }
          });

          // Tandai Ready
          htmlEl.classList.replace('i18n-loading', 'i18n-ready');
        });
      })();
    </script>
    {% block scripts %}{% endblock %}
  </body>
</html>