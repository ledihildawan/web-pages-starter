{% macro _renderTag(tag, class, content, dataAttrs = {}, condAttrs = {}) %}
  {% set attrsStr = '' %}
  {% for key, val in dataAttrs %}
    {% set attrsStr = attrsStr + ' ' + key + '="' + val + '"' %}
  {% endfor %}
  {% for key, val in condAttrs %}
    {% if val %}{% set attrsStr = attrsStr + ' ' + key + '="' + val + '"' %}{% endif %}
  {% endfor %}
  {% if tag %}
    <{{ tag }}{% if class %} class="{{ class }}"{% endif %}{{ attrsStr | safe }}>{{ content }}</{{ tag }}>
  {% else %}
    <span{{ attrsStr | safe }}>{{ content }}</span>
  {% endif %}
{% endmacro %}

{% macro t(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set translatedValue = i18n.nativeNumbers(item.v) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, translatedValue | safe, {
    'data-i18n': item.k
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro tNative(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set translatedValue = i18n.nativeNumbers(item.v, true) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, translatedValue | safe, {
    'data-i18n': item.k,
    'data-force-native': 'true'
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro tUniversal(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, item.v | safe, {
    'data-i18n': item.k,
    'data-force-universal': 'true'
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro v(key, vars = {}) -%}
  {%- set item = i18n(key, vars) -%}
  {{- item.v | safe -}}
{%- endmacro %}

{% macro html(key, vars = {}) %}
  {% set item = i18n(key, vars) %}
  {% set translatedValue = i18n.nativeNumbers(item.v) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  <div data-i18n-html="{{ item.k }}" {% if item.vars %} data-i18n-vars='{{ varsJson | safe }}' {% endif %} class="contents">
    {{ translatedValue | safe }}
  </div>
{% endmacro %}


{% macro wrap(key, vars = {}, tag = 'div', class = '', ext = {}) %}
  {% set item = i18n(key, vars) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {% set extStr = '' %}
  {% for name, value in ext %}
    {% set extStr = extStr + ' ' + name + '="' + value + '"' %}
  {% endfor %}
  <{{ tag }} class="{{ class }}" data-i18n="{{ item.k }}"{{ extStr | safe }}{% if item.vars %} data-i18n-vars='{{ varsJson | safe }}'{% endif %}>
    {{ caller(item) | safe }}
  </{{ tag }}>
{% endmacro %}

{% macro attr(key, attrName, vars = {}) %}
  {% set item = i18n(key, vars) %}
  {{ attrName }}="{{ item.v }}" data-i18n-attr="{{ attrName}}:{{ item.k }}"
  {% if item.vars %} data-i18n-vars='{{ (item.vars | replace('"', '&quot;')) | safe }}'{% endif %}
{% endmacro %}

{% macro plural(key, count, vars = {}, class = '') %}
  {% set item = i18n.plural(key, count, vars) %}
  {% set translatedValue = i18n.nativeNumbers(item.v) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, translatedValue | safe, {
    'data-i18n-plural': item.k,
    'data-i18n-count': count
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro formatNumber(value, tag = '', class = '', useNative = false) %}
  {% set formatted = i18n.formatNumber(value, { useNativeNumberingSystem: useNative }) %}
  {{ _renderTag(tag, class, formatted, {
    'data-format-number': value,
    'data-use-native': useNative
  }) }}
{% endmacro %}

