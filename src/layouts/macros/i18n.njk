{% macro _renderTag(tag, class, content, dataAttrs = {}, condAttrs = {}) %}
  {% set attrsStr = '' %}
  {% for key, val in dataAttrs %}
    {% set attrsStr = attrsStr + ' ' + key + '="' + val + '"' %}
  {% endfor %}
  {% for key, val in condAttrs %}
    {% if val %}{% set attrsStr = attrsStr + ' ' + key + '="' + val + '"' %}{% endif %}
  {% endfor %}
  {% if tag %}
    <{{ tag }}{% if class %} class="{{ class }}"{% endif %}{{ attrsStr | safe }}>{{ content }}</{{ tag }}>
  {% else %}
    <span{{ attrsStr | safe }}>{{ content }}</span>
  {% endif %}
{% endmacro %}

{% macro t(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set translatedValue = nunjucksFilters.nativeNumbers(item.v, lang) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, translatedValue | safe, {
    'data-i18n': item.k
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro tNative(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set translatedValue = nunjucksFilters.nativeNumbers(item.v, lang, true) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, translatedValue | safe, {
    'data-i18n': item.k,
    'data-force-native': 'true'
  }, {
    'data-i18n-vars': varsJson
  }) }}
{% endmacro %}

{% macro tUniversal(key, vars = {}, class = '') %}
  {% set item = i18n(key, vars) %}
  {% set varsJson = (item.vars | replace('"', '&quot;')) if item.vars else '' %}
  {{ _renderTag('span', class, item.v | safe, {
