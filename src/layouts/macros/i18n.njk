{% macro formatLocalPrice(plan, targetCurrency = '', options = {}, tag = '', class = '', pricingKey = 'pricing') %}
  {% set formatted = nunjucksFilters.convertLocalPrice(plan, lang, targetCurrency, options) %}
  {% set pricingJson = ((plan[pricingKey] | dump) | replace('"', '&quot;')) | safe %}
  {% set attrs = {
    'data-local-price': plan.id,
    'data-pricing': pricingJson,
    'data-currency': targetCurrency or i18n.currency
  } %}
  {{ _renderTag(tag, class, formatted, attrs) }}
{% endmacro %}

{% macro formatLocalPriceDiscounted(plan, discountMultiplier = 0.8, targetCurrency = '', options = {}, tag = '', class = '', pricingKey = 'pricing') %}
  {% set formatted = nunjucksFilters.convertLocalPriceDiscounted(plan, lang, discountMultiplier, targetCurrency, options) %}
  {% set pricingJson = ((plan[pricingKey] | dump) | replace('"', '&quot;')) | safe %}
  {% set attrs = {
    'data-local-price': plan.id,
    'data-discount': discountMultiplier,
    'data-pricing': pricingJson,
    'data-currency': targetCurrency or i18n.currency
  } %}
  {{ _renderTag(tag, class, formatted, attrs) }}
{% endmacro %}
