{# Language list renderer for navbar/desktop+mobile selectors.

   Pre-renders the 54-language list server-side so the browser does not need
   Alpine `<template x-for>` to set up 108 reactive items during bootstrap.

   Usage (desktop dropdown):
     {% import "macros/languages.njk" as languages %}
     <div ...>
       {% for lang in languages.desktop_list() %}
         <button>...</button>
       {% endfor %}
     </div>

   Usage (mobile grid):
     <div ...>
       {% for lang in languages.mobile_list() %}
         <button>...</button>
       {% endfor %}
     </div>
#}

{% macro desktop_item(lang) %}
<button
  @click="$store.i18n.change('{{ lang.code }}'); langOpen = false"
  class="inline-full px-3 py-2.5 block-10 flex items-center gap-3 text-start radius-icon text-[12px] font-bold transition-all duration-300 group"
  :class="$store.i18n.current === '{{ lang.code }}' ? 'bg-linear-to-r from-violet-500/20 to-fuchsia-500/20 text-white border border-violet-500/30' : 'text-slate-400 hover:text-white hover:bg-white/5'"
  role="option"
  :aria-selected="$store.i18n.current === '{{ lang.code }}'"
>
  <span class="inline-5 block-3.5 shrink-0 overflow-hidden rounded-xs bg-white/5 flex items-center justify-center aspect-4/3">
    <img src="https://flagcdn.com/w20/{{ lang.flag }}.png" width="20" height="15" class="inline-full block-full object-cover transition-all duration-300" :class="$store.i18n.current === '{{ lang.code }}' ? 'opacity-100 grayscale-0' : 'opacity-40 grayscale group-hover:grayscale-0 group-hover:opacity-100'" loading="lazy" alt="{{ lang.label }} flag - {{ lang.flag | upper }}">
  </span>
  <span class="truncate" x-text="i18nStoreLang('{{ lang.code }}')"></span>
</button>
{% endmacro %}

{% macro mobile_item(lang) %}
<button
  @click="$store.i18n.change('{{ lang.code }}'); closeMobileMenu(); hapticFeedback()"
  @touchstart.passive="$store.i18n.current !== '{{ lang.code }}' && hapticFeedback()"
  class="group relative flex items-center gap-3 px-4 pbs-4 pbe-4 radius-btn transition-all duration-300 border text-start active:scale-95"
  :class="$store.i18n.current === '{{ lang.code }}' ? 'bg-linear-to-r from-violet-500/20 to-fuchsia-500/20 border-violet-500/30 text-white' : 'bg-white/3 border-transparent text-slate-400 hover:text-slate-300 hover:bg-white/6 active:bg-white/8'"
  role="option"
  :aria-selected="$store.i18n.current === '{{ lang.code }}'"
  :aria-label="i18nStoreLang('{{ lang.code }}') + ' ({{ lang.flag | upper }})'"
>
  <div class="relative shrink-0 inline-5 block-3.5 overflow-hidden rounded-xs bg-white/5 aspect-4/3">
    <img src="https://flagcdn.com/w40/{{ lang.flag }}.png" width="40" height="30" class="inline-full block-full object-cover transition-all duration-200" :class="$store.i18n.current === '{{ lang.code }}' ? 'opacity-100 grayscale-0' : 'opacity-30 grayscale group-hover:opacity-60 group-hover:grayscale-0'" loading="lazy" alt="{{ lang.label }} flag - {{ lang.flag | upper }}">
  </div>
  <div class="flex flex-col min-inline-0">
    <span class="text-[13px] font-bold truncate leading-none" x-text="i18nStoreLang('{{ lang.code }}')"></span>
    <span class="text-[9px] font-black opacity-20 tracking-widest mbs-1.5">{{ lang.flag | upper }}</span>
  </div>
</button>
{% endmacro %}
