{
  "site_name": "Starter App",
  "site_description": "Build lightning-fast, beautiful web applications with Starter.",
  "site_url": "https://example.com",
  "site_image": "/assets/images/og-image.svg",
  "default_locale": "en-US",

  "seo": {
    "theme_color": "#020617",
    "theme_color_light": "#f8fafc",
    "og_type": "website",
    "twitter_card": "summary_large_image",
    "manifest_path": "/manifest.json",
    "favicon_path": "/favicon.svg",
    "apple_touch_icon_path": "/favicon.svg"
  },

  "pwa": {
    "mobile_web_app_capable": true,
    "apple_mobile_web_app_capable": true,
    "apple_mobile_web_app_status_bar_style": "default",
    "msapplication_tile_color": "#020617"
  },

  "format_detection": {
    "telephone": false,
    "email": false,
    "address": false
  },

  "compatibility": {
    "x_ua_compatible": "IE=edge",
    "referrer": "strict-origin-when-cross-origin"
  },

  "preconnect": [
    { "href": "https://flagcdn.com" }
  ],

  "dns_prefetch": [
    "//flagcdn.com"
  ],

  "social": {
    "github": "",
    "twitter": ""
  }
}
