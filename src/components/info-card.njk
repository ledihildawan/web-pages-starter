{% macro info_card(label, value, color, icon_name, i18n = {}) %}
  {% set icons = {
    'envelope': '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
    'phone': '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
    'map-pin': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>'
  } %}
  {% set iconPath = icons[icon_name] or '' %}
  <div class="spotlight-card card-border-glow card-squash group relative p-10 lg:p-12 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ color }}-500/40 hover:shadow-[0_20px_50px_rgba(139,92,246,0.25)] hover:-translate-y-2 transition duration-250 ease-emphasized text-center overflow-hidden backdrop-blur-xl card-hover-lift">
    <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-linear-to-br from-{{ color }}-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
    <div class="relative inline-16 lg:inline-20 block-16 lg:block-20 mx-auto mbe-8">
      <div class="absolute inset-0 bg-linear-to-br from-{{ color }}-500/20 to-transparent radius-nested-lg blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
      <div class="relative inline-full block-full radius-nested-lg bg-linear-to-br from-{{ color }}-500/10 to-{{ color }}-500/5 border border-{{ color }}-500/30 group-hover:border-{{ color }}-500/50 group-hover:scale-110 transition duration-200 flex items-center justify-center shadow-lg group-hover:shadow-[0_0_50px_rgba(139,92,246,0.3)] icon-squash">
        <svg class="inline-8 lg:inline-10 block-8 lg:block-10 text-{{ color }}-400" aria-hidden="true" focusable="false" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          {{ iconPath }}
        </svg>
      </div>
    </div>
    <h3 class="text-lg lg:text-xl font-black text-white mbe-3 tracking-tight group-hover:text-{{ color }}-200 transition-colors duration-300">{{ i18n.t(label + '_label') }}</h3>
    <p class="text-slate-400 font-medium group-hover:text-slate-300 transition-colors duration-300">{{ i18n.t(value + '_value') }}</p>
  </div>
{% endmacro %}