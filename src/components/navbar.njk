<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('navbar', () => ({
      mobileMenuOpen: false,
      menuChildrenVisible: false,
      langOpen: false,
      scrolled: false,
      navHidden: false,
      lastScroll: 0,
      activeMobileSub: null,
      scrollY: 0,
      currentPath: window.location.pathname,
      basePath: '{{ base_path }}',
      isNavigating: false,
      touchStartY: 0,
      touchCurrentY: 0,
      isDragging: false,
      focusedElement: null,
      _ticking: false,
      _pluginPromise: null,
      _pluginsReady: false,

      get pluginsReady() {
        return this._pluginsReady;
      },

      isActive(path) {
        const base = this.basePath.replace(/\/$/, '') || '';
        const current = this.currentPath.replace(/\/$/, '') || '/';
        const target = (base + path).replace(/\/$/, '') || '/';
        return current === target;
      },

      hapticFeedback() {
        if (navigator.vibrate) {
          navigator.vibrate(10);
        }
      },

      async _loadPlugins() {
        try {
          const [collapse, focus] = await Promise.all([
            import('@alpinejs/collapse'),
            import('@alpinejs/focus'),
          ]);
          Alpine.plugin(collapse.default);
          Alpine.plugin(focus.default);
        } catch (e) {
          console.warn('Failed to load Alpine plugins:', e);
        }
        this._pluginsReady = true;
      },

      init() {
        this.lastScroll = window.scrollY;
        this.scrolled = this.lastScroll > 20;

        if (window.location.hash) {
          this.navHidden = true;
        }

        this._pluginPromise = this._loadPlugins();
      },

      onScroll() {
        if (this.mobileMenuOpen || this._ticking) return;
        this._ticking = true;
        requestAnimationFrame(() => {
          const currentScroll = window.scrollY;
          this.scrolled = currentScroll > 20;
          if (currentScroll > this.lastScroll && currentScroll > 150) {
            this.navHidden = true;
          } else if (currentScroll < this.lastScroll) {
            this.navHidden = false;
          }
          this.lastScroll = currentScroll;
          this._ticking = false;
        });
      },

      handleTouchStart(e) {
        this.touchStartY = e.touches[0].clientY;
        this.isDragging = true;
      },

      handleTouchMove(e) {
        if (!this.isDragging) return;
        this.touchCurrentY = e.touches[0].clientY;
        const diff = this.touchCurrentY - this.touchStartY;
        if (diff > 0) {
          this.$refs.mobileMenu.style.transform = `translateY(${Math.min(diff, 300)}px)`;
        }
      },

      handleTouchEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;
        const diff = this.touchCurrentY - this.touchStartY;
        this.$refs.mobileMenu.style.transform = '';
        if (diff > 100) {
          this.hapticFeedback();
          this.closeMobileMenu();
        }
      },

      closeMobileMenu(url = null) {
        if (this.isNavigating) return;
        this.isNavigating = true;

        this.hapticFeedback();

        this.mobileMenuOpen = false;

        const menuButton = document.querySelector('[aria-controls="mobile-menu"]');
        if (menuButton) {
          setTimeout(() => menuButton.focus(), 550);
        }

        const targetUrl = typeof url === 'string' ? url : null;
        const isAnchorLink = targetUrl?.includes('#');

        if (targetUrl && !isAnchorLink) {
          setTimeout(() => {
            window.location.href = targetUrl;
          }, 200);
        }

        setTimeout(() => {
          this.menuChildrenVisible = false;
          this.activeMobileSub = null;

          document.body.classList.remove('no-scroll');
          document.body.style.insetBlockStart = '';
          document.documentElement.style.setProperty('--scrollbar-width', '0px');

          this.isNavigating = false;

          if (isAnchorLink) {
            this.navHidden = true;
            window.location.href = targetUrl;
            setTimeout(() => {
              this.lastScroll = window.scrollY;
            }, 50);
          } else {
            this.navHidden = this.scrollY > 150;
            this.lastScroll = this.scrollY;

            const htmlStyle = document.documentElement.style;
            const bodyStyle = document.body.style;
            const originalScrollBehavior = htmlStyle.scrollBehavior || '';

            htmlStyle.scrollBehavior = 'auto';
            bodyStyle.scrollBehavior = 'auto';
            window.scrollTo(0, this.scrollY);

            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                htmlStyle.scrollBehavior = originalScrollBehavior;
                bodyStyle.scrollBehavior = '';
              });
            });
          }
        }, 500);

        return true;
      },

      async toggleMobile() {
        if (!this._pluginsReady) {
          await this._pluginPromise;
        }

        if (!this.mobileMenuOpen) {
          this.focusedElement = document.activeElement;

          this.scrollY = window.scrollY;
          const sbWidth = window.innerWidth - document.documentElement.clientWidth;

          document.body.style.insetBlockStart = `-${this.scrollY}px`;
          document.body.classList.add('no-scroll');
          document.documentElement.style.setProperty('--scrollbar-width', `${sbWidth}px`);

          this.mobileMenuOpen = true;
          this.navHidden = false;

          this.hapticFeedback();

          setTimeout(() => {
            const firstLink = this.$refs.mobileMenu.querySelector('a[href]');
            if (firstLink) firstLink.focus();
          }, 750);

          setTimeout(() => {
            this.menuChildrenVisible = true;
          }, 50);
        } else {
          this.closeMobileMenu();
        }
      },
    }));
  });
</script>

<nav aria-label="Main navigation" x-cloak x-data="navbar" @keydown.escape.window="activeMobileSub !== null ? activeMobileSub = null : langOpen = false" @resize.window="if(window.innerWidth >= 1024 && mobileMenuOpen) toggleMobile()" @scroll.window="onScroll" class="fixed inset-bs-0 inset-s-0 inline-full z-100 transition duration-500 ease-emphasized border-be bg-transparent border-transparent translate-y-0" :class="{
    'bg-slate-950/90 backdrop-blur-2xl shadow-xl border-white/10': scrolled && !mobileMenuOpen,
    'bg-transparent border-transparent': !scrolled && !mobileMenuOpen,
    'bg-slate-950 border-transparent shadow-none': mobileMenuOpen,
    '-translate-y-full': navHidden && !mobileMenuOpen,
    'translate-y-0': !navHidden || mobileMenuOpen
  }">
  <div class="max-inline-7xl mx-auto px-6 block-20 flex justify-between items-center relative z-130 transition-colors duration-200" :class="mobileMenuOpen ? 'bg-slate-950' : ''">
    <a href="{{ url('/') }}" class="group flex flex-col transition-transform active:scale-[0.96] shrink-0" @click.prevent="mobileMenuOpen ? closeMobileMenu('{{ url('/') }}') : window.location.href='{{ url('/') }}'">
      <span class="text-2xl font-black text-gradient tracking-tighter leading-none group-hover:brightness-125 transition duration-200">
        Starter
      </span>
      <span class="text-[10px] text-slate-400 font-black tracking-[0.25em] uppercase mbs-1.5 transition-colors duration-200 group-hover:text-slate-300">
        {{ i18n.t('engine_name') }}
      </span>
    </a>
    <div class="flex items-center gap-2 lg:gap-4">
      <ul class="hidden lg:flex items-center gap-2 me-4" role="menubar" aria-label="Main menu">
        {% for item in global.menu.header %}
          <li class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
            <a href="{{ url(item.url) }}" class="text-[13px] font-bold px-4 pbs-2.5 pbe-2.5 radius-icon transition duration-300 flex items-center gap-1.5 relative" :class="isActive('{{ item.url }}') ? 'text-white bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5'" :aria-current="isActive('{{ item.url }}') ? 'page' : null" {% if item.children %} :aria-expanded="open" aria-haspopup="true" {% endif %}>
              {{ i18n.t(item.label) }}
              {% if item.children %}
                {{ icon.icon('chevron-down', 'inline-3 block-3 transition-transform duration-200 opacity-20', size='md') }}
              {% endif %}
              <span x-show="isActive('{{ item.url }}')" class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-8 block-0.5 bg-linear-to-r from-violet-500 to-fuchsia-500 rounded-full"></span>
            </a>
            {% if item.children %}
              <div x-show="open" x-cloak x-transition:enter="transition ease-emphasized duration-300" x-transition:enter-start="opacity-0 translate-y-2 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-2" class="absolute inset-bs-full inset-s-0 inline-64 pbs-2 z-140" role="menu" aria-label="submenu">
                <div class="p-2 bg-slate-950 border border-white/10 radius-btn shadow-[0_25px_60px_rgba(0,0,0,0.5)]">
                  {% for child in item.children %}
                    <a href="{{ url(child.url) }}" class="block px-4 pbs-3 pbe-3 text-[13px] font-bold text-slate-400 hover:text-white hover:bg-white/10 radius-icon transition duration-300" role="menuitem">{{ i18n.t(child.label) }}</a>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
      <div class="relative hidden lg:block">
        <button @click="langOpen = !langOpen" @click.outside="langOpen = false" :aria-expanded="langOpen" aria-haspopup="listbox" aria-label="Select language" class="flex items-center gap-2.5 px-3.5 py-2.5 block-11 bg-white/5 border border-white/10 radius-icon text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/15 transition duration-200 font-black text-[10px] group icon-squash">
          <span class="inline-5 block-3.5 shrink-0 flex items-center justify-center overflow-hidden rounded-xs opacity-70 group-hover:opacity-100 transition-opacity duration-300 bg-white/5 aspect-4/3">
            <template x-if="$store.i18n.languages.find(l => l.code === $store.i18n.current)">
              <img :src="`https://flagcdn.com/w20/${$store.i18n.languages.find(l => l.code === $store.i18n.current).flag.toLowerCase()}.png`" width="20" height="15" class="inline-full block-full object-cover" loading="lazy" :alt="`${$store.i18n.languages.find(l => l.code === $store.i18n.current)?.label || 'Language'} flag - ${$store.i18n.languages.find(l => l.code === $store.i18n.current).flag.toUpperCase()}`">
            </template>
          </span>
          <span x-text="$store.i18n.languages.find(l => l.code === $store.i18n.current)?.label || $store.i18n.current.toUpperCase()" class="tracking-[0.15em]"></span>
          {{ icon.icon('chevron-down', 'inline-3 block-3 opacity-20 transition-transform duration-200 group-hover:opacity-100 shrink-0', size='md') }}
        </button>
        <div x-show="langOpen" x-cloak x-transition:enter="transition ease-emphasized duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-2" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-2" class="absolute inset-bs-full inset-e-0 mbs-3 min-inline-56 bg-slate-950 border border-white/10 radius-btn shadow-[0_25px_60px_rgba(0,0,0,0.5)] z-140 overflow-hidden" role="listbox" aria-label="Select language" :data-current-lang="$store.i18n.current" @click="if ($event.target.closest('[data-lang-option]')) { $store.i18n.change($event.target.closest('[data-lang-option]').dataset.langOption); langOpen = false; }">
          <div class="p-2 max-block-80 overflow-y-auto scrollbar-none">
            {% for lang in locales %}
              <button data-lang-option="{{ lang.code }}" class="lang-option inline-full px-3 py-2.5 block-10 flex items-center gap-3 text-start radius-icon text-[12px] font-bold transition duration-300 group" role="option">
                <span class="inline-5 block-3.5 shrink-0 overflow-hidden rounded-xs bg-white/5 flex items-center justify-center aspect-4/3">
                  <img src="https://flagcdn.com/w20/{{ lang.flag }}.png" width="20" height="15" class="inline-full block-full object-cover transition duration-300 lang-flag" loading="lazy" alt="{{ lang.label }} flag - {{ lang.flag | upper }}">
                </span>
                <span class="truncate">{{ lang.label }}</span>
              </button>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="hidden lg:block ms-2 ps-5 border-s border-white/10">
        <a href="{{ url('/pricing') }}" class="group relative px-6 block-11 flex items-center bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white radius-icon text-[12px] font-black hover-lift btn-squash anticipate-press ripple-click sparkle-hover uppercase tracking-wider border border-white/10 overflow-hidden">
          <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"></span>
          <span class="relative z-10 flex items-center gap-2">
            {{ i18n.t('get_started') }}
            {{ icon.icon('arrow-right', 'inline-4 block-4 group-hover:translate-x-0.5 transition-transform duration-300', size='md') }}
          </span>
        </a>
      </div>
      <button @click.stop="toggleMobile()" @keydown.escape="activeMobileSub !== null ? activeMobileSub = null : toggleMobile()" aria-label="Menu" :aria-expanded="mobileMenuOpen" aria-controls="mobile-menu" class="lg:hidden relative z-150 inline-11 block-11 flex items-center justify-center text-slate-200 hover:text-white bg-white/5 radius-icon border border-white/10 hover:bg-white/8 hover:border-white/15 btn-squash icon-squash anticipate-press" :class="mobileMenuOpen ? 'bg-transparent border-transparent hover:bg-white/5' : ''">
        <div class="relative inline-5 block-4 flex flex-col justify-between items-center">
          <span class="inline-full block-0.5 bg-current transition duration-500 ease-emphasized" :class="mobileMenuOpen ? 'rotate-45 translate-y-1.75' : ''"></span>
          <span class="inline-full block-0.5 bg-current transition duration-300 ease-emphasized" :class="mobileMenuOpen ? 'opacity-0 -translate-x-4' : ''"></span>
          <span class="inline-full block-0.5 bg-current transition duration-500 ease-emphasized" :class="mobileMenuOpen ? '-rotate-45 -translate-y-1.75' : ''"></span>
        </div>
      </button>
    </div>
  </div>
  <template x-if="pluginsReady">
    <div
      id="mobile-menu"
      x-ref="mobileMenu"
      x-show="mobileMenuOpen"
      x-cloak
      x-trap.noscroll="mobileMenuOpen"
      x-transition:enter="transition ease-emphasized duration-700"
      x-transition:enter-start="-translate-y-full"
      x-transition:enter-end="translate-y-0"
      x-transition:leave="transition ease-in duration-500"
      x-transition:leave-start="translate-y-0"
      x-transition:leave-end="-translate-y-full"
      @keydown.escape.window="activeMobileSub !== null ? activeMobileSub = null : closeMobileMenu()"
      @click.self="closeMobileMenu()"
      @touchstart.passive="handleTouchStart($event)"
      @touchmove.passive="handleTouchMove($event)"
      @touchend="handleTouchEnd()"
      class="fixed inset-0 bg-slate-950 z-110 lg:hidden flex flex-col h-dvh"
      role="dialog"
      aria-modal="true"
      aria-label="Mobile menu"
    >
      <div class="absolute inset-x-0 top-0 flex justify-center pt-3 opacity-30">
        <div class="inline-12 block-1.5 rounded-full bg-slate-400"></div>
      </div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent pointer-events-none"></div>
      <div class="absolute inset-be-0 inset-e-0 inline-64 block-64 bg-fuchsia-600/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="flex-1 overflow-y-auto pbs-24 pbe-12 px-6 scrollbar-none relative z-10 text-start">
        <ul class="space-y-2 mbs-6">
          {% for item in global.menu.header %}
            <li x-show="menuChildrenVisible" x-transition:enter="transition ease-emphasized duration-700" x-transition:enter-start="opacity-0 translate-y-8 scale-95" :style="`transition-delay: {{ loop.index0 * 100 }}ms`" class="gpu-boost">
              <div class="flex items-center justify-between pbs-4 pbe-4 group">
                {% if item.children %}
                  <span class="text-4xl sm:text-5xl font-black tracking-tighter transition duration-300 text-white">
                    {{ i18n.t(item.label) }}
                  </span>
                  <button @click="activeMobileSub = (activeMobileSub === {{ loop.index0 }} ? null : {{ loop.index0 }}); hapticFeedback()" :aria-expanded="activeMobileSub === {{ loop.index0 }}" aria-controls="sub-menu-{{ loop.index0 }}" aria-label="{{ i18n.t(item.label + '_submenu', {}, {raw: true}) }}" class="inline-11 block-11 flex items-center justify-center bg-white/5 radius-btn border border-white/10 active:scale-[0.96] transition duration-200 icon-squash hover:bg-white/10">
                    <svg class="inline-6 block-6 transition-transform duration-500 ease-emphasized" :class="activeMobileSub === {{ loop.index0 }} ? 'rotate-180 text-violet-400' : 'text-slate-600'" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                {% else %}
                  <a href="{{ url(item.url) }}" @click.prevent="closeMobileMenu('{{ url(item.url) }}')" @touchstart.passive="hapticFeedback()" class="text-4xl sm:text-5xl font-black tracking-tighter transition duration-300 w-full relative" :class="isActive('{{ item.url }}') ? 'text-gradient-violet-fuchsia' : 'text-white active:text-violet-400'">
                    {{ i18n.t(item.label) }}
                    <span class="absolute inset-0 bg-white/5 rounded-lg scale-0 group-active:scale-100 transition-transform duration-150"></span>
                  </a>
                {% endif %}
              </div>
              {% if item.children %}
                <div id="sub-menu-{{ loop.index0 }}" x-show="activeMobileSub === {{ loop.index0 }}" x-cloak x-collapse="x-collapse" class="mbe-6 ms-2 ps-6 border-s-2 border-violet-500/20 space-y-4 pbs-4 pbe-4">
                  {% for child in item.children %}
                    <a href="{{ url(child.url) }}" @click.prevent="closeMobileMenu('{{ url(child.url) }}')" @touchstart.passive="hapticFeedback()" class="block text-2xl font-black transition-colors duration-300 relative py-2 -mx-2 px-2 rounded-lg" :class="isActive('{{ child.url }}') ? 'text-white bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5 active:bg-white/10'">{{ i18n.t(child.label) }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
        <div class="mbs-12 pbs-8 border-bs border-white/10" x-show="menuChildrenVisible" x-transition:enter="transition ease-emphasized duration-700" x-transition:enter-start="opacity-0 translate-y-8" role="group" aria-label="{{ i18n.t('select_language', {}, {raw: true}) }}">
          <p class="text-[10px] font-black tracking-[0.2em] text-slate-400 uppercase mbe-5 ps-1">{{ i18n.t('select_language') }}</p>
          <div class="grid grid-cols-2 gap-2" role="listbox" aria-label="Select language" :data-current-lang="$store.i18n.current" @click="const opt = $event.target.closest('[data-lang-option]'); if (opt) { $store.i18n.change(opt.dataset.langOption); closeMobileMenu(); hapticFeedback(); }">
            {% for lang in locales %}
              <button data-lang-option="{{ lang.code }}" class="lang-option group relative flex items-center gap-3 px-4 pbs-4 pbe-4 radius-btn transition duration-300 border text-start active:scale-[0.96]" role="option" aria-label="{{ lang.label }} ({{ lang.flag | upper }})">
                <div class="relative shrink-0 inline-5 block-3.5 overflow-hidden rounded-xs bg-white/5 aspect-4/3">
                  <img src="https://flagcdn.com/w40/{{ lang.flag }}.png" width="40" height="30" class="inline-full block-full object-cover transition duration-200 lang-flag" loading="lazy" alt="{{ lang.label }} flag - {{ lang.flag | upper }}">
                </div>
                <div class="flex flex-col min-inline-0">
                  <span class="text-[13px] font-bold truncate leading-none">{{ lang.label }}</span>
                  <span class="text-[9px] font-black opacity-20 tracking-widest mbs-1.5">{{ lang.flag | upper }}</span>
                </div>
              </button>
            {% endfor %}
          </div>
        </div>
        <div class="mbs-8" x-show="menuChildrenVisible" x-transition:enter="transition ease-emphasized duration-700" x-transition:enter-start="opacity-0 translate-y-10">
          <a href="{{ url('/pricing') }}" @click.prevent="closeMobileMenu('{{ url('/pricing') }}')" @touchstart.passive="hapticFeedback()" class="group block inline-full pbs-5 pbe-5 bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white radius-card-md text-center font-black text-xl shadow-2xl btn-squash anticipate-press ripple-click sparkle-hover overflow-hidden hover-lift active:scale-[0.96] relative">
            <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
            <span class="relative flex items-center justify-center gap-3">
              {{ i18n.t('get_started') }}
              {{ icon.icon('arrow-right', 'inline-5 block-5', size='lg') }}
            </span>
          </a>
        </div>
      </div>
      <div class="block-2 bg-linear-to-r from-violet-600 via-fuchsia-500 to-pink-500 inline-full shrink-0"></div>
    </div>
  </template>
</nav>
