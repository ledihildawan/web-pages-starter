<nav x-data="{
    mobileMenuOpen: false,
    langOpen: false,
    scrollY: 0,
    toggleMobile() {
      if (!this.mobileMenuOpen) {
        this.scrollY = window.scrollY;
        const sbWidth = window.innerWidth - document.documentElement.clientWidth;
        document.body.style.top = `-${this.scrollY}px`;
        document.body.classList.add('no-scroll');
        document.documentElement.style.setProperty('--scrollbar-width', `${sbWidth}px`);
        this.mobileMenuOpen = true;
      } else {
        document.body.classList.remove('no-scroll');
        document.body.style.top = '';
        window.scrollTo(0, this.scrollY);
        document.documentElement.style.setProperty('--scrollbar-width', '0px');
        this.mobileMenuOpen = false;
      }
    }
  }" @keydown.escape="if(mobileMenuOpen) toggleMobile(); langOpen = false" class="fixed top-0 w-full z-[100] transition-all duration-500" :class="mobileMenuOpen ? 'border-transparent' : 'bg-slate-950/60 backdrop-blur-xl border-b border-white/10'">
  <div class="max-w-6xl mx-auto px-6 h-20 flex justify-between items-center relative z-[110]">

    {# --- BRAND LOGO --- #}
    <a href="/" class="group flex flex-col transition-transform active:scale-95 z-[120]" @click="if(mobileMenuOpen) toggleMobile()">
      <span class="text-2xl font-black bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent tracking-tighter leading-none">
        Starter
      </span>
      <span class="text-[10px] text-slate-400 font-black tracking-[0.2em] uppercase mt-1.5">
        {{ i18n.t('engine_name') }}
      </span>
    </a>

    {# --- CONTROLS GROUP --- #}
    <div class="flex items-center gap-2">

      {# Desktop Links #}
      <div class="hidden md:flex items-center gap-1 mr-4">
        {% for item in global.menu.header %}
          <a href="{{ item.url }}" class="text-sm font-bold text-slate-200 hover:text-white px-4 py-2 rounded-xl transition-all duration-300 min-h-[48px] flex items-center hover:bg-white/5">
            {{ i18n.t(item.t_key) }}
          </a>
        {% endfor %}
      </div>

      {# --- UNIVERSAL LANGUAGE SWITCHER --- #}
      <div class="relative">
        <button @click="langOpen = !langOpen" @click.outside="langOpen = false" class="flex items-center gap-2 px-3 bg-white/5 border border-white/10 rounded-xl text-slate-300 hover:text-white transition-all font-bold text-xs min-h-[48px]" :class="mobileMenuOpen ? 'opacity-0 pointer-events-none' : 'opacity-100'">
          <svg class="w-3.5 h-3.5 text-violet-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
          </svg>
          <span id="active-lang-text" class="uppercase tracking-widest">ID</span>
          <svg class="w-3 h-3 transition-transform duration-300" :class="langOpen ? 'rotate-180' : ''" fill="none" viewbox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        {# Dropdown List #}
        <div x-show="langOpen" x-cloak="x-cloak" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-95 translate-y-2" class="absolute top-full right-0 mt-2 p-1.5 bg-slate-900/95 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl min-w-[140px] z-[130]">
          {% for lang in['id', 'en', 'jp', 'cn', 'ar'] %}
            <button @click="$store.i18n.change('{{ lang }}'); langOpen = false" class="lang-btn-item w-full px-4 py-3 flex items-center justify-between rounded-xl text-[11px] font-black transition-all hover:bg-white/10 text-slate-300 hover:text-white" data-lang-code="{{ lang }}">
              <span>{{ lang | upper }}</span>
              <svg class="check-icon w-3.5 h-3.5 opacity-0 text-emerald-400 transition-opacity" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </button>
          {% endfor %}
        </div>
      </div>

      {# CTA Button (Desktop Only) #}
      {# UPDATE: Sekarang pakai Gradient Signature agar menyala #}
      <div class="hidden md:block ms-2 ps-4 border-s border-white/15">
        <a href="/pricing" class="px-6 min-h-[48px] flex items-center justify-center bg-linear-to-r from-violet-600 to-fuchsia-600 text-white rounded-xl text-sm font-black hover:shadow-[0_0_20px_rgba(139,92,246,0.5)] transition-all active:scale-95 border border-white/10">
          {{ i18n.t('get_started') }}
        </a>
      </div>

      {# --- MOBILE TOGGLE --- #}
      <button @click="toggleMobile()" class="md:hidden relative z-[120] min-w-[48px] min-h-[48px] flex items-center justify-center text-slate-200 bg-white/5 rounded-xl border border-white/10 overflow-hidden ml-1" aria-label="Toggle Menu">
        <div class="w-6 h-5 relative flex flex-col justify-between">
          <span class="w-full h-0.5 bg-current transition-all duration-500 transform origin-left" :class="mobileMenuOpen ? 'rotate-[42deg] w-[120%] translate-x-1' : ''"></span>
          <span class="w-full h-0.5 bg-current transition-opacity duration-300" :class="mobileMenuOpen ? 'opacity-0' : ''"></span>
          <span class="w-full h-0.5 bg-current transition-all duration-500 transform origin-left" :class="mobileMenuOpen ? '-rotate-[42deg] w-[120%] translate-x-1' : ''"></span>
        </div>
      </button>
    </div>
  </div>

  {# --- FULL-SCREEN MOBILE OVERLAY --- #}
  <div x-show="mobileMenuOpen" x-cloak="x-cloak" x-transition:enter="transition ease-[cubic-bezier(0.16,1,0.3,1)] duration-700" x-transition:enter-start="translate-y-[-100%]" x-transition:enter-end="translate-y-0" x-transition:leave="transition ease-[cubic-bezier(0.16,1,0.3,1)] duration-500" x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-[-100%]" class="fixed inset-0 bg-slate-950 z-[105] md:hidden flex flex-col">
    {# Decor #}
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(139,92,246,0.1),transparent_70%)] pointer-events-none"></div>

    <div class="flex-1 flex flex-col justify-center px-8 pb-12 pt-24 relative z-10 overflow-y-auto">
      <div class="space-y-4">
        {% for item in global.menu.header %}
          <div x-show="mobileMenuOpen" x-transition:enter="transition ease-out duration-500 delay-[{{ loop.index0 * 100 }}ms]" x-transition:enter-start="opacity-0 translate-x-[-20px]" x-transition:enter-end="opacity-100 translate-x-0">
            <a href="{{ item.url }}" @click="toggleMobile()" class="text-5xl font-black text-white tracking-tighter active:text-violet-400 transition-colors block">
              {{ i18n.t(item.t_key) }}
            </a>
          </div>
        {% endfor %}
      </div>

      {# CTA Mobile - Juga diganti ke Gradient #}
      <div class="mt-12 pt-12 border-t border-white/10" x-show="mobileMenuOpen" x-transition:enter="transition ease-out duration-500 delay-400" x-transition:enter-start="opacity-0 translate-y-10" x-transition:enter-end="opacity-100 translate-y-0">

        <a href="/pricing" @click="toggleMobile()" class="block w-full py-5 bg-linear-to-r from-violet-600 to-fuchsia-600 text-white rounded-2xl text-center font-black text-xl active:scale-[0.98] transition-transform shadow-[0_0_30px_rgba(139,92,246,0.3)]">
          {{ i18n.t('get_started') }}
        </a>
      </div>
    </div>

    <div class="h-1 bg-linear-to-r from-violet-600 via-fuchsia-400 to-pink-400 w-full"></div>
  </div>
</nav>