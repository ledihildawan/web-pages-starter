<nav 
  x-data="{
    mobileMenuOpen: false,
    langOpen: false,
    scrolled: false,
    navHidden: false,
    lastScroll: 0,
    activeMobileSub: null,
    scrollY: 0,
    currentPath: window.location.pathname,
    
    init() {
      // 1. PENGECEKAN INITIAL SAAT HALAMAN SELESAI DI-REFRESH
      this.lastScroll = window.scrollY;
      this.scrolled = this.lastScroll > 20;

      // 2. LISTENER UNTUK SCROLL SELANJUTNYA
      window.addEventListener('scroll', () => {
        window.requestAnimationFrame(() => {
          let currentScroll = window.scrollY;
          this.scrolled = currentScroll > 20;
          
          if (currentScroll > this.lastScroll && currentScroll > 150 && !this.mobileMenuOpen && !this.langOpen) {
            this.navHidden = true;
          } else if (currentScroll < this.lastScroll) {
            this.navHidden = false;
          }
          this.lastScroll = currentScroll;
        });
      }, { passive: true });
    },

    toggleMobile() {
      if (!this.mobileMenuOpen) {
        const sbWidth = window.innerWidth - document.documentElement.clientWidth;
        this.scrollY = window.scrollY;
        document.body.style.insetBlockStart = `-${this.scrollY}px`;
        document.body.classList.add('no-scroll');
        document.documentElement.style.setProperty('--scrollbar-width', `${sbWidth}px`);
        this.mobileMenuOpen = true;
      } else {
        document.body.classList.remove('no-scroll');
        document.body.style.insetBlockStart = '';
        window.scrollTo(0, this.scrollY);
        document.documentElement.style.setProperty('--scrollbar-width', '0px');
        this.mobileMenuOpen = false;
        this.activeMobileSub = null;
      }
    }
  }" 
  @keydown.escape.window="if(mobileMenuOpen) toggleMobile(); langOpen = false"
  @resize.window="if(window.innerWidth >= 1024 && mobileMenuOpen) toggleMobile()"
  
  /* KOREKSI: Menggunakan transition-all agar properti native 'translate' di v4 ikut teranimasi */
  class="fixed inset-bs-0 inset-s-0 inline-full z-[100] transition-all duration-500 ease-emphasized border-be" 
  :class="{
    /* Transisi Background & Shadow */
    'bg-slate-950/80 backdrop-blur-2xl shadow-2xl border-white/10': scrolled && !mobileMenuOpen,
    'bg-transparent border-transparent': !scrolled && !mobileMenuOpen,
    'bg-slate-950 border-transparent shadow-none': mobileMenuOpen,
    
    /* KOREKSI: Transisi Posisi Y (Slide Up & Down) */
    '-translate-y-full': navHidden && !mobileMenuOpen,
    'translate-y-0': !navHidden || mobileMenuOpen
  }">
  
  <div class="max-inline-7xl mx-auto px-6 block-20 flex justify-between items-center relative z-[130] transition-colors duration-500"
       :class="mobileMenuOpen ? 'bg-slate-950' : ''">

    <a href="/" class="group flex flex-col transition-transform active:scale-95 shrink-0" @click="if(mobileMenuOpen) toggleMobile()">
      <span class="text-2xl font-black bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent tracking-tighter leading-none group-hover:brightness-125 transition-all duration-500">
        Starter
      </span>
      <span class="text-[10px] text-slate-500 font-black tracking-[0.25em] uppercase mbs-1.5 transition-colors duration-500 group-hover:text-slate-300">
        {{ i18n.t('engine_name') }}
      </span>
    </a>

    <div class="flex items-center gap-2 lg:gap-5">

      <ul class="hidden lg:flex items-center gap-1 me-4">
        {% for item in global.menu.header %}
          <li class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
            <a href="{{ item.url }}" 
               class="text-[13px] font-bold px-4 pbs-2.5 pbe-2.5 rounded-xl transition-all duration-300 flex items-center gap-1.5"
               :class="currentPath === '{{ item.url }}' ? 'text-white bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5'">
              {{ i18n.t(item.label) }}
              {% if item.children %}
                <svg class="inline-3 block-3 transition-transform duration-500 opacity-30" :class="open ? 'rotate-180 opacity-80' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/>
                </svg>
              {% endif %}
            </a>
            
            {% if item.children %}
              <div x-show="open" x-cloak 
                   x-transition:enter="transition ease-emphasized duration-500" 
                   x-transition:enter-start="opacity-0 translate-y-3 scale-95" 
                   class="absolute inset-bs-full inset-s-0 inline-60 pbs-2 gpu-boost">
                <div class="p-2 bg-slate-900 border border-white/10 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                  {% for child in item.children %}
                    <a href="{{ child.url }}" class="block px-4 pbs-3 pbe-3 text-[13px] font-bold text-slate-400 hover:text-white hover:bg-white/10 rounded-xl transition-colors duration-300">{{ i18n.t(child.label) }}</a>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      <div class="relative hidden lg:block">
        <button @click="langOpen = !langOpen" @click.outside="langOpen = false"
          class="flex items-center gap-2.5 px-3 bg-white/5 border border-white/10 rounded-xl text-slate-400 hover:text-white transition-all duration-300 font-black text-[10px] block-11 group">
          
          <template x-if="$store.i18n.languages.find(l => l.code === $store.i18n.current)">
            <img 
              :src="`https://flagcdn.com/w20/${$store.i18n.languages.find(l => l.code === $store.i18n.current).flag}.png`" 
              class="inline-[16px] block-[11px] object-cover rounded-[2px] opacity-70 group-hover:opacity-100 transition-opacity duration-300"
              alt="Flag">
          </template>
          
          <span x-text="$store.i18n.current.toUpperCase()" class="tracking-[0.15em]">ID</span>
          <svg class="inline-3 block-3 opacity-20 transition-transform duration-500 group-hover:opacity-100" :class="langOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
        </button>

        <div x-show="langOpen" x-cloak 
             x-transition:enter="transition ease-emphasized duration-500" 
             x-transition:enter-start="opacity-0 scale-90 translate-y-3"
             class="absolute inset-bs-full inset-e-0 mbs-3 inline-48 bg-slate-900 border border-white/10 rounded-2xl shadow-2xl z-[140] overflow-hidden gpu-boost">
          <div class="p-1.5 max-block-80 overflow-y-auto hide-scrollbar">
            <template x-for="lang in $store.i18n.languages" :key="lang.code">
              <button @click="$store.i18n.change(lang.code); langOpen = false" 
                class="inline-full px-3 pbs-3.5 pbe-3.5 flex items-center gap-3 text-start rounded-xl text-[12px] font-bold transition-all duration-300 group"
                :class="$store.i18n.current === lang.code ? 'bg-white/10 text-white shadow-inner' : 'text-slate-500 hover:text-white hover:bg-white/5'">
                
                <img :src="`https://flagcdn.com/w20/${lang.flag}.png`" 
                     class="inline-4 block-3 object-cover rounded-[2px] transition-all duration-300 shrink-0"
                     :class="$store.i18n.current === lang.code ? 'opacity-100 grayscale-0' : 'opacity-40 grayscale group-hover:grayscale-0 group-hover:opacity-100'"
                     :alt="lang.code">
                <span class="truncate" x-text="lang.label"></span>
              </button>
            </template>
          </div>
        </div>
      </div>

      <div class="hidden lg:block ms-2 ps-5 border-s border-white/10">
        <a href="/pricing" class="px-6 block-11 flex items-center bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white rounded-xl text-[12px] font-black transition-all duration-300 hover:shadow-[0_0_25px_rgba(139,92,246,0.4)] hover:brightness-110 active:scale-95 uppercase tracking-wider border border-white/10">
          {{ i18n.t('get_started') }}
        </a>
      </div>

      <button @click="toggleMobile()" aria-label="Menu" aria-expanded="mobileMenuOpen"
        class="lg:hidden relative z-[150] inline-11 block-11 flex items-center justify-center text-slate-200 hover:text-white bg-white/5 rounded-xl border border-white/10 transition-colors duration-300"
        :class="mobileMenuOpen ? 'bg-transparent border-transparent' : ''">
        <div class="relative inline-5 block-4 flex flex-col justify-between items-center gpu-boost">
          <span class="inline-full block-0.5 bg-current transition-all duration-500 ease-emphasized" :class="mobileMenuOpen ? 'rotate-45 translate-y-[7px]' : ''"></span>
          <span class="inline-full block-0.5 bg-current transition-all duration-300 ease-emphasized" :class="mobileMenuOpen ? 'opacity-0 -translate-x-4' : ''"></span>
          <span class="inline-full block-0.5 bg-current transition-all duration-500 ease-emphasized" :class="mobileMenuOpen ? '-rotate-45 -translate-y-[7px]' : ''"></span>
        </div>
      </button>

    </div>
  </div>

  <div x-show="mobileMenuOpen" x-cloak 
    x-trap.noscroll.inert="mobileMenuOpen"
    x-transition:enter="transition ease-emphasized duration-700" 
    x-transition:enter-start="-translate-y-full" 
    x-transition:enter-end="translate-y-0" 
    x-transition:leave="transition ease-in duration-500"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="-translate-y-full"
    class="fixed inset-0 bg-slate-950 z-[110] lg:hidden flex flex-col gpu-boost block-dvh">
    
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(139,92,246,0.1),transparent_70%)] pointer-events-none"></div>

    <div class="flex-1 overflow-y-auto pbs-24 pbe-12 px-6 hide-scrollbar relative z-10 text-start">
      
      <ul class="space-y-1 mbs-6">
        {% for item in global.menu.header %}
          <li x-show="mobileMenuOpen" 
              x-transition:enter="transition ease-emphasized duration-700" 
              x-transition:enter-start="opacity-0 translate-y-8 scale-95"
              style="transition-delay: {{ loop.index0 * 50 }}ms"
              class="gpu-boost">
            
            <div class="flex items-center justify-between pbs-4 pbe-4 group">
              <a href="{{ item.url }}" @click="if(!{{ item.children | length }}) toggleMobile()" 
                 class="text-4xl sm:text-5xl font-black tracking-tighter transition-all duration-300"
                 :class="currentPath === '{{ item.url }}' ? 'text-violet-400' : 'text-white active:text-violet-400'">
                {{ i18n.t(item.label) }}
              </a>
              {% if item.children %}
                <button @click="activeMobileSub = (activeMobileSub === {{ loop.index0 }} ? null : {{ loop.index0 }})" 
                        class="inline-11 block-11 flex items-center justify-center bg-white/5 rounded-2xl border border-white/10 active:scale-90 transition-all duration-300">
                  <svg class="inline-6 block-6 transition-transform duration-500 ease-emphasized" :class="activeMobileSub === {{ loop.index0 }} ? 'rotate-180 text-violet-400' : 'text-slate-600'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                </button>
              {% endif %}
            </div>
            
            {% if item.children %}
              <div x-show="activeMobileSub === {{ loop.index0 }}" x-cloak x-collapse class="mbe-6 ms-2 ps-6 border-s-2 border-violet-500/20 space-y-5 pbs-4 pbe-4">
                {% for child in item.children %}
                  <a href="{{ child.url }}" @click="toggleMobile()" class="block text-2xl font-black transition-colors duration-300" :class="currentPath === '{{ child.url }}' ? 'text-white' : 'text-slate-500 hover:text-white'">{{ i18n.t(child.label) }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      <div class="mbs-12 pbs-8 border-bs border-white/10" x-show="mobileMenuOpen" 
           x-transition:enter="transition ease-emphasized duration-700 delay-[400ms]" 
           x-transition:enter-start="opacity-0 translate-y-8">
        <p class="text-[10px] font-black tracking-[0.2em] text-slate-500 uppercase mbe-5 ps-1">
          {{ i18n.t('select_language') }}
        </p>
        
        <div class="grid grid-cols-2 gap-2.5">
          <template x-for="lang in $store.i18n.languages" :key="lang.code">
            <button @click="$store.i18n.change(lang.code); toggleMobile()"
              class="group relative flex items-center gap-3 px-4 pbs-4 pbe-4 rounded-2xl transition-all duration-300 border text-start gpu-boost"
              :class="$store.i18n.current === lang.code 
                      ? 'bg-white/10 border-white/10 text-white' 
                      : 'bg-white/[0.03] border-transparent text-slate-500 hover:text-slate-300 hover:bg-white/[0.06] border'">
              
              <div class="relative shrink-0 inline-5 block-3.5 overflow-hidden rounded-[2px]">
                 <img :src="`https://flagcdn.com/w40/${lang.flag}.png`" 
                  class="inline-full block-full object-cover transition-all duration-500"
                  :class="$store.i18n.current === lang.code ? 'opacity-100 grayscale-0' : 'opacity-30 grayscale group-hover:opacity-60 group-hover:grayscale-0'"
                  :alt="lang.code">
              </div>
                   
              <div class="flex flex-col min-w-0">
                <span class="text-[13px] font-bold truncate leading-none" x-text="lang.label"></span>
                <span class="text-[9px] font-black opacity-20 tracking-widest mbs-1.5" x-text="lang.code.toUpperCase()"></span>
              </div>
            </button>
          </template>
        </div>
      </div>

      <div class="mbs-8" x-show="mobileMenuOpen" 
           x-transition:enter="transition ease-emphasized duration-700 delay-[500ms]" 
           x-transition:enter-start="opacity-0 translate-y-10">
        <a href="/pricing" @click="toggleMobile()" class="block inline-full pbs-5 pbe-5 bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white rounded-3xl text-center font-black text-xl shadow-2xl active:scale-[0.98] transition-all duration-500">
          {{ i18n.t('get_started') }}
        </a>
      </div>

    </div>
    
    <div class="block-2 bg-linear-to-r from-violet-600 via-fuchsia-400 to-pink-400 inline-full shrink-0"></div>
  </div>
</nav>