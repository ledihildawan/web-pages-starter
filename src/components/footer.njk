{% import "icons.njk" as icon %}

<footer class="pbs-16 pbe-16 px-6 border-bs border-white/10 bg-slate-950 relative overflow-hidden" role="contentinfo">
  <!-- Enhanced background effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-be-0 inset-e-0 inline-96 block-96 bg-gradient-to-br from-violet-600/10 via-transparent to-fuchsia-600/5 rounded-full blur-[120px]"></div>
    <div class="absolute inset-bs-0 inset-s-0 inline-64 block-64 bg-fuchsia-600/5 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-8 mbe-12">
      <!-- Logo section -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <a href="/" class="group flex flex-col transition-transform active:scale-95">
          <span class="text-2xl font-black text-gradient tracking-tight leading-none group-hover:brightness-125 transition-all duration-200">
            Starter
          </span>
          <span class="text-[10px] text-slate-500 font-black tracking-[0.25em] uppercase mbs-1.5 transition-colors duration-200 group-hover:text-slate-300">
            {{ i18n.t('engine_name') }}
          </span>
        </a>
        <p class="text-[11px] text-slate-400 font-medium tracking-wide text-center md:text-start">
          {{ i18n.t('site_tagline') }}
        </p>
      </div>

      <!-- Navigation links -->
      <nav class="flex flex-wrap justify-center items-center gap-inline-6 gap-block-2" aria-label="Footer navigation">
        {% for item in global.menu.header %}
          <a href="{{ item.url }}" class="group relative text-sm text-slate-400 hover:text-white transition-colors duration-300 px-4 py-2.5 flex items-center font-bold">
            {{ i18n.t(item.label) }}
            <span class="absolute inset-bs-0 inset-s-0 inline-0 group-hover:inline-full block-0.5 bg-gradient-to-r from-violet-500 to-fuchsia-500 transition-all duration-200"></span>
          </a>
        {% endfor %}
      </nav>

      <!-- Copyright -->
      <div class="text-center md:text-end">
        <p class="text-sm text-slate-300 font-medium mbe-1">
          {{ i18n.html('copyright', { year: 2026 }) }}
        </p>
        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest">
          {{ i18n.t('rights_reserved') }}
        </p>
      </div>
    </div>

    <!-- Enhanced bottom section -->
    <div class="pbs-8 border-bs border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Social links -->
      <div class="flex items-center gap-2">
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="btn-squash anticipate-press hover-lift ripple-click group inline-11 block-11 flex items-center justify-center radius-icon bg-white/5 border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all duration-300 overflow-hidden">
          {{ icon.icon('github', 'inline-5 block-5 text-slate-400 group-hover:text-white transition-colors duration-300', size='lg') | safe }}
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="btn-squash anticipate-press hover-lift ripple-click group inline-11 block-11 flex items-center justify-center radius-icon bg-white/5 border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all duration-300 overflow-hidden">
          {{ icon.icon('twitter', 'inline-5 block-5 text-slate-400 group-hover:text-white transition-colors duration-300', size='lg') | safe }}
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex items-center gap-4 text-[10px] text-slate-500 font-bold uppercase tracking-wider">
        <span class="flex items-center gap-2">
          {{ icon.icon('shield', 'inline-4 block-4 text-emerald-400', size='md') | safe }}
          {{ i18n.t('secure') }}
        </span>
        <span class="flex items-center gap-2">
          {{ icon.icon('lightning', 'inline-4 block-4 text-violet-400', size='md') | safe }}
          {{ i18n.t('fast') }}
        </span>
      </div>
    </div>
  </div>
</footer>