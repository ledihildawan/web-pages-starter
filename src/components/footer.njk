<footer class="pbs-12 pbe-12 px-6 border-bs border-white/10 bg-slate-950 relative overflow-hidden">
  
  <div class="absolute inset-be-0 inset-e-0 inline-64 block-64 bg-violet-500/5 blur-3xl -z-10 rounded-full transition-all duration-700"></div>
  
  <div class="max-inline-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-10">
    
    <div class="flex flex-col items-center md:items-start gap-2">
      <span class="text-2xl font-black bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent tracking-tight">
        Starter
      </span>
      <p class="text-[10px] text-slate-300 font-bold tracking-[0.2em] uppercase opacity-90">
        {{ i18n.t('site_tagline') }}
      </p>
    </div>

    <nav class="flex flex-wrap justify-center items-center gap-x-10 gap-y-2 text-sm">
      {% for item in global.menu.header %}
        <a href="{{ item.url }}" class="text-slate-200 hover:text-white transition-colors duration-300 pbs-2 pbe-2 min-block-[44px] flex items-center font-bold">
          {{ i18n.t(item.label) }}
        </a>
      {% endfor %}
    </nav>

    <div class="text-center md:text-end">
      <p class="text-sm text-slate-300 font-bold">
        &copy; 2026 Technomira Tanzania.
      </p>
      <p class="text-[11px] text-slate-400 font-black uppercase tracking-widest mbs-1">
        {{ i18n.t('rights_reserved') }}
      </p>
    </div>
    
  </div>
</footer>