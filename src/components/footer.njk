<footer class="pbs-16 pbe-16 px-6 border-bs border-white/10 bg-slate-950 relative overflow-hidden content-auto">
  <!-- Enhanced background effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-be-0 inset-e-0 inline-96 block-96 bg-gradient-to-br from-violet-600/10 via-transparent to-fuchsia-600/5 rounded-full blur-[120px]"></div>
    <div class="absolute inset-bs-0 inset-s-0 inline-64 block-64 bg-fuchsia-600/5 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-12 mbe-12">
      <!-- Logo section -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <a href="/" class="group flex flex-col transition-transform active:scale-95">
          <span class="text-2xl font-black bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent tracking-tight leading-none group-hover:brightness-125 transition-all duration-500">
            Starter
          </span>
          <span class="text-[10px] text-slate-500 font-black tracking-[0.25em] uppercase mbs-1.5 transition-colors duration-500 group-hover:text-slate-300">
            {{ i18n.t('engine_name') }}
          </span>
        </a>
        <p class="text-[11px] text-slate-400 font-medium tracking-wide text-center md:text-start">
          {{ i18n.t('site_tagline') }}
        </p>
      </div>

      <!-- Navigation links -->
      <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-3">
        {% for item in global.menu.header %}
          <a href="{{ item.url }}" class="group relative text-sm text-slate-400 hover:text-white transition-colors duration-300 pbs-2 pbe-2 min-block-11 flex items-center font-bold">
            {{ i18n.t(item.label) }}
            <span class="absolute inset-bs-0 left-0 inline-0 group-hover:inline-full block-0.5 bg-gradient-to-r from-violet-500 to-fuchsia-500 transition-all duration-500"></span>
          </a>
        {% endfor %}
      </div>

      <!-- Copyright -->
      <div class="text-center md:text-end">
        <p class="text-sm text-slate-300 font-medium mbe-1">
          {{ i18n.html('copyright', { year: 2026 }) }}
        </p>
        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest">
          {{ i18n.t('rights_reserved') }}
        </p>
      </div>
    </div>

    <!-- Enhanced bottom section -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Social links placeholder -->
      <div class="flex items-center gap-4">
        <a href="#" class="group inline-10 block-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all duration-300">
          <svg class="inline-5 block-5 text-slate-400 group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="#" class="group inline-10 block-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all duration-300">
          <svg class="inline-5 block-5 text-slate-400 group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex items-center gap-6 text-[10px] text-slate-500 font-bold uppercase tracking-wider">
        <span class="flex items-center gap-2">
          <svg class="inline-4 block-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          {{ i18n.t('secure') }}
        </span>
        <span class="flex items-center gap-2">
          <svg class="inline-4 block-4 text-violet-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13.5 4.938a7 7 0 11-9.006 1.737c.202-.257.59-.218.793.08a5.002 5.002 0 005.05 2.122.722.722 0 01.08.722l-.967 1.733a.5.5 0 00.712.657l1.717-.875a.5.5 0 00.24-.404l.332-1.992a.5.5 0 00-.052-.34z"/>
          </svg>
          {{ i18n.t('fast') }}
        </span>
      </div>
    </div>
  </div>
</footer>