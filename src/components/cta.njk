{% import "icons.njk" as icon %}

<section aria-labelledby="cta-heading" class="pbs-40 pbe-40 px-6 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-bs-0 inset-s-0 inline-full block-full bg-[radial-gradient(ellipse_at_top_left,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent"></div>
    <div class="absolute inset-be-0 inset-e-0 inline-full block-full bg-[radial-gradient(ellipse_at_bottom_right,var(--tw-gradient-stops))] from-fuchsia-600/10 via-transparent to-transparent"></div>
  </div>

  <div class="max-inline-6xl mx-auto relative radius-card-lg overflow-hidden p-16 md:p-28 text-center border border-white/10 shadow-[0_30px_80px_rgba(0,0,0,0.4)]">
    <!-- Static background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br rtl:bg-gradient-to-bl from-violet-600/30 via-slate-950 to-fuchsia-600/20 -z-10"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-30 -z-10 grid-pattern"></div>

    <!-- Static glow points -->
    <div class="absolute inset-bs-[10%] inset-s-[10%] inline-40 block-40 bg-violet-500/20 rounded-full blur-[60px]"></div>
    <div class="absolute inset-be-[10%] inset-e-[10%] inline-32 block-32 bg-fuchsia-500/15 rounded-full blur-[50px]"></div>

    <h2 id="cta-heading" class="text-5xl md:text-6xl lg:text-7xl font-black mbe-8 text-white tracking-tighter">
      {{ i18n.t('comp.cta.heading') | safe }}
    </h2>

    <p class="text-slate-300 mbe-14 max-inline-2xl mx-auto text-xl md:text-2xl leading-relaxed font-medium">
      {{ i18n.t('comp.cta.description') | safe }}
    </p>

    <a href="/contact" class="magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click sparkle-hover group relative inline-flex items-center justify-center min-block-16 px-8 sm:px-12 md:px-16 lg:px-20 py-4 sm:py-5 md:py-6 bg-white text-slate-950 radius-btn font-black text-lg sm:text-xl md:text-2xl transition-all duration-250 ease-emphasized hover:scale-105 hover:shadow-[0_25px_60px_rgba(255,255,255,0.3)] overflow-hidden">
      <!-- Shimmer effect -->
      <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/60 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"></span>
      <span class="relative flex items-center gap-3">
        {{ i18n.t('comp.cta.button_text') | safe }}
        {{ icon.icon('arrow-right', 'inline-6 block-6 icon-transition group-hover:translate-x-1', size='xl') | safe }}
      </span>
    </a>
  </div>
</section>