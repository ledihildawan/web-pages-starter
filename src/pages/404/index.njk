{% extends "main.njk" %}

{% block content %}
  <section class="min-block-[90vh] flex items-center justify-center relative overflow-hidden px-6">
    
    {# Background Aura Dekoratif (Logical Centering) #}
    <div class="absolute inset-bs-1/2 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 -translate-y-1/2 inline-[600px] block-[600px] bg-violet-600/10 blur-[120px] rounded-full -z-10 animate-pulse gpu-boost"></div>

    <div class="text-center z-10 max-inline-2xl mx-auto">
      {# 1. Heading 404 - Huge & Logical #}
      <h1 class="text-[10rem] md:text-[18rem] font-black leading-none tracking-tighter bg-linear-to-b from-white via-white to-slate-800 bg-clip-text text-transparent opacity-20 select-none">
        {{ i18n.t('page.heading') }}
      </h1>

      {# 2. Subheading - Menggunakan mbs (margin-block-start) negatif untuk overlap yang presisi #}
      <h2 class="text-3xl md:text-5xl font-black text-white mbe-6 mbs-[-2.5rem] md:mbs-[-5rem] tracking-tight">
        {{ i18n.t('page.subheading') }}
      </h2>

      {# 3. Description - max-inline-md menggantikan max-w-md #}
      <p class="text-slate-300 text-lg md:text-xl mbe-10 max-inline-md mx-auto font-medium leading-relaxed">
        {{ i18n.t('page.description') }}
      </p>

      {# 4. Button - Smart Directional Arrow #}
      <a href="/" class="group inline-flex items-center gap-3 px-10 pbs-4 pbe-4 bg-white text-slate-950 font-black rounded-2xl transition-all duration-500 ease-emphasized transform hover:scale-105 active:scale-95 shadow-[0_20px_40px_rgba(255,255,255,0.15)] hover:bg-slate-100 gpu-boost">
        
        <svg class="inline-5 block-5 transition-transform duration-500 ltr:group-hover:-translate-x-1 rtl:group-hover:translate-x-1" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
        </svg>

        <span>{{ i18n.t('page.button_text') }}</span>
      </a>
    </div>
  </section>
{% endblock %}