{% extends "main.njk" %}
{% import "icons.njk" as icon %}

{% block content %}
  <section class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden min-block-screen flex flex-col items-center justify-center noise-texture">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent -z-10 blur-3xl"></div>
      <div class="absolute inset-bs-[10%] inset-s-[10%] inline-96 block-96 bg-violet-600/10 blur-[100px]"></div>
      <div class="absolute inset-be-[10%] inset-e-[10%] inline-80 block-80 bg-fuchsia-600/8 blur-[80px]"></div>
      <div class="hidden sm:absolute sm:inset-0 opacity-30 grid-pattern"></div>
    </div>

    <div class="max-inline-6xl mx-auto relative z-10">
      <div class="relative mbe-8">
        <h1 class="text-[10rem] md:text-[16rem] lg:text-[20rem] font-black leading-none tracking-tighter text-gradient-white-subtle select-none">
          {{ i18n.t('page.heading') }}
        </h1>
        <div class="absolute inset-0 bg-linear-to-b from-violet-600/30 to-fuchsia-600/20 blur-3xl -z-10"></div>
      </div>

      <h2 class="text-6xl md:text-8xl lg:text-9xl font-black text-white mbe-6 tracking-tight">
        <span class="text-gradient-white-full">
          {{ i18n.t('page.subheading') }}
        </span>
      </h2>

      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ i18n.t('page.description') }}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mbe-14">
        <a href="{{ url('/') }}" class="magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click sparkle-hover group relative inline-full sm:inline-auto min-block-14 px-14 py-4 bg-white text-slate-950 radius-btn font-black text-lg flex items-center justify-center transition duration-200 ease-emphasized hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:scale-105 overflow-hidden">
          <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-400 ease-in-out"></span>
          <span class="relative flex items-center gap-3">
            {{ icon.icon('arrow-left', 'inline-5 block-5 icon-transition ltr:group-hover:-translate-x-1 rtl:group-hover:translate-x-1', size='lg') }}
            {{ i18n.t('page.button_text') }}
          </span>
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-slate-400">
        <span class="font-medium">{{ i18n.t('page.or_try') }}</span>
        <a href="{{ url('/') }}" class="color-shift text-slate-400 hover:text-white transition-colors duration-300 font-medium hover:underline decoration-violet-500 underline-offset-4">{{ i18n.t('home') }}</a>
        <span class="text-slate-700">•</span>
        <a href="{{ url('/features') }}" class="color-shift text-slate-400 hover:text-white transition-colors duration-300 font-medium hover:underline decoration-violet-500 underline-offset-4">{{ i18n.t('features') }}</a>
        <span class="text-slate-700">•</span>
        <a href="{{ url('/pricing') }}" class="color-shift text-slate-400 hover:text-white transition-colors duration-300 font-medium hover:underline decoration-violet-500 underline-offset-4">{{ i18n.t('pricing') }}</a>
      </div>
    </div>
  </section>
{% endblock %}