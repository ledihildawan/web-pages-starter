{% extends "main.njk" %}

{% block content %}
  <section class="min-h-[90vh] flex items-center justify-center relative overflow-hidden px-6">
    {# Background Aura Dekoratif #}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-600/10 blur-[120px] rounded-full -z-10 animate-pulse"></div>

    <div class="text-center z-10 max-w-2xl mx-auto">
      {# 1. Heading 404 - Hydrated #}
      <h1 class="text-[10rem] md:text-[18rem] font-black leading-none tracking-tighter bg-linear-to-b from-white via-white to-slate-800 bg-clip-text text-transparent opacity-20 select-none">
        {{ i18n.t('page.heading') }}
      </h1>

      {# 2. Subheading - Hydrated & Kontras Tinggi #}
      <h2 class="text-3xl md:text-5xl font-black text-white mb-6 -mt-10 md:-mt-20 tracking-tight">
        {{ i18n.t('page.subheading') }}
      </h2>

      {# 3. Description - Hydrated dengan Slate-300 #}
      <p class="text-slate-300 text-lg md:text-xl mb-10 max-w-md mx-auto font-medium leading-relaxed">
        {{ i18n.t('page.description') }}
      </p>

      {# 4. Button - Hydrated #}
      <a href="/" class="group inline-flex items-center gap-3 px-10 py-4 bg-white text-slate-950 font-black rounded-2xl transition-all transform hover:scale-105 active:scale-95 shadow-[0_20px_40px_rgba(255,255,255,0.15)] hover:bg-slate-100">
        <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
        </svg>
        <span>{{ i18n.t('page.button_text') }}</span>
      </a>
    </div>
  </section>
{% endblock %}