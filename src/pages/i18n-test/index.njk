{% extends "main.njk" %}

{% block content %}
  {# Hero Section #}
  <section class="relative pt-24 pb-16 lg:pt-32 lg:pb-20 px-6 text-center overflow-hidden">
    {# Background Effects #}
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-violet-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-950/50 to-slate-950"></div>
    </div>

    <div class="max-w-4xl mx-auto relative">
      {# Badge #}
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-300 text-xs font-bold uppercase tracking-wider mb-8">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        {{ i18n.t('page.' + page.hero.t_key + '.badge')}}
      </div>

      {# Title #}
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight mb-6 leading-[1.1]">
        <span class="bg-gradient-to-br from-white via-white to-slate-400 bg-clip-text text-transparent">
          {{ i18n.html('page.' + page.hero.t_key + '.title')}}
        </span>
      </h1>

      {# Description #}
      <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
        {{ i18n.t('page.' + page.hero.t_key + '.description')}}
      </p>

      {# Quick Stats #}
      <div class="flex items-center justify-center gap-6 md:gap-10 text-sm">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🌍</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none tabular-nums">42</div>
            <div class="text-xs text-slate-400">{{ i18n.t('page.language_info.languages')}}</div>
          </div>
        </div>
        <div class="w-px h-12 bg-white/10"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl">💱</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none tabular-nums">16</div>
            <div class="text-xs text-slate-400">{{ i18n.t('page.currency.currencies')}}</div>
          </div>
        </div>
        <div class="w-px h-12 bg-white/10"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl">🔄</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none">Live</div>
            <div class="text-xs text-slate-400">{{ i18n.t('page.language_info.switching')}}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Language Info Bar #}
  <section class="py-8 px-6 border-y border-white/5 bg-slate-900/30">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-center gap-4 md:gap-8 flex-wrap">
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">Locale</span>
          <span class="text-sm font-bold text-white tabular-nums">{{ lang }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <span class="text-xs text-slate-400 uppercase tracking-wider">Currency</span>
          <span class="text-sm font-bold text-emerald-400 tabular-nums">{{ localeConfig.currency }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">Direction</span>
          <span class="text-sm font-bold text-white">{{ localeConfig.dir }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">Native Digits</span>
          <span class="text-sm font-bold text-white">{% if localeConfig.nativeDigits %}Enabled{% else %}Disabled{% endif %}</span>
        </div>
      </div>
    </div>
  </section>

  {# Core Features Section #}
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      {# Section Header #}
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Core Features</h2>
        <p class="text-slate-400 text-lg">Translation, Pluralization & HTML Content</p>
      </div>

      {# Features Grid #}
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {# Number Formatting #}
        <div class="group p-6 rounded-3xl bg-gradient-to-br from-violet-500/[0.08] to-transparent border border-violet-500/10 hover:border-violet-500/30 hover:shadow-xl hover:shadow-violet-500/10 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-violet-500/20 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">🔢</div>
            <h3 class="text-lg font-bold text-white">{{ i18n.t('page.numbers.title')}}</h3>
          </div>
          <div class="space-y-3">
            {% for num in page.numbers %}
              {% if loop.index <= page.display.max_numbers %}
              <div class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
                <span class="text-sm text-slate-400">{{ i18n.t('page.' + num.label)}}</span>
                <span class="text-xl font-black text-violet-400 tabular-nums">{{ i18n.formatNumber(num.val)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Pluralization #}
        <div class="group p-6 rounded-3xl bg-gradient-to-br from-fuchsia-500/[0.08] to-transparent border border-fuchsia-500/10 hover:border-fuchsia-500/30 hover:shadow-xl hover:shadow-fuchsia-500/10 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-fuchsia-500/20 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">a</div>
            <h3 class="text-lg font-bold text-white">{{ i18n.t('page.pluralization.title')}}</h3>
          </div>
          <div class="space-y-3">
            {% for count in page.display.simple_plural_counts %}
              <div class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
                <span class="text-sm text-slate-400 tabular-nums">{{ count }}</span>
                <span class="text-base text-fuchsia-400 font-medium">{{ i18n.plural('item', count)}}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        {# HTML Content #}
        <div class="group p-6 rounded-3xl bg-gradient-to-br from-emerald-500/[0.08] to-transparent border border-emerald-500/10 hover:border-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/10 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-emerald-500/20 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">&lt;/&gt;</div>
            <h3 class="text-lg font-bold text-white">{{ i18n.t('page.html_content.title')}}</h3>
          </div>
          <div class="text-center py-4 px-3 rounded-2xl bg-emerald-500/5">
            <div class="text-base text-white mb-2">{{ i18n.html('page.html_content.example')}}</div>
          </div>
        </div>

        {# Form #}
        <div class="group p-6 rounded-3xl bg-gradient-to-br from-amber-500/[0.08] to-transparent border border-amber-500/10 hover:border-amber-500/30 hover:shadow-xl hover:shadow-amber-500/10 transition-all duration-300 lg:col-span-2">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-amber-500/20 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">📝</div>
            <h3 class="text-lg font-bold text-white">{{ i18n.t('page.form.title')}}</h3>
          </div>
          <form class="grid md:grid-cols-3 gap-4">
            {% for field in page.form_fields %}
              {% if loop.index <= page.display.max_form_fields %}
              <input type="{{ field.type }}" {{ i18n.attr('page.form.' + field.key + '_placeholder', 'placeholder') }} class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-xl text-white placeholder-slate-500 text-sm focus:outline-none focus:border-amber-500/30 focus:ring-2 focus:ring-amber-500/10 transition-all">
              {% endif %}
            {% endfor %}
            <button type="submit" class="px-6 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-amber-500/20">
              {{ i18n.t('page.form.submit')}}
            </button>
          </form>
        </div>

        {# Missing Keys #}
        <div class="group p-6 rounded-3xl bg-gradient-to-br from-red-500/[0.08] to-transparent border border-red-500/10 hover:border-red-500/30 hover:shadow-xl hover:shadow-red-500/10 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-red-500/20 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">⚠️</div>
            <h3 class="text-lg font-bold text-white">{{ i18n.t('page.missing_keys.title')}}</h3>
          </div>
          <div class="space-y-2">
            {% for key in page.missing_keys %}
              {% if loop.index <= page.display.max_missing_keys %}
              <div class="px-4 py-3 rounded-xl bg-red-950/30 border border-red-500/10">
                <code class="text-red-400 text-sm">{{ key }}</code>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Currency Section #}
  <section class="py-24 px-6 bg-gradient-to-b from-slate-900/30 to-transparent">
    <div class="max-w-6xl mx-auto">
      {# Section Header #}
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">{{ i18n.t('page.currency.title')}}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.currency.description')}}</p>
      </div>

      <div class="max-w-3xl mx-auto">
        {# Currency Comparison #}
        <div class="p-8 rounded-3xl bg-slate-900/40 border border-white/5 hover:border-white/10 transition-all">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 rounded-xl bg-violet-500/20 flex items-center justify-center">
              <span class="text-xl">🌐</span>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">{{ i18n.t('page.currency_comparison.title')}}</h3>
              <p class="text-sm text-slate-400">Multi-currency view</p>
            </div>
          </div>
          <div class="text-center mb-8 p-6 rounded-2xl bg-violet-500/5">
            <div class="text-4xl font-black text-white mb-2">{{ i18n.formatCurrency(page.display.currency_comparison_base, 'USD', {raw: true})}}</div>
            <div class="text-sm text-slate-400">{{ i18n.t('page.currency_comparison.base_price')}}</div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            {% for curr in page.display.currency_comparison_currencies %}
              <div class="p-4 rounded-xl bg-slate-800/30 border border-white/5 hover:border-white/10 transition-all text-center">
                <div class="text-xs text-slate-400 mb-2">{{ i18n.t('page.currency_comparison.' + curr | lower)}}</div>
                <div class="text-lg font-black tabular-nums {% if curr == 'USD' %}text-emerald-400{% elif curr == 'JPY' %}text-fuchsia-400{% elif curr == 'CNY' %}text-amber-400{% else %}text-rose-400{% endif %}">{{ i18n.convertCurrency(page.display.currency_comparison_base, curr)}}</div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Advanced Formatting Section #}
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      {# Section Header #}
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">{{ i18n.t('page.advanced.title')}}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.advanced.description')}}</p>
      </div>

      {# Advanced Grid #}
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {# Percentages #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-emerald-500/20 hover:shadow-lg hover:shadow-emerald-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">%</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.percentages')}}</span>
          </div>
          <div class="space-y-3">
            {% for pct in page.percentages %}
              {% if loop.index <= page.display.max_percentages %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs text-slate-400">{{ i18n.t('page.' + pct.label)}}</span>
                <span class="text-lg font-black text-emerald-400 tabular-nums">{{ i18n.formatPercent(pct.val)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Bytes #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-violet-500/20 hover:shadow-lg hover:shadow-violet-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">💾</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.bytes')}}</span>
          </div>
          <div class="space-y-3">
            {% for byte in page.bytes %}
              {% if loop.index <= page.display.max_bytes %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs text-slate-400">{{ i18n.t('page.' + byte.label)}}</span>
                <span class="text-lg font-black text-violet-400 tabular-nums">{{ i18n.formatBytes(byte.val)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Ordinals #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-rose-500/20 hover:shadow-lg hover:shadow-rose-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">🥇</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.ordinals')}}</span>
          </div>
          <div class="space-y-3">
            {% for ord in page.ordinals %}
              {% if loop.index <= page.display.max_ordinals %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ ord }}</span>
                <span class="text-sm font-black text-rose-400">{{ i18n.formatOrdinal(ord)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Cardinals #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-orange-500/20 hover:shadow-lg hover:shadow-orange-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">🔢</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.cardinals')}}</span>
          </div>
          <div class="space-y-3">
            {% for card in page.cardinals %}
              {% if loop.index <= page.display.max_cardinals %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ card }}</span>
                <span class="text-sm font-black text-orange-400">{{ i18n.formatCardinal(card)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Scientific #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-cyan-500/20 hover:shadow-lg hover:shadow-cyan-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">🔬</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.scientific')}}</span>
          </div>
          <div class="space-y-3">
            {% for sci in page.scientific %}
              {% if loop.index <= page.display.max_scientific %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ sci }}</span>
                <span class="text-sm font-black text-cyan-400 tabular-nums">{{ i18n.formatScientific(sci)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Abbreviated #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-lime-500/20 hover:shadow-lg hover:shadow-lime-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">📊</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.abbreviated')}}</span>
          </div>
          <div class="space-y-3">
            {% for abb in page.abbreviated %}
              {% if loop.index <= page.display.max_abbreviated %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ abb }}</span>
                <span class="text-sm font-black text-lime-400 tabular-nums">{{ i18n.formatAbbreviated(abb)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Date Formats #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-indigo-500/20 hover:shadow-lg hover:shadow-indigo-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">📅</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.date_formats')}}</span>
          </div>
          <div class="space-y-3">
            {% for dateFmt in page.date_formats %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs text-slate-400">{{ i18n.t('page.' + dateFmt.label)}}</span>
                <span class="text-sm font-black text-indigo-400">{{ i18n.formatDate(dateFmt.val)}}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        {# Time Formats #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-purple-500/20 hover:shadow-lg hover:shadow-purple-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">🕐</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.time_formats')}}</span>
          </div>
          <div class="space-y-3">
            {% for timeFmt in page.time_formats %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs text-slate-400">{{ i18n.t('page.' + timeFmt.label)}}</span>
                <span class="text-sm font-black text-purple-400">{{ i18n.formatTime(timeFmt.val)}}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        {# Durations #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-teal-500/20 hover:shadow-lg hover:shadow-teal-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">⏱️</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.durations')}}</span>
          </div>
          <div class="space-y-3">
            {% for dur in page.durations %}
              {% if loop.index <= page.display.max_durations %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ dur }}s</span>
                <span class="text-sm font-bold text-teal-400">{{ i18n.formatDuration(dur)}}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Relative Time #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-pink-500/20 hover:shadow-lg hover:shadow-pink-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">⏰</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.relative_time')}}</span>
          </div>
          <div class="space-y-3">
            {% for rel in page.relative_time %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs font-mono text-slate-400">{{ rel.val }}{{ rel.unit[0] }}</span>
                <span class="text-sm font-bold text-pink-400">{{ i18n.formatRelativeTime(rel.val, { unit: rel.unit })}}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        {# Lists #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-amber-500/20 hover:shadow-lg hover:shadow-amber-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">📝</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.lists')}}</span>
          </div>
          <div class="space-y-3">
            {% for lst in page.lists %}
              {% if loop.index <= page.display.max_lists %}
              <div class="text-sm text-amber-400">{{ i18n.formatList(lst.items)}}</div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Regional Pricing #}
        <div class="p-6 rounded-2xl bg-slate-900/30 border border-white/5 hover:border-emerald-500/20 hover:shadow-lg hover:shadow-emerald-500/5 transition-all">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">💵</span>
            <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('page.advanced.regional_pricing')}}</span>
          </div>
          <div class="space-y-3">
            {% for plan in page.regional_pricing %}
              <div class="flex justify-between items-baseline">
                <span class="text-xs text-slate-400">{{ i18n.t('page.advanced.' + plan.id + '_plan')}}</span>
                <span class="text-lg font-black text-emerald-400 tabular-nums">{{ i18n.formatLocalPrice(plan)}}</span>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Number Modes Section #}
  <section class="py-24 px-6 bg-gradient-to-b from-slate-900/30 to-transparent">
    <div class="max-w-4xl mx-auto">
      {# Section Header #}
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">{{ i18n.t('page.advanced.number_modes')}}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.advanced.number_modes_desc')}}</p>
      </div>

      <div class="p-10 rounded-3xl bg-slate-900/40 border border-white/5">
        {# Example Number #}
        <div class="text-center mb-12">
          <div class="text-6xl md:text-7xl font-black text-white tabular-nums mb-4">{{ i18n.formatNumber(page.display.number_modes_example)}}</div>
          <div class="text-sm text-slate-400">Example: {{ page.display.number_modes_example }}</div>
        </div>

        {# Mode Comparison #}
        <div class="grid md:grid-cols-3 gap-4">
          <div class="p-6 rounded-2xl bg-slate-800/30 text-center">
            <div class="text-xs text-slate-400 uppercase tracking-wider mb-4">{{ i18n.t('page.advanced.plain_label')}}</div>
            <div class="text-2xl font-black text-white tabular-nums">{{ i18n.formatNumber(page.display.number_modes_example, {}, '', '', false)}}</div>
          </div>
          <div class="p-6 rounded-2xl bg-violet-500/10 border border-violet-500/20 text-center">
            <div class="text-xs text-slate-400 uppercase tracking-wider mb-4">{{ i18n.t('page.advanced.native_label')}}</div>
            <div class="text-2xl font-black text-violet-400 tabular-nums">{{ i18n.formatNumber(page.display.number_modes_example, {}, '', '', true)}}</div>
          </div>
          <div class="p-6 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-center">
            <div class="text-xs text-slate-400 uppercase tracking-wider mb-4">{{ i18n.t('page.advanced.universal_label')}}</div>
            <div class="text-2xl font-black text-emerald-400 tabular-nums">{{ page.display.number_modes_example }}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Language Switcher #}
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      {# Section Header #}
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">{{ i18n.t('page.switcher.title')}}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.switcher.description')}}</p>
      </div>

      {# Language Buttons #}
      <div class="flex flex-wrap justify-center gap-3">
        {% for locale in locales %}
        <button onclick="localStorage.setItem('{{ localeStorageKey }}', '{{ locale.code }}'); location.reload();" class="flex items-center gap-3 px-5 py-3 rounded-xl bg-slate-900/30 border border-white/5 hover:bg-violet-500/10 hover:border-violet-500/30 hover:shadow-lg hover:shadow-violet-500/10 text-white text-sm font-medium transition-all">
          <img src="https://flagcdn.com/w40/{{ locale.flag }}.png" alt="{{ locale.label }}" class="w-6 h-4 rounded shadow-sm object-cover" loading="lazy">
          <span>{{ locale.label }}</span>
        </button>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}
