{% extends "main.njk" %}

{% block content %}
  {# Enhanced Hero Section #}
  <section class="relative pbs-52 pbe-28 px-6 overflow-hidden">
    <!-- Enhanced background -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl animate-pulse-glow"></div>
      <div class="absolute inset-bs-[10%] inset-s-[10%] inline-80 block-80 bg-violet-600/10 rounded-full blur-[100px] animate-float"></div>
      <div class="absolute inset-be-[10%] inset-e-[10%] inline-64 block-64 bg-fuchsia-600/8 rounded-full blur-[80px] animate-float delay-300"></div>
    </div>

    <div class="max-inline-5xl mx-auto text-center">
      {# Enhanced Badge #}
      <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-all duration-500 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
        <span class="relative flex block-2.5 inline-2.5">
          <span class="animate-ping absolute inline-flex block-full inline-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full block-2.5 inline-2.5 bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)]"></span>
        </span>
        <span class="font-bold tracking-wide uppercase text-[10px]">
          {{ i18n.t('page.' + page.hero.t_key + '.badge') }}
        </span>
      </div>

      {# Enhanced Title #}
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-none">
        <span class="block bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">
          {{ i18n.t('page.' + page.hero.t_key + '.title_part1') }}
        </span>
        <span class="block bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent animate-gradient bg-size-[200%_auto]">
          {{ i18n.t('page.' + page.hero.t_key + '.title_highlight') }}
        </span>
      </h1>

      {# Description #}
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ i18n.t('page.' + page.hero.t_key + '.description') }}
      </p>

      {# Enhanced Stats #}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8 p-8 lg:p-12 border border-white/10 bg-gradient-to-br from-white/[0.03] to-transparent backdrop-blur-xl rounded-[2.5rem] shadow-2xl" x-data="{ animated: false }" x-intersect.once="animated = true">
        {% for stat in page.stats %}
          <div class="relative group" :style="`transition-delay: {{ loop.index0 * 100 }}ms`">
            <!-- Glow effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-{{ stat.color }}-500/20 to-transparent rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative">
              <div class="text-4xl md:text-5xl lg:text-6xl font-black mbe-2 tracking-tighter tabular-nums transition-all duration-700"
                   :class="animated ? 'text-white group-hover:scale-110 group-hover:text-' + stat.color + '-300' : 'text-slate-600 scale-75 opacity-0'">
                <span x-show="animated" x-transition:enter="transition ease-out duration-1000" x-transition:enter-start="opacity-0 scale-75" x-transition:enter-end="opacity-100 scale-100">
                  {{ i18n.t('page.stats.' + stat.label + '_val') }}
                </span>
              </div>
              <div class="text-[10px] text-slate-500 font-black uppercase tracking-[0.2em] group-hover:text-slate-400 transition-colors duration-500">
                {{ i18n.t('page.stats.' + stat.label) }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# Enhanced Story Section #}
  <section class="pbs-40 pbe-40 px-6 content-auto">
    <div class="max-inline-7xl mx-auto grid md:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative group order-2 md:order-1">
        <!-- Enhanced glow -->
        <div class="absolute -inset-8 bg-gradient-to-r from-violet-600/40 via-fuchsia-600/20 to-pink-600/40 rounded-[3rem] blur-3xl opacity-50 group-hover:opacity-80 transition-opacity duration-1000 ease-emphasized"></div>

        <div class="relative block-full bg-gradient-to-br from-slate-900 to-slate-950 rounded-[3rem] border border-white/10 overflow-hidden shadow-2xl">
          <!-- Grid pattern -->
          <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#8b5cf6_1px,transparent_1px)] bg-[length:32px_32px]"></div>

          <!-- Animated gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-violet-600/10 via-transparent to-fuchsia-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="relative p-12 lg:p-16 text-center">
            <div class="inline-24 block-24 bg-gradient-to-br from-violet-500/20 to-fuchsia-500/10 rounded-3xl flex items-center justify-center mx-auto mbe-10 border border-violet-500/30 shadow-[0_0_60px_rgba(139,92,246,0.2)] group-hover:rotate-12 group-hover:scale-110 transition-all duration-700 ease-emphasized">
              <svg class="inline-12 block-12 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
              </svg>
            </div>
            <p class="text-slate-400 text-xs font-black uppercase tracking-[0.3em]">
              {{ i18n.t('page.' + page.story.t_key + '.visual_label') }}
            </p>
          </div>
        </div>
      </div>

      <div class="space-y-8 order-1 md:order-2">
        <!-- Enhanced tag -->
        <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm">
          <svg class="inline-4 block-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
          <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('page.' + page.story.t_key + '.tag') }}</span>
        </div>

        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight text-white">
          {{ i18n.html('page.' + page.story.t_key + '.title') }}
        </h2>

        <div class="space-y-6 text-slate-300 text-lg md:text-xl leading-relaxed font-medium">
          <p>{{ i18n.t('page.' + page.story.t_key + '.para1') }}</p>
          <p>{{ i18n.t('page.' + page.story.t_key + '.para2') }}</p>
        </div>

        <ul class="space-y-5 pbs-4">
          {% set value_colors = ['violet', 'fuchsia', 'pink'] %}
          {% for i in range(1, 4) %}
            <li class="flex items-center gap-5 text-white group cursor-default">
              <span class="flex-none flex items-center justify-center inline-9 block-9 rounded-xl bg-gradient-to-br from-{{ value_colors[i-1] }}-500/20 to-{{ value_colors[i-1] }}-500/5 text-{{ value_colors[i-1] }}-400 text-xs font-black border border-{{ value_colors[i-1] }}-500/30 group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] transition-all duration-500">
                <svg class="inline-5 block-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="tracking-tight font-medium">{{ i18n.t('page.' + page.story.t_key + '.val' + i) }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>

  {# Enhanced Mission & Vision Section #}
  <section class="pbs-40 pbe-40 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 content-auto">
    <div class="max-inline-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10">
        {# Enhanced Mission #}
        <div class="group relative p-12 lg:p-14 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-violet-500/40 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl shadow-xl hover:shadow-[0_25px_60px_rgba(139,92,246,0.2)] hover:-translate-y-2">
          <!-- Background glow -->
          <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-violet-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <!-- Grid pattern -->
          <div class="absolute inset-0 opacity-30 bg-[radial-gradient(#8b5cf6_1px,transparent_1px)] bg-[length:32px_32px]"></div>

          <div class="relative">
            <div class="concentric-radius color-shift inline-16 block-16 rounded-3xl bg-gradient-to-br from-violet-500/20 to-violet-500/5 flex items-center justify-center text-violet-400 mbe-8 border border-violet-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
              <svg class="inline-8 block-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
              </svg>
            </div>
            <h3 class="text-2xl lg:text-3xl font-black text-white mbe-4">{{ i18n.t('page.mission.title') }}</h3>
            <p class="text-slate-400 leading-relaxed text-lg">{{ i18n.t('page.mission.description') }}</p>
          </div>
        </div>

        {# Enhanced Vision #}
        <div class="group relative p-12 lg:p-14 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-fuchsia-500/40 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl shadow-xl hover:shadow-[0_25px_60px_rgba(217,70,239,0.2)] hover:-translate-y-2">
          <!-- Background glow -->
          <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-fuchsia-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <!-- Grid pattern -->
          <div class="absolute inset-0 opacity-30 bg-[radial-gradient(#d946ef_1px,transparent_1px)] bg-[length:32px_32px]"></div>

          <div class="relative">
            <div class="concentric-radius color-shift inline-16 block-16 rounded-3xl bg-gradient-to-br from-fuchsia-500/20 to-fuchsia-500/5 flex items-center justify-center text-fuchsia-400 mbe-8 border border-fuchsia-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(217,70,239,0.3)]">
              <svg class="inline-8 block-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59"/>
              </svg>
            </div>
            <h3 class="text-2xl lg:text-3xl font-black text-white mbe-4">{{ i18n.t('page.vision.title') }}</h3>
            <p class="text-slate-400 leading-relaxed text-lg">{{ i18n.t('page.vision.description') }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Enhanced Values Section #}
  <section class="pbs-40 pbe-40 px-6 content-auto">
    <div class="max-inline-7xl mx-auto">
      <!-- Enhanced section header -->
      <div class="text-center mbe-24 space-y-4">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mb-6">
          <svg class="inline-4 block-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3.6 5.4A1.2 1.2 0 014.8 4.2h10.4a1.2 1.2 0 011.2 1.2v9.6a1.2 1.2 0 01-1.2 1.2H4.8a1.2 1.2 0 01-1.2-1.2V5.4zM2.4 5.4a2.4 2.4 0 012.4-2.4h10.4a2.4 2.4 0 012.4 2.4v9.6a2.4 2.4 0 01-2.4 2.4H4.8a2.4 2.4 0 01-2.4-2.4V5.4z" clip-rule="evenodd"/>
            <path d="M8.4 10.2a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0zm5.4 0a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z"/>
          </svg>
          <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('page.values.title') }}</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white">
          {{ i18n.t('page.values.title') }}
        </h2>
        <p class="text-slate-400 text-lg max-inline-2xl mx-auto">
          {{ i18n.t('page.values.subtitle') }}
        </p>
        <div class="block-1.5 inline-24 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {% for value in page.values %}
          <div class="group relative p-10 lg:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ value.color }}-500/40 hover:shadow-[0_20px_50px_rgba(139,92,246,0.2)] hover:-translate-y-2 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl">
            <!-- Animated background glow -->
            <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-{{ value.color }}-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <!-- Grid pattern -->
            <div class="absolute inset-0 opacity-20 group-hover:opacity-40 transition-opacity duration-700 bg-[radial-gradient(currentColor_1px,transparent_1px)] bg-[length:32px_32px]" style="color: rgb(var(--color-{{ value.color }}-500))"></div>

            <div class="relative">
              <div class="inline-16 lg:inline-20 block-16 lg:block-20 rounded-2xl bg-gradient-to-br from-{{ value.color }}-500/20 to-{{ value.color }}-500/5 flex items-center justify-center text-{{ value.color }}-400 mbe-8 border border-{{ value.color }}-500/30 group-hover:rotate-6 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
                {% if value.icon == 'heart' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                  </svg>
                {% elseif value.icon == 'users' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                  </svg>
                {% elseif value.icon == 'light' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
                  </svg>
                {% elseif value.icon == 'shield' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                {% elseif value.icon == 'rocket' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                  </svg>
                {% elseif value.icon == 'star' %}
                  <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                  </svg>
                {% endif %}
              </div>
              <h3 class="text-xl lg:text-2xl font-black text-white mbe-3 group-hover:text-{{ value.color }}-200 transition-colors duration-500">{{ i18n.t('page.' + value.t_key + '.title') }}</h3>
              <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-500">{{ i18n.t('page.' + value.t_key + '.description') }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# Enhanced Team Section #}
  <section class="pbs-40 pbe-40 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 content-auto">
    <div class="max-inline-7xl mx-auto">
      <!-- Enhanced section header -->
      <div class="text-center mbe-24 space-y-4">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mb-6">
          <svg class="inline-4 block-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
          </svg>
          <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('our_team') }}</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white">
          {{ i18n.t('page.' + page.team.t_key + '.title') }}
        </h2>
        <p class="text-slate-400 text-lg max-inline-2xl mx-auto">
          {{ i18n.t('page.' + page.team.t_key + '.subtitle') }}
        </p>
        <div class="block-1.5 inline-20 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {% for member in page.team.members %}
          <div class="group relative p-8 lg:p-10 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ member.color }}-500/50 hover:shadow-[0_20px_50px_rgba(139,92,246,0.25)] hover:-translate-y-2 transition-all duration-700 ease-emphasized text-center overflow-hidden backdrop-blur-xl">
            <!-- Animated background glow -->
            <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-{{ member.color }}-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="relative">
              <!-- Enhanced avatar -->
              <div class="relative inline-24 lg:inline-28 block-24 lg:block-28 mx-auto mbe-6">
                <div class="absolute inset-0 bg-gradient-to-br from-{{ member.color }}-500 to-transparent rounded-full blur-md opacity-20 group-hover:opacity-60 transition-opacity duration-500"></div>
                <div class="relative inline-full block-full rounded-full bg-gradient-to-br from-slate-800 to-slate-900 border-2 border-white/10 group-hover:border-{{ member.color }}-500/50 transition-all duration-500 flex items-center justify-center overflow-hidden shadow-inner group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
                  <svg class="inline-12 block-12 text-slate-600 group-hover:text-{{ member.color }}-400 transition-colors duration-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z"/>
                  </svg>
                </div>
                <!-- Status indicator -->
                <div class="absolute inset-be-1 inset-e-1 inline-5 block-5 bg-emerald-500 rounded-full border-4 border-slate-950"></div>
              </div>

              <h3 class="text-xl font-black text-white mbe-2 tracking-tight group-hover:text-{{ member.color }}-200 transition-colors duration-500">{{ member.name }}</h3>
              <p class="text-[10px] font-black text-{{ member.color }}-400 mbe-4 uppercase tracking-[0.2em]">{{ member.role }}</p>
              <p class="text-sm text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-500">
                {{ i18n.t('page.' + member.desc_key) }}
              </p>

              <!-- Social links (appear on hover) -->
              <div class="mt-6 flex justify-center gap-3 opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-y-2 group-hover:translate-y-0">
                <a href="#" class="inline-8 block-8 flex items-center justify-center rounded-2xl bg-white/5 hover:bg-{{ member.color }}-500/20 text-slate-400 hover:text-{{ member.color }}-400 transition-all duration-300">
                  <svg class="inline-4 block-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
                <a href="#" class="inline-8 block-8 flex items-center justify-center rounded-2xl bg-white/5 hover:bg-{{ member.color }}-500/20 text-slate-400 hover:text-{{ member.color }}-400 transition-all duration-300">
                  <svg class="inline-4 block-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}