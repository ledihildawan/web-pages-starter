<section class="pbs-32 pbe-32 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 content-auto overflow-hidden">
  <!-- Subtle background effects -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute inset-bs-0 inset-s-0 inline-full block-full bg-[radial-gradient(ellipse_at_top_left,var(--tw-gradient-stops))] from-violet-600/5 via-transparent to-transparent"></div>
    <div class="absolute inset-be-0 inset-e-0 inline-full block-full bg-[radial-gradient(ellipse_at_bottom_right,var(--tw-gradient-stops))] from-fuchsia-600/5 via-transparent to-transparent"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 lg:gap-16 text-center">
      {% for stat in page.stats %}
        <div class="group relative">
          <!-- Background glow on hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-{{ stat.color }}-500/10 to-transparent rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="relative">
            <!-- Stat number -->
            <p class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter tabular-nums mbe-3 text-{{ stat.color }}-400 group-hover:scale-110 group-hover:text-{{ stat.color }}-300 transition-all duration-700 ease-emphasized">
              {{ i18n.t('page.stats.' + stat.t_key + '_val') }}
            </p>

            <!-- Stat label -->
            <p class="text-slate-400 font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] group-hover:text-slate-300 transition-colors duration-500">
              {{ i18n.t('page.stats.' + stat.t_key) }}
            </p>

            <!-- Decorative underline (appears on hover) -->
            <div class="mt-4 block-1 inline-8 bg-gradient-to-r from-transparent via-{{ stat.color }}-500/50 to-transparent rounded-full mx-auto opacity-0 group-hover:opacity-100 transition-all duration-700 group-hover:inline-12"></div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Trust badges below stats -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 opacity-50">
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        <svg class="inline-5 block-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        {{ i18n.t('soc2_compliant') }}
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        <svg class="inline-5 block-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        {{ i18n.t('gdpr_ready') }}
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        <svg class="inline-5 block-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"/>
        </svg>
        {{ i18n.t('uptime_guarantee') }}
      </div>
    </div>
  </div>
</section>