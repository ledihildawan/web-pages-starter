{% import "icons.njk" as icon %}

<section aria-labelledby="stats-heading" class="pbs-40 pbe-40 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 overflow-hidden">
  <!-- Subtle background effects -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute inset-bs-0 inset-s-0 inline-full block-full bg-[radial-gradient(ellipse_at_top_left,var(--tw-gradient-stops))] from-violet-600/5 via-transparent to-transparent"></div>
    <div class="absolute inset-be-0 inset-e-0 inline-full block-full bg-[radial-gradient(ellipse_at_bottom_right,var(--tw-gradient-stops))] from-fuchsia-600/5 via-transparent to-transparent"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <h2 id="stats-heading" class="sr-only">Statistics and Trust Indicators</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 lg:gap-16 text-center" role="list" aria-label="Key statistics">
      {% for stat in page.stats %}
        <div class="group relative" role="listitem">
          <!-- Background glow on hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-{{ stat.color }}-500/10 to-transparent radius-card-md blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>

          <div class="relative">
            <!-- Stat number -->
            <p class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter tabular-nums mbe-3 text-{{ stat.color }}-400 group-hover:scale-110 group-hover:text-{{ stat.color }}-300 transition-all duration-400 ease-emphasized">
              {{ i18n.t('page.stats.' + stat.t_key + '_val') }}
            </p>

            <!-- Stat label -->
            <p class="text-slate-400 font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] group-hover:text-slate-300 transition-colors duration-200">
              {{ i18n.t('page.stats.' + stat.t_key) }}
            </p>

            <!-- Decorative underline (appears on hover) -->
            <div class="mt-4 block-1 inline-8 bg-gradient-to-r from-transparent via-{{ stat.color }}-500/50 to-transparent rounded-full mx-auto opacity-0 group-hover:opacity-100 transition-all duration-400 group-hover:inline-12"></div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Trust badges below stats -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 opacity-50">
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        {{ icon.icon('shield', 'inline-5 block-5', size='lg') }}
        {{ i18n.t('soc2_compliant') }}
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        {{ icon.icon('shield', 'inline-5 block-5', size='lg') }}
        {{ i18n.t('gdpr_ready') }}
      </div>
      <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wider">
        {{ icon.icon('shield', 'inline-5 block-5', size='lg') }}
        {{ i18n.t('uptime_guarantee') }}
      </div>
    </div>
  </div>
</section>