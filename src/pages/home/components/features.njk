<section id="features" class="pbs-32 pbe-32 px-6 relative text-start" style="content-visibility: auto; contain-intrinsic-size: 1px 800px;">
  <div class="max-inline-6xl mx-auto">
    <div class="text-center mbe-24 space-y-6">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white">
        {{ i18n.t('home:features.heading') }}
      </h2>
      <p class="text-slate-400 max-inline-2xl mx-auto text-lg md:text-xl leading-relaxed">
        {{ i18n.t('home:features.subheading') }}
      </p>
      <div class="block-1.5 inline-20 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-10">
      {% for item in page.features.list %}
        {% set feat_key = 'home:features.list.' ~ item.t_key %}
        {% set feat_title_key = feat_key ~ '.title' %}
        {% set feat_desc_key = feat_key ~ '.description' %}
        <div class="group p-12 radius-card-2xl bg-slate-900/40 border border-white/5 hover:bg-slate-900/60 hover:border-{{ item.color }}-500/30 transition duration-500 ease-emphasized relative overflow-hidden shadow-2xl gpu-boost">

          <div class="absolute -inset-be-16 -inset-e-16 inline-32 block-32 bg-{{ item.color }}-500/10 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="inline-16 block-16 radius-nested-2xl bg-{{ item.color }}-500/10 flex items-center justify-center text-{{ item.color }}-400 mbe-10 border border-{{ item.color }}-500/20 group-hover:rotate-6 transition-transform duration-500 ease-emphasized">
            {{ icon.icon(item.icon, 'inline-8 block-8', size='xl') }}
          </div>
          <h3 class="text-2xl font-black mbe-5 text-white tracking-tight">
            {{ i18n.t(feat_title_key) }}
          </h3>
          <p class="text-slate-400 leading-relaxed text-lg">
            {{ i18n.t(feat_desc_key) }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
