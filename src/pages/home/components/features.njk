<section id="features" class="pbs-40 pbe-40 px-6 relative text-start content-auto">
  <!-- Subtle background -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-bs-[20%] inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-full block-full bg-[radial-gradient(ellipse_at_center,var(--tw-gradient-stops))] from-violet-600/5 via-transparent to-transparent"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <!-- Enhanced section header -->
    <div class="text-center mbe-32 space-y-6">
      <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mb-6">
        <svg class="inline-4 block-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/>
        </svg>
        <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('features') }}</span>
      </div>
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight text-white">
        {{ i18n.t('page.features.heading') }}
      </h2>
      <p class="text-slate-400 max-inline-2xl mx-auto text-lg md:text-xl leading-relaxed">
        {{ i18n.t('page.features.subheading') }}
      </p>
      <div class="block-1.5 inline-24 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
    </div>

    <!-- Enhanced feature cards -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
      {% for item in page.features.list %}
        <div class="group relative p-10 lg:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ item.color }}-500/40 transition-all duration-700 ease-emphasized overflow-hidden shadow-xl hover:shadow-[0_20px_60px_rgba(139,92,246,0.2)] hover:-translate-y-2">
          <!-- Animated background glow -->
          <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-{{ item.color }}-500/15 via-{{ item.color }}-500/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <!-- Grid pattern overlay -->
          <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[32px_32px] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="relative">
            <!-- Enhanced icon container -->
            <div class="inline-flex items-center justify-center inline-16 block-16 lg:inline-20 lg:block-20 rounded-3xl bg-gradient-to-br from-{{ item.color }}-500/10 to-{{ item.color }}-500/5 flex items-center justify-center text-{{ item.color }}-400 mbe-8 border border-{{ item.color }}-500/20 group-hover:border-{{ item.color }}-500/40 group-hover:rotate-6 group-hover:scale-110 transition-all duration-700 ease-emphasized shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
              {% if item.icon == 'lightning' %}
                <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                </svg>
              {% elif item.icon == 'design' %}
                <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.39m3.421 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
                </svg>
              {% elif item.icon == 'shield' %}
                <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
              {% endif %}
            </div>

            <!-- Title with gradient -->
            <h3 class="text-2xl lg:text-3xl font-black mbe-4 text-white tracking-tight group-hover:text-{{ item.color }}-200 transition-colors duration-500">
              {{ i18n.t('page.features.list.' + item.t_key + '.title') }}
            </h3>

            <!-- Description -->
            <p class="text-slate-400 leading-relaxed text-base lg:text-lg group-hover:text-slate-300 transition-colors duration-500">
              {{ i18n.t('page.features.list.' + item.t_key + '.description') }}
            </p>

            <!-- Learn more link (appears on hover) -->
            <div class="mt-6 flex items-center gap-2 text-{{ item.color }}-400 text-sm font-bold opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-y-2 group-hover:translate-y-0">
              <span>{{ i18n.t('learn_more') }}</span>
              <svg class="inline-4 block-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>