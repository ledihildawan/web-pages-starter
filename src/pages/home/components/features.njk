{# --- FEATURES GRID --- #}
<section id="features" class="py-32 px-6 relative overflow-hidden">
  {# Background dekoratif khusus section fitur #}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[radial-gradient(circle_at_center,rgba(99,102,241,0.03)_0%,transparent_70%)] -z-10"></div>

  <div class="max-w-6xl mx-auto">
    {# Header Section #}
    <div class="text-center mb-24 space-y-6">
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white">
        {{ i18n.t('page.features.heading') }}
      </h2>
      <p class="text-slate-300 max-w-2xl mx-auto text-lg md:text-xl leading-relaxed">
        {{ i18n.t('page.features.subheading') }}
      </p>
      <div class="h-1.5 w-20 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto rounded-full shadow-[0_0_15px_rgba(139,92,246,0.5)]"></div>
    </div>

    {# Grid Features #}
    <div class="grid md:grid-cols-3 gap-10">
      {% for item in page.features.list %}
        <div class="group relative p-10 rounded-[2.5rem] bg-slate-900/40 border border-white/10 hover:border-{{ item.color }}-500/50 transition-all duration-500 overflow-hidden shadow-2xl backdrop-blur-sm">

          {# Glow ambient saat hover #}
          <div class="absolute -bottom-16 -right-16 w-32 h-32 bg-{{ item.color }}-500/20 blur-[60px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          {# Icon Container #}
          <div class="w-16 h-16 rounded-2xl bg-{{ item.color }}-500/10 flex items-center justify-center text-{{ item.color }}-400 mb-8 border border-{{ item.color }}-500/20 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-inner">
            {% if item.icon == 'lightning' %}
              <svg class="w-8 h-8" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            {% elif item.icon == 'design' %}
              <svg class="w-8 h-8" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.39m3.421 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>
            {% elif item.icon == 'shield' %}
              <svg class="w-8 h-8" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
            {% endif %}
          </div>

          {# Text Content #}
          <h3 class="text-2xl font-black mb-4 text-white tracking-tight group-hover:text-{{ item.color }}-300 transition-colors">
            {{ i18n.t('page.features.list.' + item.t_key + '.title') }}
          </h3>
          <p class="text-slate-300 leading-relaxed text-lg opacity-80 group-hover:opacity-100 transition-opacity">
            {{ i18n.t('page.features.list.' + item.t_key + '.description') }}
          </p>

          {# Border dekoratif bawah (hanya muncul saat hover) #}
          <div class="absolute bottom-0 left-0 w-0 h-1 bg-linear-to-r from-{{ item.color }}-500 to-transparent group-hover:w-full transition-all duration-700"></div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>