{% import "icons.njk" as icon %}

<section id="features" aria-labelledby="features-heading" class="pbs-40 pbe-40 px-6 relative text-start">
  <!-- Subtle background -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-bs-[20%] inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-full block-full bg-[radial-gradient(ellipse_at_center,var(--tw-gradient-stops))] from-violet-600/5 via-transparent to-transparent"></div>
  </div>

  <div class="max-inline-7xl mx-auto">
    <!-- Enhanced section header -->
    <div class="text-center mbe-24 space-y-4">
      <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mbe-6">
        {{ icon.icon('lightning', 'inline-4 block-4') }}
        <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('features') }}</span>
      </div>
      <h2 id="features-heading" class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-white">
        {{ i18n.t('page.features.heading') }}
      </h2>
      <p class="text-slate-400 max-inline-2xl mx-auto text-lg md:text-xl leading-relaxed">
        {{ i18n.t('page.features.subheading') }}
      </p>
      <div class="block-1.5 inline-24 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
    </div>

    <!-- Enhanced feature cards -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
      {% for item in page.features.list %}
        <div class="spotlight-card card-border-glow card-squash group relative p-10 lg:p-12 radius-card-lg bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ item.color }}-500/40 transition-all duration-250 ease-emphasized overflow-hidden shadow-xl hover:shadow-[0_20px_60px_rgba(139,92,246,0.2)] hover:-translate-y-2 card-hover-lift">
          <!-- Animated background glow -->
          <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-{{ item.color }}-500/15 via-{{ item.color }}-500/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>

          <!-- Grid pattern overlay -->
          <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[32px_32px] opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>

          <div class="relative">
            <!-- Enhanced icon container with proper nested radius -->
            <div class="inline-flex items-center justify-center inline-16 block-16 lg:inline-20 lg:block-20 radius-nested-lg bg-gradient-to-br from-{{ item.color }}-500/10 to-{{ item.color }}-500/5 flex items-center justify-center text-{{ item.color }}-400 mbe-8 border border-{{ item.color }}-500/20 group-hover:border-{{ item.color }}-500/40 group-hover:rotate-6 group-hover:scale-110 transition-all duration-200 ease-emphasized shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)] icon-squash">
              {% if item.icon == 'lightning' %}
                {{ icon.icon('lightning', 'inline-8 block-8 lg:inline-10 lg:block-10', size='xl') }}
              {% elseif item.icon == 'design' %}
                {{ icon.icon('design', 'inline-8 block-8 lg:inline-10 lg:block-10', size='xl') }}
              {% elseif item.icon == 'shield' %}
                {{ icon.icon('shield', 'inline-8 block-8 lg:inline-10 lg:block-10', size='xl') }}
              {% endif %}
            </div>

            <!-- Title with gradient -->
            <h3 class="text-2xl lg:text-3xl font-black mbe-4 text-white tracking-tight group-hover:text-{{ item.color }}-200 transition-colors duration-300">
              {{ i18n.t('page.features.list.' + item.t_key + '.title') }}
            </h3>

            <!-- Description -->
            <p class="text-slate-400 leading-relaxed text-base lg:text-lg group-hover:text-slate-300 transition-colors duration-300">
              {{ i18n.t('page.features.list.' + item.t_key + '.description') }}
            </p>

            <!-- Learn more link (appears on hover) -->
            <div class="mt-6 flex items-center gap-2 text-{{ item.color }}-400 text-sm font-bold opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
              <span>{{ i18n.t('learn_more') }}</span>
              {{ icon.icon('arrow-right', 'inline-4 block-4 group-hover:translate-x-1 transition-transform duration-300', size='md') }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
