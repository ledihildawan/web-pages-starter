{% import "icons.njk" as icon %}

<section aria-labelledby="hero-heading" class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden">
  <!-- Enhanced Background Effects -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <!-- Main radial gradient -->
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl"></div>

    <!-- Static glow points -->
    <div class="absolute inset-bs-[10%] inset-s-[10%] inline-80 block-80 bg-violet-600/10 rounded-full blur-[100px]"></div>
    <div class="absolute inset-be-[10%] inset-e-[10%] inline-64 block-64 bg-fuchsia-600/8 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-inline-6xl mx-auto relative">
    <!-- Enhanced Badge -->
    <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-all duration-200 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
      <span class="relative flex block-2.5 inline-2.5" aria-hidden="true">
        <span class="relative inline-flex rounded-full block-2.5 inline-2.5 bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)]"></span>
      </span>
      <span class="font-bold tracking-wide uppercase text-[10px]">
        {{ i18n.t('page.hero.badge') }}
      </span>
    </div>

    <!-- LCP Candidate: Enhanced Hero Title -->
    <h1 id="hero-heading" class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1]">
      <span class="block text-gradient-white">
        {{ i18n.t('page.hero.title_start') }}
      </span>
      <span class="block text-gradient">
        {{ i18n.t('page.hero.title_highlight') }}
      </span>
    </h1>

    <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
      {{ i18n.t('page.hero.description') }}
    </p>

    <!-- Enhanced Button Group with Modern Interactions -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mbe-14">
      <a href="{{ page.hero.primary_btn.url }}" class="magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click group relative inline-full sm:inline-auto min-block-14 px-14 py-4 bg-white text-slate-950 radius-btn font-black text-lg flex items-center justify-center overflow-hidden duration-standard">
        <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-400 ease-in-out"></span>
        <span class="relative flex items-center gap-3">
          {{ i18n.t('page.hero.primary_btn.label') }}
          {{ icon.icon('arrow-right', 'inline-5 block-5 icon-transition group-hover:translate-x-1', size='lg') }}
        </span>
      </a>
      <a href="{{ page.hero.secondary_btn.url }}" class="magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click spotlight-card group inline-full sm:inline-auto min-block-14 px-14 py-4 bg-slate-900/60 backdrop-blur-xl text-white border border-white/10 radius-btn font-black text-lg flex items-center justify-center hover:bg-slate-800/80 hover:border-white/20 duration-standard">
        <span class="relative flex items-center gap-3">
          {{ i18n.t('page.hero.secondary_btn.label') }}
          {{ icon.icon('question', 'inline-5 block-5 icon-bounce icon-anticipate', size='lg') }}
        </span>
      </a>
    </div>

    <!-- Trust indicators -->
    <p class="text-[11px] text-slate-400 font-bold tracking-[0.2em] uppercase mbe-20 flex items-center justify-center gap-3">
      <span class="flex items-center gap-1.5">
        {{ icon.icon('check', 'inline-4 block-4 text-emerald-400', size='md') }}
        {{ i18n.t('page.hero.note') }}
      </span>
      <span class="inline-1 block-1 rounded-full bg-slate-700"></span>
      <span class="flex items-center gap-1.5">
        {{ icon.icon('star', 'inline-4 block-4 text-violet-400', size='md') }}
        {{ i18n.t('rating') }}
      </span>
    </p>

    <!-- LCP Element: Hero Image - Clean with subtle effects -->
    <div class="relative group max-inline-3xl mx-auto aspect-[16/10]">
      <!-- Static decorative blur (no animation) -->
      <div class="absolute -inset-4 bg-violet-600/10 rounded-full blur-3xl -z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 to-fuchsia-500/5 rounded-2xl blur-2xl -z-10"></div>

      <!-- Main image container with backdrop blur -->
      <div class="relative bg-slate-900/80 backdrop-blur-sm radius-card-md p-2 border border-white/10 overflow-hidden">
        <!-- Image container -->
        <div class="relative overflow-hidden radius-card-sm">
          <img
            src="/assets/images/hero-test.avif"
            alt="{{ i18n.v('page.hero.image_alt') }}"
            width="1600"
            height="1000"
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1200px"
            class="inline-full block-auto radius-card-sm"
            fetchpriority="high"
            decoding="sync"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </div>
</section>