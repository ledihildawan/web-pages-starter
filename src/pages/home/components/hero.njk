<section class="relative pt-40 pb-20 px-6 text-center overflow-hidden">
  {# Background Glow #}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-violet-500/10 via-transparent to-transparent -z-10"></div>

  <div class="max-w-6xl mx-auto">
    <div class="inline-flex items-center gap-2 px-4 py-2 bg-violet-500/10 border border-violet-500/20 rounded-full text-violet-300 text-sm mb-8 animate-fade-in">
      <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
      {{ i18n.t('page.hero.badge') }}
    </div>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1] bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent">
      {{ i18n.t('page.hero.title_start') }}
      <span class="block bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
        {{ i18n.t('page.hero.title_highlight') }}
      </span>
    </h1>

    {# Image Test dengan Styling Konsisten #}
    <div class="relative group max-w-lg mx-auto my-12">
      <div class="absolute -inset-1 bg-linear-to-r from-violet-500 to-fuchsia-500 rounded-2xl blur-md opacity-20 group-hover:opacity-40 transition duration-500"></div>
      <img width="512" height="344" src="{% static 'images/hero-test.webp' %}" alt="Hero Illustration" class="relative w-full h-auto rounded-2xl shadow-2xl border border-white/10 group-hover:scale-[1.01] transition-transform duration-500" fetchpriority="high">
    </div>

    <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
      {{ i18n.t('page.hero.description') }}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a href="{{ page.hero.primary_btn.url }}" class="group relative w-full sm:w-auto px-10 py-4 bg-white text-slate-950 rounded-xl font-bold text-lg overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-lg shadow-white/5">
        <span class="relative">{{ i18n.t('page.hero.primary_btn.label') }}</span>
      </a>
      <a href="{{ page.hero.secondary_btn.url }}" class="w-full sm:w-auto px-10 py-4 bg-slate-900 text-white border border-white/10 rounded-xl font-bold text-lg hover:bg-slate-800 transition-all hover:border-white/20">
        {{ i18n.t('page.hero.secondary_btn.label') }}
      </a>
    </div>

    <p class="text-sm text-slate-500 font-medium tracking-wide">
      {{ i18n.t('page.hero.note') }}
    </p>
  </div>
</section>