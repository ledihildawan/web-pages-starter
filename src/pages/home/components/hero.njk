{% static 'images/hero-test-400.avif' as hero_400 %}
{% static 'images/hero-test-500.avif' as hero_500 %}
{% static 'images/hero-test-700.avif' as hero_700 %}
{% static 'images/hero-test-800.avif' as hero_800 %}
{% static 'images/hero-test-900.avif' as hero_900 %}
{% static 'images/hero-test-1200.avif' as hero_1200 %}

<section class="relative pbs-44 pbe-24 px-6 text-center overflow-hidden">

  {# Spotlight Effect (Logical Centering dengan dukungan RTL) #}
  <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[120%] block-[120%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent -z-10 blur-3xl opacity-60"></div>

  <div class="max-inline-6xl mx-auto relative">

    <div class="inline-flex items-center gap-3 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-10 transition-colors hover:bg-violet-500/20 cursor-default gpu-boost">
      <span class="relative flex block-2 inline-2">
        <span class="animate-ping absolute inline-flex block-full inline-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full block-2 inline-2 bg-emerald-500"></span>
      </span>
      <span class="font-bold tracking-wide uppercase text-[10px]">
        {{ i18n.t('page.hero.badge') }}
      </span>
    </div>

    <h1 class="text-6xl md:text-8xl font-black tracking-tighter mbe-8 leading-none bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent">
      <span>{{ i18n.t('page.hero.title_start') }}</span>
      <span class="block bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
        {{ i18n.t('page.hero.title_highlight') }}
      </span>
    </h1>

    <p class="text-xl md:text-2xl text-slate-300 max-inline-3xl mx-auto mbe-14 leading-relaxed font-medium">
      {{ i18n.t('page.hero.description') }}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mbe-12 min-block-14">
      <a href="{{ page.hero.primary_btn.url }}" class="group relative inline-full sm:inline-auto min-block-14 px-12 py-4 bg-white text-slate-950 rounded-2xl font-black text-lg flex items-center justify-center transition-all duration-300 ease-emphasized hover:shadow-[0_0_30px_rgba(255,255,255,0.2)] active:scale-95 gpu-boost min-inline-[180px]">
        {{ i18n.t('page.hero.primary_btn.label') }}
      </a>
      <a href="{{ page.hero.secondary_btn.url }}" class="inline-full sm:inline-auto min-block-14 px-12 py-4 bg-slate-900/50 backdrop-blur-md text-white border border-white/10 rounded-2xl font-black text-lg flex items-center justify-center hover:bg-slate-800 transition-all duration-300 ease-emphasized hover:border-white/20 active:scale-95 gpu-boost min-inline-[180px]">
        {{ i18n.t('page.hero.secondary_btn.label') }}
      </a>
    </div>

    <p class="text-[11px] text-slate-400 font-bold tracking-[0.2em] uppercase mbe-16">
      {{ i18n.t('page.hero.note') }}
    </p>

    {# Image LCP — resolved via simple-nunjucks-loader static tag #}
    <div class="relative group max-inline-2xl mx-auto">
      <div class="absolute -inset-1 bg-linear-to-r from-violet-600 to-fuchsia-600 rounded-3xl blur-2xl opacity-20 group-hover:opacity-40 transition-opacity duration-700 ease-emphasized"></div>
      <div class="relative bg-slate-900 rounded-2xl p-2 border border-white/10 shadow-2xl overflow-hidden gpu-boost">
        <img width="1200" height="800" src="{{ hero_700 }}" srcset="{{ hero_400 }} 400w, {{ hero_500 }} 500w, {{ hero_700 }} 700w, {{ hero_800 }} 800w, {{ hero_900 }} 900w, {{ hero_1200 }} 1200w" sizes="(min-width: 720px) 654px, calc(100vw - 66px)" alt="Web Pages Starter dashboard preview showing the analytics view with sidebar navigation" class="inline-full block-auto rounded-xl transition-transform duration-700 ease-emphasized group-hover:scale-[1.02]" fetchpriority="high" loading="eager" decoding="async">
      </div>
    </div>

  </div>
</section>