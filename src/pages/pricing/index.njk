{% extends "main.njk" %}

{% block content %}
  {# --- HERO SECTION --- #}
  <section class="relative pt-44 pb-20 px-6 text-center overflow-hidden">
    {# Background Spotlight #}
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-violet-600/20 via-transparent to-transparent -z-10 blur-3xl"></div>

    <div class="max-w-4xl mx-auto">
      <h1 class="text-6xl md:text-7xl font-black tracking-tighter mb-8 leading-[1.1] bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent">
        {{ i18n.t('page.' + page.hero.t_key + '.title_part1') }}
        <span class="block bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
          {{ i18n.t('page.' + page.hero.t_key + '.title_highlight') }}
        </span>
      </h1>

      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-14 leading-relaxed font-medium">
        {{ i18n.t('page.' + page.hero.t_key + '.description') }}
      </p>

      {# --- TOGGLE SWITCHER --- #}
      <div class="flex items-center justify-center gap-6 mb-16">
        <span class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">{{ i18n.t('page.toggle.monthly') }}</span>

        {# Perbaikan Touch Target: min-h-[44px] #}
        <button class="group w-16 h-8 bg-slate-800 rounded-full relative p-1 transition-all border border-white/10 flex items-center min-h-[44px] sm:min-h-0">
          <div class="w-6 h-6 bg-white rounded-full shadow-[0_0_15px_rgba(255,255,255,0.5)] transform translate-x-8 transition-transform"></div>
        </button>

        <div class="flex items-center gap-3">
          <span class="text-xs font-black uppercase tracking-[0.2em] text-white">{{ i18n.t('page.toggle.yearly') }}</span>
          <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-[10px] font-black rounded-full border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]">
            SAVE 20%
          </span>
        </div>
      </div>
    </div>
  </section>

  {# --- PRICING CARDS --- #}
  <section class="pb-32 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8 items-stretch">
      {% for plan in page.plans %}
        <div class="{% if plan.featured %}
          relative p-12 rounded-[2.5rem] bg-slate-900 border-2 border-violet-500/50 shadow-[0_20px_50px_rgba(139,92,246,0.15)] transform md:-translate-y-8 z-10
          {% else %}
          group p-10 rounded-[2.5rem] bg-slate-900/40 border border-white/5 backdrop-blur-sm hover:border-white/20 transition-all duration-500
          {% endif %} flex flex-col">

          {% if plan.featured %}
            <div class="absolute -top-5 left-1/2 -translate-x-1/2 px-6 py-2 bg-linear-to-r from-violet-500 via-fuchsia-500 to-pink-500 rounded-full text-[10px] font-black text-white uppercase tracking-[0.2em] shadow-xl">
              {{ i18n.t('page.plans.' + plan.id + '.badge') | default('MOST POPULAR') }}
            </div>
          {% endif %}

          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-{{ 'violet-300' if plan.featured else 'slate-400' }} mb-8">
            {{ i18n.t('page.plans.' + plan.id + '.name') }}
          </h3>

          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-6xl font-black text-white tracking-tighter">${{ plan.price }}</span>
            <span class="text-slate-400 font-bold">/mo</span>
          </div>

          <p class="text-slate-300 mb-10 leading-relaxed font-medium">
            {{ i18n.t('page.plans.' + plan.id + '.desc') }}
          </p>

          {# Separator #}
          <div class="h-px w-full bg-white/5 mb-10"></div>

          <ul class="space-y-5 flex-grow mb-12">
            {% for i in range(0, plan.feature_count) %}
              <li class="flex items-start gap-4 text-sm {% if plan.featured %}text-slate-200{% else %}text-slate-300{% endif %}">
                <div class="mt-1 flex-none w-5 h-5 rounded-full bg-{{ 'violet-500/20' if plan.featured else 'white/5' }} flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-{{ 'violet-400' if plan.featured else 'slate-500' }}" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="font-medium leading-tight">{{ i18n.t('page.plans.' + plan.id + '.feature_' + i) }}</span>
              </li>
            {% endfor %}
          </ul>

          <a href="#" class="group relative flex items-center justify-center w-full min-h-[60px] px-8 py-4 rounded-2xl font-black text-lg transition-all active:scale-95 overflow-hidden
            {% if plan.featured %}
            bg-white text-slate-950 shadow-[0_10px_25px_rgba(255,255,255,0.1)]
            {% else %}
            bg-slate-800 text-white border border-white/10 hover:bg-slate-700
            {% endif %}">
            <span class="relative z-10">{{ i18n.t('page.plans.' + plan.id + '.btn') }}</span>
          </a>
        </div>
      {% endfor %}
    </div>
  </section>

  {# --- FAQ SECTION --- #}
  <section class="py-32 px-6 relative bg-white/[0.01] border-t border-white/5">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-20 space-y-4">
        <h2 class="text-4xl font-black tracking-tighter text-white">{{ i18n.t('page.faq.title') }}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.faq.subtitle') | default('Punya pertanyaan? Kami punya jawabannya.') }}</p>
        <div class="h-1.5 w-16 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto rounded-full shadow-[0_0_15px_rgba(139,92,246,0.3)]"></div>
      </div>

      <div class="grid gap-4">
        {% for i in range(0, page.faq_count) %}
          <div class="p-8 rounded-3xl bg-slate-900/40 border border-white/5 hover:border-white/10 transition-all duration-300 group cursor-default">
            <h3 class="text-xl font-black text-white mb-4 flex items-start gap-4">
              <span class="text-transparent bg-linear-to-b from-violet-400 to-fuchsia-500 bg-clip-text font-mono text-sm mt-1">0{{ i + 1 }}.</span>
              <span class="flex-grow">{{ i18n.t('page.faq.q_' + i) }}</span>
            </h3>
            <p class="text-slate-400 leading-relaxed pl-11 font-medium">
              {{ i18n.t('page.faq.a_' + i) }}
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endblock %}