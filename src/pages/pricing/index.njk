{% extends "main.njk" %}

{% block content %}
  {# --- HERO SECTION --- #}
  <section class="relative pbs-44 pbe-20 px-6 text-center overflow-hidden">
    {# Background Spotlight (Logical Centering) #}
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-full block-[500px] bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-violet-600/20 via-transparent to-transparent -z-10 blur-3xl opacity-60"></div>

    <div class="max-inline-4xl mx-auto">
      <h1 class="text-6xl md:text-7xl font-black tracking-tighter mbe-8 leading-[1.1] bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent">
        {{ i18n.t('page.' + page.hero.t_key + '.title_part1') }}
        <span class="block bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
          {{ i18n.t('page.' + page.hero.t_key + '.title_highlight') }}
        </span>
      </h1>

      <p class="text-xl text-slate-300 max-inline-2xl mx-auto mbe-14 leading-relaxed font-medium">
        {{ i18n.t('page.' + page.hero.t_key + '.description') }}
      </p>

      {# --- TOGGLE SWITCHER (ALPINIZED) --- #}
      <div class="flex items-center justify-center gap-6 mbe-16" x-data="{ yearly: true }">
        <span class="text-xs font-black uppercase tracking-[0.2em] transition-colors" :class="!yearly ? 'text-white' : 'text-slate-500'">
          {{ i18n.t('page.toggle.monthly') }}
        </span>

        <button 
          @click="yearly = !yearly"
          aria-label="Toggle Pricing Plan"
          class="group inline-16 block-8 bg-slate-800 rounded-full relative p-1 transition-all border border-white/10 flex items-center cursor-pointer min-block-[44px] sm:min-block-0 gpu-boost">
          <div class="inline-6 block-6 bg-white rounded-full shadow-[0_0_15px_rgba(255,255,255,0.5)] transition-all duration-500 ease-emphasized"
               :class="yearly ? 'inset-s-[34px]' : 'inset-s-1'"></div>
        </button>

        <div class="flex items-center gap-3">
          <span class="text-xs font-black uppercase tracking-[0.2em] transition-colors" :class="yearly ? 'text-white' : 'text-slate-500'">
            {{ i18n.t('page.toggle.yearly') }}
          </span>
          <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-[10px] font-black rounded-full border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]">
            SAVE 20%
          </span>
        </div>
      </div>
    </div>
  </section>

  {# --- PRICING CARDS --- #}
  <section class="pbe-32 px-6">
    <div class="max-inline-7xl mx-auto grid md:grid-cols-3 gap-8 items-stretch">
      {% for plan in page.plans %}
        <div class="{% if plan.featured %}
          relative p-12 rounded-[2.5rem] bg-slate-900 border-is border-ie border-bs border-be border-violet-500/50 shadow-[0_20px_50px_rgba(139,92,246,0.15)] md:-translate-y-8 z-10
          {% else %}
          group p-10 rounded-[2.5rem] bg-slate-900/40 border border-white/5 backdrop-blur-sm hover:border-white/20 transition-all duration-500 ease-emphasized
          {% endif %} flex flex-col gpu-boost">

          {% if plan.featured %}
            <div class="absolute -inset-bs-5 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 px-6 py-2 bg-linear-to-r from-violet-500 via-fuchsia-500 to-pink-500 rounded-full text-[10px] font-black text-white uppercase tracking-[0.2em] shadow-xl whitespace-nowrap">
              {{ i18n.t('page.plans.' + plan.id + '.badge') | default('MOST POPULAR') }}
            </div>
          {% endif %}

          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-{{ 'violet-300' if plan.featured else 'slate-400' }} mbe-8">
            {{ i18n.t('page.plans.' + plan.id + '.name') }}
          </h3>

          <div class="flex items-baseline gap-2 mbe-6">
            <span class="text-6xl font-black text-white tracking-tighter">${{ plan.price }}</span>
            <span class="text-slate-400 font-bold">/mo</span>
          </div>

          <p class="text-slate-300 mbe-10 leading-relaxed font-medium">
            {{ i18n.t('page.plans.' + plan.id + '.desc') }}
          </p>

          {# Separator #}
          <div class="block-px inline-full bg-white/5 mbe-10"></div>

          <ul class="space-y-5 flex-grow mbe-12">
            {% for i in range(0, plan.feature_count) %}
              <li class="flex items-start gap-4 text-sm {% if plan.featured %}text-slate-200{% else %}text-slate-300{% endif %}">
                <div class="mbs-1 flex-none inline-5 block-5 rounded-full bg-{{ 'violet-500/20' if plan.featured else 'white/5' }} flex items-center justify-center">
                  <svg class="inline-3.5 block-3.5 text-{{ 'violet-400' if plan.featured else 'slate-500' }}" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="font-medium leading-tight">{{ i18n.t('page.plans.' + plan.id + '.feature_' + i) }}</span>
              </li>
            {% endfor %}
          </ul>

          <a href="#" class="group relative flex items-center justify-center inline-full min-block-[60px] px-8 py-4 rounded-2xl font-black text-lg transition-all duration-300 ease-emphasized active:scale-95 overflow-hidden gpu-boost
            {% if plan.featured %}
            bg-white text-slate-950 shadow-[0_10px_25px_rgba(255,255,255,0.1)]
            {% else %}
            bg-slate-800 text-white border border-white/10 hover:bg-slate-700
            {% endif %}">
            <span class="relative z-10">{{ i18n.t('page.plans.' + plan.id + '.btn') }}</span>
          </a>
        </div>
      {% endfor %}
    </div>
  </section>

  {# --- FAQ SECTION --- #}
  <section class="pbs-32 pbe-32 px-6 relative bg-white/[0.01] border-bs border-white/5">
    <div class="max-inline-4xl mx-auto">
      <div class="text-center mbe-20 space-y-4">
        <h2 class="text-4xl font-black tracking-tighter text-white">{{ i18n.t('page.faq.title') }}</h2>
        <p class="text-slate-400 text-lg">{{ i18n.t('page.faq.subtitle') | default('Punya pertanyaan? Kami punya jawabannya.') }}</p>
        <div class="block-1.5 inline-16 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto rounded-full shadow-[0_0_15px_rgba(139,92,246,0.3)]"></div>
      </div>

      <div class="grid gap-4">
        {% for i in range(0, page.faq_count) %}
          <div class="p-8 rounded-3xl bg-slate-900/40 border border-white/5 hover:border-white/10 transition-all duration-500 ease-emphasized group cursor-default gpu-boost">
            <h3 class="text-xl font-black text-white mbe-4 flex items-start gap-4">
              <span class="text-transparent bg-linear-to-b from-violet-400 to-fuchsia-500 bg-clip-text font-mono text-sm mbs-1">0{{ i + 1 }}.</span>
              <span class="flex-grow">{{ i18n.t('page.faq.q_' + i) }}</span>
            </h3>
            <p class="text-slate-400 leading-relaxed pis-11 font-medium">
              {{ i18n.t('page.faq.a_' + i) }}
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}