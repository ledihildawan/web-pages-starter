{% extends "main.njk" %}

{% block content %}
  {# --- HERO SECTION --- #}
  <section class="relative pbs-40 pbe-24 px-6 text-center overflow-hidden">
    {# Ambient Background (Logical Centering) #}
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-full block-full bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-violet-500/10 via-transparent to-transparent -z-10"></div>

    <div class="max-inline-4xl mx-auto">
      {# Badge dengan animasi fade-in yang lebih smooth #}
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-violet-500/10 border border-violet-500/20 rounded-full text-violet-300 text-xs font-medium mbe-8 uppercase tracking-widest gpu-boost">
        {{ i18n.t('page.' + page.hero.t_key + '.badge') }}
      </div>

      <h1 class="text-5xl md:text-7xl font-black tracking-tight mbe-8 bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent leading-tight">
        {{ i18n.t('page.' + page.hero.t_key + '.title') }}
      </h1>

      <p class="text-xl text-slate-400 max-inline-2xl mx-auto leading-relaxed mbe-10">
        {{ i18n.t('page.' + page.hero.t_key + '.description') }}
      </p>
    </div>
  </section>

  {# --- MAIN FEATURES LOOP --- #}
  <section class="pbs-20 pbe-20 px-6 space-y-32">
    {% for feature in page.main_features %}
      <div class="max-inline-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

        {# Content Area #}
        <div class="{{ 'order-2' if feature.reverse else 'order-2 md:order-1' }} space-y-6">
          <div class="inline-flex inline-14 block-14 rounded-2xl bg-{{ feature.accent }}-500/10 items-center justify-center text-{{ feature.accent }}-400 border border-{{ feature.accent }}-500/20 shadow-lg shadow-{{ feature.accent }}-500/5 gpu-boost">
            {% if feature.icon == 'lightning' %}
              <svg class="inline-7 block-7" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            {% elseif feature.icon == 'chart' %}
              <svg class="inline-7 block-7" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            {% endif %}
          </div>

          <h2 class="text-4xl font-bold text-white tracking-tight">
            {{ i18n.t('page.' + feature.t_key + '.title') }}
          </h2>

          <p class="text-slate-400 text-lg leading-relaxed">
            {{ i18n.t('page.' + feature.t_key + '.description') }}
          </p>

          <ul class="grid grid-cols-1 gap-4 pbs-4">
            {% for i in range(0, feature.checklist_count) %}
              <li class="flex items-center gap-4 text-slate-300 group">
                <div class="flex-none inline-5 block-5 rounded-full bg-{{ feature.accent }}-500/20 flex items-center justify-center group-hover:bg-{{ feature.accent }}-500/40 transition-colors duration-300">
                  <svg class="inline-3 block-3 text-{{ feature.accent }}-400" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm font-medium">{{ i18n.t('page.' + feature.t_key + '.check_' + i) }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>

        {# Visual Placeholder Area #}
        <div class="{{ 'order-1' if feature.reverse else 'order-1 md:order-2' }} relative group">
          <div class="absolute inset-[-4px] bg-linear-to-r from-{{ feature.accent }}-500 to-fuchsia-500 rounded-2xl blur-md opacity-20 group-hover:opacity-40 transition-opacity duration-500 ease-emphasized"></div>
          <div class="relative rounded-2xl bg-slate-900 border border-white/10 p-3 aspect-4/3 shadow-2xl overflow-hidden backdrop-blur-3xl gpu-boost">
            <div class="inline-full block-full bg-slate-950/80 rounded-xl flex items-center justify-center relative overflow-hidden border border-white/5">
              
              {% if feature.id == 'sync' %}
                {# Mockup UI Sync (Logical Layout) #}
                <div class="inline-4/5 space-y-4">
                  <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg border border-white/10 animate-pulse">
                    <div class="flex items-center gap-3">
                      <div class="inline-8 block-8 rounded bg-violet-500/20"></div>
                      <div class="block-2 inline-24 bg-slate-700 rounded"></div>
                    </div>
                    <div class="block-4 inline-4 rounded-full bg-green-500/50"></div>
                  </div>
                  <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg border border-white/10">
                    <div class="flex items-center gap-3">
                      <div class="inline-8 block-8 rounded bg-blue-500/20"></div>
                      <div class="block-2 inline-32 bg-slate-700 rounded"></div>
                    </div>
                    <div class="block-4 inline-4 rounded-full bg-yellow-500/50 animate-bounce"></div>
                  </div>
                </div>

              {% elseif feature.id == 'analytics' %}
                {# Mockup Analytics (Logical Size) #}
                <div class="inline-3/4 block-1/2 flex items-end justify-between gap-3 px-4">
                  {% for h in [40, 70, 50, 90, 60, 85] %}
                    <div class="inline-full bg-linear-to-t from-{{ feature.accent }}-500/40 to-{{ feature.accent }}-400 rounded-bs-md rounded-be-md transition-all duration-1000 hover:brightness-125" style="block-size: {{ h }}%"></div>
                  {% endfor %}
                </div>
              {% endif %}

            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </section>

  {# --- ADDITIONAL FEATURES GRID --- #}
  <section class="pbs-24 pbe-24 px-6 relative bg-white/[0.01]">
    <div class="max-inline-6xl mx-auto">
      <div class="text-center mbe-16 space-y-4">
        <h2 class="text-3xl font-bold tracking-tight text-white">
          {{ i18n.t('page.more_title') }}
        </h2>
        <div class="block-1 inline-20 bg-violet-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {% for item in page.additional_features %}
          <div class="group p-8 bg-slate-900/40 border border-white/5 rounded-2xl hover:bg-slate-900/60 hover:border-violet-500/30 transition-all duration-300 ease-emphasized gpu-boost">
            <div class="inline-10 block-10 rounded-lg bg-slate-800 flex items-center justify-center mbe-6 group-hover:scale-110 transition-transform duration-500">
              <svg class="inline-5 block-5 text-violet-400" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path d="M12 6V12M12 12V18M12 12H18M12 12H6" stroke-width="2"/></svg>
            </div>
            <h3 class="text-lg font-bold text-white mbe-3">
              {{ i18n.t('page.' + item.t_key + '.title') }}
            </h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              {{ i18n.t('page.' + item.t_key + '.desc') }}
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}