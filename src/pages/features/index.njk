{% extends "main.njk" %}

{% block content %}
  {# Enhanced Hero Section #}
  <section class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden">
    <!-- Enhanced background -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl animate-pulse-glow"></div>
      <div class="absolute inset-bs-[10%] inset-s-[10%] inline-80 block-80 bg-violet-600/10 rounded-full blur-[100px] animate-float"></div>
      <div class="absolute inset-be-[10%] inset-e-[10%] inline-64 block-64 bg-fuchsia-600/8 rounded-full blur-[80px] animate-float delay-300"></div>
    </div>

    <div class="max-inline-5xl mx-auto">
      {# Enhanced Badge #}
      <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-all duration-500 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
        <span class="relative flex block-2.5 inline-2.5">
          <span class="animate-ping absolute inline-flex block-full inline-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full block-2.5 inline-2.5 bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)]"></span>
        </span>
        <span class="font-bold tracking-wide uppercase text-[10px]">
          {{ i18n.t('page.hero.badge') }}
        </span>
      </div>

      {# Enhanced Title #}
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1]">
        <span class="block bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">
          {{ i18n.html('page.hero.title') }}
        </span>
      </h1>

      {# Description #}
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ i18n.t('page.hero.description') }}
      </p>
    </div>
  </section>

  {# Enhanced Main Features Section #}
  <section class="pbs-40 pbe-40 px-6 space-y-32 lg:space-y-40 content-auto">
    {% for feature in page.main_features %}
      <div class="max-inline-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="{{ 'order-2' if feature.reverse else 'order-2 md:order-1' }} space-y-8">
          {# Enhanced Icon with Concentric Radius #}
          <div class="concentric-radius color-shift inline-flex items-center justify-center inline-16 lg:inline-20 block-16 lg:block-20 rounded-3xl bg-gradient-to-br from-{{ feature.accent }}-500/20 to-{{ feature.accent }}-500/5 flex items-center justify-center text-{{ feature.accent }}-400 border border-{{ feature.accent }}-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_50px_rgba(139,92,246,0.3)]">
            {% if feature.icon == 'lightning' %}
              <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            {% elseif feature.icon == 'chart' %}
              <svg class="inline-8 block-8 lg:inline-10 lg:block-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            {% endif %}
          </div>

          {# Content #}
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-[1.1]">
            {{ i18n.t('page.' + feature.t_key + '.title') }}
          </h2>

          <p class="text-slate-400 text-lg md:text-xl leading-relaxed font-medium">
            {{ i18n.t('page.' + feature.t_key + '.description') }}
          </p>

          {# Enhanced Checklist #}
          <ul class="grid grid-cols-1 gap-5 pbs-4">
            {% for i in range(0, feature.checklist_count) %}
              <li class="flex items-center gap-5 text-slate-300 group cursor-default">
                <div class="flex-none inline-7 block-7 rounded-xl bg-gradient-to-br from-{{ feature.accent }}-500/20 to-{{ feature.accent }}-500/5 border border-{{ feature.accent }}-500/30 flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-[0_0_20px_rgba(139,92,246,0.3)] transition-all duration-500">
                  <svg class="inline-4 block-4 text-{{ feature.accent }}-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm md:text-base font-medium group-hover:text-white transition-colors duration-300">{{ i18n.t('page.' + feature.t_key + '.check_' + i) }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>

        {# Enhanced Visual/Preview with Tilt Effect #}
        <div class="{{ 'order-1' if feature.reverse else 'order-1 md:order-2' }} relative group tilt-card" style="--tilt-x: 0deg; --tilt-y: 0deg;">
          <!-- Enhanced glow -->
          <div class="absolute -inset-4 bg-gradient-to-r from-{{ feature.accent }}-500/40 via-fuchsia-500/20 to-pink-500/40 rounded-3xl blur-2xl opacity-40 group-hover:opacity-70 transition-opacity duration-1000 ease-emphasized"></div>

          <div class="relative rounded-[2.5rem] bg-gradient-to-br from-slate-900 to-slate-950 border border-white/10 p-4 aspect-4/3 shadow-2xl overflow-hidden backdrop-blur-3xl">
            <!-- Grid pattern -->
            <div class="absolute inset-0 opacity-30 bg-[radial-gradient(#8b5cf6_1px,transparent_1px)] bg-[length:32px_32px]"></div>

            <!-- Animated gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-br from-{{ feature.accent }}-600/10 via-transparent to-fuchsia-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="inline-full block-full bg-slate-950/60 rounded-2xl flex items-center justify-center relative overflow-hidden border border-white/5">
              {% if feature.id == 'sync' %}
                <div class="inline-4/5 space-y-5">
                  <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10 hover:bg-white/8 transition-colors duration-300">
                    <div class="flex items-center gap-4">
                      <div class="inline-10 block-10 rounded-xl bg-gradient-to-br from-violet-500/30 to-violet-500/10 flex items-center justify-center">
                        <svg class="inline-5 block-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                      </div>
                      <div class="space-y-2">
                        <div class="block-2.5 inline-20 bg-slate-700 rounded"></div>
                        <div class="block-2 inline-14 bg-slate-600/50 rounded"></div>
                      </div>
                    </div>
                    <div class="inline-5 block-5 rounded-full bg-emerald-500/50 shadow-[0_0_20px_rgba(16,185,129,0.5)] animate-pulse"></div>
                  </div>
                  <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10 hover:bg-white/8 transition-colors duration-300">
                    <div class="flex items-center gap-4">
                      <div class="inline-10 block-10 rounded-xl bg-gradient-to-br from-blue-500/30 to-blue-500/10 flex items-center justify-center">
                        <svg class="inline-5 block-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                        </svg>
                      </div>
                      <div class="space-y-2">
                        <div class="block-2.5 inline-28 bg-slate-700 rounded"></div>
                        <div class="block-2 inline-16 bg-slate-600/50 rounded"></div>
                      </div>
                    </div>
                    <div class="inline-5 block-5 rounded-full bg-amber-500/50 shadow-[0_0_20px_rgba(245,158,11,0.5)] animate-bounce"></div>
                  </div>
                  <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10 hover:bg-white/8 transition-colors duration-300">
                    <div class="flex items-center gap-4">
                      <div class="inline-10 block-10 rounded-xl bg-gradient-to-br from-fuchsia-500/30 to-fuchsia-500/10 flex items-center justify-center">
                        <svg class="inline-5 block-5 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                      </div>
                      <div class="space-y-2">
                        <div class="block-2.5 inline-24 bg-slate-700 rounded"></div>
                        <div class="block-2 inline-12 bg-slate-600/50 rounded"></div>
                      </div>
                    </div>
                    <div class="inline-5 block-5 rounded-full bg-violet-500/50 shadow-[0_0_20px_rgba(139,92,246,0.5)]"></div>
                  </div>
                </div>
              {% elseif feature.id == 'analytics' %}
                <div class="inline-4/5 space-y-5">
                  {# Enhanced Card 1: Summary/Statistik #}
                  <div class="flex items-center justify-between p-4 bg-gradient-to-r from-white/5 to-transparent rounded-xl border border-white/10 hover:border-{{ feature.accent }}-500/30 transition-all duration-500">
                    <div class="flex items-center gap-4">
                      <div class="inline-10 block-10 rounded-xl bg-gradient-to-br from-{{ feature.accent }}-500/30 to-{{ feature.accent }}-500/10 flex items-center justify-center">
                        <div class="block-3 block-3 rounded-full bg-{{ feature.accent }}-400 animate-pulse"></div>
                      </div>
                      <div class="space-y-2">
                        <div class="block-2.5 inline-20 bg-slate-700 rounded"></div>
                        <div class="block-3 inline-28 bg-white/10 rounded"></div>
                      </div>
                    </div>
                    <div class="inline-6 block-6 rounded-full bg-emerald-500/20 animate-pulse"></div>
                  </div>
                  {# Enhanced Card 2: Bar Chart #}
                  <div class="p-5 bg-gradient-to-br from-white/5 to-transparent rounded-xl border border-white/10 hover:border-{{ feature.accent }}-500/30 transition-all duration-500 space-y-5">
                    <div class="block-2.5 inline-28 bg-slate-700 rounded"></div>
                    <div class="inline-full block-28 flex items-end justify-between gap-4 px-2">
                      {% for h in [40, 70, 50, 90, 60, 85] %}
                        <div class="inline-full bg-gradient-to-t from-{{ feature.accent }}-500/60 to-{{ feature.accent }}-400 rounded-ts-lg rounded-te-lg transition-all duration-1000 hover:brightness-125 hover:from-{{ feature.accent }}-500/80 hover:to-{{ feature.accent }}-400" style="block-size: {{ h }}%">
                          <div class="inline-full block-full rounded-ts-lg rounded-te-lg bg-gradient-to-t from-white/10 to-transparent"></div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </section>

  {# Enhanced Additional Features Section #}
  <section class="pbs-40 pbe-40 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 content-auto">
    <div class="max-inline-7xl mx-auto">
      <!-- Enhanced section header -->
      <div class="text-center mbe-24 space-y-4">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mb-6">
          <svg class="inline-4 block-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('more') }}</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white">
          {{ i18n.t('page.more_title') }}
        </h2>
        <div class="block-1.5 inline-24 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {% for item in page.additional_features %}
          <div class="spotlight-card card-border-glow group relative p-10 lg:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:shadow-[0_20px_50px_rgba(139,92,246,0.2)] hover:-translate-y-2 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl">
            <!-- Animated background glow -->
            <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-violet-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="relative">
              <div class="inline-14 block-14 rounded-3xl bg-gradient-to-br from-violet-500/20 to-violet-500/5 flex items-center justify-center mbe-8 group-hover:rotate-6 group-hover:scale-110 transition-all duration-500 border border-violet-500/30 group-hover:border-violet-500/50 shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
                <svg class="inline-7 block-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path d="M12 6V12M12 12V18M12 12H18M12 12H6" stroke-width="2.5"/>
                </svg>
              </div>
              <h3 class="text-xl font-black text-white mbe-4 tracking-tight group-hover:text-violet-200 transition-colors duration-500">
                {{ i18n.t('page.' + item.t_key + '.title') }}
              </h3>
              <p class="text-slate-400 text-base leading-relaxed font-medium group-hover:text-slate-300 transition-colors duration-500">
                {{ i18n.t('page.' + item.t_key + '.desc') }}
              </p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}
