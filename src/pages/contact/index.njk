{% extends "main.njk" %}

{% block content %}
  {# Enhanced Hero Section #}
  <section class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden">
    <!-- Enhanced background -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl animate-pulse-glow"></div>
      <div class="absolute inset-bs-[10%] inset-s-[10%] inline-80 block-80 bg-violet-600/10 rounded-full blur-[100px] animate-float"></div>
      <div class="absolute inset-be-[10%] inset-e-[10%] inline-64 block-64 bg-fuchsia-600/8 rounded-full blur-[80px] animate-float delay-300"></div>
    </div>

    <div class="max-inline-5xl mx-auto relative">
      {# Enhanced Badge with Concentric Radius #}
      <div class="concentric-radius color-shift inline-flex items-center gap-3 px-5 py-2.5 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-all duration-500 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
        <span class="relative flex block-2.5 inline-2.5">
          <span class="animate-ping absolute inline-flex block-full inline-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full block-2.5 inline-2.5 bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)]"></span>
        </span>
        <span class="font-bold tracking-wide uppercase text-[10px]">
          {{ i18n.t('page.' + page.hero.t_key + '.badge') }}
        </span>
      </div>

      {# Enhanced Title #}
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-none">
        <span class="block bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">
          {{ i18n.t('page.' + page.hero.t_key + '.title_part1') }}
        </span>
        <span class="block bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent animate-gradient bg-size-[200%_auto]">
          {{ i18n.t('page.' + page.hero.t_key + '.title_highlight') }}
        </span>
      </h1>

      {# Description #}
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ i18n.t('page.' + page.hero.t_key + '.description') }}
      </p>
    </div>
  </section>

  {# Enhanced Contact Info Cards #}
  <section class="pbs-40 pbe-40 px-6 content-auto">
    <div class="max-inline-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        {% for item in page.contact_items %}
          <div class="group relative p-10 lg:p-12 rounded-[2.5rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-{{ item.color }}-500/40 hover:shadow-[0_20px_50px_rgba(139,92,246,0.25)] hover:-translate-y-2 transition-all duration-700 ease-emphasized text-center overflow-hidden backdrop-blur-xl">
            {# Background Glow #}
            <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-gradient-to-br from-{{ item.color }}-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            {# Enhanced Icon with Concentric Radius #}
            <div class="relative inline-16 lg:inline-20 block-16 lg:block-20 mx-auto mbe-8">
              <div class="absolute inset-0 bg-gradient-to-br from-{{ item.color }}-500/20 to-transparent rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              <div class="concentric-radius color-shift relative inline-full block-full rounded-3xl bg-gradient-to-br from-{{ item.color }}-500/10 to-{{ item.color }}-500/5 border border-{{ item.color }}-500/30 group-hover:border-{{ item.color }}-500/50 group-hover:scale-110 transition-all duration-500 flex items-center justify-center shadow-lg group-hover:shadow-[0_0_50px_rgba(139,92,246,0.3)]">
                <svg class="inline-8 lg:inline-10 block-8 lg:block-10 text-{{ item.color }}-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {{ item.icon | safe }}
                </svg>
              </div>
            </div>

            {# Content #}
            <h3 class="text-lg lg:text-xl font-black text-white mbe-3 tracking-tight group-hover:text-{{ item.color }}-200 transition-colors duration-500">{{ i18n.t('page.' + item.label + '_label') }}</h3>
            <p class="text-slate-400 font-medium group-hover:text-slate-300 transition-colors duration-500">{{ i18n.t('page.' + item.label + '_value') }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# Enhanced Contact Form & Map Section #}
  <section class="pbs-40 pbe-40 px-6 relative bg-gradient-to-b from-white/[0.02] to-transparent border-bs border-be border-white/5 content-auto">
    <div class="max-inline-7xl mx-auto">
      {# Enhanced Section Header #}
      <div class="text-center mbe-24 space-y-4">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-300 text-sm mb-6">
          <svg class="inline-4 block-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="font-bold tracking-wide uppercase text-[10px]">{{ i18n.t('page.contact.badge') }}</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white">
          {{ i18n.t('page.contact.form_title') }}
        </h2>
        <p class="text-slate-400 text-lg max-inline-2xl mx-auto">
          {{ i18n.t('page.contact.form_subtitle') }}
        </p>
        <div class="block-1.5 inline-20 bg-gradient-to-r from-violet-500 via-fuchsia-500 to-pink-500 mx-auto rounded-full shadow-[0_0_20px_rgba(139,92,246,0.4)]"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        {# Enhanced Form #}
        <div class="relative">
          <div class="relative p-10 lg:p-12 rounded-[3rem] bg-gradient-to-br from-slate-900/80 to-slate-900/60 border border-white/10 backdrop-blur-2xl shadow-2xl overflow-hidden">
            {# Enhanced Form Background #}
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,var(--tw-gradient-stops))] from-violet-600/10 via-transparent to-transparent"></div>
            <div class="absolute -inset-be-24 -inset-e-24 inline-48 block-48 bg-violet-600/5 blur-3xl rounded-full"></div>
            <div class="absolute inset-0 opacity-30 bg-[radial-gradient(#8b5cf6_1px,transparent_1px)] bg-[length:32px_32px]"></div>

            <form class="space-y-6 relative">
              {# Name #}
              <div class="space-y-3">
                <label class="block text-sm font-black uppercase tracking-[0.15em] text-slate-400">
                  {{ i18n.t('page.contact.form.name') }}
                </label>
                <input
                  type="text"
                  {{ i18n.attr('page.contact.form.name_placeholder', 'placeholder') }}
                  class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-all duration-300 font-medium hover:border-white/20"
                >
              </div>

              {# Email #}
              <div class="space-y-3">
                <label class="block text-sm font-black uppercase tracking-[0.15em] text-slate-400">
                  {{ i18n.t('page.contact.form.email') }}
                </label>
                <input
                  type="email"
                  {{ i18n.attr('page.contact.form.email_placeholder', 'placeholder') }}
                  class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-all duration-300 font-medium hover:border-white/20"
                >
              </div>

              {# Subject #}
              <div class="space-y-3">
                <label class="block text-sm font-black uppercase tracking-[0.15em] text-slate-400">
                  {{ i18n.t('page.contact.form.subject') }}
                </label>
                <input
                  type="text"
                  {{ i18n.attr('page.contact.form.subject_placeholder', 'placeholder') }}
                  class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-all duration-300 font-medium hover:border-white/20"
                >
              </div>

              {# Message #}
              <div class="space-y-3">
                <label class="block text-sm font-black uppercase tracking-[0.15em] text-slate-400">
                  {{ i18n.t('page.contact.form.message') }}
                </label>
                <textarea
                  rows="4"
                  {{ i18n.attr('page.contact.form.message_placeholder', 'placeholder') }}
                  class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-all duration-300 font-medium resize-none hover:border-white/20"
                ></textarea>
              </div>

              {# Enhanced Submit Button #}
              <button
                type="submit"
                class="group relative inline-full min-block-14 px-12 py-4 bg-white text-slate-950 rounded-2xl font-black text-lg flex items-center justify-center gap-3 transition-all duration-500 ease-emphasized hover:shadow-[0_20px_50px_rgba(255,255,255,0.3)] hover:scale-[1.02] active:scale-95 overflow-hidden"
              >
                <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"></span>
                <span class="relative flex items-center gap-3">
                  {{ i18n.t('page.contact.form.submit') }}
                  <svg class="inline-5 block-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                  </svg>
                </span>
              </button>
            </form>
          </div>
        </div>

        {# Enhanced Info Cards #}
        <div class="space-y-6">
          {# Response Time #}
          <div class="group relative p-8 lg:p-10 rounded-[2rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-emerald-500/40 hover:shadow-[0_15px_40px_rgba(16,185,129,0.2)] hover:-translate-y-1 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-gradient-to-br from-emerald-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative flex items-start gap-6">
              <div class="concentric-radius color-shift flex-none inline-14 lg:inline-16 block-14 lg:block-16 rounded-3xl bg-gradient-to-br from-emerald-500/20 to-emerald-500/5 flex items-center justify-center text-emerald-400 border border-emerald-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(16,185,129,0.3)]">
                <svg class="inline-7 block-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-emerald-200 transition-colors duration-500">{{ i18n.t('page.contact.info.response_time.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-500">{{ i18n.t('page.contact.info.response_time.description') }}</p>
              </div>
            </div>
          </div>

          {# Working Hours #}
          <div class="group relative p-8 lg:p-10 rounded-[2rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-violet-500/40 hover:shadow-[0_15px_40px_rgba(139,92,246,0.2)] hover:-translate-y-1 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-gradient-to-br from-violet-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative flex items-start gap-6">
              <div class="concentric-radius color-shift flex-none inline-14 lg:inline-16 block-14 lg:block-16 rounded-3xl bg-gradient-to-br from-violet-500/20 to-violet-500/5 flex items-center justify-center text-violet-400 border border-violet-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)]">
                <svg class="inline-7 block-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-violet-200 transition-colors duration-500">{{ i18n.t('page.contact.info.working_hours.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-500">{{ i18n.t('page.contact.info.working_hours.description') }}</p>
              </div>
            </div>
          </div>

          {# Support #}
          <div class="group relative p-8 lg:p-10 rounded-[2rem] bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/5 hover:border-fuchsia-500/40 hover:shadow-[0_15px_40px_rgba(217,70,239,0.2)] hover:-translate-y-1 transition-all duration-700 ease-emphasized overflow-hidden backdrop-blur-xl">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-gradient-to-br from-fuchsia-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative flex items-start gap-6">
              <div class="concentric-radius color-shift flex-none inline-14 lg:inline-16 block-14 lg:block-16 rounded-3xl bg-gradient-to-br from-fuchsia-500/20 to-fuchsia-500/5 flex items-center justify-center text-fuchsia-400 border border-fuchsia-500/30 group-hover:scale-110 transition-all duration-500 shadow-lg group-hover:shadow-[0_0_40px_rgba(217,70,239,0.3)]">
                <svg class="inline-7 block-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-fuchsia-200 transition-colors duration-500">{{ i18n.t('page.contact.info.support.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-500">{{ i18n.t('page.contact.info.support.description') }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# Enhanced Social Links Section #}
  <section class="pbs-40 pbe-40 px-6 relative">
    <div class="max-inline-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight text-white mbe-6">
        {{ i18n.t('page.contact.social_title') }}
      </h2>
      <p class="text-slate-400 text-lg mbe-12">
        {{ i18n.t('page.contact.social_subtitle') }}
      </p>

      <div class="inline-flex items-center gap-4">
        {% for social in page.socials %}
          <a
            href="{{ social.url }}"
            class="group relative inline-14 lg:inline-16 block-14 lg:block-16 rounded-2xl bg-gradient-to-br from-slate-900/60 to-slate-900/40 border border-white/10 hover:border-{{ social.color }}-500/50 hover:bg-slate-900/80 flex items-center justify-center transition-all duration-500 ease-emphasized hover:scale-110 hover:shadow-[0_15px_40px_rgba(139,92,246,0.3)] hover:-translate-y-1"
            aria-label="{{ social.name }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="absolute inset-0 bg-gradient-to-br from-{{ social.color }}-500/20 to-transparent rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <svg class="inline-6 lg:inline-7 block-6 lg:block-7 text-slate-400 group-hover:text-{{ social.color }}-400 transition-colors duration-500 relative z-10" fill="currentColor" viewBox="0 0 24 24">
              {{ social.icon | safe }}
            </svg>
          </a>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "cta.njk" %}
{% endblock %}
