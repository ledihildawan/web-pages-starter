{% extends "main.njk" %}

{% block extra_head %}
  {{ super() }}
  <link rel="preconnect" href="https://images.unsplash.com">
{% endblock %}

{% block content %}
<section class="relative min-block-screen overflow-hidden">
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl"></div>
    <div class="absolute inset-bs-[10%] inset-s-[10%] inline-96 block-96 bg-violet-600/10 blur-[100px]"></div>
  </div>

  <div class="max-inline-7xl mx-auto pbs-20 pbe-10 px-6">
    <div class="text-center mbe-16">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white mbe-6 tracking-tight">
        {{ i18n.t('page.hero.slide_1.title') }}
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 max-inline-3xl mx-auto">
        {{ i18n.t('page.hero.slide_1.subtitle') }}
      </p>
    </div>

    <div id="main-carousel" class="splide" aria-label="Carousel Demo">
      <div class="splide__track">
        <ul class="splide__list">
          <li class="splide__slide">
            <img
              src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80"
              data-splide-lazy="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80"
              alt="{{ i18n.text('page.hero.slide_1.alt', {}, {raw: true}) }}"
              width="1600"
              height="1067"
              loading="lazy"
              decoding="async"
            >
          </li>
          <li class="splide__slide">
            <img
              src="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1600&q=80"
              data-splide-lazy="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1600&q=80"
              alt="{{ i18n.text('page.hero.slide_2.alt', {}, {raw: true}) }}"
              width="1600"
              height="1067"
              loading="lazy"
              decoding="async"
            >
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
{% endblock %}
