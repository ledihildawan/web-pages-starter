{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["./configs/*"],
      "@constants": ["./constants.ts"],
      "@utils/*": ["./utils/*"],
      "@generated/*": ["./generated/*"],
      "@i18n": ["./packages/i18n/index.ts"],
      "@i18n/*": ["./packages/i18n/*"],
      "@page-engine": ["./packages/page-engine/index.ts"],
      "@page-engine/*": ["./packages/page-engine/*"],
      "@web-pages-starter/env": ["./packages/env/index.ts"],
      "@web-pages-starter/env/*": ["./packages/env/*"],
      "@scripts/*": ["./scripts/*"]
    },
    "types": ["bun-types", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules", "temp", "coverage"]
}
