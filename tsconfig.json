{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo/.tsbuildinfo",
    "target": "ES2024",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@config/*": ["./configs/*"],
      "@constants": ["./packages/core/constants/index.ts"],
      "@constants/*": ["./packages/core/constants/*"],
      "@data/*": ["./data/*"],
      "@dist/*": ["./dist/*"],
      "@rsbuild-out/*": ["./rsbuild-out/*"],
      "@features/*": ["./features/*"],
      "@generated/*": ["./generated/*"],
      "@layouts/*": ["./shared/ui/layouts/*"],
      "@locales/*": ["./locales/*"],
      "@pages/*": ["./pages/*"],
      "@public/*": ["./public/*"],
      "@shared/*": ["./shared/*"],
      "@shared/ui/*": ["./shared/ui/*"],
      "@utils/*": ["./shared/utils/*"],
      "@types/*": ["./shared/types/*"],
      "@i18n": ["./packages/i18n/index.ts"],
      "@i18n/*": ["./packages/i18n/*"],
      "@template-engine": ["./packages/template-engine/index.ts"],
      "@template-engine/*": ["./packages/template-engine/*"],
      "@page-system": ["./packages/page-system/index.ts"],
      "@page-system/*": ["./packages/page-system/*"],
      "@cli/*": ["./packages/cli/*"],
      "@core/*": ["./packages/core/*"]
    },
    "types": ["bun-types", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "rsbuild-out", "node_modules", "temp", "coverage", "packages/cli/templates/**"]
}
