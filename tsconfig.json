{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@config/*": ["./configs/*"],
      "@constants": ["./shared/constants/index.ts"],
      "@constants/*": ["./shared/constants/*"],
      "@data/*": ["./data/*"],
      "@dist/*": ["./dist/*"],
      "@features/*": ["./features/*"],
      "@generated/*": ["./generated/*"],
      "@layouts/*": ["./shared/layouts/*"],
      "@locales/*": ["./locales/*"],
      "@pages/*": ["./pages/*"],
      "@public/*": ["./public/*"],
      "@shared/*": ["./shared/*"],
      "@shared/ui/*": ["./shared/ui/*"],
      "@utils/*": ["./shared/utils/*"],
      "@types/*": ["./shared/types/*"],
      "@i18n": ["./packages/i18n/index.ts"],
      "@i18n/*": ["./packages/i18n/*"],
      "@template-engine": ["./packages/template-engine/index.ts"],
      "@template-engine/*": ["./packages/template-engine/*"],
      "@page-system": ["./packages/page-system/index.ts"],
      "@page-system/*": ["./packages/page-system/*"],
      "@codegen": ["./packages/codegen/index.ts"],
      "@codegen/*": ["./packages/codegen/*"],
      "@env": ["./packages/env/index.ts"],
      "@env/*": ["./packages/env/*"],
      "@scripts/*": ["./scripts/*"]
    },
    "types": ["bun-types", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules", "temp", "coverage", "packages/codegen/templates"]
}
