{
  "name": "web-pages-starter",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun ./packages/page-engine/cli/sync-system-pages.ts && bun ./scripts/clean-cache.ts && bun ./scripts/fetch-exchange-rates.ts && bun ./packages/i18n/cli/generate-active-locales.ts && bun ./packages/i18n/cli/sync-locales.ts && bun ./packages/i18n/cli/generate-types.ts && bun ./scripts/generate-images.ts && concurrently \"bun ./packages/i18n/cli/watch.ts\" \"rsbuild dev\"",
    "build": "bun ./packages/page-engine/cli/sync-system-pages.ts && bun ./scripts/clean-cache.ts && bun ./scripts/fetch-exchange-rates.ts && bun ./packages/i18n/cli/generate-active-locales.ts --prod && bun ./packages/i18n/cli/sync-locales.ts && bun ./packages/i18n/cli/generate-types.ts && bun ./scripts/build.ts",
    "postbuild": "bun ./scripts/restore-dev-stub.ts",
    "preview": "bun ./scripts/preview.ts",
    "serve": "bun ./scripts/serve.ts",
    "clean:cache": "bun ./scripts/clean-cache.ts",
    "cli": "bun ./scripts/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "rstest",
    "prepare": "husky"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@alpinejs/focus": "^3.15.12",
    "@fontsource-variable/noto-sans": "^5.2.10",
