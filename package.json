{
  "name": "web-pages-starter",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun ./packages/cli/scripts/dev.ts",
    "build": "bun ./packages/cli/scripts/build.ts",
    "preview": "bun ./packages/cli/tools/preview.ts",
    "serve": "bun ./packages/cli/scripts/serve.ts",
    "clean:cache": "bun ./packages/cli/scripts/clean-cache.ts",
    "cli": "bun ./packages/cli/tools/menu.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "rstest",
    "prepare": "husky && git config merge.generated.name 'auto-resolve generated files' 2>/dev/null; git config merge.generated.driver true 2>/dev/null; true"
  },
  "dependencies": {
    "@web-pages-starter/core": "*",
    "@web-pages-starter/fonts": "*",
    "@web-pages-starter/i18n": "*",
    "@web-pages-starter/page-system": "*",
    "@web-pages-starter/template-engine": "*",
    "@alpinejs/collapse": "^3.15.12",
    "@alpinejs/csp": "^3.15.12",
    "@alpinejs/focus": "^3.15.12",
    "@hono/node-server": "^2.0.5",
    "@splidejs/splide": "^4.1.4",
    "alpinejs": "^3.15.12",
    "disable-devtool": "^0.3.9",
    "hono": "^4.12.26",
    "html-minifier-terser": "^7.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@ngrok/ngrok": "^1.7.0",
    "@rsbuild/core": "^2.0.15",
    "@rstest/core": "^0.10.6",
    "@rstest/coverage-istanbul": "^0.10.6",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__collapse": "^3.13.4",
    "@types/alpinejs__focus": "^3.13.4",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.14",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "cssnano": "^8.0.2",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "jiti": "^2.7.0",
    "js-beautify": "^1.15.4",
    "lighthouse": "^13.4.0",
    "linkedom": "^0.18.12",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "postcss-prune-var": "^1.1.2",
    "read-cache": "^1.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "browserslist": {
    "production": [
      ">= 0.5%",
      "last 2 versions",
      "not dead",
      "not ie 11"
    ],
    "pretty": [
      "Chrome >= 111",
      "Safari >= 15.4",
      "Firefox >= 113",
      "Edge >= 111"
    ]
  },
  "trustedDependencies": [
    "core-js"
  ]
}
