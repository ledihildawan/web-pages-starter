    "@fontsource-variable/noto-sans-bengali": "^5.2.11",
    "@fontsource-variable/noto-sans-ethiopic": "^5.2.7",
    "@fontsource-variable/noto-sans-georgian": "^5.2.8",
    "@fontsource-variable/noto-sans-gujarati": "^5.2.7",
    "@fontsource-variable/noto-sans-gurmukhi": "^5.2.9",
    "@fontsource-variable/noto-sans-hebrew": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource-variable/noto-sans-kannada": "^5.2.9",
    "@fontsource-variable/noto-sans-khmer": "^5.2.8",
    "@fontsource-variable/noto-sans-kr": "^5.2.10",
    "@fontsource-variable/noto-sans-lao": "^5.2.8",
    "@fontsource-variable/noto-sans-malayalam": "^5.2.8",
    "@fontsource-variable/noto-sans-myanmar": "^5.2.1",
