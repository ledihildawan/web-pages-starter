    "@fontsource-variable/noto-sans-tamil": "^5.2.7",
    "@fontsource-variable/noto-sans-tc": "^5.2.10",
    "@fontsource-variable/noto-sans-telugu": "^5.2.8",
    "@fontsource-variable/noto-sans-thai": "^5.2.8",
    "@fontsource-variable/noto-serif-tibetan": "^5.2.8",
    "@fontsource/noto-sans-nko": "^5.2.6",
    "@fontsource/noto-sans-oriya": "^5.2.9",
    "@hono/node-server": "^2.0.4",
    "@splidejs/splide": "^4.1.4",
