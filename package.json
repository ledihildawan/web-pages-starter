{
  "name": "web-pages-starter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.8",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run fetch:rates && concurrently \"bun run watch:i18n\" \"rsbuild dev\"",
    "build": "bun run fetch:rates && bun run gen:i18n && bun run ./tools/build.ts",
    "preview": "cross-env NODE_ENV=production bun ./tools/preview.ts",
    "gen:page": "bun run ./tools/generate-page.ts",
    "gen:i18n": "bun ./tools/generate-i18n.ts",
    "sync:locales": "bun ./tools/sync-locales.ts",
    "watch:i18n": "bun ./tools/watch-i18n.ts",
    "fetch:rates": "bun ./tools/fetch-exchange-rates.ts",
    "fetch:rates:force": "bun ./tools/fetch-exchange-rates.ts --force",
    "check:parity": "bun ./tools/check-locale-parity.ts",
    "clean": "rm -rf dist bun.lock node_modules && bun install"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@alpinejs/focus": "^3.15.12",
    "@fontsource-variable/noto-sans": "^5.2.10",
