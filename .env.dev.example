# =============================================================================
# Development environment (STAGE=dev)
# =============================================================================
# Stage-specific overrides for .env (general). Stage pipeline:
# dev → qa → uat → preprod → prod
# All values are required (no defaults in schema).
# Copy .env.example to .env first, then this file to .env.dev.
# =============================================================================

STAGE=dev
NODE_ENV=development
SITE_URL=http://localhost:8888
BASE_PATH=/

# Ngrok (optional)
NGROK_AUTHTOKEN=
