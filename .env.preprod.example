# =============================================================================
# Pre-production environment (STAGE=preprod)
# =============================================================================
# Stage-specific overrides for .env (general). Stage pipeline:
# dev → qa → uat → preprod → prod
# All values are required (no defaults in schema).
# Copy .env.example to .env first, then this file to .env.preprod.
# =============================================================================

STAGE=preprod
NODE_ENV=production
SITE_URL=https://preprod.your-domain.com
BASE_PATH=/
