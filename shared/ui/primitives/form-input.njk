{% macro form_input(type, label_key, placeholder_key, name, rows, i18n) %}
  {% set input_id = name %}
  {% set error_id = input_id ~ "-error" %}
  {% set autocomplete_map = {
    'name': 'name',
    'email': 'email',
    'subject': 'off',
    'message': 'off'
  } %}
  {% set autocomplete_val = autocomplete_map[name] or '' %}

  <div class="space-y-3">
    <label for="{{ input_id }}" class="block text-sm font-black uppercase tracking-[0.15em] text-slate-400">
      {{ i18n.t(label_key) }}
    </label>
    {% if rows %}
      <textarea
        id="{{ input_id }}"
        rows="{{ rows }}"
        {{ i18n.attr(placeholder_key, 'placeholder') }}
        name="{{ name }}"
        required
        aria-required="true"
        aria-describedby="{{ error_id }}"
        aria-invalid="false"
        class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 radius-btn text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-[border-color,box-shadow] duration-200 font-medium resize-none hover:border-white/20 input-active"
      ></textarea>
    {% else %}
      <input
        id="{{ input_id }}"
        type="{{ type }}"
        {{ i18n.attr(placeholder_key, 'placeholder') }}
        name="{{ name }}"
        {% if autocomplete_val %} autocomplete="{{ autocomplete_val }}" {% endif %}
        required
        aria-required="true"
        aria-describedby="{{ error_id }}"
        aria-invalid="false"
        class="inline-full px-6 py-4 bg-slate-800/50 border border-white/10 radius-btn text-white placeholder-slate-500 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/20 transition-[border-color,box-shadow] duration-200 font-medium hover:border-white/20 input-active"
      >
    {% endif %}
    <p id="{{ error_id }}" class="text-rose-400 text-xs hidden" role="alert" data-error-for="{{ input_id }}"></p>
  </div>
{% endmacro %}