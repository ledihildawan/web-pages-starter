{% import "@shared/ui/primitives/icons.njk" as icon %}

{% macro info_card(label_text, value_text, color, icon_name) %}
  <div class="spotlight-card card-border-glow card-squash group relative p-10 lg:p-12 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border hover:border-{{ color }}-500/40 hover:shadow-[0_20px_50px_rgba(139,92,246,0.25)] hover:-translate-y-2 transition-[transform,box-shadow,border-color] duration-250 ease-emphasized text-center overflow-hidden backdrop-blur-xl card-hover-lift">
    <div class="absolute inset-be-0 inset-e-0 inline-40 block-40 bg-linear-to-br from-{{ color }}-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400">
    </div>
    <div class="relative inline-16 lg:inline-20 block-16 lg:block-20 mx-auto mbe-8">
      <div class="absolute inset-0 bg-linear-to-br from-{{ color }}-500/20 to-transparent radius-nested-lg blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-400">
      </div>
      <div class="relative inline-full block-full radius-nested-lg bg-linear-to-br from-{{ color }}-500/10 to-{{ color }}-500/5 border border-{{ color }}-500/30 group-hover:border-{{ color }}-500/50 group-hover:scale-110 transition-[border-color,scale,box-shadow] duration-200 flex items-center justify-center shadow-lg group-hover:shadow-[0_0_50px_rgba(139,92,246,0.3)] icon-squash">
        {{
          icon.icon(icon_name, 'inline-8 lg:inline-10 block-8 lg:block-10 text-' ~ color ~ '-400', size='xl')
        }}
      </div>
    </div>
    <h3 class="text-lg lg:text-xl font-black text-white mbe-3 tracking-tight group-hover:text-{{ color }}-200 transition-colors duration-300">
      {{ label_text }}
    </h3>
    <p class="text-slate-400 font-medium group-hover:text-slate-300 transition-colors duration-300">
      {{ value_text }}
    </p>
  </div>
{% endmacro %}
