<nav
  aria-label="Main navigation" x-cloak x-data="navbar"
  @keydown.escape.window="onNavEscape"
  @resize.window.passive="onResize"
  @scroll.window.passive="onScroll"
  class="fixed inset-bs-0 inset-s-0 inline-full z-100 transition-[transform,background-color,border-color,box-shadow] duration-500 ease-emphasized border-be bg-transparent border-transparent translate-y-0"
  :class="{
  'bg-slate-950/90 backdrop-blur-2xl shadow-xl border-white/10': scrolled && !mobileMenuOpen,
  'bg-transparent border-transparent': !scrolled && !mobileMenuOpen,
  'bg-slate-950 border-transparent shadow-none': mobileMenuOpen,
  '-translate-y-full': navHidden && !mobileMenuOpen,
  'translate-y-0': !navHidden || mobileMenuOpen
  }"
>
<div
class="max-inline-7xl mx-auto px-6 block-20 flex justify-between items-center relative z-130 transition-colors duration-200"
:class="mobileMenuOpen ? 'bg-slate-950' : ''"
>
<a
href="{{ url('/') }}"
class="group flex flex-col transition-transform active:scale-[0.96] shrink-0"
@click.prevent="navigateToHome()"
>
<span class="text-2xl font-black text-gradient tracking-tighter leading-none group-hover:brightness-125 transition-[filter] duration-200">
Starter
</span>
<span class="text-[10px] text-slate-400 font-black tracking-[0.25em] uppercase mbs-1.5 transition-colors duration-200 group-hover:text-slate-300">
{{ i18n.t('engine_name') }}
</span>
</a>
<div class="flex items-center gap-2 lg:gap-4">
<ul class="hidden lg:flex items-center gap-2 me-4">
{% for item in global.menu.header %}
  <li class="relative group/dd">
    <a
      href="{{ url(item.url) }}"
      class="text-[13px] font-bold px-4 pbs-2.5 pbe-2.5 radius-icon transition-[color,background-color] duration-300 flex items-center gap-1.5 relative"
      :class="isActive('{{ item.url }}') ? 'text-white bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5'"
      :aria-current="isActive('{{ item.url }}') ? 'page' : false"
      >
      {{ i18n.t(item.label) }}
      {% if item.children %}
        {{ icon.icon('chevron-down', 'inline-3 block-3 transition-transform duration-200 opacity-20 group-hover/dd:rotate-180 group-hover/dd:opacity-100 group-focus-within/dd:rotate-180 group-focus-within/dd:opacity-100', size='md') }}
      {% endif %}
      <span
        class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-8 block-0.5 bg-linear-to-r from-violet-500 to-fuchsia-500 rounded-full transition-opacity duration-300"
        :class="isActive('{{ item.url }}') ? 'opacity-100' : 'opacity-0'"
        >
      </span>
    </a>
    {% if item.children %}
      <div class="absolute inset-bs-full inset-s-0 inline-64 pbs-2 z-140 opacity-0 invisible translate-y-2 scale-95 transition-[opacity,visibility,transform] duration-300 ease-emphasized group-hover/dd:opacity-100 group-hover/dd:visible group-hover/dd:translate-y-0 group-hover/dd:scale-100 group-focus-within/dd:opacity-100 group-focus-within/dd:visible group-focus-within/dd:translate-y-0 group-focus-within/dd:scale-100">
        <div class="p-2 bg-slate-950 border border-white/10 radius-btn shadow-[0_25px_60px_rgba(0,0,0,0.5)]">
          {% for child in item.children %}
            <a
              href="{{ url(child.url) }}"
              class="block px-4 pbs-3 pbe-3 text-[13px] font-bold text-slate-400 hover:text-white hover:bg-white/10 radius-icon transition-[color,background-color] duration-300"
              >
              {{ i18n.t(child.label) }}
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </li>
{% endfor %}
</ul>
{% if locales.length > 1 %}
<div class="relative hidden lg:block">
  <button
    @click="langOpen = !langOpen"
    @click.outside="langOpen = false"
    :aria-expanded="langOpen"
    aria-haspopup="listbox"
    aria-label="Select language"
    class="flex items-center gap-2.5 px-3.5 py-2.5 block-11 bg-white/5 border border-white/10 radius-icon text-slate-400 hover:text-white hover:bg-white/8 hover:border-white/15 transition-[color,background-color,border-color] duration-200 font-black text-[10px] group icon-squash"
    >
    <span class="inline-5 block-3.5 shrink-0 flex items-center justify-center overflow-hidden rounded-xs opacity-70 group-hover:opacity-100 transition-opacity duration-300 bg-white/5 aspect-4/3">
      <template x-if="getCurrentLanguageObj()">
        <img
          :src="getCurrentFlagUrl()"
          width="20"
          height="15"
          class="inline-full block-full object-cover"
          loading="lazy"
          :alt="getCurrentFlagAlt()"
        >
      </template>
    </span>
    <span
      x-text="getCurrentLanguageLabel()"
      class="tracking-[0.15em]"
      >
    </span>
    {{ icon.icon('chevron-down', 'inline-3 block-3 opacity-20 transition-[transform,opacity] duration-200 group-hover:opacity-100 shrink-0', size='md') }}
  </button>
  <div
    x-show="langOpen"
    x-cloak
    x-transition:enter="transition ease-emphasized duration-300"
    x-transition:enter-start="opacity-0 scale-95 translate-y-2"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 scale-100 translate-y-0"
    x-transition:leave-end="opacity-0 scale-95 translate-y-2"
    class="absolute inset-bs-full inset-e-0 mbs-3 min-inline-56 bg-slate-950 border border-white/10 radius-btn shadow-[0_25px_60px_rgba(0,0,0,0.5)] z-140 overflow-hidden"
    role="group"
    aria-label="Select language"
    :data-current-lang="$store.i18n.current"
    @click="selectLanguageFromClick($event)"
    >
    <div class="p-2 max-block-80 overflow-y-auto scrollbar-none">
      {% for lang in locales %}
        <button
          data-lang-option="{{ lang.code }}"
          class="lang-option inline-full px-3 py-2.5 block-10 flex items-center gap-3 text-start radius-icon text-[12px] font-bold transition-[color,background-color,border-color] duration-300 group"
          :aria-current="$store.i18n.current === '{{ lang.code }}'"
          >
          <span class="inline-5 block-3.5 shrink-0 overflow-hidden rounded-xs bg-white/5 flex items-center justify-center aspect-4/3">
            <img
              src="{{ global.flag_cdn }}/w20/{{ lang.flag }}.png"
              width="20"
              height="15"
              class="inline-full block-full object-cover transition-[opacity,filter] duration-300 lang-flag"
              loading="lazy"
              alt="{{ lang.label }} flag - {{ lang.flag | upper }}"
            >
          </span>
          <span class="truncate">{{ lang.label }}</span>
        </button>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}
<div class="hidden lg:block {% if locales.length > 1 %}ms-2 ps-5 border-s border-white/10{% endif %}">
<a
  href="{{ url('/pricing') }}"
  class="group relative pl-6 pr-5.5 block-11 flex items-center bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white radius-icon text-[12px] font-black hover-lift btn-squash anticipate-press ripple-click sparkle-hover uppercase tracking-wider border border-white/10 overflow-hidden"
  >
  <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out">
  </span>
  <span class="relative z-10 flex items-center gap-2">
    {{ i18n.t('get_started') }}
    {{ icon.icon('arrow-right', 'inline-4 block-4 group-hover:translate-x-0.5 transition-transform duration-300', size='md') }}
  </span>
</a>
</div>
<button
@click.stop="toggleMobile()"
@keydown.escape="onMobileEscape"
:aria-label="mobileMenuOpen ? 'Close menu' : 'Open menu'"
:aria-expanded="mobileMenuOpen"
aria-controls="mobile-menu"
class="lg:hidden relative z-150 inline-11 block-11 flex items-center justify-center text-slate-200 hover:text-white bg-white/5 radius-icon border border-white/10 hover:bg-white/8 hover:border-white/15 btn-squash icon-squash anticipate-press"
:class="mobileMenuOpen ? 'bg-transparent border-transparent hover:bg-white/5' : ''"
>
<div class="relative inline-5 block-4 flex flex-col justify-between items-center">
  <span
    class="inline-full block-0.5 bg-current transition-[transform] duration-500 ease-emphasized"
    :class="mobileMenuOpen ? 'rotate-45 translate-y-1.75' : ''"
    >
  </span>
  <span
    class="inline-full block-0.5 bg-current transition-[opacity,transform] duration-300 ease-emphasized"
    :class="mobileMenuOpen ? 'opacity-0 -translate-x-4' : ''"
    >
  </span>
  <span
    class="inline-full block-0.5 bg-current transition-[transform] duration-500 ease-emphasized"
    :class="mobileMenuOpen ? '-rotate-45 -translate-y-1.75' : ''"
    >
  </span>
</div>
</button>
</div>
</div>
<div
id="mobile-menu"
x-ref="mobileMenu"
x-show="mobileMenuOpen"
x-trap="mobileMenuOpen"
x-cloak
x-transition:enter="transition ease-emphasized duration-700"
x-transition:enter-start="-translate-y-full"
x-transition:enter-end="translate-y-0"
x-transition:leave="transition ease-in duration-500"
x-transition:leave-start="translate-y-0"
x-transition:leave-end="-translate-y-full"
@keydown.escape.window="onMenuEscape"
@click.self="closeMobileMenu()"
@touchstart.passive="handleTouchStart($event)"
@touchmove.passive="handleTouchMove($event)"
@touchend="handleTouchEnd()"
@transitionend.self="onMenuVisible()"
@animationend.self="onAnimationEnd()"
:class="mobileMenuOpen && menuChildrenVisible && 'menu-ready'"
class="fixed inset-0 bg-slate-950 z-110 lg:hidden flex flex-col h-dvh"
role="dialog"
aria-modal="true"
aria-label="Mobile menu"
>
<div class="absolute inset-x-0 top-0 flex justify-center pt-3 opacity-30">
<div class="inline-12 block-1.5 rounded-full bg-slate-400">
</div>
</div>
<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent pointer-events-none">
</div>
<div class="absolute inset-be-0 inset-e-0 inline-64 block-64 bg-fuchsia-600/10 rounded-full blur-[100px] pointer-events-none">
</div>
<div class="flex-1 overflow-y-auto pbs-24 pbe-12 px-6 scrollbar-none relative z-10 text-start">
<ul class="space-y-2 mbs-6">
{% for item in global.menu.header %}
  <li
    x-show="menuChildrenVisible"
    x-transition:enter="transition ease-emphasized duration-700"
    x-transition:enter-start="opacity-0 translate-y-8 scale-95"
    class="gpu-boost td-{{ loop.index0 }}"
    >
    <div class="flex items-center justify-between pbs-4 pbe-4 group">
      {% if item.children %}
        <span class="text-4xl sm:text-5xl font-black tracking-tighter transition-[color] duration-300 text-white">
          {{ i18n.t(item.label) }}
        </span>
        {% set submenu_key = item.label ~ '_submenu' %}
        <button
          @click="toggleSubmenuWithFeedback({{ loop.index0 }})"
          :aria-expanded="activeMobileSub === {{ loop.index0 }}"
          aria-controls="sub-menu-{{ loop.index0 }}"
          aria-label="{{ i18n.t(submenu_key, {}, {raw: true}) }}"
          class="inline-11 block-11 flex items-center justify-center bg-white/5 radius-btn border border-white/10 active:scale-[0.96] transition-[background-color] duration-200 icon-squash hover:bg-white/10"
          >
          <svg
            class="inline-6 block-6 transition-transform duration-500 ease-emphasized"
            :class="activeMobileSub === {{ loop.index0 }} ? 'rotate-180 text-violet-400' : 'text-slate-600'"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>
        {% else %}
          <a
            href="{{ url(item.url) }}"
            @click.prevent="closeMenuAndFeedback('{{ url(item.url) }}')"
            class="text-4xl sm:text-5xl font-black tracking-tighter transition-[color] duration-300 w-full relative"
            :class="isActive('{{ item.url }}') ? 'text-gradient-violet-fuchsia' : 'text-white active:text-violet-400'"
            >
            {{ i18n.t(item.label) }}
            <span class="absolute inset-0 bg-white/5 rounded-lg scale-0 group-active:scale-100 transition-transform duration-150">
            </span>
          </a>
        {% endif %}
      </div>
      {% if item.children %}
        <div
          id="sub-menu-{{ loop.index0 }}"
          x-show="activeMobileSub === {{ loop.index0 }}"
          x-cloak
          x-collapse
          class="mbe-6 ms-2 ps-6 border-s-2 border-violet-500/20 space-y-4 pbs-4 pbe-4"
          >
          {% for child in item.children %}
            <a
              href="{{ url(child.url) }}"
              @click.prevent="closeMenuAndFeedback('{{ url(child.url) }}')"
              class="block text-2xl font-black transition-colors duration-300 relative py-2 -mx-2 px-2 rounded-lg"
              :class="isActive('{{ child.url }}') ? 'text-white bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5 active:bg-white/10'"
              >
              {{ i18n.t(child.label) }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </li>
  {% endfor %}
</ul>
{% if locales.length > 1 %}
  <div
    class="mbs-12 pbs-8 border-bs border-white/10"
    x-show="menuChildrenVisible"
    x-transition:enter="transition ease-emphasized duration-700"
    x-transition:enter-start="opacity-0 translate-y-8"
    role="group"
    aria-label="{{ i18n.t('select_language', {}, {raw: true}) }}"
    >
    <p class="text-[10px] font-black tracking-[0.2em] text-slate-400 uppercase mbe-5 ps-1">{{ i18n.t('select_language') }}</p>
    <div
      class="grid grid-cols-2 gap-2"
      role="group"
      aria-label="Select language"
      :data-current-lang="$store.i18n.current"
      @click="selectLanguageOption($event)"
      >
      {% for lang in locales %}
        <button
          data-lang-option="{{ lang.code }}"
          class="lang-option group relative flex items-center gap-3 px-4 pbs-4 pbe-4 radius-btn transition-[color,background-color,border-color] duration-300 border text-start active:scale-[0.96]"
          :aria-current="$store.i18n.current === '{{ lang.code }}'"
          aria-label="{{ lang.label }} ({{ lang.flag | upper }})"
          >
          <div class="relative shrink-0 inline-5 block-3.5 overflow-hidden rounded-xs bg-white/5 aspect-4/3">
            <img
              src="{{ global.flag_cdn }}/w40/{{ lang.flag }}.png"
              width="40"
              height="30"
              class="inline-full block-full object-cover transition-[opacity,filter] duration-200 lang-flag"
              loading="lazy"
              alt="{{ lang.label }} flag - {{ lang.flag | upper }}"
            >
          </div>
          <div class="flex flex-col min-inline-0">
            <span class="text-[13px] font-bold truncate leading-none">{{ lang.label }}</span>
            <span class="text-[9px] font-black opacity-20 tracking-widest mbs-1.5">{{ lang.flag | upper }}</span>
          </div>
        </button>
      {% endfor %}
    </div>
  </div>
{% endif %}
<div
  class="mbs-8"
  x-show="menuChildrenVisible"
  x-transition:enter="transition ease-emphasized duration-700"
  x-transition:enter-start="opacity-0 translate-y-10"
  >
  <a
    href="{{ url('/pricing') }}"
    @click.prevent="closeMenuAndFeedback('{{ url('/pricing') }}')"
    class="group block inline-full pbs-5 pbe-5 bg-linear-to-r from-violet-600 via-fuchsia-600 to-pink-600 text-white radius-card-md text-center font-black text-xl shadow-2xl btn-squash anticipate-press ripple-click sparkle-hover overflow-hidden hover-lift active:scale-[0.96] relative"
    >
    <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700">
    </span>
    <span class="relative flex items-center justify-center gap-3">
      {{ i18n.t('get_started') }}
      {{ icon.icon('arrow-right', 'inline-5 block-5', size='lg') }}
    </span>
  </a>
</div>
</div>
<div class="block-2 bg-linear-to-r from-violet-600 via-fuchsia-500 to-pink-500 inline-full shrink-0">
</div>
</div>
</div>
</nav>
