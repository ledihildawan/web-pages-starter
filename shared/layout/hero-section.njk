{% macro hero_section(badge, title_part1, title_highlight, description, center = true, show_stats = false, h1 = null) %}
  {% set h1_override = h1 or page.meta.h1 %}
  <section class="relative pbs-52 pbe-28 px-6 {{ 'text-center' if center else 'text-start' }} overflow-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl"></div>
      <div class="absolute inset-bs-[10%] inset-s-[10%] inline-80 block-80 bg-violet-600/10 rounded-full blur-[100px]"></div>
      <div class="absolute inset-be-[10%] inset-e-[10%] inline-64 block-64 bg-fuchsia-600/8 rounded-full blur-[80px]"></div>
    </div>
    <div class="max-inline-6xl mx-auto relative">
      {% if badge %}
        <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-linear-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-[background-color,border-color,box-shadow] duration-200 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
          <span class="relative flex block-2.5 inline-2.5">
            <span class="relative inline-flex rounded-full block-2.5 inline-2.5 bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)]"></span>
          </span>
          <span class="font-bold tracking-wide uppercase text-[10px]">
            {{ badge }}
          </span>
        </div>
      {% endif %}
      {% if h1_override %}
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1] text-gradient-white">
          {{ h1_override }}
        </h1>
      {% else %}
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1]">
          <span class="block text-gradient-white">
            {{ title_part1 }}
          </span>
          <span class="block text-gradient">
            {{ title_highlight }}
          </span>
        </h1>
      {% endif %}
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ description }}
      </p>
      {% if show_stats %}
        <div id="hero-stats"></div>
      {% endif %}
    </div>
  </section>
{% endmacro %}