// Mapping of locale codes to language codes for translations
const localeToLanguage = {
  'zh-Hans-CN': 'zh-Hans',
  'zh-Hans-MY': 'zh-Hans',
  'zh-Hans-SG': 'zh-Hans',
  'zh-Hant-TW': 'zh-Hant',
  'zh-Hant-HK': 'zh-Hant',
  'zh-Hant-MO': 'zh-Hant',
  'ja-JP': 'ja',
  'ar-SA': 'ar',
  'ar-AE': 'ar',
  'ar-EG': 'ar',
  'ar-MA': 'ar',
  'ar-TN': 'ar',
  'fr-FR': 'fr',
  'fr-BE': 'fr',
  'fr-CA': 'fr',
  'fr-CH': 'fr',
  'de-DE': 'de',
  'de-AT': 'de',
  'de-CH': 'de',
  'es-ES': 'es',
  'es-AR': 'es',
  'es-CO': 'es',
  'es-MX': 'es',
  'es-PE': 'es',
  'pt-BR': 'pt',
  'pt-PT': 'pt',
  'pt-AO': 'pt',
  'pt-MZ': 'pt',
  'en-US': 'en', // Keep English as-is
  'en-GB': 'en',
  'en-CA': 'en',
  'en-AU': 'en',
  'en-IN': 'en',
  'en-NZ': 'en',
  'en-ZA': 'en',
  'hi-IN': 'hi',
  'hi-NP': 'hi',
  'ko-KR': 'ko',
  'ko-KP': 'ko',
  'ru-RU': 'ru',
  'th-TH': 'th'
};

const localesDir = path.join(__dirname, '../src/locales');
const localeDirs = fs.readdirSync(localesDir).filter(f => {
  const stat = fs.statSync(path.join(localesDir, f));
  return stat.isDirectory();
});

let updatedCount = 0;
let skippedCount = 0;

for (const locale of localeDirs) {
  const commonPath = path.join(localesDir, locale, 'common.json5');

  if (!fs.existsSync(commonPath)) {
    continue;
  }

  // Get the language code for this locale
  const langCode = localeToLanguage[locale];

  // Skip if no translation available or if it's Indonesian (already translated)
  if (!langCode || !regionTranslations[langCode] || locale === 'id-ID') {
    skippedCount++;
    continue;
  }

  // Read existing content
  const content = fs.readFileSync(commonPath, 'utf8');
  const data = JSON.parse(content);

  // Update region keys with translations
  const translations = regionTranslations[langCode];
  let updatedKeys = 0;

  for (const [code, translation] of Object.entries(translations)) {
    const key = `region_${code.toLowerCase()}`;
    if (data[key] && data[key] !== translation) {
      data[key] = translation;
      updatedKeys++;
    }
  }

  if (updatedKeys > 0) {
    // Write back with proper formatting
    const output = JSON.stringify(data, null, 4).replace(/"([^"]+)":/g, '    "$1":');
    fs.writeFileSync(commonPath, output + '\n');
    console.log(`Updated ${locale} - ${updatedKeys} region keys`);
    updatedCount++;
  } else {
    skippedCount++;
  }
}

console.log(`\n=== Summary ===`);
console.log(`Updated: ${updatedCount} locales`);
console.log(`Skipped: ${skippedCount} locales`);
console.log(`Total processed: ${localeDirs.length}`);
