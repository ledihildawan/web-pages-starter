set -e

echo "Running pre-commit checks..."

# Run lint-staged (biome on staged files)
bunx lint-staged

# Run typecheck and test in parallel
bun run typecheck &
PID1=$!

bun run test &
PID2=$!

FAILED=0

wait $PID1 || FAILED=1
wait $PID2 || FAILED=1

if [ $FAILED -eq 1 ]; then
  echo "Pre-commit checks failed (typecheck or test)"

  exit 1
fi

echo "All pre-commit checks passed"

exit 0
