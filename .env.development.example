# =============================================================================
# Development environment
# =============================================================================
# Copy this file to .env.development and adjust values.
# =============================================================================

# --- Server ---
# NODE_ENV=development
# PORT=8888
# HOST=127.0.0.1

# --- Client ---
# SITE_URL=http://localhost:8888

# --- Optional ---
# NGROK_AUTHTOKEN=your_ngrok_authtoken
