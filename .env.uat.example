# =============================================================================
# UAT environment (STAGE=uat)
# =============================================================================
# Stage-specific overrides for .env (general). Stage pipeline:
# dev → qa → uat → preprod → prod
# All values are required (no defaults in schema).
# Copy .env.example to .env first, then this file to .env.uat.
# =============================================================================

STAGE=uat
NODE_ENV=production
SITE_URL=https://uat.your-domain.com
BASE_PATH=/
