{% extends "main.njk" %}
{% import "shared/layout/section-header.njk" as section %}
{% import "shared/ui/icons.njk" as icon %}

{% block content %}

  <section class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 inline-200 block-100 bg-violet-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute inset-0 bg-linear-to-b from-transparent via-slate-950/50 to-slate-950"></div>
    </div>

    <div class="max-inline-4xl mx-auto relative">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-300 text-sm font-black uppercase tracking-wider mbe-12">
        <span class="inline-2 block-2 rounded-full bg-emerald-400 animate-pulse"></span>
        {{ i18n.t('i18n-test:hero.badge') | safe }}
      </div>

      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1]">
        <span class="bg-linear-to-br from-white via-white to-slate-400 bg-clip-text text-transparent">
          <span data-i18n-html="{{ i18n('i18n-test:hero.title').k }}">Tes
            <span class="text-violet-400">Lengkap</span>
            Internasionalisasi</span>
        </span>
      </h1>

      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 font-medium leading-relaxed">
        {{ i18n.t('i18n-test:hero.description') | safe }}
      </p>

      <div class="flex items-center justify-center gap-6 md:gap-10 text-sm">
        <div class="flex items-center gap-3">
          <span class="text-2xl" aria-hidden="true">🌍</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none tabular-nums">{{ locales | length }}</div>
            <div class="text-xs text-slate-400">
              {{ i18n.t('i18n-test:language_info.languages') | safe }}</div>
          </div>
        </div>
        <div class="inline-px block-12 bg-white/10"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl" aria-hidden="true">💱</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none tabular-nums">{{ page.display.currency_comparison_currencies | length }}</div>
            <div class="text-xs text-slate-400">
              {{ i18n.t('i18n-test:currency.currencies') | safe }}</div>
          </div>
        </div>
        <div class="inline-px block-12 bg-white/10"></div>
        <div class="flex items-center gap-3">
          <span class="text-2xl" aria-hidden="true">🔄</span>
          <div class="text-left">
            <div class="text-2xl font-black text-white leading-none">Live</div>
            <div class="text-xs text-slate-400">
              {{ i18n.t('i18n-test:language_info.switching') | safe }}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pbs-8 pbe-8 px-6 border-y border-white/5 bg-slate-900/30">
    <div class="max-inline-5xl mx-auto">
      <div class="flex items-center justify-center gap-4 md:gap-8 flex-wrap">
        <div class="flex items-center gap-2 px-4 py-2 radius-card-md bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:language_info.code') | safe }}</span>
          <span class="text-sm font-black text-white tabular-nums">{{ localeConfig.code }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 radius-card-md bg-emerald-500/10 border border-emerald-500/20">
          <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:language_info.currency') | safe }}</span>
          <span class="text-sm font-black text-emerald-400 tabular-nums">{{ localeConfig.currency }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 radius-card-md bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:language_info.direction') | safe }}</span>
          <span class="text-sm font-black text-white">{{ localeConfig.dir }}</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 radius-card-md bg-slate-900/50 border border-white/5">
          <span class="text-xs text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:language_info.digits') | safe }}</span>
          <span class="text-sm font-black text-white">
            {% if localeConfig.nativeDigits %}
              {{ i18n.t('i18n-test:language_info.enabled') | safe }}
            {% else %}
              {{ i18n.t('i18n-test:language_info.disabled') | safe }}{% endif %}
          </span>
        </div>
      </div>
    </div>
  </section>

  <nav x-data="sectionNav" class="sticky top-0 z-30 bg-slate-950/80 backdrop-blur-xl border-b border-white/5">
    <div class="max-inline-6xl mx-auto px-6">
      <div class="flex items-center gap-1 py-2 overflow-x-auto scrollbar-none">
        <a href="#translations" :class="activeId === 'translations' ? 'bg-violet-500/20 text-white border-violet-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.translations') | safe }}
        </a>
        <a href="#formatting" :class="activeId === 'formatting' ? 'bg-emerald-500/20 text-white border-emerald-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.formatting') | safe }}
        </a>
        <a href="#pricing" :class="activeId === 'pricing' ? 'bg-amber-500/20 text-white border-amber-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.pricing') | safe }}
        </a>
        <a href="#modes" :class="activeId === 'modes' ? 'bg-cyan-500/20 text-white border-cyan-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.modes') | safe }}
        </a>
        <a href="#systems" :class="activeId === 'systems' ? 'bg-sky-500/20 text-white border-sky-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.systems') | safe }}
        </a>
        <a href="#switcher" :class="activeId === 'switcher' ? 'bg-fuchsia-500/20 text-white border-fuchsia-500/40' : 'text-slate-400 border-transparent hover:text-white hover:bg-white/5'" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 radius-icon text-xs font-black border transition-colors">
          {{ i18n.t('i18n-test:nav.switcher') | safe }}
        </a>
      </div>
    </div>
  </nav>

  <section id="translations" class="px-6 pbs-40 pbe-40 scroll-mt-16">
    <div class="max-inline-6xl mx-auto">
      {{ section.section_header(
        null,
        i18n.t('i18n-test:core.title'),
        i18n.t('i18n-test:core.description'),
        icon.icon('book', 'inline-5 block-5')
      ) }}

      <div class="grid lg:grid-cols-2 gap-6">
        <div class="group p-6 radius-card-lg bg-linear-to-br from-fuchsia-500/8 to-transparent card-border card-border-hover hover-lift transition">
          <div class="flex items-center gap-4 mbe-6">
            <div class="inline-14 block-14 radius-nested-lg bg-fuchsia-500/20 flex items-center justify-center text-2xl group-hover:scale-110 icon-squash transition-transform" aria-hidden="true">a</div>
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:pluralization.title') | safe }}</h3>
          </div>
          <div class="space-y-4">
            {% for plural in page.plurals %}
              {% set plural_title_key = 'i18n-test:pluralization.' ~ plural.key ~ '_title' %}
              <div class="border-b border-white/5 last:border-0 pbe-3 last:pbe-0">
                <div class="text-xs uppercase tracking-wider text-fuchsia-300/70 mbe-2">
                  {{ i18n.t(plural_title_key) | safe }}</div>
                <div class="space-y-1.5">
                  {% for count in plural.counts %}
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-slate-400 tabular-nums">{{ count }}</span>
                      <span class="text-fuchsia-400 font-medium">{{ i18n.plural(plural.key, count) }}</span>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="group p-6 radius-card-lg bg-linear-to-br from-emerald-500/8 to-transparent card-border card-border-hover hover-lift transition">
          <div class="flex items-center gap-4 mbe-6">
            <div class="inline-14 block-14 radius-nested-lg bg-emerald-500/20 flex items-center justify-center text-2xl group-hover:scale-110 icon-squash transition-transform" aria-hidden="true">&lt;/&gt;</div>
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:html_content.title') | safe }}</h3>
          </div>
          <div class="text-center py-4 px-3 radius-card-md bg-emerald-500/5">
            <div class="text-base text-white mbe-2">
              <span data-i18n-html="{{ i18n('i18n-test:html_content.example').k }}">Ini adalah contoh teks dengan
                <span class='text-emerald-400'>highlight warna</span>
                dan
                <strong>teks tebal</strong>.</span></div>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-6 mbs-6">
        <div class="group p-6 radius-card-lg bg-linear-to-br from-amber-500/8 to-transparent card-border card-border-hover hover-lift transition">
          <div class="flex items-center gap-4 mbe-6">
            <div class="inline-14 block-14 radius-nested-lg bg-amber-500/20 flex items-center justify-center text-2xl group-hover:scale-110 icon-squash transition-transform" aria-hidden="true">📝</div>
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:form.title') | safe }}</h3>
          </div>
          <form class="grid md:grid-cols-2 gap-3">
            {% for field in page.form_fields %}
              {% if loop.index <= page.display.max_form_fields %}
                {% set field_key = 'i18n-test:form.' ~ field.key %}
                <input type="{{ field.type }}" {{ i18n.attr(field_key ~ '_placeholder', 'placeholder', {}, {raw: true}) }} {{ i18n.attr(field_key ~ '_label', 'aria-label', {}, {raw: true}) }} class="inline-full px-4 py-3 bg-slate-900/50 border border-white/10 radius-card-md text-white placeholder-slate-500 text-sm focus:outline-none focus:border-amber-500/30 focus:ring-2 focus:ring-amber-500/10 transition">
              {% endif %}
            {% endfor %}
            <button type="submit" class="md:col-span-2 px-6 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 radius-btn font-black text-sm transition hover:shadow-lg hover:shadow-amber-500/20">
              {{ i18n.t('i18n-test:form.submit') | safe }}
            </button>
          </form>
        </div>

        <div class="group p-6 radius-card-lg bg-linear-to-br from-red-500/8 to-transparent card-border card-border-hover hover-lift transition">
          <div class="flex items-center gap-4 mbe-6">
            <div class="inline-14 block-14 radius-nested-lg bg-red-500/20 flex items-center justify-center text-2xl group-hover:scale-110 icon-squash transition-transform" aria-hidden="true">⚠️</div>
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:missing_keys.title') | safe }}</h3>
          </div>
          <p class="text-xs text-slate-500 mbe-3">
              {{ i18n.t('i18n-test:missing_keys.description') | safe }}</p>
          <div class="space-y-2">
            {% for key in page.missing_keys %}
              {% if loop.index <= page.display.max_missing_keys %}
                <div class="px-4 py-3 radius-card-md bg-red-950/30 border border-red-500/10">
                  <code class="text-red-400 text-sm">{{ i18n.t(key) | safe }}</code>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-6 mbs-6">
        <div class="p-6 radius-card-lg bg-linear-to-br from-slate-900/40 to-slate-900/20 card-border">
          <div class="flex items-center justify-between mbe-4">
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:native_digits.title') | safe }}</h3>
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-500/20 uppercase tracking-wider">{{ i18n.t('i18n-test:live_label') | safe }}</span>
          </div>
          <p class="text-xs text-slate-500 mbe-3">
            {{ i18n.t('i18n-test:native_digits.description') | safe }}</p>
          <div class="space-y-2">
            {% for sample in page.native_digit_samples %}
              {% if loop.index <= page.display.max_native_samples %}
                <div class="flex items-center justify-between px-4 py-2.5 radius-card-md bg-slate-800/40 border border-white/5">
                  <code class="text-xs text-slate-500 font-mono">{{ sample }}</code>
                  <span class="text-sm font-black text-amber-300">{{ i18n.nativeDigits(sample) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-6 radius-card-lg bg-linear-to-br from-slate-900/40 to-slate-900/20 card-border">
          <div class="flex items-center justify-between mbe-4">
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:inflection.title') | safe }}</h3>
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-500/20 uppercase tracking-wider">{{ i18n.t('i18n-test:live_label') | safe }}</span>
          </div>
          <p class="text-xs text-slate-500 mbe-3">
            {{ i18n.t('i18n-test:inflection.description') | safe }}</p>
          <div class="space-y-2">
            {% for pair in page.inflection_pairs %}
              {% if loop.index <= page.display.max_inflection %}
                <div class="grid grid-cols-3 gap-2 px-4 py-2.5 radius-card-md bg-slate-800/40 border border-white/5 text-sm">
                  <code class="text-slate-500 font-mono">{{ pair.singular }}</code>
                  <span class="text-emerald-400 text-center">{{ i18n.pluralize(pair.singular) }}</span>
                  <code class="text-slate-500 font-mono text-right">{{ pair.plural }}
                    →
                    {{ i18n.singularize(pair.plural) }}</code>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="formatting" class="px-6 pbs-40 pbe-40 bg-linear-to-b from-white/2 to-transparent scroll-mt-16">
    <div class="max-inline-6xl mx-auto">
      {{ section.section_header(
        null,
        i18n.t('i18n-test:advanced.title'),
        i18n.t('i18n-test:advanced.description'),
        icon.icon('chart', 'inline-5 block-5')
      ) }}

      <div class="grid lg:grid-cols-2 gap-6">
        <div class="group p-6 radius-card-lg bg-linear-to-br from-violet-500/8 to-transparent card-border card-border-hover hover-lift transition">
          <div class="flex items-center gap-4 mbe-6">
            <div class="inline-14 block-14 radius-nested-lg bg-violet-500/20 flex items-center justify-center text-2xl group-hover:scale-110 icon-squash transition-transform" aria-hidden="true">🔢</div>
            <h3 class="text-lg font-black text-white">
              {{ i18n.t('i18n-test:numbers.title') | safe }}</h3>
          </div>
          <div class="space-y-3">
            {% for num in page.numbers %}
              {% if loop.index <= page.display.max_numbers %}
                {% set num_label_key = 'i18n-test:' ~ num.label %}
                <div class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
                  <span class="text-sm text-slate-400">{{ i18n.t(num_label_key) | safe }}</span>
                  <span class="text-xl font-black text-violet-400 tabular-nums">{{ i18n.formatNumber(num.val) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-6 radius-card-lg bg-slate-900/40 card-border card-border-hover transition">
          <div class="flex items-center gap-3 mbe-6">
            <div class="inline-12 block-12 radius-icon bg-violet-500/20 flex items-center justify-center">
              <span class="text-xl" aria-hidden="true">🌐</span>
            </div>
            <div>
              <h3 class="text-lg font-black text-white">
                {{ i18n.t('i18n-test:currency_comparison.title') | safe }}</h3>
              <p class="text-sm text-slate-400">
                {{ i18n.t('i18n-test:currency_comparison.description') | safe }}</p>
            </div>
          </div>
          <div class="text-center mbe-6 p-4 radius-card-md bg-violet-500/5">
            <div class="text-3xl font-black text-white mbe-1">{{ i18n.formatCurrency(page.display.currency_comparison_base, 'USD', {raw: true}) }}</div>
            <div class="text-xs text-slate-400">
              {{ i18n.t('i18n-test:currency_comparison.base_price') | safe }}</div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
            {% for curr in page.display.currency_comparison_currencies %}
              {% set curr_key = 'i18n-test:currency_comparison.' ~ (curr | lower) %}
              <div class="p-3 radius-icon bg-slate-800/30 border border-white/5 hover:border-white/10 transition text-center">
                <div class="text-[10px] text-slate-400 mbe-1">
                  {{ i18n.t(curr_key) | safe }}</div>
                <div class="text-sm font-black tabular-nums {% if curr == 'USD' %}text-emerald-400{% elif curr == 'JPY' %}text-fuchsia-400{% elif curr == 'CNY' %}text-amber-400{% else %}text-rose-400{% endif %}">{{ i18n.convertCurrency(page.display.currency_comparison_base, curr) }}</div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mbs-6">
        <div class="p-5 radius-card-md bg-slate-900/30 card-border card-border-hover transition">
          <div class="flex items-center gap-2 mbe-3">
            <span class="text-base" aria-hidden="true">%</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:advanced.percentages') | safe }}</span>
          </div>
          <div class="space-y-2">
            {% for pct in page.percentages %}
              {% if loop.index <= page.display.max_percentages %}
                {% set pct_key = 'i18n-test:' ~ pct.label %}
                <div class="flex justify-between items-baseline">
                  <span class="text-[11px] text-slate-400">{{ i18n.t(pct_key) | safe }}</span>
                  <span class="text-sm font-black text-emerald-400 tabular-nums">{{ i18n.formatPercent(pct.val) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-5 radius-card-md bg-slate-900/30 card-border card-border-hover transition">
          <div class="flex items-center gap-2 mbe-3">
            <span class="text-base" aria-hidden="true">💾</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:advanced.bytes') | safe }}</span>
          </div>
          <div class="space-y-2">
            {% for byte in page.bytes %}
              {% if loop.index <= page.display.max_bytes %}
                {% set byte_key = 'i18n-test:' ~ byte.label %}
                <div class="flex justify-between items-baseline">
                  <span class="text-[11px] text-slate-400">{{ i18n.t(byte_key) | safe }}</span>
                  <span class="text-sm font-black text-violet-400 tabular-nums">{{ i18n.formatBytes(byte.val) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-5 radius-card-md bg-slate-900/30 card-border card-border-hover transition">
          <div class="flex items-center gap-2 mbe-3">
            <span class="text-base" aria-hidden="true">🔬</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:advanced.scientific') | safe }}</span>
          </div>
          <div class="space-y-2">
            {% for sci in page.scientific %}
              {% if loop.index <= page.display.max_scientific %}
                <div class="flex justify-between items-baseline">
                  <span class="text-[11px] font-mono text-slate-400">{{ sci }}</span>
                  <span class="text-sm font-black text-cyan-400 tabular-nums">{{ i18n.formatScientific(sci) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-5 radius-card-md bg-slate-900/30 card-border card-border-hover transition">
          <div class="flex items-center gap-2 mbe-3">
            <span class="text-base" aria-hidden="true">📊</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:advanced.abbreviated') | safe }}</span>
          </div>
          <div class="space-y-2">
            {% for abb in page.abbreviated %}
              {% if loop.index <= page.display.max_abbreviated %}
                <div class="flex justify-between items-baseline">
                  <span class="text-[11px] font-mono text-slate-400">{{ abb }}</span>
                  <span class="text-sm font-black text-lime-400 tabular-nums">{{ i18n.formatAbbreviated(abb) }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mbs-4">
        <div class="p-5 radius-card-md bg-slate-900/30 card-border card-border-hover transition">
          <div class="flex items-center gap-2 mbe-3">
            <span class="text-base" aria-hidden="true">🥇</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-wider">{{ i18n.t('i18n-test:advanced.ordinals') | safe }}</span>
          </div>
          <div class="space-y-1.5">
            {% for ord in page.ordinals %}
              {% if loop.index <= page.display.max_ordinals %}
                <div class="flex justify-between items-baseline">
                  <span class="text-[11px] font-mono text-slate-400">{{ ord }}</span>
