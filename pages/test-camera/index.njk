{% extends "@layouts/main.njk" %}

{% block content %}
  <section
    class="relative min-block-screen flex flex-col"
    x-data="cameraTest">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(139,92,246,0.06),transparent_60%)]"></div>
    </div>

    <header class="relative z-20 pt-8 pb-4 px-6 text-center">
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full text-xs text-white/70 backdrop-blur-md transition-all duration-300"
        :class="isActive ? 'opacity-100' : 'opacity-60'">
        <span
          class="relative flex h-2 w-2"
          x-show="isActive">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75"
            :class="isActive ? 'bg-emerald-400' : ''"></span>
          <span
            class="relative inline-flex rounded-full h-2 w-2"
            :class="isActive ? 'bg-emerald-500' : 'bg-white/30'"></span>
        </span>
        <span
          x-show="!isActive"
          class="w-2 h-2 rounded-full bg-white/30"></span>
        <span
          class="font-medium"
          x-text="isActive ? (selectedCamera && selectedCamera.label) || 'Camera Active' : 'Camera Off'"></span>
      </div>
    </header>

    <main class="flex-1 relative flex items-center justify-center px-4 pb-32">
      <div
        class="relative w-full max-w-3xl aspect-4/3 md:aspect-video rounded-2xl overflow-hidden transition-all duration-500 ease-out"
        :class="isActive ? 'shadow-2xl shadow-black/50 ring-1 ring-white/10' : 'shadow-xl shadow-black/30 ring-1 ring-white/5'">
        <video
          x-ref="video"
          x-show="isActive"
          autoplay
          playsinline
          muted
          class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
          :class="isActive ? 'opacity-100' : 'opacity-0'">
        </video>

        <canvas
          x-ref="canvas"
          x-show="captured && !isActive"
          class="absolute inset-0 w-full h-full object-cover"></canvas>

        <img
          x-ref="preview"
          x-show="captured && !isActive"
          class="absolute inset-0 w-full h-full object-cover"
          alt="Captured photo"
        />

        <div
          x-show="!isActive && !captured"
          class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-b from-slate-900 to-slate-950">
          <div class="relative mb-6">
            <div class="w-24 h-24 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
              <svg
                class="w-10 h-10 text-white/30"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z">
                </path>
              </svg>
            </div>
            <div
              class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-violet-600 flex items-center justify-center opacity-0 transition-opacity duration-300"
              :class="isInitializing ? 'opacity-100' : ''">
              <svg
                class="w-4 h-4 text-white animate-spin"
                fill="none"
                viewBox="0 0 24 24">
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4">
                </circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                </path>
              </svg>
            </div>
          </div>
          <p
            class="text-white/40 text-sm"
            x-text="isInitializing ? 'Starting camera...' : 'Tap to start camera'">
          </p>
        </div>

        <div
          x-ref="vignetteOverlay"
          class="absolute inset-0 pointer-events-none transition-opacity duration-500 vignette-overlay"
          :class="isActive ? 'opacity-100' : 'opacity-0'">
        </div>

        <div
          x-ref="flashOverlay"
          class="absolute inset-0 bg-white pointer-events-none opacity-0">
        </div>

        <div
          x-ref="captureSuccess"
          class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-200">
          <div class="w-20 h-20 rounded-full bg-emerald-500/90 flex items-center justify-center">
            <svg
              class="w-10 h-10 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M5 13l4 4L19 7">
              </path>
            </svg>
          </div>
        </div>
      </div>
    </main>

    <div
      x-ref="controlBar"
      class="fixed bottom-0 left-0 right-0 z-50 px-4 pb-8 pt-4 transition-all duration-400"
      :class="isActive ? 'translate-y-0 opacity-100' : 'translate-y-8 opacity-0 pointer-events-none'">
      <div class="max-w-lg mx-auto">
        <div
          class="flex items-center justify-center gap-3 p-2 bg-white/10 backdrop-blur-xl border border-white/15 rounded-2xl shadow-2xl">
          <button
            x-show="hasMultipleCameras"
            @click="switchCamera()"
            class="flex items-center justify-center w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white/80 hover:text-white transition-all duration-150 active:scale-95"
            title="Switch Camera">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4">
              </path>
            </svg>
          </button>

          <button
            @click="captureImage()"
            class="flex items-center justify-center w-16 h-16 rounded-full bg-white hover:bg-white/95 text-slate-900 transition-all duration-150 active:scale-95 shadow-lg hover:shadow-xl">
            <div class="w-12 h-12 rounded-full border-2 border-slate-900 flex items-center justify-center">
              <div
                class="w-10 h-10 rounded-full bg-slate-900 transition-transform duration-150"
                :class="isCapturing ? 'scale-90' : ''">
              </div>
            </div>
          </button>

          <button
            @click="initCamera()"
            class="flex items-center justify-center w-12 h-12 rounded-full bg-red-600 hover:bg-red-500 text-white transition-all duration-150 active:scale-95"
            title="Stop Camera">
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24">
              <path d="M6 6h12v12H6z"></path>
            </svg>
          </button>
        </div>

        <div class="flex items-center justify-center gap-4 mt-3">
          <button
            x-show="hasMultipleCameras"
            @click="toggleCameraSelector()"
            class="text-xs text-white/50 hover:text-white/80 transition-colors duration-150">
            <span x-text="devices.length + ' cameras'"></span>
          </button>
        </div>

        <div
          x-ref="cameraSelector"
          x-show="showCameraSelector"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-2"
          class="mt-3 p-2 bg-white/10 backdrop-blur-xl border border-white/15 rounded-xl">
          <div class="flex flex-wrap gap-2 justify-center">
            <template
              x-for="(cam, i) in devices"
              :key="cam.index">
              <button
                @click="selectCamera(i); showCameraSelector = false;"
                class="px-3 py-1.5 text-xs rounded-lg transition-all duration-150 active:scale-95"
                :class="i === selectedIndex ? 'bg-emerald-600 text-white' : 'bg-white/10 text-white/70 hover:bg-white/20 hover:text-white'">
                <span x-text="cam.label.slice(0, 20)"></span>
                <span
                  x-show="cam.isUltra"
                  class="ml-1 text-white/50">[Ultra]</span>
                <span
                  x-show="cam.isWide && !cam.isUltra"
                  class="ml-1 text-white/50">[Wide]</span>
              </button>
            </template>
          </div>
        </div>
      </div>
    </div>

    <button
      x-show="!isActive"
      @click="initCamera()"
      class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-6 py-3.5 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-full shadow-lg shadow-violet-600/30 transition-all duration-150 active:scale-95"
      :class="isInitializing ? 'opacity-70 pointer-events-none' : ''">
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z">
        </path>
      </svg>
      <span x-text="isInitializing ? 'Starting...' : 'Start Camera'"></span>
    </button>

    <div
      x-ref="errorToast"
      x-show="lastError"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 translate-y-4"
      class="fixed top-20 left-1/2 -translate-x-1/2 z-50 px-4 py-3 bg-red-600/90 backdrop-blur-md text-white text-sm rounded-xl shadow-xl max-w-xs text-center">
      <span x-text="lastError"></span>
    </div>

    <button
      @click="showDebugInfo = !showDebugInfo"
      class="fixed top-4 right-4 z-50 p-2 text-white/40 hover:text-white/70 transition-colors duration-150">
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
        </path>
      </svg>
    </button>

    <div
      x-show="showDebugInfo"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      class="fixed top-16 right-4 z-50 w-72 p-4 bg-slate-900/95 backdrop-blur-md border border-white/10 rounded-xl shadow-xl">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-white">Camera Settings</h3>
        <button
          @click="showDebugInfo = false"
          class="text-white/50 hover:text-white">
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12">
            </path>
          </svg>
        </button>
      </div>

      <div class="space-y-3">
        <div>
          <label class="text-xs text-white/50 mb-1 block">Back Camera Priority</label>
          <select
            x-ref="backPrioritySelect"
            @change="handlePriorityChange('back')"
            class="w-full bg-white/10 text-white text-xs rounded-lg px-3 py-2 border border-white/10 focus:border-violet-500 focus:outline-none">
            <option value="camera0">camera0</option>
            <option value="wide">wide</option>
            <option value="ultra">ultra</option>
            <option value="standard">standard</option>
            <option value="highest">highest</option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
            <option value="first-available">first-available</option>
          </select>
        </div>

        <div>
          <label class="text-xs text-white/50 mb-1 block">Front Camera Priority</label>
          <select
            x-ref="frontPrioritySelect"
            @change="handlePriorityChange('front')"
            class="w-full bg-white/10 text-white text-xs rounded-lg px-3 py-2 border border-white/10 focus:border-violet-500 focus:outline-none">
            <option value="camera0">camera0</option>
            <option value="wide">wide</option>
            <option value="ultra">ultra</option>
            <option value="standard">standard</option>
            <option
              value="highest"
              selected>
              highest
            </option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
            <option value="first-available">first-available</option>
          </select>
        </div>

        <button
          @click="copyDebugInfo()"
          class="w-full mt-2 px-3 py-2 bg-white/10 hover:bg-white/20 text-white text-xs rounded-lg transition-colors duration-150">
          Copy Debug Info
        </button>
      </div>
    </div>
  </section>
{% endblock %}
