{% extends "@layouts/main.njk" %}

{% block content %}
  <section class="relative pbs-32 pbe-16 px-6 overflow-hidden">
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-full block-full bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent -z-10 blur-3xl opacity-60"></div>
    <div class="max-inline-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-3 px-4 py-2 bg-violet-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-10 transition-colors hover:bg-violet-500/20 cursor-default gpu-boost">
        <span class="relative flex block-2 inline-2">
          <span class="relative inline-flex rounded-full block-2 inline-2 bg-violet-500"></span>
        </span>
        <span class="font-bold tracking-wide uppercase text-[10px]">
          {{ i18n.t('test-camera:hero.badge') }}
        </span>
      </div>
      <h1 class="text-6xl md:text-7xl font-black tracking-tighter mbe-8 leading-[1.1] bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent">
        {{ i18n.t('test-camera:hero.title') }}
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 max-inline-2xl mx-auto mbe-14 leading-relaxed font-medium">
        {{ i18n.t('test-camera:hero.description') }}
      </p>
    </div>
  </section>

  <section class="pbs-8 pbe-32 px-6" x-data="cameraTest">
    <div class="max-inline-4xl mx-auto space-y-8">
      <div class="relative radius-card-lg overflow-hidden bg-slate-900 border border-white/10 aspect-video">
        <video
          x-ref="video"
          x-show="isActive"
          autoplay
          playsinline
          muted
          class="hidden inline-full block-full object-cover mirror"
        ></video>

        <canvas
          x-ref="canvas"
          x-show="captured"
          class="hidden inline-full block-full object-cover"
        ></canvas>

        <img
          x-ref="preview"
          x-show="captured"
          class="hidden inline-full block-full object-cover"
          alt="Captured photo"
        />

        <div
          x-ref="logOutput"
          class="absolute bottom-0 left-0 right-0 max-bs-48 bg-slate-950/90 text-emerald-400 text-xs font-mono p-4 overflow-y-auto"
          style="display: none;"
        ></div>
      </div>

      <div class="flex items-center justify-center gap-4 flex-wrap">
        <button
          @click="initCamera()"
          class="inline-flex items-center gap-3 px-6 py-3 text-white font-semibold rounded-lg transition-colors duration-200"
          :class="btnColorClass"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          <span x-text="btnLabelText"></span>
        </button>

        <button
          x-show="hasMultipleCameras && isActive"
          @click="switchCamera()"
          class="hidden inline-flex items-center gap-3 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
          </svg>
          <span>Switch Camera</span>
        </button>

        <button
          x-show="hasMultipleCameras && isActive && backIndex >= 0 && selectedIndex !== backIndex"
          @click="switchToBack()"
          class="hidden inline-flex items-center gap-3 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Back Camera</span>
        </button>

        <button
          x-show="hasMultipleCameras && isActive && frontIndex >= 0 && selectedIndex !== frontIndex"
          @click="switchToFront()"
          class="hidden inline-flex items-center gap-3 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Front Camera</span>
        </button>

        <button
          x-show="isActive"
          @click="captureImage()"
          class="hidden inline-flex items-center gap-3 px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Capture</span>
        </button>

        <button
          @click="copyDebugInfo()"
          class="inline-flex items-center gap-3 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="inline-block block-5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Debug Info</span>
        </button>
      </div>

      <div class="flex items-center justify-center gap-8 flex-wrap">
        <div class="flex items-center gap-3">
          <label class="text-slate-300 text-sm font-medium">Back Priority:</label>
          <select
            x-ref="backPrioritySelect"
            @change="handlePriorityChange('back')"
            class="bg-slate-800 text-white text-sm rounded-lg px-3 py-2 border border-slate-600 focus:border-violet-500 focus:outline-none"
          >
            <option value="camera0">camera0</option>
            <option value="wide">wide</option>
            <option value="ultra">ultra</option>
            <option value="standard">standard</option>
            <option value="highest">highest</option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
            <option value="first-available">first-available</option>
          </select>
        </div>

        <div class="flex items-center gap-3">
          <label class="text-slate-300 text-sm font-medium">Front Priority:</label>
          <select
            x-ref="frontPrioritySelect"
            @change="handlePriorityChange('front')"
            class="bg-slate-800 text-white text-sm rounded-lg px-3 py-2 border border-slate-600 focus:border-violet-500 focus:outline-none"
          >
            <option value="camera0">camera0</option>
            <option value="wide">wide</option>
            <option value="ultra">ultra</option>
            <option value="standard">standard</option>
            <option value="highest" selected>highest</option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
            <option value="first-available">first-available</option>
          </select>
        </div>
      </div>

      <div
        x-ref="selector"
        class="hidden flex flex-wrap gap-3 justify-center"
      ></div>
    </div>
  </section>
{% endblock %}
