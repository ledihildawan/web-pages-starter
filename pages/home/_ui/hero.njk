{% import "@shared/ui/composites/responsive-image.njk" as ri %}

<section class="relative pbs-52 pbe-28 px-6 text-center overflow-hidden">
  <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[120%] block-[120%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/15 via-transparent to-transparent -z-10 blur-3xl opacity-60">
  </div>

  <div class="max-inline-6xl mx-auto relative">
    <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-linear-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/30 rounded-full text-violet-100 text-sm mbe-12 transition-[background-color,border-color,box-shadow] duration-200 hover:bg-violet-500/20 hover:border-violet-500/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.3)] cursor-default">
      <span class="relative flex block-2 inline-2">
        <span
          class="animate-ping absolute inline-flex block-full inline-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full block-2 inline-2 bg-emerald-500"></span>
      </span>
      <span class="font-bold tracking-wide uppercase text-[10px]">
        {{ i18n.t('home:hero.badge') }}
      </span>
    </div>

    <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter mbe-8 leading-[1.1]">
      <span class="block text-gradient-white">{{ i18n.t('home:hero.title_part1') }}</span>
      <span
        class="block bg-linear-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
        {{ i18n.t('home:hero.title_highlight') }}
      </span>
    </h1>

    <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
      {{ i18n.t('home:hero.description') }}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mbe-12 min-block-14">
      <a
        href="{{ url(i18n.t('home:hero.primary_btn.url', {}, {raw: true})) }}"
        class="group relative inline-full sm:inline-auto min-block-14 px-12 py-4 bg-white text-slate-950 radius-btn font-black text-lg flex items-center justify-center transition-[box-shadow,scale] duration-300 ease-emphasized hover:shadow-[0_0_30px_rgba(255,255,255,0.2)] active:scale-[0.96] gpu-boost min-inline-45">
        {{ i18n.t('home:hero.primary_btn.label') }}
      </a>
      <a
        href="{{ url(i18n.t('home:hero.secondary_btn.url', {}, {raw: true})) }}"
        class="inline-full sm:inline-auto min-block-14 px-12 py-4 bg-slate-900/50 backdrop-blur-md text-white border border-white/10 radius-btn font-black text-lg flex items-center justify-center hover:bg-slate-800 transition-[background-color,border-color] duration-300 ease-emphasized hover:border-white/20 active:scale-[0.96] gpu-boost min-inline-45">
        {{ i18n.t('home:hero.secondary_btn.label') }}
      </a>
    </div>

    <p class="text-[11px] text-slate-400 font-bold tracking-[0.2em] uppercase mbe-16">
      {{ i18n.t('home:hero.note') }}
    </p>

    <div class="relative group max-inline-2xl mx-auto">
      <div class="absolute -inset-1 bg-linear-to-r from-violet-600 to-fuchsia-600 rounded-3xl blur-2xl opacity-20 group-hover:opacity-40 transition-opacity duration-700 ease-emphasized">
      </div>
      <div class="relative bg-slate-900 rounded-2xl p-2 border border-white/10 shadow-2xl overflow-hidden gpu-boost">
        {{
          ri.render(images['hero-test'], i18n.t('home:hero.image_alt', {}, { raw: true }), '(min-width: 720px) 654px, calc(100vw - 66px)', 'eager', 'inline-full block-auto rounded-lg transition-transform duration-700 ease-emphasized group-hover:scale-[1.02]', 'high', true, true)
        }}
      </div>
    </div>
  </div>
</section>
