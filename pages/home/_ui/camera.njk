<section class="relative pbs-20 pbe-20 px-6 text-center overflow-hidden bg-slate-900/50">
  <div class="max-inline-2xl mx-auto">
    <h2 class="text-3xl font-bold mbe-8 text-white">Kamera Test</h2>

    <div class="flex flex-col items-center gap-6">
      <button
        id="backCameraBtn"
        class="hidden items-center gap-3 min-block-14 px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white radius-btn font-bold transition-colors duration-200">
        <svg
          class="block w-5 h-5" fill="none" stroke="currentColor"
          viewBox="0 0 24 24">
          <path
            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
          />
          <path
            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"
          />
        </svg>
        Kamera Belakang
      </button>

      <button
        id="frontCameraBtn"
        class="hidden items-center gap-3 min-block-14 px-6 py-3 bg-violet-600 hover:bg-violet-500 text-white radius-btn font-bold transition-colors duration-200">
        <svg
          class="block w-5 h-5" fill="none" stroke="currentColor"
          viewBox="0 0 24 24">
          <path
            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
          />
        </svg>
        Kamera Depan
      </button>

      <button
        id="debugCameraBtn"
        class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-400 radius-btn font-mono text-xs transition-colors duration-200">
        <svg
          class="block w-4 h-4" fill="none" stroke="currentColor"
          viewBox="0 0 24 24">
          <path
            stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        </svg>
        Copy Debug Info
      </button>

      <div class="flex flex-wrap justify-center gap-4 text-xs font-mono">
        <div class="flex items-center gap-2">
          <span class="text-amber-400">Back:</span>
          <select
            id="backPrioritySelect"
            class="bg-slate-800 text-amber-400 px-2 py-1 rounded border border-slate-700 cursor-pointer hover:bg-slate-700">
            <option value="camera0">camera0</option>
            <option value="wide">wide</option>
            <option value="ultra">ultra</option>
            <option value="highest">highest</option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-violet-400">Front:</span>
          <select
            id="frontPrioritySelect"
            class="bg-slate-800 text-violet-400 px-2 py-1 rounded border border-slate-700 cursor-pointer hover:bg-slate-700">
            <option value="highest">highest</option>
            <option value="lowest">lowest</option>
            <option value="first">first</option>
            <option value="last">last</option>
          </select>
        </div>
      </div>

      <div id="cameraSelector" class="hidden flex-wrap justify-center gap-3 mbe-4"></div>

      <div class="flex gap-4">
        <button
          id="captureBtn"
          class="hidden items-center gap-3 min-block-14 px-6 py-4 bg-blue-600 hover:bg-blue-500 text-white radius-btn font-bold transition-colors duration-200">
          <svg
            class="block w-5 h-5" fill="none" stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
            />
            <path
              stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"
            />
          </svg>
          Capture
        </button>

        <button
          id="startCameraBtn"
          class="inline-flex items-center gap-3 min-block-14 px-10 py-4 bg-emerald-600 hover:bg-emerald-500 text-white radius-btn font-black text-lg transition-colors duration-200">
          <svg
            class="block w-5 h-5" fill="none" stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
            />
            <path
              stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"
            />
          </svg>
          <span id="btnLabel">Nyalakan Kamera</span>
        </button>

        <button
          id="switchCameraBtn"
          class="hidden items-center gap-3 min-block-14 px-6 py-4 bg-slate-700 hover:bg-slate-600 text-white radius-btn font-bold transition-colors duration-200">
          <svg
            class="block w-5 h-5" fill="none" stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
            />
          </svg>
          Ganti Kamera
        </button>
      </div>

      <div
        class="relative"
        x-data="{ cameraError: null, cameraLoading: false }"
        x-on:camera-error.window="cameraError = $event.detail.message; cameraLoading = false"
        x-on:camera-start.window="cameraError = null; cameraLoading = true"
        x-on:camera-ready.window="cameraLoading = false"
        x-on:camera-stop.window="cameraError = null; cameraLoading = false">
        <video
          id="videoElement" autoplay playsinline
          muted x-show="!cameraError && !cameraLoading" class="w-full max-w-md rounded-xl bg-black">
        </video>

        <div
          x-show="cameraLoading && !cameraError"
          class="w-full max-w-md rounded-xl bg-black flex items-center justify-center min-h-60">
          <div class="text-white animate-pulse">Memuat kamera...</div>
        </div>

        <div
          x-show="cameraError"
          class="w-full max-w-md rounded-xl bg-red-900/50 border border-red-500 p-6 text-center">
          <div class="text-red-400 text-sm font-bold mb-2">Kamera Error</div>
          <div class="text-red-300 text-xs mb-4" x-text="cameraError"></div>
          <button
            type="button"
            onclick="initCamera()"
            class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-bold rounded-lg transition-colors">
            Coba Lagi
          </button>
        </div>

        <canvas id="captureCanvas" class="hidden"></canvas>

        <img id="capturePreview" class="hidden w-full max-w-md rounded-xl bg-black mt-4" />
      </div>

      <div class="w-full max-w-md text-left">
        <p class="text-sm font-bold text-slate-400 mbe-2 uppercase tracking-wide">Log Kamera:</p>
        <div
          id="logOutput"
          class="bg-black/50 rounded-lg p-4 font-mono text-sm text-emerald-400 min-h-30 overflow-auto">
          Klik tombol untuk mulai.
        </div>
      </div>
    </div>
  </div>
</section>
