<section class="pbs-24 pbe-24 px-6 relative bg-white/2 border-bs border-be border-white/5 cv-auto-300">
  <div class="max-inline-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-16 text-center">
      {% for stat in page.stats %}
        {% set stat_key = 'home:stats.' ~ stat.t_key %}
        {% set stat_val_key = stat_key ~ '_val' %}
        {% set stat_label_key = stat_key %}
        <div class="group gpu-boost">
          <p class="text-6xl font-black text-{{ stat.color }}-400 tracking-tighter mbe-3 transition-transform ease-emphasized group-hover:scale-110 duration-500">
            {{ i18n.t(stat_val_key) }}
          </p>
          <p class="text-slate-300 font-bold uppercase tracking-[0.2em] text-[10px]">
            {{ i18n.t(stat_label_key) }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
