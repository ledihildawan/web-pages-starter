{% extends "main.njk" %}
{% import "shared/ui/hero-section.njk" as hero %}
{% import "shared/ui/section-header.njk" as section %}
{% import "shared/ui/info-card.njk" as card %}
{% import "shared/ui/form-input.njk" as form %}
{% import "shared/ui/social-link.njk" as social_link %}
{% import "shared/ui/icons.njk" as icon %}

{% block content %}
  {% set hero_key = 'contact:contact' %}
  {{ hero.hero_section(
    i18n.t(hero_key ~ '.badge'),
    i18n.t(hero_key ~ '.title_part1'),
    i18n.t(hero_key ~ '.title_highlight'),
    i18n.t(hero_key ~ '.description'),
    h1=page.meta.h1
  ) }}

  <section class="pbs-40 pbe-40 px-6" aria-labelledby="contact-info-heading">
    <h2 id="contact-info-heading" class="sr-only">{{ i18n.t('contact:contact.info_title') }}</h2>
    <div class="max-inline-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        {% for item in page.contact_items %}
          {% set contact_key = 'contact:' ~ item.label %}
          {{ card.info_card(
            i18n.t(contact_key ~ '_label'),
            i18n.t(contact_key ~ '_value'),
            item.color,
            item.icon
          ) }}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="pbs-40 pbe-40 px-6 relative bg-linear-to-b from-white/2 to-transparent border-bs border-be border-white/5">
    <div class="max-inline-7xl mx-auto">
      {{ section.section_header(
        i18n.t('contact:contact.badge'),
        i18n.t('contact:contact.form_title'),
        i18n.t('contact:contact.form_subtitle'),
        icon.icon('envelope', 'inline-4 block-4'),
        true,
        'contact-form-heading'
      ) }}

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="relative">
          <div class="relative p-10 lg:p-12 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border card-border-glow backdrop-blur-xl shadow-2xl overflow-hidden spotlight-card card-squash hover-lift">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,var(--tw-gradient-stops))] from-violet-600/10 via-transparent to-transparent"></div>
            <div class="absolute -inset-be-24 -inset-e-24 inline-48 block-48 bg-violet-600/5 blur-3xl rounded-full"></div>
            <div class="absolute inset-0 opacity-30 bg-[radial-gradient(#8b5cf6_1px,transparent_1px)] bg-size-[32px_32px]"></div>

            <form class="space-y-6 relative" method="post" action="{{ url('/contact') }}" novalidate="novalidate" x-data="contactForm()" @submit.prevent="validate()" aria-labelledby="contact-form-heading">
              {{ form.form_input('text', 'contact:contact.form.name', 'contact:contact.form.name_placeholder', 'name', i18n=i18n) }}
              {{ form.form_input('email', 'contact:contact.form.email', 'contact:contact.form.email_placeholder', 'email', i18n=i18n) }}
              {{ form.form_input('text', 'contact:contact.form.subject', 'contact:contact.form.subject_placeholder', 'subject', i18n=i18n) }}
              {{ form.form_input('textarea', 'contact:contact.form.message', 'contact:contact.form.message_placeholder', 'message', rows=4, i18n=i18n) }}

              <div class="sr-only" role="status" aria-live="polite" x-text="statusMessage"></div>

              <button type="submit" class="magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click sparkle-hover group relative inline-full min-block-14 pl-12 pr-11.5 py-4 bg-white text-slate-950 radius-btn font-black text-lg flex items-center justify-center gap-3 transition-[scale,box-shadow] duration-200 ease-emphasized hover:shadow-[0_20px_50px_rgba(255,255,255,0.3)] hover:scale-[1.02] overflow-hidden">
                <span class="absolute inset-0 bg-linear-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-400 ease-in-out"></span>
                <span class="relative flex items-center gap-3">
                  {{ i18n.t('contact:contact.form.submit') }}
                  {{ icon.icon('arrow-right', 'inline-5 block-5 icon-transition group-hover:translate-x-1', size='md') }}
                </span>
              </button>
            </form>
          </div>
        </div>

        <div class="space-y-6">
          <div class="spotlight-card card-border-glow card-squash group relative p-8 lg:p-10 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border hover:border-emerald-500/40 hover:shadow-[0_20px_50px_rgba(16,185,129,0.2)] hover:-translate-y-2 transition-[transform,box-shadow,border-color] duration-250 ease-emphasized overflow-hidden backdrop-blur-xl hover-lift">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-linear-to-br from-emerald-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
            <div class="relative flex items-start gap-6">
              <div class="flex-none inline-14 lg:inline-16 block-14 lg:block-16 radius-nested-lg bg-linear-to-br from-emerald-500/20 to-emerald-500/5 flex items-center justify-center text-emerald-400 border border-emerald-500/30 group-hover:scale-110 transition-[scale,box-shadow] duration-200 shadow-lg group-hover:shadow-[0_0_40px_rgba(16,185,129,0.3)] icon-squash">
                {{ icon.icon('clock', 'inline-7 block-7', size='xl') }}
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-emerald-200 transition-colors duration-200">{{ i18n.t('contact:contact.info.response_time.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-200">{{ i18n.t('contact:contact.info.response_time.description') }}</p>
              </div>
            </div>
          </div>

          <div class="spotlight-card card-border-glow card-squash group relative p-8 lg:p-10 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border hover:border-violet-500/40 hover:shadow-[0_20px_50px_rgba(139,92,246,0.2)] hover:-translate-y-2 transition-[transform,box-shadow,border-color] duration-250 ease-emphasized overflow-hidden backdrop-blur-xl hover-lift">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-linear-to-br from-violet-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
            <div class="relative flex items-start gap-6">
              <div class="flex-none inline-14 lg:inline-16 block-14 lg:block-16 radius-nested-lg bg-linear-to-br from-violet-500/20 to-violet-500/5 flex items-center justify-center text-violet-400 border border-violet-500/30 group-hover:scale-110 transition-[scale,box-shadow] duration-200 shadow-lg group-hover:shadow-[0_0_40px_rgba(139,92,246,0.3)] icon-squash">
                {{ icon.icon('sun', 'inline-7 block-7', size='xl') }}
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-violet-200 transition-colors duration-200">{{ i18n.t('contact:contact.info.working_hours.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-200">{{ i18n.t('contact:contact.info.working_hours.description') }}</p>
              </div>
            </div>
          </div>

          <div class="spotlight-card card-border-glow card-squash group relative p-8 lg:p-10 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border hover:border-fuchsia-500/40 hover:shadow-[0_20px_50px_rgba(217,70,239,0.2)] hover:-translate-y-2 transition-[transform,box-shadow,border-color] duration-250 ease-emphasized overflow-hidden backdrop-blur-xl hover-lift">
            <div class="absolute inset-be-0 inset-e-0 inline-32 block-32 bg-linear-to-br from-fuchsia-500/15 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
            <div class="relative flex items-start gap-6">
              <div class="flex-none inline-14 lg:inline-16 block-14 lg:block-16 radius-nested-lg bg-linear-to-br from-fuchsia-500/20 to-fuchsia-500/5 flex items-center justify-center text-fuchsia-400 border border-fuchsia-500/30 group-hover:scale-110 transition-[scale,box-shadow] duration-200 shadow-lg group-hover:shadow-[0_0_40px_rgba(217,70,239,0.3)] icon-squash">
                {{ icon.icon('support', 'inline-7 block-7', size='xl') }}
              </div>
              <div>
                <h3 class="text-xl font-black text-white mbe-2 group-hover:text-fuchsia-200 transition-colors duration-200">{{ i18n.t('contact:contact.info.support.title') }}</h3>
                <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors duration-200">{{ i18n.t('contact:contact.info.support.description') }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pbs-40 pbe-40 px-6 relative">
    <div class="max-inline-6xl mx-auto text-center">
      {{ section.section_header(i18n.t('contact:contact.social_badge'), i18n.t('contact:contact.social_title'), i18n.t('contact:contact.social_subtitle'), icon.icon('share', 'inline-4 block-4')) }}

      <div class="inline-flex items-center gap-4">
        {% for social in page.socials %}
          {{ social_link.social_link(social.url, social.name, social.color, size='md') }}
        {% endfor %}
      </div>
    </div>
  </section>

  {% include "shared/ui/cta.njk" %}
{% endblock %}