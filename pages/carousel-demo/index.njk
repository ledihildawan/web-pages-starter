{% extends "main.njk" %}
{% import "shared/ui/icons.njk" as icon %}
{% import "shared/ui/responsive-image.njk" as responsive_image %}

{% block content %}
<section class="relative min-block-screen overflow-hidden">
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="absolute inset-bs-0 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 inline-[150%] block-[150%] bg-[radial-gradient(circle_at_top,var(--tw-gradient-stops))] from-violet-600/20 via-fuchsia-600/10 to-transparent blur-3xl"></div>
    <div class="absolute inset-bs-[10%] inset-s-[10%] inline-96 block-96 bg-violet-600/10 blur-[100px]"></div>
  </div>

  <div class="max-inline-7xl mx-auto pbs-52 pbe-28 px-6">
    <div class="text-center mbe-16">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white mbe-8 tracking-tighter leading-[1.1]">
        {{ i18n.t('carousel-demo:hero.slide_1.title') }}
      </h1>
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-300 max-inline-3xl mx-auto mbe-16 leading-relaxed font-medium">
        {{ i18n.t('carousel-demo:hero.slide_1.subtitle') }}
      </p>
    </div>

    <div id="main-carousel" class="splide" aria-label="Carousel Demo">
      <div class="splide__track">
        <ul class="splide__list">
          <li class="splide__slide">
            {{ responsive_image.render(images['carousel-1'], i18n.t('carousel-demo:hero.slide_1.alt', {}, {raw: true}), "(min-width: 800px) 800px, 100vw", loading="eager", fetchpriority="high", lcp=true) }}
          </li>
          <li class="splide__slide">
            {{ responsive_image.render(images['carousel-2'], i18n.t('carousel-demo:hero.slide_2.alt', {}, {raw: true}), "(min-width: 800px) 800px, 100vw", loading="lazy") }}
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{% include "shared/layout/cta.njk" %}
{% endblock %}
