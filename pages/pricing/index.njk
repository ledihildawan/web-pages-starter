{% extends "@layouts/main.njk" %}
{% import "@shared/ui/composites/hero-section.njk" as hero %}
{% import "@shared/ui/composites/section-header.njk" as section %}
{% import "@shared/ui/primitives/icons.njk" as icon %}

{% block content %}
  <div x-data="{ yearly: false }">
    {% set hero_key = 'pricing:hero' %}
    {{
      hero.hero_section(
        i18n.t(hero_key ~ '.badge'),
        i18n.t(hero_key ~ '.title_part1'),
        i18n.t(hero_key ~ '.title_highlight'),
        i18n.t(hero_key ~ '.description'),
        h1=page.meta.h1
      )
    }}

    <div class="pbe-40 px-6">
      <div class="max-inline-lg mx-auto">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 p-6 bg-slate-900/40 backdrop-blur-xl radius-card-md border border-white/10">
          <span
            class="text-sm font-bold uppercase tracking-[0.15em] transition-[color,scale] duration-200"
            :class="!yearly ? 'text-slate-400' : 'text-white scale-105'">
            {{ i18n.t('pricing:toggle.monthly') }}
          </span>
          <button
            type="button" @click="yearly = !yearly" role="switch"
            :aria-checked="yearly.toString()"
            aria-label="{{ i18n.t('pricing:toggle.aria_label', {}, {raw: true}) }}"
            class="toggle-btn group relative inline-16 block-11 bg-slate-800 rounded-full transition-[border-color,scale,box-shadow] duration-200 border border-white/10 cursor-pointer hover:border-violet-500/50 hover:scale-105 shadow-lg btn-squash icon-squash anticipate-press"
            :class="yearly ? 'border-violet-500/50 toggle-active' : ''">
            <div
              class="absolute inset-0 bg-linear-to-r from-violet-500/20 to-fuchsia-500/20 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200"
              :class="yearly ? 'opacity-100' : ''">
            </div>
            <div class="absolute inset-0 flex items-center px-1.5">
              <div
                class="toggle-knob inline-5 block-5 bg-linear-to-br rounded-full shadow transition-[background,box-shadow] duration-200 ease-emphasized"
                :class="yearly ? 'from-violet-400 to-fuchsia-400 toggle-knob-active toggle-knob-pos-end' : 'from-white to-slate-200 toggle-knob-pos-start'">
              </div>
            </div>
          </button>
          <div class="flex items-center gap-3">
            <span
              class="text-sm font-bold uppercase tracking-[0.15em] transition-[color,scale] duration-200"
              :class="yearly ? 'text-white scale-105' : 'text-slate-400'">
              {{ i18n.t('pricing:toggle.yearly') }}
            </span>
            <span
              class="px-4 py-2 text-[11px] font-black rounded-full border shadow-[0_0_20px_rgba(16,185,129,0.2)] transition-[background,color,border-color,box-shadow,scale] duration-200"
              :class="yearly ? 'bg-linear-to-r from-emerald-500/30 to-emerald-500/20 text-emerald-300 border-emerald-500/50 shadow-[0_0_30px_rgba(16,185,129,0.4)] scale-110' : 'bg-linear-to-r from-emerald-500/10 to-emerald-500/5 text-emerald-400/60 border-emerald-500/20'">
              {{ i18n.t('pricing:toggle.discount') }}
            </span>
          </div>
        </div>
      </div>
    </div>

    <section class="pbe-40 px-6" aria-labelledby="plans-heading">
      <h2 id="plans-heading" class="sr-only">{{ i18n.t('pricing:plans.section_title') }}</h2>
      <div class="max-inline-7xl mx-auto grid md:grid-cols-3 gap-8 items-stretch">
        {% for plan in page.plans %}
          {% set plan_key = 'pricing:plans.' ~ plan.id %}
          {% set plan_badge_key = plan_key ~ '.badge' %}
          {% set plan_name_key = plan_key ~ '.name' %}
          {% set plan_desc_key = plan_key ~ '.desc' %}
          {% set plan_btn_key = plan_key ~ '.btn' %}
          <div
            class="
              spotlight-card card-border-glow card-squash group relative {% if plan.featured %}p-12 lg:p-14 bg-linear-to-br from-violet-900/40 to-slate-900/60 border border-violet-500/40 shadow-[0_25px_60px_rgba(139,92,246,0.25)] md:-translate-y-8 z-10 hover:shadow-[0_30px_80px_rgba(139,92,246,0.35)] hover:-translate-y-10
              {% else %}p-10 lg:p-12 bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border card-border-hover backdrop-blur-xl hover:shadow-[0_20px_50px_rgba(0,0,0,0.3)] hover:-translate-y-2
              {% endif %} radius-card-lg flex flex-col transition-[transform,box-shadow] duration-250 ease-emphasized hover-lift overflow-hidden
            ">
            {% if plan.featured %}
              <div class="absolute -inset-bs-6 inset-s-1/2 ltr:-translate-x-1/2 rtl:translate-x-1/2 px-6 py-2.5 bg-linear-to-r from-violet-500 via-fuchsia-500 to-pink-500 rounded-full text-[10px] font-black text-white uppercase tracking-[0.2em] shadow-[0_10px_30px_rgba(139,92,246,0.4)] whitespace-nowrap">
                {{ i18n.t(plan_badge_key) }}
              </div>
            {% endif %}

            <h3 class="text-xs font-black uppercase tracking-[0.2em] mbe-8 {% if plan.featured %}text-violet-300{% else %}text-slate-400 group-hover:text-slate-400{% endif %} transition-colors duration-200">
              {{ i18n.t(plan_name_key) }}
            </h3>

            <div class="mbe-6">
              <div class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-black leading-[1.1] tracking-tight tabular-nums word-break-all {% if plan.featured %}text-white{% else %}text-slate-200{% endif %} mbe-1">
                <span x-show="!yearly">{{ i18n.formatLocalPrice(plan) }}</span>
                <span x-show="yearly">{{ i18n.formatLocalPriceDiscounted(plan, 0.8) }}</span>
              </div>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-slate-400 font-bold text-xs sm:text-sm">/{{
                    i18n.t('pricing:period_monthly')
                  }}</span>
                <span
                  x-show="yearly" class="text-[10px] sm:text-xs text-violet-400 font-semibold">{{
                  i18n.t('pricing:toggle.yearly_hint')
                }}</span>
              </div>
            </div>

            <p class="text-slate-400 mbe-10 leading-relaxed font-medium">
              {{ i18n.t(plan_desc_key) }}
            </p>

            <div class="block-px inline-full bg-linear-to-r from-transparent via-white/10 to-transparent mbe-10">
            </div>

            <ul class="space-y-5 grow mbe-12">
              {% for i in range(0, plan.feature_count) %}
                {% set plan_feat_key = plan_key ~ '.feature_' ~ i %}
                <li class="flex items-start gap-4 text-sm {% if plan.featured %}text-slate-200{% else %}text-slate-400{% endif %} group/icon">
                  <div class="mbs-1 flex-none inline-5.5 block-5.5 rounded-full bg-{{ 'violet-500/20' if plan.featured else 'white/5' }} flex items-center justify-center border border-{{ 'violet-500/30' if plan.featured else 'white/10' }} group-hover/icon:scale-110 group-hover/icon:rotate-12 transition-[transform] duration-200">
                    {{
                      icon.icon('check', 'inline-3.5 block-3.5 text-' ~ ('violet-400' if plan.featured else 'slate-500'), size='md')
                    }}
                  </div>
                  <span class="font-medium leading-tight">{{ i18n.t(plan_feat_key) }}</span>
                </li>
              {% endfor %}
            </ul>

            <a
              href="{{ url('/contact') }}"
              class="
                magnetic-btn btn-press btn-squash anticipate-press hover-lift ripple-click sparkle-hover group relative flex items-center justify-center inline-full min-block-16 pl-8 pr-[30px] py-4 radius-btn font-black text-lg transition-[background,border-color,scale,box-shadow] duration-200 ease-emphasized overflow-hidden
                {% if plan.featured %}
                bg-linear-to-r from-violet-500 via-fuchsia-500 to-pink-500 text-white shadow-[0_15px_35px_rgba(139,92,246,0.4)] hover:shadow-[0_20px_50px_rgba(139,92,246,0.5)] hover:scale-105
                {% else %}
                bg-slate-800 text-white border border-white/10 hover:bg-slate-700 hover:border-white/20
                {% endif %}
              ">
              {% if plan.featured %}
                <span
                  class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
              {% endif %}
              <span class="relative flex items-center gap-2">
                {{ i18n.t(plan_btn_key) }}
                {{
                  icon.icon('arrow-right', 'inline-5 block-5 icon-transition group-hover:translate-x-1', size='md')
                }}
              </span>
            </a>
          </div>
        {% endfor %}
      </div>
    </section>

    <section class="pbs-40 pbe-40 px-6 relative bg-linear-to-b from-white/2 to-transparent border-bs border-be border-white/5">
      <div class="max-inline-6xl mx-auto">
        {{
          section.section_header(
            i18n.t('pricing:faq.title'),
            i18n.t('pricing:faq.title'),
            i18n.t('pricing:faq.subtitle'),
            icon.icon('question', 'inline-4 block-4')
          )
        }}

        <div class="grid gap-5">
          {% for i in range(0, page.faq_count) %}
            {% set q_key = 'pricing:faq.q_' ~ i %}
            {% set a_key = 'pricing:faq.a_' ~ i %}
            <div class="spotlight-card card-border-glow card-squash group p-8 lg:p-10 radius-card-lg bg-linear-to-br from-slate-900/60 to-slate-900/40 card-border card-border-hover hover:shadow-[0_15px_40px_rgba(0,0,0,0.3)] transition-[transform,box-shadow,border-color] duration-250 ease-emphasized overflow-hidden backdrop-blur-xl hover-lift cursor-default">
              <h3 class="text-xl lg:text-2xl font-black text-white mbe-5 flex items-start gap-5">
                <span class="text-gradient-violet-fuchsia-br font-mono text-sm mbs-1.5">{{
                  i18n.formatNumber(i + 1, { nativeDigits: true })
                }}</span>
                <span class="grow group-hover:text-slate-200 transition-colors duration-300">{{
                  i18n.t(q_key)
                }}</span>
              </h3>
              <p class="text-slate-400 leading-relaxed pis-14 font-medium group-hover:text-slate-300 transition-colors duration-300">
                {{ i18n.t(a_key) }}
              </p>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  </div>

  {% include "@shared/ui/composites/cta.njk" %}
{% endblock %}
