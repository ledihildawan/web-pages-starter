<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>CORE-65 | Dual-Fade Infinite Scroll</title>
        <style>
            /* --- 0. PREMIUM FONT IMPORT --- */
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=JetBrains+Mono:wght@700;800&display=swap');

            /* --- 1. CSS RESET & GLOBAL --- */
            *,
            *::after,
            *::before {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }

            :root {
                --u: 52px;
                --gap: 4px;
                --radius-key: 6px;
                --radius-case: 32px;

                /* Theme Light */
                --bg-canvas: #f0f2f5;
                --mesh-1: #e2e8f0;
                --mesh-2: #cbd5e1;
                --mesh-3: #94a3b8;

                --text-ghost: rgba(0, 0, 0, 0.08);
                --caret-color: rgba(0, 0, 0, 0.5);
                --selection-bg: rgba(0, 0, 0, 0.15);
                --selection-fg: rgba(0, 0, 0, 0.6);

                --mat-case-base: oklch(0.85 0.01 240);
                --mat-case-slope: oklch(0.9 0.01 240);
                --mat-case-bezel: oklch(0.96 0.01 240);
                --mat-plate-inner: oklch(0.7 0.02 240);

                --key-alpha-base: oklch(0.88 0.01 240);
                --key-alpha-top: oklch(0.98 0.01 240);
                --key-alpha-fg: oklch(0.25 0.05 240);
                --key-mod-base: oklch(0.8 0.08 240);
                --key-mod-top: oklch(0.88 0.1 240);
                --key-mod-fg: oklch(0.25 0.05 240);
                --key-accent-base: oklch(0.2 0.12 255);
                --key-accent-top: oklch(0.3 0.12 255);
                --key-accent-fg: oklch(0.98 0.01 240);

                --led-active: oklch(0.6 0.2 250);
                --label-stealth: oklch(0.6 0.01 240);
            }

            [data-theme="dark"] {
                --bg-canvas: #0a0c10;
                --mesh-1: #1a1c24;
                --mesh-2: #0f172a;
                --mesh-3: #1e293b;

                --text-ghost: rgba(255, 255, 255, 0.05);
                --caret-color: rgba(255, 255, 255, 0.6);
                --selection-bg: rgba(255, 255, 255, 0.15);
                --selection-fg: rgba(255, 255, 255, 0.8);

                --mat-case-base: oklch(0.12 0.02 240);
                --mat-case-slope: oklch(0.18 0.02 240);
                --mat-case-bezel: oklch(0.28 0.02 240);
                --mat-plate-inner: oklch(0.08 0.02 240);
                --key-alpha-base: oklch(0.35 0.03 240);
                --key-alpha-top: oklch(0.42 0.03 240);
                --key-alpha-fg: oklch(0.95 0.01 240);
                --key-mod-base: oklch(0.25 0.08 240);
                --key-mod-top: oklch(0.32 0.1 240);
                --key-mod-fg: oklch(0.95 0.01 240);
                --key-accent-base: oklch(0.1 0.1 255);
                --key-accent-top: oklch(0.18 0.1 255);
                --key-accent-fg: oklch(0.9 0.05 240);
                --led-active: oklch(0.9 0.1 190);
                --label-stealth: oklch(0.4 0.01 240);
            }

            body {
                background-color: var(--bg-canvas);
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                overflow: hidden;
                text-rendering: optimizeLegibility;
            }

            /* --- CIRCULAR TRANSITION API --- */
            ::view-transition-new(root),
            ::view-transition-old(root) {
                animation: none;
                mix-blend-mode: normal;
            }
            ::view-transition-old(root) {
                z-index: 1;
            }
            ::view-transition-new(root) {
                z-index: 2;
            }

            .bg-studio {
                position: fixed;
                inset: 0;
                z-index: -2;
                background: radial-gradient(at 50% 0%, var(--mesh-1) 0px, transparent 50%), radial-gradient(at 100% 0%, var(--mesh-2) 0px, transparent 50%), radial-gradient(at 0% 100%, var(--mesh-3) 0px, transparent 50%);
                filter: blur(60px);
                opacity: 0.5;
            }

            /* --- 2. LAYER MASKING & SCROLLING --- */
            #mask-wrapper {
                position: fixed;
                inset: 0;
                z-index: 1;
                pointer-events: none;
                -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
                mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
            }

            #bg-scroller {
                position: absolute;
                inset: 0;
                overflow-y: auto;
                pointer-events: auto;
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
            #bg-scroller::-webkit-scrollbar {
                display: none;
            }

            /* CSS GRID TRICK & TYPOGRAPHY OPTIMIZATION */
            #editor-wrapper {
                display: grid;
                width: 100%;
                margin-top: 15vh;
                margin-bottom: 40vh;
                padding: 0 5vw;
            }

            #editor-wrapper::after {
                content: attr(data-replicated-value) " ";
                white-space: pre-wrap;
                word-break: break-word;
                visibility: hidden;
                grid-area: 1 / 1 / 2 / 2;
                font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
                font-weight: 800;
                font-size: 6vw;
                line-height: 1.35;
                letter-spacing: -0.03em;
            }

            #editor {
                width: 100%;
                height: 100%;
                grid-area: 1 / 1 / 2 / 2;
                background: transparent;
                border: none;
                outline: none;
                resize: none;
                font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
                font-weight: 800;
                font-size: 6vw;
                line-height: 1.35;
                letter-spacing: -0.03em;
                color: var(--text-ghost);
                caret-color: var(--caret-color);
                overflow: hidden;
            }
            #editor::placeholder {
                color: var(--text-ghost);
                opacity: 0.5;
                transition: opacity 0.3s ease;
            }
            #editor:focus::placeholder {
                opacity: 0.2;
            }
            #editor::selection {
                background-color: var(--selection-bg);
                color: var(--selection-fg);
            }

            /* --- 3. CHASSIS --- */
            .chassis-housing {
                background-color: var(--mat-case-base);
                padding: 10px;
                border-radius: var(--radius-case);
                position: absolute;
                top: 75%;
                left: 50%;
                transform: translate(-50%, -50%);
                box-shadow: 0 0 80px rgba(0,0,0,0.2), 0 20px 40px rgba(0,0,0,0.4);
                z-index: 10;
                pointer-events: auto;
                cursor: grab;
                will-change: transform;
                user-select: none;
            }
            .chassis-housing:active {
                cursor: grabbing;
            }

            .angled-slope {
                background-color: var(--mat-case-slope);
                padding: 8px;
                border-radius: 26px;
                box-shadow: inset 0 0 12px rgba(0,0,0,0.1);
            }
            .bezel-frame {
                background-color: var(--mat-case-bezel);
                padding: 12px 16px;
                border-radius: 20px;
                position: relative;
                box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            }
            .inner-plate {
                background-color: var(--mat-plate-inner);
                padding: 8px;
                border-radius: 10px;
                box-shadow: inset 0 0 20px rgba(0,0,0,0.45);
                overflow: hidden;
            }
            .row {
                display: flex;
                gap: var(--gap);
                margin-bottom: var(--gap);
            }
            .row:last-child {
                margin-bottom: 0;
            }

            /* KEYCAPS */
            .key {
                height: 52px;
                position: relative;
                border: none;
                cursor: pointer;
                outline: none;
                border-radius: var(--radius-key);
                background-color: var(--key-base);
                overflow: visible;
                transition: transform 0.05s ease;
                transform-style: preserve-3d;
                user-select: none;
                touch-action: none;
            }
            .key-top {
                position: absolute;
                top: 5px;
                left: 5px;
                right: 5px;
                bottom: 5px;
                border-radius: calc(var(--radius-key) - 2px);
                background-color: var(--key-top);
                color: var(--key-fg);
                font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
                box-shadow: inset 0 0 4px rgba(0,0,0,0.06);
                z-index: 2;
                transition: all 0.05s ease;
            }

            /* --- 7-WAY SEVEN DOT POSITION ENGINE --- */
            .legend-item {
                position: absolute;
                font-weight: 800;
                text-shadow: 0 1px 1px rgba(255,255,255,0.1);
                white-space: nowrap;
            }

            .loc-tl {
                top: 6px;
                left: 8px;
                text-align: left;
            }
            .loc-tr {
                top: 6px;
                right: 8px;
                text-align: right;
            }
            .loc-bl {
                bottom: 6px;
                left: 8px;
                text-align: left;
            }
            .loc-br {
                bottom: 6px;
                right: 8px;
                text-align: right;
            }

            /* Sumbu Tengah Baru Berbasis TranslateY */
            .loc-cl {
                top: 50%;
                left: 8px;
                transform: translateY(-50%);
                text-align: left;
            }
            .loc-cr {
                top: 50%;
                right: 8px;
                transform: translateY(-50%);
                text-align: right;
            }

            /* Titik Pusat Absolut */
            .loc-c {
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                text-align: center;
            }

            .type-alpha {
                --key-base: var(--key-alpha-base);
                --key-top: var(--key-alpha-top);
                --key-fg: var(--key-alpha-fg);
            }
            .type-mod {
                --key-base: var(--key-mod-base);
                --key-top: var(--key-mod-top);
                --key-fg: var(--key-mod-fg);
            }
            .type-accent {
                --key-base: var(--key-accent-base);
                --key-top: var(--key-accent-top);
                --key-fg: var(--key-accent-fg);
            }

            .key.active {
                transform: scale(0.97);
            }
            .key.active .key-top {
                filter: brightness(0.9);
            }

            .key.alt-active .key-top,
            .key.ctrl-active .key-top,
            .key.fn-active .key-top,
            .key.shift-active .key-top {
                background-color: var(--led-active);
                color: var(--bg-canvas);
                box-shadow: inset 0 0 10px rgba(255,255,255,0.2);
            }

            /* INDICATOR */
            .indicator-plate {
                position: absolute;
                left: 6px;
                top: 38px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 3px;
            }
            .led-line {
                width: 8px;
                height: 2px;
                border-radius: 1px;
                background-color: oklch(from var(--mat-case-bezel) calc(l - 0.3) c h);
            }
            .caps-on .led-line {
                background-color: var(--led-active);
                box-shadow: 0 0 10px var(--led-active);
            }
            .led-label {
                font-size: 7px;
                font-weight: 900;
                color: var(--label-stealth);
                font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
                opacity: 0.6;
            }

            /* UTILS */
            .w-1u {
                width: var(--u);
            }
            .w-1-25u {
                width: calc(var(--u) * 1.25 + var(--gap) * 0.25);
            }
            .w-1-5u {
                width: calc(var(--u) * 1.5 + var(--gap) * 0.5);
            }
            .w-1-75u {
                width: calc(var(--u) * 1.75 + var(--gap) * 0.75);
            }
            .w-2u {
                width: calc(var(--u) * 2 + var(--gap));
            }
            .w-2-25u {
                width: calc(var(--u) * 2.25 + var(--gap) * 1.25);
            }
            .w-flex {
                flex: 1;
            }

            /* --- USER PROFILE BADGE --- */
            .profile-badge {
                position: fixed;
                top: 30px;
                right: 30px;
                width: 48px;
                height: 48px;
                border-radius: 50%;
                overflow: visible;
                z-index: 100;
                box-shadow: 0 10px 30px rgba(0,0,0,0.2);
                border: 2px solid var(--mat-case-bezel);
                background-color: var(--mat-case-base);
                text-decoration: none;
                transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .profile-badge img {
                width: 100%;
                height: 100%;
                border-radius: 50%;
                object-fit: cover;
                pointer-events: none;
            }
            .profile-badge::after {
                content: "@ledihildawan";
                position: absolute;
                right: calc(100% + 12px);
                top: 50%;
                transform: translateY(-50%) translateX(10px);
                background: var(--mat-case-bezel);
                color: var(--key-alpha-fg);
                padding: 6px 12px;
                border-radius: 20px;
                font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
                font-size: 11px;
                font-weight: 800;
                opacity: 0;
                pointer-events: none;
                transition: all 0.3s ease;
                white-space: nowrap;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            }
            .profile-badge:hover {
                transform: scale(1.1) translateY(-2px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.3);
                border-color: var(--led-active);
            }
            .profile-badge:hover::after {
                opacity: 1;
                transform: translateY(-50%) translateX(0);
            }

            /* --- RGB AURORA & REACTIVE STRIKE --- */
            .key::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: inherit;
                z-index: -1;
                opacity: 0;
                transition: opacity 0.6s ease;
            }

            @keyframes aurora-flow {
                0% {
                    box-shadow: 0 0 10px 1px oklch(0.70 0.18 240 / 0.5);
                }
                50% {
                    box-shadow: 0 0 10px 1px oklch(0.65 0.22 280 / 0.5);
                }
                100% {
                    box-shadow: 0 0 10px 1px oklch(0.75 0.15 190 / 0.5);
                }
            }

            body.rgb-on .key::before {
                opacity: 1;
                animation: aurora-flow 5s infinite alternate ease-in-out;
                animation-delay: var(--delay);
            }

            .key::after {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: inherit;
                z-index: -1;
                opacity: 0;
                box-shadow: 0 0 12px 1px oklch(0.9 0.1 180 / 0.8), 0 0 6px 1px oklch(0.9 0.1 180 / 0.5) inset;
                transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            }

            body.rgb-on .key.active::after {
                opacity: 1;
                transition: opacity 0.02s ease-out;
            }
        </style>
    </head>
    <body>

        <div class="bg-studio"></div>

        <div id="mask-wrapper">
            <div id="bg-scroller">
                <div id="editor-wrapper" data-replicated-value="">
                    <textarea id="editor" spellcheck="false" autofocus="autofocus" placeholder="Type anything here..."></textarea>
                </div>
            </div>
        </div>

        <a href="https://github.com/ledihildawan" target="_blank" rel="noopener noreferrer" class="profile-badge">
            <img src="https://github.com/ledihildawan.png" alt="@ledihildawan"/>
        </a>

        <div class="chassis-housing" id="main-shell">
            <div class="angled-slope">
                <div class="bezel-frame">
                    <div class="indicator-plate" id="caps-group">
                        <div class="led-line"></div>
                        <div class="led-label">C</div>
                    </div>
                    <div class="inner-plate">
                        <div id="kb-case"></div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // --- STATE PERSISTENCE ---
            const savedTheme = localStorage.getItem('kb-theme') || 'dark';
            document
                .body
                .setAttribute('data-theme', savedTheme);

            const isRgbOn = localStorage.getItem('kb-rgb') === 'true';
            if (isRgbOn) 
                document
                    .body
                    .classList
                    .add('rgb-on');
            
            const capsGroup = document.getElementById('caps-group');
            let isCapsOn = localStorage.getItem('kb-caps') === 'true';
            if (isCapsOn) 
                capsGroup
                    .classList
                    .add('caps-on');
            
            function updateCapsState(state) {
                if (isCapsOn !== state) {
                    isCapsOn = state;
                    capsGroup
                        .classList
                        .toggle('caps-on', isCapsOn);
                    localStorage.setItem('kb-caps', isCapsOn);
                }
            }

            let initialTranslateX = parseFloat(localStorage.getItem('kb-x')) || 0;
            let initialTranslateY = parseFloat(localStorage.getItem('kb-y')) || 0;
            const mainShell = document.getElementById('main-shell');
            mainShell.style.transform = `translate(calc(-50% + ${initialTranslateX}px), calc(-50% + ${initialTranslateY}px))`;

            // --- GLOBAL MOUSE TRACKER ---
            let mouseX = window.innerWidth / 2;
            let mouseY = window.innerHeight / 2;

            window.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            window.addEventListener('touchstart', (e) => {
                if (e.touches.length > 0) {
                    mouseX = e
                        .touches[0]
                        .clientX;
                    mouseY = e
                        .touches[0]
                        .clientY;
                }
            });

            // --- EDITOR LOGIC ---
            const editor = document.getElementById('editor');
            const editorWrapper = document.getElementById('editor-wrapper');
            const bgScroller = document.getElementById('bg-scroller');

            const savedText = localStorage.getItem('kb-text') || '';
            editor.value = savedText;

            function updateEditorSize() {
                editorWrapper.dataset.replicatedValue = editor.value;
                localStorage.setItem('kb-text', editor.value);
            }
            editor.addEventListener('input', updateEditorSize);
            updateEditorSize();

            function insertTextAtCursor(text) {
                const start = editor.selectionStart;
                const end = editor.selectionEnd;
                editor.value = editor
                    .value
                    .substring(0, start) + text + editor
                    .value
                    .substring(end);
                editor.selectionStart = editor.selectionEnd = start + text.length;
                updateEditorSize();
            }

            function deleteAtCursor() {
                const start = editor.selectionStart;
                const end = editor.selectionEnd;
                if (start === end && start > 0) {
                    editor.value = editor
                        .value
                        .substring(0, start - 1) + editor
                        .value
                        .substring(end);
                    editor.selectionStart = editor.selectionEnd = start - 1;
                } else if (start !== end) {
                    editor.value = editor
                        .value
                        .substring(0, start) + editor
                        .value
                        .substring(end);
                    editor.selectionStart = editor.selectionEnd = start;
                }
                updateEditorSize();
            }

            function deleteForwardAtCursor() {
                const start = editor.selectionStart;
                const end = editor.selectionEnd;
                if (start === end && start < editor.value.length) {
                    editor.value = editor
                        .value
                        .substring(0, start) + editor
                        .value
                        .substring(start + 1);
                    editor.selectionStart = editor.selectionEnd = start;
                } else if (start !== end) {
                    editor.value = editor
                        .value
                        .substring(0, start) + editor
                        .value
                        .substring(end);
                    editor.selectionStart = editor.selectionEnd = start;
                }
                updateEditorSize();
            }

            function moveCursor(dir) {
                if (dir === 'left') 
                    editor.selectionStart = editor.selectionEnd = Math.max(0, editor.selectionStart - 1);
                else if (dir === 'right') 
                    editor.selectionStart = editor.selectionEnd = Math.min(editor.value.length, editor.selectionStart + 1);
                else if (dir === 'start') 
                    editor.selectionStart = editor.selectionEnd = 0;
                else if (dir === 'end') 
                    editor.selectionStart = editor.selectionEnd = editor.value.length;
                }
            
            window.addEventListener('click', (e) => {
                if (!e.target.closest('#main-shell') && !e.target.closest('.profile-badge')) {
                    editor.focus();
                }
            });

            // --- THEME TOGGLE (CIRCULAR TRANSITION) ---
            function toggleThemeWithTransition(x, y) {
                if (!document.startViewTransition) {
                    toggleTheme();
                    return;
                }

                const endRadius = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));

                const transition = document.startViewTransition(() => {
                    toggleTheme();
                });

                transition
                    .ready
                    .then(() => {
                        document
                            .documentElement
                            .animate([
                                {
                                    clipPath: `circle(0px at ${x}px ${y}px)`
                                }, {
                                    clipPath: `circle(${endRadius}px at ${x}px ${y}px)`
                                }
                            ], {
                                duration: 600,
                                easing: "cubic-bezier(0.4, 0, 0.2, 1)",
                                pseudoElement: "::view-transition-new(root)"
                            });
                    });
            }

            function toggleTheme() {
                const current = document
                    .body
                    .getAttribute('data-theme');
                const next = current === 'light'
                    ? 'dark'
                    : 'light';
                document
                    .body
                    .setAttribute('data-theme', next);
                localStorage.setItem('kb-theme', next);
            }

            // --- AUDIO LOGIC ---
            const audioCtx = new(window.AudioContext || window.webkitAudioContext)();
            function playThock(isSpace = false) {
                if (audioCtx.state === 'suspended') 
                    audioCtx.resume();
                const now = audioCtx.currentTime;
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                const filter = audioCtx.createBiquadFilter();

                osc.type = 'triangle';
                osc
                    .frequency
                    .setValueAtTime(
                        isSpace
                        ? 70
                        : 105,
                    now);
                osc
                    .frequency
                    .exponentialRampToValueAtTime(30, now + 0.1);

                filter.type = 'lowpass';
                filter.frequency.value = isSpace
                    ? 300
                    : 550;

                gain
                    .gain
                    .setValueAtTime(0.2, now);
                gain
                    .gain
                    .exponentialRampToValueAtTime(0.01, now + 0.12);

                osc.connect(filter);
                filter.connect(gain);
                gain.connect(audioCtx.destination);

                osc.start();
                osc.stop(now + 0.12);
            }

            // --- LAYOUT DATA ---
            const layoutData = [
                [
                    {
                        code: 'Escape',
                        type: 'type-accent',
                        width: 'w-1u',
                        legends: [
                            {
                                text: 'ESC',
                                position: 'loc-c',
                                size: '10px'
                            }
                        ]
                    }, {
                        code: 'Digit1',
                        type: 'type-alpha',
                        width: 'w-1u',
                        legends: [
                            {
                                text: '1',
                                position: 'loc-bl',
                                size: '13px'
                            }, {
                                text: '!',
                                position: 'loc-tl',
                                size: '9px',
