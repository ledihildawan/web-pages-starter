                            }
                        ]
                    }, {
                        code: 'ControlRight',
                        type: 'type-mod',
                        width: 'w-1u',
                        legends: [
                            {
                                text: 'CTRL',
                                position: 'loc-c',
                                size: '10px'
                            }
                        ]
                    }, {
                        code: 'ArrowLeft',
                        type: 'type-alpha',
                        width: 'w-1u',
                        legends: [
                            {
                                text: '◀',
                                position: 'loc-c',
                                size: '13px'
                            }
                        ]
                    }, {
                        code: 'ArrowDown',
                        type: 'type-alpha',
                        width: 'w-1u',
                        legends: [
                            {
                                text: '▼',
                                position: 'loc-c',
                                size: '13px'
                            }
                        ]
                    }, {
                        code: 'ArrowRight',
                        type: 'type-alpha',
                        width: 'w-1u',
                        legends: [
                            {
                                text: '▶',
                                position: 'loc-c',
                                size: '13px'
                            }
                        ]
                    }
                ]
            ];

            const container = document.getElementById('kb-case');
            let keyIndex = 0;

            let isVirtualShiftActive = false;
            let isVirtualFnActive = false;
            let isVirtualCtrlActive = false;
            let isVirtualAltActive = false;

            const getLoc = (pos, defaultPos) => pos
                ? pos
                : defaultPos;

            layoutData.forEach(row => {
                const rowDiv = document.createElement('div');
                rowDiv.className = 'row';

                row.forEach(key => {
                    const btn = document.createElement('button');
                    btn.className = `key ${key.type} ${key.width}`;
                    btn.id = key.code;

                    btn
                        .style
                        .setProperty('--delay', `${keyIndex * -0.05}s`);
                    keyIndex++;

                    const top = document.createElement('div');
                    top.className = 'key-top';

                    if (key.legends && key.legends.length > 0) {
                        key
                            .legends
                            .forEach(legend => {
                                const span = document.createElement('span');
                                span.className = `legend-item ${legend.position}`;
                                span.innerText = legend.text;

                                if (legend.size) 
                                    span.style.fontSize = legend.size;
                                if (legend.color) 
                                    span.style.color = legend.color;
                                
                                top.appendChild(span);
                            });
                    }

                    btn.appendChild(top);
                    rowDiv.appendChild(btn);

                    let repeatInterval,
                        repeatTimeout;

                    const stopRepeat = () => {
                        clearTimeout(repeatTimeout);
                        clearInterval(repeatInterval);
                        handleRelease(key.code);
                    };

                    btn.addEventListener('pointerdown', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        editor.focus();
                        handleVirtualPress(key);

                        const nonRepeatKeys = [
                            'ShiftLeft',
                            'ShiftRight',
                            'Fn',
                            'AltLeft',
                            'AltRight',
                            'ControlLeft',
                            'ControlRight',
                            'MetaLeft'
                        ];
                        if (!nonRepeatKeys.includes(key.code)) {
                            repeatTimeout = setTimeout(() => {
                                repeatInterval = setInterval(() => {
                                    handleVirtualPress(key);
                                }, 80);
                            }, 400);
                        }
                    });

                    btn.addEventListener('pointerup', stopRepeat);
                    btn.addEventListener('pointerleave', stopRepeat);
                    btn.addEventListener('pointercancel', stopRepeat);
                });
                container.appendChild(rowDiv);
            });

            function resetVirtualModifiers() {
                isVirtualShiftActive = false;
                isVirtualCtrlActive = false;
                isVirtualAltActive = false;

                document
                    .querySelectorAll('.key')
                    .forEach(el => {
                        el
                            .classList
                            .remove('shift-active', 'ctrl-active', 'alt-active', 'active');
                    });
            }

            window.addEventListener('blur', () => {
                resetVirtualModifiers();
                isVirtualFnActive = false;
                if (document.getElementById('Fn')) 
                    document
                        .getElementById('Fn')
                        .classList
                        .remove('fn-active');
                }
            );
            window.addEventListener('focus', () => {
                resetVirtualModifiers();
            });

            // --- VIRTUAL TYPING LOGIC ---
            function handleVirtualPress(key) {
                const code = key.code;
                const el = document.getElementById(code);

                if (el) {
                    if (!el.classList.contains('active')) 
                        el
                            .classList
                            .add('active');
                    playThock(code === 'Space');

                    if (code === 'Backspace') 
                        deleteAtCursor();
                    else if (code === 'Delete') 
                        deleteForwardAtCursor();
                    else if (code === 'Enter') 
                        insertTextAtCursor("\n");
                    else if (code === 'Space') 
                        insertTextAtCursor(" ");
                    else if (code === 'Tab') 
                        insertTextAtCursor("\t");
                    else if (code === 'ArrowLeft') 
                        moveCursor('left');
                    else if (code === 'ArrowRight') 
                        moveCursor('right');
                    else if (code === 'ArrowUp' || code === 'PageUp' || code === 'Home') 
                        moveCursor('start');
                    else if (code === 'ArrowDown' || code === 'PageDown') 
                        moveCursor('end');
                    else if (code === 'CapsLock') {
                        updateCapsState(!isCapsOn);
                    } else if (code === 'Fn') {
                        isVirtualFnActive = !isVirtualFnActive;
                        document
                            .getElementById('Fn')
                            .classList
                            .toggle('fn-active', isVirtualFnActive);
                        return;
                    } else if (code === 'ShiftLeft' || code === 'ShiftRight') {
                        isVirtualShiftActive = !isVirtualShiftActive;
                        document
                            .getElementById('ShiftLeft')
                            .classList
                            .toggle('shift-active', isVirtualShiftActive);
                        document
                            .getElementById('ShiftRight')
                            .classList
                            .toggle('shift-active', isVirtualShiftActive);
                        return;
                    } else if (code === 'ControlLeft' || code === 'ControlRight') {
                        isVirtualCtrlActive = !isVirtualCtrlActive;
                        document
                            .getElementById('ControlLeft')
                            .classList
                            .toggle('ctrl-active', isVirtualCtrlActive);
                        document
                            .getElementById('ControlRight')
                            .classList
                            .toggle('ctrl-active', isVirtualCtrlActive);
                        return;
                    } else if (code === 'AltLeft' || code === 'AltRight') {
                        isVirtualAltActive = !isVirtualAltActive;
                        document
                            .getElementById('AltLeft')
                            .classList
                            .toggle('alt-active', isVirtualAltActive);
                        document
                            .getElementById('AltRight')
                            .classList
                            .toggle('alt-active', isVirtualAltActive);
                        return;
                    } else if (code === 'MetaLeft') {
                        return;
                    } else {
                        // 1. Cek Kombinasi Virtual FN
                        if (isVirtualFnActive) {
                            if (code === 'KeyX') {
                                const isOn = document
                                    .body
                                    .classList
                                    .toggle('rgb-on');
                                localStorage.setItem('kb-rgb', isOn);
                            }
                            isVirtualFnActive = false;
                            document
                                .getElementById('Fn')
                                .classList
                                .remove('fn-active');
                            return;
                        }

                        // 2. Cek Kombinasi Virtual CTRL (Copy, Paste, Cut, All, Undo)
                        if (isVirtualCtrlActive) {
                            let shortcutTriggered = false;

                            if (code === 'KeyA') {
                                editor.select();
                                shortcutTriggered = true;
                            } else if (code === 'KeyC') {
                                const selectedText = editor
                                    .value
                                    .substring(editor.selectionStart, editor.selectionEnd);
                                if (selectedText) 
                                    navigator
                                        .clipboard
                                        .writeText(selectedText);
                                shortcutTriggered = true;
                            } else if (code === 'KeyX') {
                                const selectedText = editor
                                    .value
                                    .substring(editor.selectionStart, editor.selectionEnd);
                                if (selectedText) {
                                    navigator
                                        .clipboard
                                        .writeText(selectedText);
                                    deleteAtCursor();
                                }
                                shortcutTriggered = true;
                            } else if (code === 'KeyV') {
                                navigator
                                    .clipboard
                                    .readText()
                                    .then(text => {
                                        insertTextAtCursor(text);
                                    })
                                    .catch(err => console.log('Clipboard permission denied', err));
                                shortcutTriggered = true;
                            } else if (code === 'KeyZ') {
                                document.execCommand('undo');
                                updateEditorSize();
                                shortcutTriggered = true;
                            } else if (code === 'KeyY') {
                                document.execCommand('redo');
                                updateEditorSize();
                                shortcutTriggered = true;
                            }

                            if (shortcutTriggered) {
                                resetVirtualModifiers();
                                return;
                            }
                        }

                        // 3. Cek Kombinasi Virtual ALT + T
                        if (isVirtualAltActive && code === 'KeyT') {
                            toggleThemeWithTransition(mouseX, mouseY);
                            resetVirtualModifiers();
                            return;
                        }

                        // 4. Pencetakan Huruf Biasa
                        if (!isVirtualCtrlActive && !isVirtualAltActive) {
                            const shiftLegend = key
                                .legends
                                .find(l => l.isShifted);
                            const mainLegend = key
                                .legends
                                .find(l => !l.isShifted) || key
                                .legends[0];

                            let charToInsert = "";
                            if (isVirtualShiftActive && shiftLegend) {
                                charToInsert = shiftLegend.text;
                            } else if (mainLegend && mainLegend.text) {
                                charToInsert = mainLegend.text;
                                let isLetter = charToInsert.length === 1 && charToInsert.toUpperCase() !== charToInsert.toLowerCase();

                                if (isLetter) {
                                    if (isCapsOn !== isVirtualShiftActive) 
                                        charToInsert = charToInsert.toUpperCase();
                                    else 
                                        charToInsert = charToInsert.toLowerCase();
                                    }
                                else {
                                    charToInsert = charToInsert.toLowerCase();
                                }
                            }

                            if (charToInsert) {
                                insertTextAtCursor(charToInsert);
                            }
                        }

                        resetVirtualModifiers();
                    }

                    setTimeout(() => {
                        if (editor.selectionStart === editor.value.length) {
                            const scrollBehavior = (code === 'Enter')
                                ? 'smooth'
                                : 'auto';
                            bgScroller.scrollTo({top: bgScroller.scrollHeight, behavior: scrollBehavior});
                        }
                    }, 10);
                }
            }

            // --- HARDWARE KEYBOARD LOGIC ---
            window.addEventListener('keydown', e => {
                if (e.getModifierState) {
                    updateCapsState(e.getModifierState('CapsLock'));
                }

                if (e.key === 'Tab') {
                    e.preventDefault();
                    insertTextAtCursor("\t");
                }

                if (e.code === 'KeyT' && e.altKey) {
                    e.preventDefault();
                    toggleThemeWithTransition(mouseX, mouseY);

                    const el = document.getElementById(e.code);
                    if (el) 
                        el
                            .classList
                            .add('active');
                    playThock(false);
                    return;
                }

                const el = document.getElementById(e.code);
                if (el && !el.classList.contains('active')) {
                    el
                        .classList
                        .add('active');
                    playThock(e.code === 'Space');
                }

                setTimeout(() => {
                    if (editor.selectionStart === editor.value.length) {
                        const scrollBehavior = (e.code === 'Enter')
                            ? 'smooth'
                            : 'auto';
                        bgScroller.scrollTo({top: bgScroller.scrollHeight, behavior: scrollBehavior});
                    }
                }, 10);
            });

            window.addEventListener('keyup', e => {
                if (e.getModifierState) {
                    updateCapsState(e.getModifierState('CapsLock'));
                }
                handleRelease(e.code);
            });

            function handleRelease(code) {
                const el = document.getElementById(code);
                if (el) 
                    el
                        .classList
                        .remove('active');
                }
            
            // --- DRAG LOGIC ---
            let isDragging = false;
            let dragStartX,
                dragStartY;

            mainShell.addEventListener('pointerdown', (e) => {
                if (e.target.closest('.key')) 
                    return;
                
                isDragging = true;
                dragStartX = e.clientX;
                dragStartY = e.clientY;
                mainShell.setPointerCapture(e.pointerId);
            });

            mainShell.addEventListener('pointermove', (e) => {
                if (!isDragging) 
                    return;
                
                const dx = e.clientX - dragStartX;
                const dy = e.clientY - dragStartY;

                mainShell.style.transform = `translate(calc(-50% + ${initialTranslateX + dx}px), calc(-50% + ${initialTranslateY + dy}px))`;
            });

            mainShell.addEventListener('pointerup', (e) => {
                if (isDragging) {
                    isDragging = false;

                    initialTranslateX += (e.clientX - dragStartX);
                    initialTranslateY += (e.clientY - dragStartY);

                    mainShell.releasePointerCapture(e.pointerId);

                    localStorage.setItem('kb-x', initialTranslateX);
                    localStorage.setItem('kb-y', initialTranslateY);
                }
            });
        </script>
    </body>
</html>