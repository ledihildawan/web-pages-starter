        this.appEvents.on('SHEET:SET_INITIAL', () => { this.sheetY = window.innerHeight; const sheet = DOMHelper.select('.story-sheet__content'); if (sheet) { sheet.style.transition = 'none'; sheet.style.transform = `translate3d(0, ${this.sheetY}px, 0)`; } });
        this.appEvents.on('SHEET:ANIMATE_TO', ({ state, velocity = 0, onComplete }) => {
          const vh = window.innerHeight; let target = vh; if (state === 'full') target = 0; if (state === 'half') target = vh * 0.35; if (state === 'hidden') target = vh;
          
          if (this.state.prefersReducedMotion) {
