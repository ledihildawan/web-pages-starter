            if (sheet) { sheet.style.transition = 'none'; sheet.style.transform = `translate3d(0, ${this.sheetY}px, 0)`; sheet.style.setProperty('--sheet-y', `${Math.max(0, this.sheetY)}px`); if (target === 0) sheet.classList.add('is-full-sheet'); else sheet.classList.remove('is-full-sheet'); }
            if (onComplete) onComplete(); return;
          }
          
