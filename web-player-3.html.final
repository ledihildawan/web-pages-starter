          const fill = activeScrubBar.querySelector('.story-progress-bar__fill'); if (fill) fill.style.transform = `scaleX(${localPercentage})`;
          if (this.state.currentMedia && this.state.currentMedia.getDuration() > 0) {
            pendingSeekTime = this.state.currentMedia.getDuration() * localPercentage; const mins = Math.floor(pendingSeekTime / 60); const secs = Math.floor(pendingSeekTime % 60).toString().padStart(2, '0');
            if (tooltip) { tooltip.innerText = `${mins}:${secs}`; tooltip.style.insetInlineStart = `${localPercentage * 100}%`; }
          }
