<!doctype html>
<html lang="id" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, shrink-to-fit=no" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#0f0f11" id="meta-theme-color" />
  
  <title>NextGen Story - 2026 ES Standard</title>

  <meta property="og:title" content="NextGen Story - 2026 ES Standard" />
  <meta property="og:description" content="A living, organic storytelling library." />
  <meta property="og:image" content="" />
  <meta property="og:url" content="" />
  
  <link rel="preconnect" href="https://www.youtube.com" />
  <link rel="preconnect" href="https://i.ytimg.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  
  <style id="demo-styles">
    body { margin: 0; padding: 0; background-color: #0f0f11; color: #ffffff; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; min-height: 100dvh; display: flex; flex-direction: column; align-items: center; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; overscroll-behavior-y: none; }
    .demo-header { text-align: center; padding: 4rem 2rem 2rem; max-width: 800px; }
    .demo-header h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin-bottom: 1rem; background: linear-gradient(135deg, #ffffff 0%, #a0a0a0 100%); background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.03em; text-wrap: balance; }
    .demo-header p { color: #888888; font-size: 1.125rem; line-height: 1.5; margin-bottom: 3rem; text-wrap: pretty; }
    .story-tray { display: flex; gap: 1.5rem; padding: 1rem 2rem; max-width: 100vw; overflow-x: auto; scrollbar-width: none; overscroll-behavior-x: contain; }
    .story-ring-wrapper { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; cursor: pointer; width: 5.5rem; &:hover .story-ring { transform: scale(1.08); filter: brightness(1.1); } &:active .story-ring { transform: scale(0.92, 1.05); } &:hover .story-ring-inner img { transform: scale(1.1); } }
    .story-ring { width: 4.5rem; height: 4.5rem; border-radius: 50%; background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); padding: 0.25rem; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease; will-change: transform; }
    .story-ring-inner { width: 100%; height: 100%; border-radius: 50%; border: 0.25rem solid #0f0f11; overflow: hidden; background: #222; }
    .story-ring-inner img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .story-label { font-size: 0.75rem; font-weight: 600; color: #e0e0e0; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; padding: 4rem 2rem; max-width: 1000px; width: 100%; box-sizing: border-box; }
    .feature-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 2rem; border-radius: 1.5rem; transition: transform 0.3s ease, background 0.3s ease; &:hover { transform: translateY(-0.25rem); background: rgba(255,255,255,0.06); } h3 { margin: 0 0 1rem 0; font-size: 1.25rem; } p { margin: 0; color: #888; font-size: 0.875rem; line-height: 1.5; text-wrap: pretty; } }
  </style>

  <style id="library-styles">
    @layer reset, design-tokens, layout, components, utilities;
    @property --grad-start { syntax: '<color>'; initial-value: transparent; inherits: true; }
    @property --grad-end { syntax: '<color>'; initial-value: transparent; inherits: true; }
    
    @layer design-tokens { 
      :root { 
        --space-05: 0.125rem; --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem; --space-5: 1.25rem; --space-6: 1.5rem; --space-8: 2rem; --space-10: 2.5rem; --space-12: 3rem; --space-14: 3.5rem; --space-16: 4rem; 
        color-scheme: dark light; 
        --c-white-pure: oklch(100% 0 0); --c-black-pure: oklch(0% 0 0); 
        --bg-base: light-dark(var(--c-white-pure), var(--c-black-pure)); 
        --text-main: light-dark(oklch(10% 0 0), oklch(98% 0 0)); 
        --text-sub: light-dark(oklch(35% 0 0), oklch(85% 0 0)); 
        --text-muted: light-dark(oklch(50% 0 0), oklch(65% 0 0)); 
        --surface-glass-bg: light-dark(color-mix(in oklch, var(--c-white-pure) 70%, transparent), color-mix(in oklch, oklch(10% 0 0) 45%, transparent)); 
        --glass-bg: light-dark(color-mix(in oklch, var(--c-white-pure) 60%, transparent), color-mix(in oklch, oklch(15% 0 0) 40%, transparent)); 
        --glass-border: light-dark(color-mix(in oklch, var(--c-black-pure) 8%, transparent), color-mix(in oklch, var(--c-white-pure) 12%, transparent)); 
        --glass-hl-1: inset 0 1px 1px 0 light-dark(color-mix(in oklch, var(--c-white-pure) 100%, transparent), color-mix(in oklch, var(--c-white-pure) 25%, transparent)); 
        --glass-hl-2: inset 0 -1px 1px 0 light-dark(transparent, color-mix(in oklch, var(--c-black-pure) 40%, transparent)); 
        --glass-highlight: var(--glass-hl-1), var(--glass-hl-2); 
        --surface-glass-blur: blur(40px) saturate(220%); 
        --shadow-base: light-dark(color-mix(in oklch, oklch(20% 0 0) 15%, transparent), color-mix(in oklch, var(--c-black-pure) 95%, transparent)); 
        --video-gradient: light-dark(var(--c-white-pure), var(--c-black-pure)); 
        
        --ease-out: cubic-bezier(0.2, 0, 0, 1); 
        --ease-spring: linear(0, 0.006, 0.025 1.8%, 0.103 4%, 0.233 6.4%, 0.407 9.1%, 0.589 12%, 0.748 15.2%, 0.869 18.6%, 0.949 22.3%, 0.995 26.5%, 1.018 31.4%, 1.025 37.1%, 1.018 43.8%, 1.006 51.5%, 0.998 60.5%, 1); 
        --ease-bounce: cubic-bezier(0.25, 1.3, 0.4, 1); 
        --ease-snappy: cubic-bezier(0.05, 0.9, 0.1, 1); 
        --ease-fluid: cubic-bezier(0.4, 0, 0.2, 1); 
        
        --card-inline-size: 28rem; --frame-radius: var(--space-8); 
        --fab-size: clamp(2.5rem, 2rem + 3cqi, 3.5rem); --fab-icon-size: clamp(1.25rem, 1rem + 1cqi, 1.5rem); 
      } 
    }
    
    @layer reset { 
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; } 
      :focus-visible { outline: var(--space-05) solid var(--text-main); outline-offset: var(--space-1); box-shadow: 0 0 0 var(--space-1) var(--bg-base); border-radius: inherit; transition: outline-offset 0.2s var(--ease-spring), outline-color 0.2s var(--ease-out); } 
      :is(.fab-wrapper, .reaction-option-btn, .volume-btn):focus-visible { border-radius: 50%; } 
      .story-excerpt:focus-visible { border-radius: var(--space-6); } 
      .volume-wrapper:focus-visible { border-radius: var(--space-12); } 
      input[type=range]:focus-visible { border-radius: var(--space-1); outline-offset: var(--space-2); } 
      .sr-only { position: absolute; inline-size: 1px; block-size: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0; } 
      button { background: none; border: none; font-family: inherit; color: inherit; cursor: pointer; } 
      .story-body__cms-content, .story-view__title { cursor: text; user-select: text; } 
      .lucide { width: var(--space-5); height: var(--space-5); stroke-width: 2.2px; } 
      .fab-inner .lucide, .volume-btn .lucide, .story-center-play .lucide { width: var(--fab-icon-size); height: var(--fab-icon-size); transition: transform 0.4s var(--ease-spring), fill 0.3s var(--ease-out), stroke 0.3s var(--ease-out); } 
      .story-center-play .lucide { width: 5rem; height: 5rem; filter: drop-shadow(0 4px 16px oklch(0% 0 0 / 50%)); } 
    }
    
    @layer layout { 
      .layout-wrapper {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100dvh; pointer-events: none; background: var(--bg-base); transition: transform .6s var(--ease-spring), opacity .5s var(--ease-out); transform-origin: center; will-change: transform, opacity; container-type: size; container-name: story-player; z-index: 99999; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: var(--text-main); user-select: none; overscroll-behavior: none; touch-action: pan-y; overflow: hidden;
        &.is-closing { opacity: 0 !important; pointer-events: none; } 
        &.is-ready { pointer-events: none; } 
        &.is-ready > * { pointer-events: auto; }
        &.is-scrub-locked * { cursor: grabbing !important; } 
        &.is-ui-open .story-feed, &.is-scrub-locked .story-feed { overflow-y: hidden !important; touch-action: none !important; } 
        
        &.is-fullscreen.is-idle .story-viewport {
          :is(.story-excerpt, .story-top-actions, .story-player-actions, .story-progress-bar-wrapper, .story-mobile-top-actions) { opacity: 0 !important; pointer-events: none !important; transform: translateY(var(--space-5)) scale(0.95) !important; transition: transform 0.4s var(--ease-spring), opacity 0.3s var(--ease-out) !important; }
          .story-video-wrapper::after { opacity: 0 !important; visibility: hidden !important; transition: opacity 0.4s var(--ease-out), visibility 0.4s var(--ease-out) !important; }
        }
        
        /* FIX: CSS Specificity Fullscreen Mode */
        @media (pointer: fine) {
          &.is-fullscreen.is-idle *:not(.desktop-controls-wrapper):not(.desktop-controls-wrapper *) { cursor: none !important; }
          &.is-fullscreen.is-idle .desktop-controls-wrapper { opacity: 1 !important; pointer-events: auto !important; }
          &.is-fullscreen.is-idle .desktop-controls-wrapper *:not(.is-disabled):not(:disabled) { 
            cursor: pointer !important; pointer-events: auto !important; 
          }
        }
        
        &.is-gesture-active .story-video-wrapper { transform: scale(1.02); transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
        &.is-gesture-active .story-viewport {
          /* FIX: Clean Mode (Mempertahankan Progress Bar) */
          :is(.story-excerpt, .story-top-actions, .story-player-actions, .story-mobile-top-actions) { opacity: 0 !important; pointer-events: none !important; transform: translateY(var(--space-5)) scale(0.95) !important; transition: transform 0.4s var(--ease-spring), opacity 0.3s var(--ease-out) !important; }
          .story-video-wrapper::after { opacity: 0 !important; visibility: hidden !important; transition: opacity 0.4s ease, visibility 0.4s ease !important; }
        }
      } 
      
      .story-feed { 
        position: absolute; inset: 0; inline-size: 100%; block-size: 100dvh; overflow-y: scroll; scroll-snap-type: y mandatory; scrollbar-width: none; z-index: 10; display: flex; flex-direction: column; align-items: center; transition: transform .6s var(--ease-spring); overscroll-behavior-y: contain; will-change: transform; 
        &.is-dragging {
          .story-player-actions, .story-top-actions, .story-mobile-top-actions, .story-excerpt, .story-progress-bar-wrapper { opacity: 0 !important; transform: scale(0.95) translateY(10px) !important; transition: opacity 0.2s ease, transform 0.2s ease !important; }
          .story-viewport { transform: scale(0.92) translateZ(0); border-radius: var(--space-8); box-shadow: 0 20px 40px rgba(0,0,0,0.5); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1), border-radius 0.3s ease, box-shadow 0.3s ease; }
          .ambient-layer { opacity: 0.1 !important; transition: opacity 0.3s ease !important; }
        }
      } 
      .story-slot { 
        position: relative; flex-shrink: 0; inline-size: 100%; block-size: 100dvh; 
        scroll-snap-align: center; scroll-snap-stop: always; transform: translateZ(0);
        
        /* PATCH: Render Skipping untuk performa GPU maksimal */
        content-visibility: auto; 
        contain-intrinsic-size: 100vw 100dvh; 
      }
    }
    
    @layer components {
      ::view-transition-old(story-hero), ::view-transition-new(story-hero) { animation-timing-function: var(--ease-spring); animation-duration: 0.6s; }
      .is-transitioning-hero { view-transition-name: story-hero; contain: layout; }
      
      .story-container {
        position: absolute; inset: 0; inline-size: 100%; block-size: 100%; border-radius: 0; transform: translateZ(0); background-color: var(--bg-base); z-index: 10; transition: border-radius .5s var(--ease-spring), box-shadow .5s var(--ease-out), transform .5s var(--ease-spring); will-change: transform; 
        &.is-loading .story-viewport { cursor: progress; } 
        &.has-started:not(.is-paused):not(.is-loading) .ambient-layer { opacity: .65; filter: blur(45px) saturate(300%); transform: scale(3.2) translateZ(0); } 
        &.is-paused { .ambient-layer { opacity: .25; filter: blur(50px) saturate(150%); transform: scale(3) translateZ(0); } .story-video-wrapper { filter: brightness(.80) contrast(1.1) grayscale(.05); } }
        &.is-loading .ambient-layer { opacity: .1; filter: blur(64px) saturate(100%); transform: scale(2.8) translateZ(0); transition: opacity .4s var(--ease-out), filter .4s var(--ease-out), transform .5s var(--ease-out); } 
        &.has-started .story-loader { opacity: 0; transform: scale(0.8); } 
        &.has-started.is-loading .story-loader { opacity: 1; transform: scale(1); } 
        &.is-story-format .story-progress-bar-wrapper { opacity: 1 !important; transform: translateY(0) scale(1) !important; pointer-events: auto !important; } 
        &.is-loading .story-progress-bar.is-current::after { opacity: 1; } 
        
        &.show-ui {
          .story-top-actions { opacity: 1; pointer-events: none; transform: translateY(0) scale(1); transition: opacity 0.2s ease-out 0s, transform 0.25s var(--ease-out) 0s; } 
          .story-top-actions > * { pointer-events: auto; }
          .story-mobile-top-actions { opacity: 1; pointer-events: none; transform: translateY(0) scale(1); transition: opacity 0.2s ease-out 0s, transform 0.25s var(--ease-out) 0s; } 
          .story-mobile-top-actions > * { pointer-events: auto; }
          .story-player-actions { opacity: 1; pointer-events: none; transform: translateY(0) scale(1); transition: opacity 0.2s ease-out 0s, transform 0.25s var(--ease-out) 0s; } 
          .story-player-actions > * { pointer-events: auto; }
          .story-excerpt { opacity: 1; pointer-events: auto; transform: translateY(0); transition: opacity 0.2s ease-out 0.05s, transform 0.25s var(--ease-out) 0.05s; } 
          .story-progress-bar-wrapper { opacity: 1 !important; pointer-events: auto !important; transform: translateY(0) scale(1) !important; transition: opacity 0.2s ease-out 0s, transform 0.25s var(--ease-out) 0s !important; } 
          .story-excerpt__badges { opacity: 1; transform: translateY(0); transition-delay: 0.1s; } .story-excerpt__title { opacity: 1; transform: translateY(0); transition-delay: 0.15s; } .story-excerpt__text { opacity: 1; transform: translateY(0); transition-delay: 0.2s; }
        }
      }
      
      .layout-wrapper.is-scrub-locked .ambient-layer { opacity: .1; filter: blur(64px) saturate(100%); transform: scale(2.8) translateZ(0); transition: opacity .4s var(--ease-out), filter .4s var(--ease-out), transform .5s var(--ease-out); }
      
      :is(.story-top-actions, .story-player-actions) { position: absolute; z-index: 55; display: flex; gap: var(--space-4); opacity: 0; pointer-events: none; transition: opacity .3s var(--ease-out), transform .35s var(--ease-spring); } 
      .story-top-actions { inset-block-start: max(var(--space-6), env(safe-area-inset-top)); inset-inline-start: var(--space-6); transform: translateY(calc(var(--space-4) * -1)) scale(0.95); align-items: center; } 
      .story-player-actions { inset-block-end: max(var(--space-16), env(safe-area-inset-bottom)); inset-inline-end: var(--space-6); flex-direction: column; align-items: center; transform: translateY(var(--space-4)) scale(0.95); }

      .story-mobile-top-actions {
        position: absolute; inset-block-start: max(var(--space-6), env(safe-area-inset-top)); inset-inline-end: var(--space-6); display: flex; gap: var(--space-3); align-items: center; z-index: 60; opacity: 0; pointer-events: none; transform: translateY(calc(var(--space-4) * -1)) scale(0.95); transition: opacity .3s var(--ease-out), transform .35s var(--ease-spring);
      }
      
      .desktop-controls-wrapper { position: fixed; inset-inline-end: var(--space-6); inset-block-start: max(var(--space-6), env(safe-area-inset-top)); display: flex; flex-direction: column; align-items: flex-end; z-index: 60; transition: opacity .6s var(--ease-out); } 
      .story-close-player { position: relative; cursor: pointer; }
      .external-nav-group { display: flex; flex-direction: column; gap: var(--space-5); margin-block-start: var(--space-16); }

      .story-dummy-card {
        position: absolute; inset: 0; inline-size: 100%; block-size: 100%; border-radius: 0; transform: translateZ(0); --grad-start: var(--bg-base); --grad-end: var(--bg-base); background: linear-gradient(180deg in oklch, var(--grad-start) 0%, var(--grad-end) 100%); overflow: hidden; filter: brightness(.4); z-index: 5; transition: filter .6s var(--ease-out), --grad-start .8s linear, --grad-end .8s linear, transform .4s var(--ease-spring); pointer-events: auto; cursor: pointer; 
        &::after { content: ''; position: absolute; inset: 0; background-image: var(--peek-img, none); background-size: var(--peek-fit, cover); background-position: center; background-repeat: no-repeat; z-index: 2; pointer-events: none; transition: background-image .5s ease; } 
        @media (hover: hover) and (pointer: fine) { &:hover { filter: brightness(.6); transform: scale(1.02); } }
      }
      
      .ambient-layer { 
        display: none; position: absolute; inset-block-start: 50%; inset-inline-start: 50%; inline-size: 30%; block-size: 30%; margin-block-start: -15%; margin-inline-start: -15%; z-index: 1; pointer-events: none; transform: scale(3) translateZ(0); opacity: 0; filter: blur(60px) saturate(80%); background-image: var(--bg-image, linear-gradient(180deg in oklch, var(--grad-start, var(--bg-base)) 0%, var(--grad-end, var(--bg-base)) 100%)); background-size: cover; background-position: center; transition: opacity .8s var(--ease-out), filter .8s var(--ease-out), transform 1.5s var(--ease-spring), --grad-start .8s linear, --grad-end .8s linear; will-change: transform, opacity, filter, --grad-start, --grad-end; 
      } 
      .layout-wrapper.is-ui-open .ambient-layer { opacity: .02 !important; } 
      
      @keyframes ambientBreathe { 0%, 100% { transform: scale(3.2) translateZ(0); } 50% { transform: scale(3.35) translateZ(0); filter: blur(35px) saturate(280%); } } 
      .is-breathing { animation: ambientBreathe 10s ease-in-out infinite; }
      
      .media-container { iframe, video, img { inline-size: 100%; block-size: 100%; border: none; pointer-events: none; transform: translateZ(0); transform-origin: center; will-change: transform; } }
      .ambient-media-container { inline-size: 100%; block-size: 100%; opacity: 0; transition: opacity .8s var(--ease-out); will-change: opacity; mix-blend-mode: screen; } 
      .story-viewport { position: absolute; inset: 0; z-index: 10; overflow: hidden; border-radius: inherit; transition: filter .5s var(--ease-out), transform .5s var(--ease-spring), border-radius 0.5s var(--ease-spring), box-shadow 0.5s ease; will-change: filter, transform; contain: paint; }
      
      .story-video-wrapper {
        position: relative; inline-size: 100%; block-size: 100%; --grad-start: var(--bg-base); --grad-end: var(--bg-base); background-color: var(--bg-base); transition: filter .5s var(--ease-out), --grad-start 1.2s linear, --grad-end 1.2s linear, background-color 0.8s ease, transform 0.5s var(--ease-out); will-change: filter, --grad-start, --grad-end, transform; overflow: hidden; 
        &::before { content: ''; position: absolute; inset: -20%; inline-size: 140%; block-size: 140%; background-image: var(--bg-image, linear-gradient(180deg in oklch, var(--grad-start) 0%, var(--grad-end) 100%)); background-size: cover; background-position: center; filter: blur(60px) saturate(200%); opacity: 0.9; pointer-events: none; z-index: 1; transition: opacity .5s var(--ease-out); } 
        &::after { content: ''; position: absolute; inset: 0; z-index: 5; pointer-events: none; box-shadow: inset 0 0 160px color-mix(in oklch, var(--video-gradient) 95%, transparent); background: linear-gradient(to bottom, color-mix(in oklch, var(--video-gradient) 75%, transparent) 0%, color-mix(in oklch, var(--video-gradient) 55%, transparent) 8.1%, color-mix(in oklch, var(--video-gradient) 38%, transparent) 15.5%, color-mix(in oklch, var(--video-gradient) 25%, transparent) 22.5%, color-mix(in oklch, var(--video-gradient) 12%, transparent) 29%, transparent 35%, transparent 55%, color-mix(in oklch, var(--video-gradient) 15%, transparent) 68%, color-mix(in oklch, var(--video-gradient) 35%, transparent) 79%, color-mix(in oklch, var(--video-gradient) 60%, transparent) 88%, color-mix(in oklch, var(--video-gradient) 88%, transparent) 96%, color-mix(in oklch, var(--video-gradient) 100%, transparent) 100%); transition: opacity .5s var(--ease-out); }
      }
      
      .thumbnail-overlay, .main-media-container { position: absolute; inset: 0; inline-size: 100%; block-size: 100%; z-index: 8; pointer-events: none; transition: opacity .4s var(--ease-out); color: transparent; will-change: opacity; } 
      .main-media-container { z-index: 2; opacity: 0; transition: opacity .4s var(--ease-out); }
      .story-loader { position: absolute; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; transition: opacity .4s var(--ease-out), transform .4s var(--ease-spring); pointer-events: none; cursor: progress; } 
      .story-loader__spinner-simple { inline-size: var(--space-10); block-size: var(--space-10); border-radius: 50%; border: var(--space-1) solid color-mix(in oklch, var(--text-main) 15%, transparent); border-top-color: var(--text-main); animation: story-spin-simple .8s cubic-bezier(.4, 0, .2, 1) infinite; filter: drop-shadow(0 4px 12px var(--shadow-base)); will-change: transform; } 
      
      @keyframes story-spin-simple { to { transform: rotate(1turn); } }
      @keyframes story-spin-linear { 100% { transform: rotate(360deg); } }
      @keyframes story-spin-ease { 12.5% { transform: rotate(135deg); } 25% { transform: rotate(270deg); } 37.5% { transform: rotate(405deg); } 50% { transform: rotate(540deg); } 62.5% { transform: rotate(675deg); } 75% { transform: rotate(810deg); } 87.5% { transform: rotate(945deg); } 100% { transform: rotate(1080deg); } }
      @keyframes story-spin-left { 0%, 100% { transform: rotate(130deg); } 50% { transform: rotate(-5deg); } }
      @keyframes story-spin-right { 0%, 100% { transform: rotate(-130deg); } 50% { transform: rotate(5deg); } }
      
      .story-error-overlay { position: absolute; inset: 0; z-index: 60; background: color-mix(in oklch, var(--bg-base) 85%, transparent); backdrop-filter: var(--surface-glass-blur); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .4s var(--ease-out); cursor: default; &.is-visible { opacity: 1; pointer-events: auto; } } 
      .error-content { text-align: center; padding-inline: var(--space-8); color: var(--text-main); transform: translateY(var(--space-4)); transition: transform .4s var(--ease-spring); } 
      .story-error-overlay.is-visible .error-content { transform: translateY(0); } 
      .error-icon { font-size: 3.5rem; margin-block-end: var(--space-5); display: block; filter: drop-shadow(0 8px 16px var(--shadow-base)); animation: float 3s ease-in-out infinite; } 
      @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(calc(var(--space-3) * -1)); } } 
      
      @keyframes edgeBumpLeft { 0%, 100% { transform: translateX(0) scale(1); } 50% { transform: translateX(12px) scale(0.98) rotateY(-2deg); } }
      @keyframes edgeBumpRight { 0%, 100% { transform: translateX(0) scale(1); } 50% { transform: translateX(-12px) scale(0.98) rotateY(2deg); } }
      .is-bumping-left { animation: edgeBumpLeft 0.4s var(--ease-spring) forwards; }
      .is-bumping-right { animation: edgeBumpRight 0.4s var(--ease-spring) forwards; }

      .error-title { font-size: 1.5rem; font-weight: 800; margin-block-end: var(--space-2); letter-spacing: -.03em; } 
      .error-desc { font-size: 1rem; color: var(--text-sub); margin-block-end: var(--space-8); line-height: 1.5; text-wrap: balance; } 
      .error-retry-btn {
        background: var(--text-main); color: var(--bg-base); border: none; padding: var(--space-4) var(--space-10); border-radius: var(--space-12); font-size: 1rem; font-weight: 700; cursor: pointer; transition: transform .4s var(--ease-spring), box-shadow .3s var(--ease-out), background-color .3s var(--ease-out); box-shadow: 0 8px 24px color-mix(in oklch, var(--text-main) 20%, transparent); 
        &.is-disabled, &:disabled { opacity: 0.3 !important; cursor: not-allowed !important; filter: grayscale(1) !important; pointer-events: none !important; transform: none !important; box-shadow: none !important; } 
        /* FIX: Squash and Stretch Active State */
        &:not(.is-disabled):not(:disabled):active { transform: scale(1.02, 0.94) translateY(2px) !important; box-shadow: 0 2px 4px color-mix(in oklch, var(--c-black-pure) 20%, transparent), inset 0 4px 8px color-mix(in oklch, var(--c-black-pure) 10%, transparent) !important; transition: transform 0.05s var(--ease-snappy), box-shadow 0.05s var(--ease-snappy) !important; } 
        @media (hover: hover) and (pointer: fine) { &:not(.is-disabled):not(:disabled):hover { box-shadow: 0 16px 32px color-mix(in oklch, var(--text-main) 20%, transparent); transform: translateY(-2px) scale(1.02); } }
      }
      
      .reaction-container-layer { position: absolute; inset: 0; z-index: 15; pointer-events: none; contain: strict; } 
      .particle { position: absolute; inset-block-end: 5rem; inset-inline-start: var(--x); font-size: var(--size); opacity: 0; animation: float-physics var(--duration) var(--ease-fluid) forwards; animation-delay: var(--delay); filter: blur(var(--blur)) drop-shadow(0 4px 12px var(--shadow-base)); z-index: var(--z); will-change: transform, opacity; pointer-events: none; } 
      @keyframes float-physics { 0% { transform: translate3d(0, 0, 0) scale(0.4) rotate(0deg); opacity: 0; } 15% { opacity: 1; transform: translate3d(calc(var(--drift) * 0.2), -15vh, 0) scale(1.2) rotate(calc(var(--rotation) * 0.3)); filter: blur(0px); } 80% { opacity: 0.9; transform: translate3d(calc(var(--drift) * 0.8), -50vh, 0) scale(1) rotate(calc(var(--rotation) * 0.8)); } 100% { transform: translate3d(var(--drift), -70vh, 0) scale(0.8) rotate(var(--rotation)); opacity: 0; filter: blur(4px); } }
      
      .story-center-play { position: absolute; inset-block-start: 50%; inset-inline-start: 50%; transform: translate(-50%, -50%) scale(0.5); font-size: 5rem; color: var(--text-main); z-index: 15; opacity: 0; pointer-events: none; filter: drop-shadow(0 16px 32px var(--shadow-base)); will-change: transform, opacity, filter; } 
      @keyframes centerFlash { 0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); filter: blur(8px); } 20% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); filter: blur(0px); } 100% { opacity: 0; transform: translate(-50%, -50%) scale(1.4); filter: blur(4px); } } 
      :is(.story-center-play.is-flashing) { animation: centerFlash 0.5s var(--ease-out) forwards; }
      
      .story-center-reaction { position: absolute; inset-block-start: 50%; inset-inline-start: 50%; transform: translate(-50%, -50%) scale(0); color: #ef4444; z-index: 60; opacity: 0; pointer-events: none; filter: drop-shadow(0 8px 32px color-mix(in oklch, var(--c-black-pure) 50%, transparent)); display: flex; align-items: center; justify-content: center; font-size: 8rem; line-height: 1; .lucide { width: 8rem; height: 8rem; fill: currentColor; } } 
      @keyframes reactionBurst { 0% { transform: translate(-50%, -50%) scale(0) rotate(var(--tilt, 0deg)); opacity: 1; } 15% { transform: translate(-50%, -50%) scale(1.2) rotate(calc(var(--tilt, 0deg) * 1.2)); opacity: 1; filter: drop-shadow(0 0 40px rgba(239,68,68,0.6)); } 30% { transform: translate(-50%, -50%) scale(1) rotate(var(--tilt, 0deg)); opacity: 1; } 70% { transform: translate(-50%, -50%) scale(1) rotate(var(--tilt, 0deg)); opacity: 1; } 100% { transform: translate(-50%, -50%) scale(1.5) rotate(var(--tilt, 0deg)); opacity: 0; } } 
      .story-center-reaction.is-animating { animation: reactionBurst 0.8s var(--ease-spring) forwards; }
      
      /* FIX: Speed Badge Capsule di Top Center */
      .speed-badge { 
        position: absolute; 
        inset-block-start: max(var(--space-12), env(safe-area-inset-top)); 
        inset-inline-start: 50%; 
        transform: translateX(-50%) translateY(calc(var(--space-4) * -1)) scale(0.8); 
        background: color-mix(in oklch, var(--c-black-pure) 70%, transparent); 
        backdrop-filter: blur(16px) saturate(150%); 
        color: var(--c-white-pure); 
        padding: var(--space-2) var(--space-5); 
        border-radius: var(--space-12); 
        border: 1px solid color-mix(in oklch, var(--c-white-pure) 15%, transparent); 
        box-shadow: 0 8px 32px color-mix(in oklch, var(--c-black-pure) 50%, transparent);
        font-size: .875rem; 
        font-weight: 700; 
        letter-spacing: 0.02em; 
        opacity: 0; 
        pointer-events: none; 
        transition: transform 0.4s var(--ease-spring), opacity 0.2s var(--ease-out); 
        z-index: 90; 
        display: flex; 
        align-items: center; 
        gap: var(--space-2); 
        &.is-visible { 
          opacity: 1; 
          transform: translateX(-50%) translateY(0) scale(1); 
        } 
      }
      
      .ripple-edge { position: absolute; inset-block: 0; inline-size: 45%; display: flex; flex-direction: column; justify-content: center; align-items: center; opacity: 0; pointer-events: none; z-index: 25; mix-blend-mode: overlay; &.is-animating { animation: ambientRipple 0.7s var(--ease-out) forwards; } } 
      .ripple-edge--left { inset-inline-start: 0; background: radial-gradient(120% 60% at 0% 50%, color-mix(in oklch, var(--c-white-pure) 15%, transparent) 0%, transparent 100%); .ripple-edge__capsule { --ripple-dir: calc(var(--space-5) * -1); } } 
      .ripple-edge--right { inset-inline-end: 0; background: radial-gradient(120% 60% at 100% 50%, color-mix(in oklch, var(--c-white-pure) 15%, transparent) 0%, transparent 100%); .ripple-edge__capsule { --ripple-dir: var(--space-5); } } 
      .ripple-edge__capsule { background: transparent; color: var(--c-white-pure); font-size: 1.125rem; font-weight: 800; letter-spacing: .05em; text-shadow: 0 4px 12px rgba(0,0,0,0.4); border: none; box-shadow: none; backdrop-filter: none; transition: transform 0.3s var(--ease-out); } 
      @keyframes ambientRipple { 0% { opacity: 0; transform: translateX(var(--ripple-dir, 0)) scale(0.95); filter: blur(8px); } 20% { opacity: 1; transform: translateX(0) scale(1); filter: blur(0px); } 80% { opacity: 1; transform: translateX(0) scale(1.05); filter: blur(0px); } 100% { opacity: 0; transform: translateX(calc(var(--ripple-dir, 0) * -1)) scale(1.1); filter: blur(12px); } } 
      
      .story-gesture-layer { position: absolute; inset: 0; z-index: 20; display: flex; cursor: default; touch-action: pan-y; } .gesture-zone { block-size: 100%; cursor: pointer; } .gesture-zone--left, .gesture-zone--right { inline-size: 30%; } .gesture-zone--center { inline-size: 40%; }
      
      .story-progress-bar-wrapper {
        position: absolute; inset-block-end: max(var(--space-5), env(safe-area-inset-bottom)); inset-inline: var(--space-6); block-size: var(--space-10); z-index: 65; display: flex; align-items: center; gap: clamp(2px, 0.5vw, 6px); opacity: 0; transform: scale(0.95) translateY(var(--space-3)); touch-action: none; cursor: default; 
        &::before { content: ''; position: absolute; inset-block: calc(var(--space-5) * -1); inline-size: 100%; z-index: 0; } 
        &.is-scrubbing, &.is-scrubbing * { cursor: grabbing !important; } 
        &:not(.is-scrubbing) .story-progress-bar__fill { transition: transform .1s linear; } 
        &.is-scrubbing .story-progress-bar { opacity: 1; transform: scaleY(2.5); border-radius: var(--space-2); transition: opacity .2s var(--ease-out), transform .2s var(--ease-spring), border-radius .2s var(--ease-spring); &.is-current { opacity: 1; box-shadow: 0 0 16px color-mix(in oklch, var(--text-main) 60%, transparent), 0 0 4px var(--text-main); } }
        &.is-scrubbing .story-progress-tooltip { opacity: 1; transform: translateX(-50%) translateY(0) scale(1.2); } 
        @media (hover: hover) and (pointer: fine) { &:hover .story-progress-bar { opacity: 1; transform: scaleY(2.5); border-radius: var(--space-2); transition: opacity .2s var(--ease-out), transform .2s var(--ease-spring), border-radius .2s var(--ease-spring); &.is-current { opacity: 1; } } }
      } 
      .story-progress-tooltip { position: absolute; inset-block-end: 120%; inset-inline-start: 0; transform: translateX(-50%) translateY(var(--space-1)) scale(0.5); background: var(--text-main); color: var(--bg-base); padding: var(--space-1) var(--space-2); border-radius: var(--space-2); font-size: 0.75rem; font-weight: 800; opacity: 0; pointer-events: none; transition: opacity 0.2s var(--ease-out), transform 0.4s var(--ease-spring); z-index: 70; } 
      .story-progress-bar {
        flex: 1; block-size: 4px; background: color-mix(in oklch, var(--text-main) 25%, transparent); border-radius: 4px; overflow: hidden; transition: background .4s var(--ease-out), opacity .4s var(--ease-out), transform 0.5s var(--ease-spring), border-radius 0.5s var(--ease-spring); opacity: .6; cursor: pointer; transform-origin: bottom; position: relative; 
        &.is-viewed { opacity: .9; background: color-mix(in oklch, var(--text-main) 60%, transparent); } 
        &.is-current { opacity: 1; background: color-mix(in oklch, var(--text-main) 20%, transparent); position: relative; box-shadow: 0 0 12px color-mix(in oklch, var(--text-main) 30%, transparent); 
          &::after { content: ''; position: absolute; inset-block: 0; inline-size: 200%; inset-inline-start: -200%; background: linear-gradient(90deg, transparent 0%, color-mix(in oklch, var(--text-main) 15%, transparent) 30%, color-mix(in oklch, var(--text-main) 80%, transparent) 50%, color-mix(in oklch, var(--text-main) 15%, transparent) 70%, transparent 100%); opacity: 0; transition: opacity .4s var(--ease-out); pointer-events: none; border-radius: inherit; z-index: 3; will-change: transform; } 
        }
        &.is-upcoming { opacity: .4; cursor: default; } 
      } 
      .story-container.is-loading .story-progress-bar.is-current::after { opacity: 1; animation: progressBarBuffering 1.2s infinite cubic-bezier(0.4, 0, 0.2, 1); } 
      .story-progress-bar__buffer { position: absolute; inset-block: 0; inline-size: 100%; background: color-mix(in oklch, var(--text-main) 45%, transparent); transform-origin: left; transform: scaleX(0); border-radius: inherit; will-change: transform; transition: transform 0.4s var(--ease-out); pointer-events: none; z-index: 1; } 
      .story-progress-bar__fill { position: relative; z-index: 2; block-size: 100%; inline-size: 100%; background: var(--text-main); transform-origin: left; transform: scaleX(0); border-radius: inherit; will-change: transform; cursor: inherit; box-shadow: 2px 0 8px color-mix(in oklch, var(--text-main) 80%, transparent), 0 0 2px color-mix(in oklch, var(--text-main) 40%, transparent); } 
      @keyframes progressBarBuffering { 0% { transform: translateX(0); } 100% { transform: translateX(150%); } }
      
      :is(.fab-wrapper, .reaction-option-btn) { position: relative; &::after { content: ''; position: absolute; inset: calc(var(--space-4) * -1); z-index: -1; border-radius: 50%; } } 
      
      :is(.fab-wrapper, .volume-wrapper) {
        display: flex; align-items: center; justify-content: center; padding: var(--space-1); inline-size: calc(var(--fab-size) + var(--space-2)); block-size: calc(var(--fab-size) + var(--space-2)); border-radius: 50%; background-color: var(--glass-bg); backdrop-filter: var(--surface-glass-blur); border: 1px solid var(--glass-border); box-shadow: var(--shadow-floating), var(--glass-highlight); outline: none; transition: box-shadow .4s var(--ease-out), background-color .4s var(--ease-out), transform .4s var(--ease-spring); cursor: pointer; 
        &.is-disabled, &:disabled { opacity: 0.3 !important; cursor: not-allowed !important; filter: grayscale(1) !important; pointer-events: none !important; transform: none !important; box-shadow: none !important; } 
        /* FIX: Squash and Stretch Active State */
        &:not(.is-disabled):not(:disabled):active { transform: scale(1.02, 0.94) translateY(2px) !important; box-shadow: 0 2px 4px color-mix(in oklch, var(--c-black-pure) 20%, transparent), inset 0 4px 8px color-mix(in oklch, var(--c-black-pure) 10%, transparent) !important; transition: transform 0.05s var(--ease-snappy), box-shadow 0.05s var(--ease-snappy) !important; } 
        @media (hover: hover) and (pointer: fine) { &:not(.is-disabled):not(:disabled):hover { box-shadow: 0 16px 32px color-mix(in oklch, var(--text-main) 20%, transparent); transform: translateY(-2px) scale(1.02); } }
      }
      
      .volume-wrapper {
        border-radius: var(--space-12); justify-content: flex-start; overflow: hidden; transition: inline-size 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-out), background-color 0.4s var(--ease-out), transform 0.4s var(--ease-spring); 
        @media (hover: hover) and (pointer: fine) { 
          &:not(.is-disabled):not(:disabled):hover, &:not(.is-disabled):not(:disabled):focus-within { inline-size: 12.5rem; .volume-slider-box { opacity: 1; visibility: visible; transform: translateX(0); pointer-events: auto; transition: transform 0.4s var(--ease-spring) 0.1s, opacity 0.3s var(--ease-out) 0.1s, visibility 0s 0s; } .volume-inner { background-color: color-mix(in oklch, var(--text-main) 15%, transparent); } } 
        } 
      } 
      
      :is(.fab-inner, .volume-inner) { display: flex; align-items: center; justify-content: center; inline-size: 100%; block-size: 100%; background-color: transparent; color: var(--text-main); transition: transform .4s var(--ease-spring), color .3s var(--ease-out), background-color .3s var(--ease-out); } 
      .fab-inner { border-radius: 50%; } .volume-inner { border-radius: 2.75rem; overflow: hidden; justify-content: flex-start; } 
      @media (hover: hover) and (pointer: fine) { .fab-wrapper:not(.is-disabled):not(:disabled):hover .fab-inner { background-color: color-mix(in oklch, var(--text-main) 15%, transparent); } }
      
      .volume-btn { inline-size: var(--fab-size); block-size: var(--fab-size); flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--text-main); background: transparent; border: none; cursor: pointer; transition: transform .3s var(--ease-spring); outline: none; } 
      .volume-slider-box { inline-size: 8rem; flex-shrink: 0; display: flex; align-items: center; padding-inline-end: var(--space-4); opacity: 0; visibility: hidden; transform: translateX(calc(var(--space-4) * -1)); transition: transform 0.3s var(--ease-out), opacity 0.2s var(--ease-out), visibility 0s 0.3s; pointer-events: none; } 
      .volume-slider {
        appearance: none; inline-size: 100%; block-size: 6px; background: linear-gradient(to right, var(--text-main) var(--vol, 0%), color-mix(in oklch, var(--text-main) 15%, transparent) var(--vol, 0%)); border-radius: 3px; outline: none; cursor: pointer; box-shadow: inset 0 1px 3px color-mix(in oklch, var(--shadow-base) 40%, transparent); 
        &::-webkit-slider-thumb { appearance: none; width: 16px; height: 16px; border-radius: 50%; background: var(--text-main); box-shadow: 0 2px 8px var(--shadow-base), 0 0 0 1px color-mix(in oklch, var(--shadow-base) 30%, transparent); cursor: grab; transition: transform 0.3s var(--ease-spring), background-color 0.3s var(--ease-spring); } 
        &:not(:disabled):active::-webkit-slider-thumb { cursor: grabbing; transform: scale(1.5); background-color: var(--c-white-pure); transition: transform 0.05s var(--ease-snappy), background-color 0.05s var(--ease-snappy); } 
        &::-moz-range-thumb { width: 16px; height: 16px; border-radius: 50%; border: none; background: var(--text-main); box-shadow: 0 2px 8px var(--shadow-base), 0 0 0 1px color-mix(in oklch, var(--shadow-base) 30%, transparent); cursor: grab; transition: transform 0.3s var(--ease-spring), background-color 0.3s var(--ease-spring); } 
        &:not(:disabled):active::-moz-range-thumb { cursor: grabbing; transform: scale(1.5); background-color: var(--c-white-pure); transition: transform 0.05s var(--ease-snappy), background-color 0.05s var(--ease-snappy); } 
      }
      
      .reaction-option-btn {
        inline-size: var(--fab-size); block-size: var(--fab-size); border-radius: 50%; background-color: var(--glass-bg); backdrop-filter: var(--surface-glass-blur); border: 1px solid var(--glass-border); color: var(--text-main); font-size: 1.25rem; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: var(--shadow-floating), var(--glass-highlight); transition: transform .4s var(--ease-spring), opacity .3s var(--ease-out), box-shadow .3s var(--ease-out), background-color .3s var(--ease-out); opacity: 0; transform: translateY(var(--space-6)) scale(0.6) rotate(-20deg); transform-origin: bottom center; 
        &.is-disabled, &:disabled { opacity: 0.3 !important; cursor: not-allowed !important; filter: grayscale(1) !important; pointer-events: none !important; transform: none !important; box-shadow: none !important; } 
        &:not(.is-disabled):not(:disabled):active { transform: scale(1.02, 0.94) translateY(2px) !important; box-shadow: 0 2px 4px color-mix(in oklch, var(--c-black-pure) 20%, transparent), inset 0 4px 8px color-mix(in oklch, var(--c-black-pure) 10%, transparent) !important; transition: transform 0.05s var(--ease-snappy), box-shadow 0.05s var(--ease-snappy) !important; filter: brightness(0.9); } 
        @media (hover: hover) and (pointer: fine) { &:not(.is-disabled):not(:disabled):hover { background-color: color-mix(in oklch, var(--text-main) 15%, transparent); box-shadow: 0 12px 24px color-mix(in oklch, var(--shadow-base) 40%, transparent), var(--glass-highlight); transform: scale(1.1) translateY(-4px) rotate(0deg); } }
      }
      
      .reaction-wrapper {
        position: relative; display: flex; flex-direction: column; align-items: center; cursor: pointer; transform-origin: bottom center; 
        &.is-active {
          .reaction-options { pointer-events: auto; } 
          .reaction-option-btn { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); margin-block-end: var(--space-2); 
            &:nth-child(5) { transition-delay: 0s; } &:nth-child(4) { transition-delay: .03s; } &:nth-child(3) { transition-delay: .06s; } &:nth-child(2) { transition-delay: .09s; } &:nth-child(1) { transition-delay: .12s; }
          } 
          .fab-inner { background-color: color-mix(in oklch, var(--text-main) 15%, transparent); box-shadow: 0 0 32px color-mix(in oklch, var(--text-main) 20%, transparent); transform: translateY(-2px); > * { transform: scale(1.15) rotate(-15deg); transition: transform 0.4s var(--ease-spring); } }
        }
        @media (hover: hover) and (pointer: fine) { &.is-active .fab-wrapper:not(.is-disabled):not(:disabled):hover .fab-inner { box-shadow: 0 0 44px color-mix(in oklch, var(--text-main) 30%, transparent); } } 
      } 
      
      .reaction-options { position: absolute; inset-block-end: 100%; inset-inline-end: 0; display: flex; flex-direction: column; align-items: center; gap: var(--space-3); pointer-events: none; padding-block-end: var(--space-4); } .fab-inner.is-liked { color: #ef4444; }
      
      .story-excerpt {
        position: absolute; inset-block-end: max(var(--space-16), env(safe-area-inset-bottom)); inset-inline-start: var(--space-6); inset-inline-end: var(--space-6); 
        padding-inline-end: 5rem; padding-block: var(--space-6); margin-block-end: calc(var(--space-6) * -1); touch-action: manipulation; z-index: 55; color: var(--text-main); cursor: pointer; opacity: 0; pointer-events: none; text-align: start; display: block; transition: opacity .25s var(--ease-out), transform .25s var(--ease-out); 
        &.is-disabled, &:disabled { opacity: 0.3 !important; cursor: not-allowed !important; filter: grayscale(1) !important; pointer-events: none !important; transform: none !important; } 
        &:active { transform: translateY(2px) scale(0.98); opacity: 0.8; transition: transform 0.05s var(--ease-snappy), opacity 0.05s var(--ease-snappy); } 
        @media (hover: hover) and (pointer: fine) { &:not(.is-disabled):not(:disabled):hover { opacity: 1; transform: translateY(-2px) scale(1.01); } } 
      } 
      
      :is(.story-excerpt__badges, .story-excerpt__title, .story-excerpt__text) { opacity: 0; transform: translateY(var(--space-4)); transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out); } 
      .story-excerpt__badges, .story-view__badges { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-block-end: var(--space-3); cursor: pointer; } .story-view__badges { margin-block-end: var(--space-4); }
      
      .story-badge-item {
        background: color-mix(in oklch, var(--text-main) 15%, transparent); color: var(--text-main); backdrop-filter: blur(24px); border: 1px solid var(--glass-border); font-size: .6875rem; font-weight: 800; text-transform: uppercase; padding: var(--space-1) var(--space-4); border-radius: var(--space-8); letter-spacing: .06em; box-shadow: 0 4px 16px var(--shadow-base), inset 0 1px 1px color-mix(in oklch, var(--text-main) 20%, transparent); cursor: pointer; transition: background .3s var(--ease-out), transform .4s var(--ease-spring); 
        &:active { transform: scale(0.92); transition: transform 0.05s var(--ease-snappy); } 
        @media (hover: hover) and (pointer: fine) { &:hover { transform: scale(1.05); background: color-mix(in oklch, var(--text-main) 25%, transparent); } } 
      } 
      
      .story-excerpt__title { display: block; font-weight: 800; text-wrap: pretty; font-size: 1.375rem; margin-block-end: var(--space-2); text-shadow: 0 4px 20px color-mix(in oklch, var(--video-gradient) 90%, transparent); line-height: 1.25; letter-spacing: -.02em; } 
      .story-view__title { display: block; font-weight: 800; text-wrap: balance; font-size: 1.75rem; margin-block-end: var(--space-1); line-height: 1.2; outline: none; letter-spacing: -.03em; } 
      .story-view__meta { font-size: .875rem; font-weight: 500; color: var(--text-muted); display: block; letter-spacing: .02em; margin-block-end: var(--space-6); }
      
      .story-excerpt__text { font-size: .9375rem; line-height: 1.6; color: var(--text-main); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-shadow: 0 2px 16px color-mix(in oklch, var(--video-gradient) 80%, transparent); font-weight: 500; text-wrap: pretty; opacity: 0.95; } 
      .story-read-more { opacity: 0.85; font-weight: 700; margin-inline-start: var(--space-1); color: var(--text-main); cursor: pointer; transition: opacity 0.3s ease, transform 0.3s var(--ease-spring); display: inline-block; @media (hover: hover) and (pointer: fine) { &:not(.is-disabled):not(:disabled):hover { opacity: 1; transform: scale(1.05); } } }
      
      .story-close-btn { position: absolute; inset-block-start: var(--space-4); inset-inline-end: var(--space-4); z-index: 10; } 
      
      dialog {
        padding: 0; margin: auto; border: none; background: transparent; color: var(--text-main); overflow: visible; transition: display 0.4s allow-discrete, overlay 0.4s allow-discrete, opacity 0.25s var(--ease-out); opacity: 0; 
        &[open] { opacity: 1; @starting-style { opacity: 0; } } 
        &::backdrop { 
          background: color-mix(in oklch, var(--c-black-pure) 20%, transparent); 
          backdrop-filter: blur(0px); opacity: 0; 
          transition: opacity 0.25s var(--ease-out), backdrop-filter 0.5s var(--ease-spring), background-color 0.25s var(--ease-out), display 0.4s allow-discrete, overlay 0.4s allow-discrete; 
        } 
        &[open]::backdrop { 
          opacity: var(--bg-opacity, 1); 
          backdrop-filter: blur(calc(20px * var(--bg-opacity, 1))) saturate(120%); 
          background: color-mix(in oklch, var(--c-black-pure) 50%, transparent); 
          @starting-style { opacity: 0; backdrop-filter: blur(0px); } 
        } 
      } 
      dialog.is-dragging-backdrop::backdrop { transition: none !important; }
      
      :is(.story-sheet, .story-popup) { position: fixed; inset: 0; z-index: 100; pointer-events: none; &[open] { pointer-events: auto; } } 
      :is(.story-sheet__content, .story-popup__content, .story-card) { position: relative; background-color: var(--surface-glass-bg); backdrop-filter: var(--surface-glass-blur); z-index: 101; display: flex; flex-direction: column; contain: paint; border: 1px solid var(--glass-border); box-shadow: var(--shadow-floating), var(--glass-highlight); } 
      
      @keyframes popupFadeIn { 0% { opacity: 0; transform: translateY(var(--space-12)) scale(0.92); filter: blur(12px); } 100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0px); } }
      
      .story-sheet {
        margin-block-start: auto; margin-block-end: 0; inline-size: 100%; max-inline-size: 100vw; border-radius: var(--space-10) var(--space-10) 0 0; 
        &.is-exiting::backdrop { opacity: 0; } 
        .story-body { padding-block-end: calc(var(--space-12) + var(--sheet-y, 0px)); }
        &[open] .story-sheet__content .story-header, &[open] .story-sheet__content .story-body { opacity: 1; transform: translateY(0); }
        &[open] .story-body__cms-content > * { animation: slideUpContent 0.6s var(--ease-spring) backwards; &:nth-child(1) { animation-delay: 0.1s; } &:nth-child(2) { animation-delay: 0.15s; } &:nth-child(3) { animation-delay: 0.2s; } &:nth-child(4) { animation-delay: 0.25s; } }
      } 
      
      .story-sheet__content {
        border-radius: var(--space-10) var(--space-10) 0 0; inline-size: 100%; padding: var(--space-2) 0 max(var(--space-8), env(safe-area-inset-bottom)); block-size: 100dvh; max-block-size: 100dvh; padding-block-start: max(var(--space-6), env(safe-area-inset-top)); will-change: transform; border-bottom: none; transform: translate3d(0, 100dvh, 0); transition: border-radius 0.25s var(--ease-out); 
        overscroll-behavior-y: none;
        &.is-dragging { border-radius: var(--space-12) var(--space-12) 0 0; .story-sheet__handle { background-color: color-mix(in oklch, var(--text-main) 60%, transparent); transform: scale(1.6, 0.4); inline-size: var(--space-16); } } 
        .story-header { opacity: 0; transform: translateY(var(--space-4)); transition: opacity 0.25s var(--ease-out) 0.05s, transform 0.25s var(--ease-out) 0.05s; } 
        .story-body { opacity: 0; transform: translateY(var(--space-5)); transition: opacity 0.25s var(--ease-out) 0.1s, transform 0.25s var(--ease-out) 0.1s; } 
      } 
      
      .story-popup__content {
        inline-size: var(--card-inline-size); padding-block: var(--space-8) 0; opacity: 0; transform: translateY(var(--space-8)) scale(0.95); max-block-size: calc(100dvh - var(--space-16)); border-radius: var(--frame-radius); transition: transform 0.25s var(--ease-out), opacity 0.25s var(--ease-out); 
        &.is-entering { animation: popupFadeIn 0.3s var(--ease-out) forwards; }
      } 
      
      .story-popup {
        &[open] .story-popup__content { opacity: 1; transform: translateY(0) scale(1); } 
        &.is-exiting .story-popup__content { transform: translate3d(var(--exit-translate-x, 0), var(--space-12), 0) scale(0.92) !important; opacity: 0 !important; filter: blur(8px) !important; transition: transform 0.25s var(--ease-out), opacity 0.25s var(--ease-out), filter 0.25s var(--ease-out) !important; } 
        &.is-exiting::backdrop { opacity: 0; }
      }
      
      .story-sheet__handle-wrapper {
        inline-size: 100%; padding-block: var(--space-4) var(--space-6); cursor: grab; display: flex; justify-content: center; flex-shrink: 0; 
        touch-action: none; -webkit-user-drag: none;
        &:active { cursor: grabbing; .story-sheet__handle { background-color: color-mix(in oklch, var(--text-main) 60%, transparent); transform: scale(1.6, 0.4); inline-size: var(--space-16); } } 
      } 
      .story-sheet__handle { inline-size: var(--space-14); block-size: 6px; background-color: color-mix(in oklch, var(--text-main) 20%, transparent); border-radius: var(--space-4); transition: transform 0.4s var(--ease-spring), background-color 0.2s var(--ease-out), inline-size 0.4s var(--ease-spring); cursor: inherit; } 
      
      .story-card { display: none; inline-size: var(--card-inline-size); max-block-size: calc(100dvh - var(--space-16)); border-radius: var(--frame-radius); padding-block-start: var(--space-8); overflow: hidden; } 
      :is(.story-dynamic-area, .story-view) { display: flex; flex-direction: column; min-block-size: 0; flex: 1 1 auto; } 
      .story-header { flex-shrink: 0; padding-inline: var(--space-10) 4.5rem; margin-block-end: var(--space-6); } 
      
      .story-body {
        flex: 1 1 auto; overflow-y: auto; padding-inline: var(--space-10); padding-block-end: var(--space-12); min-block-size: 0; overscroll-behavior-y: contain; scrollbar-width: thin; scrollbar-color: color-mix(in oklch, var(--text-main) 20%, transparent) transparent; 
        @media (hover: hover) and (pointer: fine) { &::-webkit-scrollbar-thumb:hover { background: color-mix(in oklch, var(--text-main) 40%, transparent); } } 
      } 
      
      .story-body__cms-content {
        font-size: 1.0625rem; color: var(--text-sub); line-height: 1.75; font-weight: 500; text-wrap: pretty; 
        p { margin-block-end: var(--space-6); } 
        strong, b { color: var(--text-main); font-weight: 700; } 
        code { background: color-mix(in oklch, var(--text-main) 12%, transparent); padding: var(--space-1) var(--space-2); border-radius: var(--space-2); font-family: ui-monospace, SFMono-Regular, monospace; font-size: .9em; border: 1px solid var(--glass-border); color: var(--text-main); }
      }
      
      @keyframes slideUpContent { from { opacity: 0; transform: translateY(var(--space-5)); } to { opacity: 1; transform: translateY(0); } } 
      
      .custom-toast {
        position: fixed; inset-block-end: max(var(--space-12), env(safe-area-inset-bottom)); inset-inline-start: 50%; transform: translateX(-50%) translateY(var(--space-12)) scale(0.8); background: color-mix(in oklch, var(--surface-glass-bg) 98%, transparent); color: var(--text-main); padding: var(--space-4) var(--space-8); border-radius: var(--space-12); font-size: .9375rem; font-weight: 700; z-index: 1000; opacity: 0; transition: opacity 0.4s var(--ease-out), transform 0.5s var(--ease-spring); backdrop-filter: var(--surface-glass-blur); pointer-events: auto; cursor: pointer; box-shadow: var(--shadow-floating), var(--glass-highlight); border: 1px solid var(--glass-border); letter-spacing: .02em; 
        &.show { transform: translateX(-50%) translateY(0) scale(1); opacity: 1; } 
      }
      
      .is-eco-mode .ambient-layer { display: none !important; animation: none !important; }
      .is-eco-mode .story-video-wrapper::before { display: none !important; } 
      .is-eco-mode .ripple-edge { display: none !important; }
      .is-eco-mode .story-video-wrapper::after { box-shadow: none !important; background: linear-gradient(to bottom, transparent 60%, var(--bg-base) 100%) !important; }

      /* --- PULL TO CLOSE INDICATOR --- */
      .pull-indicator {
        position: absolute; inset-inline-start: 50%; transform: translateX(-50%) scale(0.8);
        display: flex; flex-direction: column; align-items: center; gap: var(--space-2);
        color: var(--text-muted); opacity: 0; transition: opacity 0.3s var(--ease-out), color 0.3s var(--ease-out);
        pointer-events: none; z-index: 5; will-change: transform, opacity;
      }
      .pull-indicator--top { inset-block-start: max(var(--space-12), env(safe-area-inset-top)); }
      .pull-indicator--bottom { inset-block-end: max(var(--space-12), env(safe-area-inset-bottom)); }
      .pull-indicator__icon {
        display: flex; align-items: center; justify-content: center;
        inline-size: var(--space-10); block-size: var(--space-10); border-radius: 50%;
        background-color: var(--glass-bg); backdrop-filter: var(--surface-glass-blur); border: 1px solid var(--glass-border);
        transition: transform 0.4s var(--ease-spring), background-color 0.3s var(--ease-out);
      }
      .pull-indicator__text { font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.02em; }
      .pull-indicator.is-visible { opacity: 1; }
      .pull-indicator.is-ready { color: var(--text-main); }
      .pull-indicator.is-ready .pull-indicator__icon { transform: rotate(180deg) scale(1.1); background-color: color-mix(in oklch, var(--text-main) 15%, transparent); color: var(--text-main); }
    }
    
    @layer utilities {
      @container story-player (width < 48rem) {
        .story-popup { display: none !important; }
        .story-header, .story-body { padding-inline: var(--space-6); }
        .layout-wrapper.is-ui-open .story-viewport { filter: brightness(0.6) !important; transform-origin: top center; transform: translateY(max(var(--space-4), env(safe-area-inset-top))) scale(0.94); border-radius: var(--space-10); box-shadow: 0 40px 80px var(--shadow-base); transition: transform 0.25s var(--ease-out), filter 0.25s var(--ease-out), border-radius 0.25s var(--ease-out); }
        .story-sheet[open]::backdrop { background: color-mix(in oklch, var(--bg-base) 75%, transparent) !important; backdrop-filter: blur(8px) !important; }
        
        .desktop-controls-wrapper { display: none !important; }
        .layout-wrapper.is-ui-open .story-viewport .story-mobile-top-actions { opacity: 0 !important; pointer-events: none !important; visibility: hidden !important; transform: scale(0.9) !important; transition: transform 0.25s var(--ease-out), opacity 0.2s var(--ease-out), visibility 0.2s var(--ease-out) !important; }
        .layout-wrapper.is-ui-open .story-viewport :is(.story-excerpt, .story-player-actions, .story-top-actions, .story-progress-bar-wrapper) { opacity: 0 !important; pointer-events: none !important; visibility: hidden !important; transform: scale(0.9) !important; transition: transform 0.25s var(--ease-out), opacity 0.2s var(--ease-out), visibility 0.2s var(--ease-out) !important; }
        .layout-wrapper.is-ui-open .story-video-wrapper::after { opacity: 0 !important; visibility: hidden !important; }
        
        /* MOBILE ONLY: Hide UI During Pinch Zoom */
        .layout-wrapper.is-gesture-active[data-action="pinch"] .story-viewport :is(.story-excerpt, .story-player-actions, .story-top-actions, .story-progress-bar-wrapper, .story-mobile-top-actions) { 
          opacity: 0 !important; pointer-events: none !important; visibility: hidden !important; 
          transform: translateY(var(--space-5)) scale(0.95) !important; 
          transition: transform 0.25s var(--ease-out), opacity 0.2s var(--ease-out), visibility 0.2s var(--ease-out) !important; 
        }
        .layout-wrapper.is-gesture-active[data-action="pinch"] .story-video-wrapper::after { opacity: 0 !important; visibility: hidden !important; }
      }
      
      @container story-player (width >= 48rem) {
        .story-loader__spinner-simple { display: none; }
        .story-loader__spinner-complex { display: block; inline-size: var(--space-16); block-size: var(--space-16); position: relative; pointer-events: none; filter: drop-shadow(0 8px 16px var(--shadow-base)); }
        .story-loader__container { position: absolute; inline-size: 100%; block-size: 100%; animation: story-spin-linear 1.568s linear infinite; }
        .story-loader__rotator { position: absolute; inline-size: 100%; block-size: 100%; animation: story-spin-ease 5332ms cubic-bezier(.4, 0, .2, 1) infinite both; }
        .story-loader__left, .story-loader__right { position: absolute; inset-block: 0; overflow: hidden; }
        .story-loader__left { inset-inline-start: 0; inset-inline-end: 49%; }
        .story-loader__right { inset-inline-start: 49%; inset-inline-end: 0; }
        .story-loader__circle { box-sizing: border-box; position: absolute; inline-size: 200%; block-size: 100%; border-style: solid; border-color: var(--text-main) var(--text-main) transparent; border-radius: 50%; border-width: 8px; }
        .story-loader__left .story-loader__circle { inset-inline-start: 0; inset-inline-end: -100%; border-right-color: transparent; animation: story-spin-left 1333ms cubic-bezier(.4, 0, .2, 1) infinite both; }
        .story-loader__right .story-loader__circle { inset-inline-start: -100%; inset-inline-end: 0; border-left-color: transparent; animation: story-spin-right 1333ms cubic-bezier(.4, 0, .2, 1) infinite both; }
        
        .story-sheet { display: none !important; }
        .story-mobile-top-actions { display: none !important; }
        .ambient-layer { display: block; }
        .story-feed { gap: var(--space-10); padding-block: 5dvh; }
        .story-slot { inline-size: auto; block-size: 90dvh; aspect-ratio: 9/16; }
        .story-container, .story-dummy-card { border-radius: var(--frame-radius); box-shadow: var(--shadow-floating); }
        .desktop-controls-wrapper { inset-block: 0; margin-block: auto; justify-content: center; }
        .desktop-top-actions { position: absolute; inset-block-start: max(var(--space-6), env(safe-area-inset-top)); inset-inline-end: 0; display: flex; gap: var(--space-4); align-items: center; }
      }
      
      @container story-player (width < 80rem) {
        .layout-wrapper.is-ui-open .desktop-controls-wrapper { opacity: 0; pointer-events: none; }
        .layout-wrapper.is-ui-open .story-viewport { filter: blur(20px) brightness(.5); transform: scale(0.95); }
        .layout-wrapper.is-ui-open .story-viewport :is(.story-excerpt, .story-player-actions, .story-top-actions, .story-progress-bar-wrapper) { opacity: 0 !important; pointer-events: none !important; visibility: hidden !important; }
        .layout-wrapper.is-ui-open .story-video-wrapper::after { opacity: 0 !important; visibility: hidden !important; }
      }
      
      @container story-player (width >= 80rem) {
        .story-popup { display: none !important; }
        .ambient-layer { opacity: .75; }
        .story-feed { gap: var(--space-12); padding-block: 6dvh; }
        .story-slot { block-size: 88dvh; }
        .layout-wrapper.is-ui-open .story-feed { transform: translateX(calc((var(--card-inline-size) + var(--space-12)) / -2)); }
        .story-card { display: flex; position: fixed; inset-inline-start: calc(50% + (88dvh * 9 / 32) + var(--space-10)); inset-block-start: 50%; transform: translateY(-50%) translateX(var(--space-16)) scale(0.95); margin: 0; opacity: 0; pointer-events: none; transition: all .6s var(--ease-spring); z-index: 100; }
        .layout-wrapper.is-ui-open .story-card { opacity: 1; pointer-events: auto; transform: translateY(-50%) translateX(calc((var(--card-inline-size) + var(--space-12)) / -2)) scale(1); }
        .desktop-controls-wrapper { inset-inline-end: var(--space-14); }
        .layout-wrapper.is-ui-open .desktop-controls-wrapper, .layout-wrapper.is-ui-open .story-container.show-ui .story-player-actions, .layout-wrapper.is-ui-open .story-container.show-ui .story-top-actions { opacity: 1; pointer-events: auto; }
      }
      
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
        .is-breathing, .is-inner-breathing { animation: none !important; transform: none !important; }
        .story-popup__content, .story-card, .story-excerpt, .story-player-actions, .story-top-actions, .story-mobile-top-actions { transition: none !important; transform: none !important; }
      }
    }
  </style>
</head>

<body>
  <header class="demo-header">
    <h1>NextGen Story</h1>
    <p>A living, organic, and ultra-fluid storytelling library for the modern web. Zero boilerplate, fully accessible, and purely driven by physics.</p>
  </header>

  <div class="story-tray">
    <div class="story-ring-wrapper" data-index="0" aria-label="View Architecture Story" tabindex="0" role="button">
      <div class="story-ring"><div class="story-ring-inner"><img src="https://i.ytimg.com/vi/lxSM-MYJsA8/maxresdefault.jpg" alt="Modern Architecture" decoding="async" /></div></div>
      <div class="story-label">Architecture</div>
    </div>
    <div class="story-ring-wrapper" data-index="1" aria-label="View Features Story" tabindex="0" role="button">
      <div class="story-ring"><div class="story-ring-inner"><img src="https://images.unsplash.com/photo-1682687220742-aba13b6e50ba?q=80&w=200&auto=format&fit=crop" alt="Features" decoding="async" /></div></div>
      <div class="story-label">Features</div>
    </div>
    <div class="story-ring-wrapper" data-index="2" aria-label="View Cinematic Story" tabindex="0" role="button">
      <div class="story-ring"><div class="story-ring-inner"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/0c/ElephantsDreamPoster.jpg/960px-ElephantsDreamPoster.jpg" alt="Cinematic" decoding="async" /></div></div>
      <div class="story-label">Cinematic</div>
    </div>
  </div>

  <section class="features-grid">
    <div class="feature-card"><h3>Fluid Physics</h3><p>Spring-based animations for an organic and satisfying tactile response.</p></div>
    <div class="feature-card"><h3>Smart Reactions</h3><p>Double-tap to like with stateful emojis and anti-spam debouncing.</p></div>
    <div class="feature-card"><h3>Zero Boilerplate</h3><p>Just initialize the JS class and let the library handle the DOM injection.</p></div>
  </section>

  <script id="library-js" type="module">
    "use strict";
    
    let ttPolicy;
    if (window.trustedTypes && trustedTypes.createPolicy) {
      ttPolicy = trustedTypes.createPolicy('nextgenPolicy', {
        createHTML: string => window.DOMPurify ? DOMPurify.sanitize(string) : string
      });
    }

    const MOCK_USER = { id: 'usr_ledi_001', username: 'ledi_dev', reactions: new Map([['vid_1_1', '❤️']]) };
    
    const DEFAULT_CONFIG = Object.freeze({
      API_URL: '', API_HEADERS: {}, startIndex: undefined, TOAST_DURATION_MS: 3000, CROSSFADE_DURATION_MS: 300,
      AUTOPLAY_CHECK_MS: 1500, THUMBNAIL_MAX_CACHE: 50, VIRTUAL_WINDOW_SIZE: 2, DEFAULT_VOLUME: 100, STORAGE_KEY: 'nextgen_story_state',
      
      /* NEW PATCH: Custom Templates & Lifecycle Hooks */
      renderExcerpt: null, 
      renderContext: null, 
      renderActions: null,
      onStoryChange: null,
      onReactionTriggered: null,
      onContextOpened: null,
      
      /* NEW PATCH: i18n Localization */
      locale: {
        videoPlaying: "Video diputar",
        videoPaused: "Video dijeda",
        unmuteAudio: "Suara diaktifkan",
        muteAudio: "Suara dibisukan",
        readMore: "Lihat detail",
        interactiveMode: "Mode kontrol interaktif",
        detailsOpened: "Detail dibuka",
        detailsClosed: "Detail ditutup",
        volume: "Volume",
        noTitle: "Tanpa Judul",
        noInfo: "Informasi tidak tersedia",
        accessDenied: "Akses Ditolak",
        openInYouTube: "Buka di YouTube",
        connectionLost: "Koneksi Terputus",
        checkNetwork: "Silakan periksa jaringan Anda.",
        tryAgain: "Coba Lagi",
        videoUnavailable: "Video Tidak Tersedia",
        mediaFailed: "Media ini gagal dimuat atau telah dihapus.",
        skip: "Lewati",
        pullToClose: "Lepas untuk menutup",
        pullDown: "Tarik ke bawah",
        pullUp: "Tarik ke atas",
        failedToLoad: "Gagal memuat konten media.",
        internetDisconnected: "Koneksi internet terputus.",
        internetRestored: "Koneksi pulih.",
        copiedToClipboard: "Tautan berhasil disalin ke clipboard 📋",
        failedToShare: "Gagal membagikan tautan."
      }
    });

    const DOM_SELECTORS = {
      ROOT: '.js-layout-wrapper', STORY_CONTAINER: '.js-story-container', MAIN_MEDIA: '.main-media-container',
      AMBIENT_MEDIA: '.ambient-media-container', AMBIENT_WRAPPER: '.js-ambient-container', THUMBNAIL_OVERLAY: '.js-thumbnail-overlay',
      PROGRESS_WRAPPER: '.js-progress-wrapper', FEED: '.js-story-feed', BTN_PLAY: '.js-btn-play', BTN_PREV: '.js-btn-prev',
      BTN_NEXT: '.js-btn-next', BTN_MUTE: '.js-btn-mute', BTN_OPEN_CONTEXT: '.js-btn-open-context', BTN_CLOSE: '.js-btn-close',
      BTN_REACTION: '.js-btn-reaction', REACTION_WRAPPER: '.js-reaction-wrapper', REACTION_CONTAINER: '.js-reaction-container',
      BTN_SHARE: '.js-btn-share', BTN_CLEAN: '.js-btn-clean', VOLUME_SLIDER: '.js-volume-slider', CENTER_PLAY_ICON: '.js-center-play',
      CENTER_REACTION: '.js-center-reaction', GESTURE_LAYER: '.js-gesture-layer', ERROR_OVERLAY: '.js-error-overlay',
      ERROR_TITLE: '.js-error-title', ERROR_DESC: '.js-error-desc', ERROR_RETRY: '.js-error-retry', SHEET_CONTENT: '.story-sheet__content'
    };

    const MEDIA_STATE = { UNSTARTED: -1, ENDED: 0, PLAYING: 1, PAUSED: 2, BUFFERING: 3 };
    const UI_ICONS = {
      play: `<i data-lucide="play"></i>`, pause: `<i data-lucide="pause"></i>`, mute: `<i data-lucide="volume-x"></i>`,
      volumeLow: `<i data-lucide="volume-1"></i>`, volumeHigh: `<i data-lucide="volume-2"></i>`, heart: `<i data-lucide="heart"></i>`,
      heartFilled: `<i data-lucide="heart" fill="currentColor"></i>`
    };

    class StateMachine {
      constructor(initialState, config) { this.state = initialState; this.config = config; }
      dispatch(action) {
        const currentStateConfig = this.config[this.state]; const nextState = currentStateConfig.transitions[action];
        if (nextState) {
          if (currentStateConfig.onExit) currentStateConfig.onExit();
          this.state = nextState;
          if (this.config[this.state].onEnter) this.config[this.state].onEnter();
          return true;
        }
        return false;
      }
      getState() { return this.state; }
    }

    class EventBus extends EventTarget {
      on(type, listener, options) { this.addEventListener(type, (e) => listener(e.detail), options); }
      emit(type, detail) { this.dispatchEvent(new CustomEvent(type, { detail })); }
    }

    class A11yAnnouncer {
      static speak(message) {
        const region = document.querySelector('.js-a11y');
        if (region) { region.textContent = ''; setTimeout(() => { region.textContent = message; }, 50); }
      }
    }

    class DOMHelper {
      static get root() { return document.querySelector(DOM_SELECTORS.ROOT) || document.body; }
      static select(selector) { return this.root.querySelector(selector); }
      static selectAll(selector) { return this.root.querySelectorAll(selector); }
      static updateElements(selector, property, value) { this.selectAll(selector).forEach(element => { element[property] = value; }); }
      
      static sanitizeHTML(stringHTML) {
        if (!stringHTML) return '';
        // Langsung eksekusi, tanpa blok try/catch atau pengecekan typeof!
        const clean = window.DOMPurify.sanitize(stringHTML, {
          ALLOWED_URI_REGEXP: /^(?:(?:(?:f|ht)tps?|mailto|tel|callto|cid|xmpp|sms):|[^a-z]|[a-z+.\-]+(?:[^a-z+.\-:]|$))/i,
          FORBID_ATTR: ['style', 'onmouseover', 'onload', 'onerror']
        });
        return ttPolicy ? ttPolicy.createHTML(clean) : clean;
      }
    }

    /* PATCH: FLIP Animation untuk Transisi Container Mulus */
    class FluidBounds {
      static animate(containerElement, domChangeCallback) {
        if (!containerElement || window.matchMedia('(prefers-reduced-motion: reduce)').matches) { domChangeCallback(); return; }
        
        const firstRect = containerElement.getBoundingClientRect();
        const firstRadius = window.getComputedStyle(containerElement).borderRadius;
        
        domChangeCallback();
        
        const lastRect = containerElement.getBoundingClientRect();
        const lastRadius = window.getComputedStyle(containerElement).borderRadius;
        
        const deltaX = firstRect.left - lastRect.left;
        const deltaY = firstRect.top - lastRect.top;
        const deltaW = firstRect.width / lastRect.width;
        const deltaH = firstRect.height / lastRect.height;
        
        if (Math.abs(deltaX) < 1 && Math.abs(deltaY) < 1 && Math.abs(deltaW - 1) < 0.01 && Math.abs(deltaH - 1) < 0.01) return;
        
        containerElement.animate([
          { transformOrigin: 'top left', transform: `translate(${deltaX}px, ${deltaY}px) scale(${deltaW}, ${deltaH})`, borderRadius: firstRadius },
          { transformOrigin: 'top left', transform: 'translate(0, 0) scale(1, 1)', borderRadius: lastRadius }
        ], { 
          duration: 500, 
          easing: 'linear(0, 0.006, 0.025 1.8%, 0.103 4%, 0.233 6.4%, 0.407 9.1%, 0.589 12%, 0.748 15.2%, 0.869 18.6%, 0.949 22.3%, 0.995 26.5%, 1.018 31.4%, 1.025 37.1%, 1.018 43.8%, 1.006 51.5%, 0.998 60.5%, 1)',
          fill: 'both' 
        });
      }
    }

    const IconHelper = {
      update(element, iconString) {
        if (!element) return;
        const safeIcon = typeof window.DOMPurify !== 'undefined' ? window.DOMPurify.sanitize(iconString) : iconString;
        const finalHTML = ttPolicy ? ttPolicy.createHTML(safeIcon) : safeIcon;
        if (element.classList.contains('js-center-play') || element.classList.contains('js-center-reaction')) {
          element.innerHTML = finalHTML;
          if (window.lucide?.createIcons) window.lucide.createIcons({ root: element });
          return;
        }
        element.style.transition = 'transform 0.1s var(--ease-out), opacity 0.1s var(--ease-out)';
        element.style.transform = 'scale(0.6) rotate(-15deg)'; element.style.opacity = '0';
        setTimeout(() => {
          element.innerHTML = finalHTML;
          if (window.lucide?.createIcons) window.lucide.createIcons({ root: element });
          element.style.transition = 'transform 0.4s var(--ease-spring), opacity 0.2s var(--ease-out)';
          element.style.transform = 'scale(1) rotate(0deg)'; element.style.opacity = '1';
          setTimeout(() => { element.style.transition = ''; element.style.transform = ''; element.style.opacity = ''; }, 400);
        }, 100);
      }
    };

    class MediaUtils {
      static parseYouTubeData(url) {
        if (!url) return { isShort: false, videoId: '' };
        if (url.includes('/shorts/')) return { isShort: true, videoId: url.split('/shorts/')[1].split('?')[0] };
        const match = url.match(/^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/);
        return { isShort: false, videoId: (match && match[2].length === 11) ? match[2] : '' };
      }
      static slugify(text) { return text.toString().toLowerCase().replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '-').replace(/-+/g, '-'); }
      static rampUpVolume(mediaInstance, targetVolume, duration = 300) {
        if (!mediaInstance || typeof mediaInstance.setVolume !== 'function') return;
        if (mediaInstance._rampInterval) { clearInterval(mediaInstance._rampInterval); mediaInstance._rampInterval = null; }
        mediaInstance.unMute?.();
        let currentVol = 0; const steps = 10, stepTime = duration / steps, increment = targetVolume / steps;
        mediaInstance.setVolume(0);
        mediaInstance._rampInterval = setInterval(() => {
          currentVol += increment;
          if (currentVol >= targetVolume) { mediaInstance.setVolume(targetVolume); clearInterval(mediaInstance._rampInterval); mediaInstance._rampInterval = null; }
          else { mediaInstance.setVolume(currentVol); }
        }, stepTime);
      }
      static executeIdle(cb) { window.requestIdleCallback(cb); }
    }

    class ToastService {
      static timer = null;
      static show(message) {
        let toastElement = document.querySelector('.custom-toast');
        if (!toastElement) {
          toastElement = document.createElement('div'); toastElement.className = 'custom-toast'; toastElement.setAttribute('role', 'status');
          document.body.appendChild(toastElement); toastElement.style.pointerEvents = 'auto'; toastElement.style.cursor = 'pointer';
          const hideToast = () => { toastElement.classList.remove('show'); clearTimeout(this.timer); };
          toastElement.addEventListener('click', hideToast); toastElement.addEventListener('touchstart', hideToast, { passive: true });
        }
        toastElement.innerText = message;
        void toastElement.offsetWidth; // Force reflow
        toastElement.classList.add('show');
        clearTimeout(this.timer);
        this.timer = setTimeout(() => { toastElement.classList.remove('show'); }, 3000);
        A11yAnnouncer.speak(message);
      }
    }

    class HapticsEngine {
      static trigger(pattern) { navigator.vibrate?.(pattern); }
      static light() { this.trigger(10); } static medium() { this.trigger(25); } static heavy() { this.trigger([30, 40, 30]); } static tick() { this.trigger(5); }
    }

    class EventRegistry {
      static controllers = new Map();
      static add(target, type, handler, options = {}, group = 'global') {
        if (!this.controllers.has(group)) this.controllers.set(group, new AbortController());
        const opts = typeof options === 'boolean' ? { capture: options } : { ...options };
        opts.signal = this.controllers.get(group).signal;
        target.addEventListener(type, handler, opts);
      }
      static clear(group = 'global') {
        if (this.controllers.has(group)) { this.controllers.get(group).abort(); this.controllers.delete(group); }
      }
    }

    class WakeLockManager {
      static wakeLock = null; static isRequested = false;
      static async request() {
        this.isRequested = true;
        if (navigator.wakeLock && !this.wakeLock && document.visibilityState === 'visible') {
          try { this.wakeLock = await navigator.wakeLock.request('screen'); this.wakeLock.addEventListener('release', () => { this.wakeLock = null; }); } catch (e) { console.debug('WakeLock request failed', e); }
        }
      }
      static release() {
        this.isRequested = false;
        if (this.wakeLock) { this.wakeLock.release().catch(() => {}); this.wakeLock = null; }
      }
      static handleVisibilityChange() { if (document.visibilityState === 'visible' && this.isRequested) this.request(); }
    }
    document.addEventListener('visibilitychange', () => WakeLockManager.handleVisibilityChange(), { passive: true });

    /* PATCH: ADSR Envelope pada UISoundFX */
    class UISoundFX {
      static ctx = null; static isUIMuted = false; static lastScrubTime = 0;
      static init() {
        if (!this.ctx) this.ctx = new window.AudioContext();
        if (this.ctx && this.ctx.state === 'suspended') this.ctx.resume();
      }
      static play(type, xRatio = 0.5) {
        if (this.isUIMuted || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        if (!this.ctx) this.init(); if (!this.ctx || this.ctx.state !== 'running') return;
        try {
          const now = this.ctx.currentTime; const outNode = this.ctx.destination; 
          const panner = this.ctx.createStereoPanner ? this.ctx.createStereoPanner() : null;
          let connectTarget = outNode;
          if (panner) { panner.pan.value = (xRatio * 2) - 1; panner.connect(outNode); connectTarget = panner; }
          
          if (type === 'pop') {
            const osc = this.ctx.createOscillator(); const gain = this.ctx.createGain(); 
            osc.type = 'sine';
            osc.frequency.setValueAtTime(350, now); 
            osc.frequency.exponentialRampToValueAtTime(150, now + 0.12); 
            gain.gain.setValueAtTime(0, now); 
            gain.gain.linearRampToValueAtTime(0.12, now + 0.015); 
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.12); 
            osc.connect(gain); gain.connect(connectTarget); 
            osc.start(now); osc.stop(now + 0.12);
          } else if (type.startsWith('swoosh')) {
            const osc = this.ctx.createOscillator(); const gain = this.ctx.createGain(); 
            osc.type = 'sine';
            if (type === 'swoosh_up') { 
              osc.frequency.setValueAtTime(100, now); osc.frequency.exponentialRampToValueAtTime(400, now + 0.2); 
            } else { 
              osc.frequency.setValueAtTime(400, now); osc.frequency.exponentialRampToValueAtTime(100, now + 0.2); 
            }
            gain.gain.setValueAtTime(0, now); 
            gain.gain.linearRampToValueAtTime(0.04, now + 0.08); 
            gain.gain.linearRampToValueAtTime(0, now + 0.2);
            osc.connect(gain); gain.connect(connectTarget); 
            osc.start(now); osc.stop(now + 0.2);
          } else if (type === 'tick') {
            const osc = this.ctx.createOscillator(); const gain = this.ctx.createGain(); 
            osc.type = 'triangle'; 
            osc.frequency.setValueAtTime(600, now);
            osc.frequency.exponentialRampToValueAtTime(300, now + 0.03); 
            gain.gain.setValueAtTime(0, now);
            gain.gain.linearRampToValueAtTime(0.06, now + 0.005); 
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.03);
            osc.connect(gain); gain.connect(connectTarget); 
            osc.start(now); osc.stop(now + 0.03);
          }
        } catch (e) { console.debug(e); }
      }
      static playGearTick(velocity) {
        if (this.isUIMuted || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        if (!this.ctx) this.init(); if (!this.ctx || this.ctx.state !== 'running') return;
        const now = this.ctx.currentTime; const minDelay = Math.max(0.02, 0.1 - (Math.abs(velocity) * 0.005));
        if (now - this.lastScrubTime < minDelay) return;
        this.lastScrubTime = now;
        try {
          const osc = this.ctx.createOscillator(); const gain = this.ctx.createGain(); const filter = this.ctx.createBiquadFilter();
          const baseFreq = 400 + (Math.abs(velocity) * 15);
          osc.type = 'square'; osc.frequency.setValueAtTime(baseFreq, now); osc.frequency.exponentialRampToValueAtTime(baseFreq * 0.5, now + 0.02);
          filter.type = 'lowpass'; filter.frequency.value = 1000 + (Math.abs(velocity) * 20);
          gain.gain.setValueAtTime(0.0, now); gain.gain.linearRampToValueAtTime(0.08, now + 0.005); gain.gain.exponentialRampToValueAtTime(0.001, now + 0.03);
          osc.connect(filter); filter.connect(gain); gain.connect(this.ctx.destination);
          osc.start(now); osc.stop(now + 0.03);
        } catch (e) { console.debug(e); }
      }
    }

    class DominantColorService {
      static worker = null; static workerBlobUrl = null; static callbacks = new Map(); static idCounter = 0;
      static init() {
        if (this.worker) return;
        const workerCode = `
          function rgbToOklch(r, g, b) { 
            let R = r / 255, G = g / 255, B = b / 255; 
            R = R > 0.04045 ? Math.pow((R + 0.055) / 1.055, 2.4) : R / 12.92; 
            G = G > 0.04045 ? Math.pow((G + 0.055) / 1.055, 2.4) : G / 12.92; 
            B = B > 0.04045 ? Math.pow((B + 0.055) / 1.055, 2.4) : B / 12.92; 
            const l = 0.4122214708 * R + 0.5363325363 * G + 0.0514459929 * B; 
            const m = 0.2119034982 * R + 0.6806995451 * G + 0.1073969566 * B; 
            const s = 0.0883024619 * R + 0.2817188376 * G + 0.6299787005 * B; 
            const l_ = Math.cbrt(Math.max(0, l)), m_ = Math.cbrt(Math.max(0, m)), s_ = Math.cbrt(Math.max(0, s)); 
            const L = 0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_; 
            const a = 1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_; 
            const b_ = 0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_; 
            const C = Math.hypot(a, b_); 
            let H = Math.atan2(b_, a) * (180 / Math.PI); 
            if (H < 0) H += 360; 
            return 'oklch(' + (L*100).toFixed(2) + '% ' + C.toFixed(3) + ' ' + H.toFixed(2) + ')'; 
          } 
          self.onmessage = async function(e) { 
            const id = e.data.id; const bitmap = e.data.bitmap; 
            try { 
              const canvas = new OffscreenCanvas(32, 32); const ctx = canvas.getContext('2d', { willReadFrequently: true }); 
              ctx.drawImage(bitmap, 0, 0, 32, 32); const data = ctx.getImageData(0, 0, 32, 32).data; 
              let r1 = 0, g1 = 0, b1 = 0, c1 = 0; let r2 = 0, g2 = 0, b2 = 0, c2 = 0; 
              for (let i = 0; i < data.length; i += 4) { 
                if (data[i + 3] < 128) continue; 
                const y = Math.floor((i / 4) / 32); 
                if (y < 16) { r1 += data[i]; g1 += data[i + 1]; b1 += data[i + 2]; c1++; } 
                else { r2 += data[i]; g2 += data[i + 1]; b2 += data[i + 2]; c2++; } 
              } 
              const mix = 0.60; 
              const gradStart = c1 > 0 ? rgbToOklch(~~((r1 / c1) * mix), ~~((g1 / c1) * mix), ~~((b1 / c1) * mix)) : ''; 
              const gradEnd = c2 > 0 ? rgbToOklch(~~((r2 / c2) * mix), ~~((g2 / c2) * mix), ~~((b2 / c2) * mix)) : ''; 
              self.postMessage({ id: id, gradStart: gradStart, gradEnd: gradEnd }); 
            } catch (err) { 
              self.postMessage({ id: id, error: err.message }); 
            } finally { 
              if (bitmap && bitmap.close) bitmap.close(); 
            } 
          };
        `;
        const blob = new Blob([workerCode], { type: 'application/javascript' });
        this.workerBlobUrl = URL.createObjectURL(blob);
        this.worker = new Worker(this.workerBlobUrl);
        
        this.worker.onmessage = (e) => {
          const { id, gradStart, gradEnd, error } = e.data;
          if (this.callbacks.has(id)) {
            const { elements, isInstant } = this.callbacks.get(id);
            if (!error) {
              if (gradStart) { const metaTheme = document.getElementById('meta-theme-color'); if (metaTheme) metaTheme.setAttribute('content', gradStart); }
              elements.forEach(el => {
                if (!el) return;
                if (isInstant) {
                  const originalTransition = el.style.transition; el.style.transition = 'none';
                  if (gradStart) el.style.setProperty('--grad-start', gradStart); if (gradEnd) el.style.setProperty('--grad-end', gradEnd);
                  void el.offsetHeight; requestAnimationFrame(() => { el.style.transition = originalTransition || ''; });
                } else {
                  if (gradStart) el.style.setProperty('--grad-start', gradStart); if (gradEnd) el.style.setProperty('--grad-end', gradEnd);
                }
              });
            }
            this.callbacks.delete(id);
          }
        };
      }
      static async extract(source, targetElements, isInstant = false) {
        if (!source || !targetElements) return;
        this.init();
        try {
          const bitmap = await createImageBitmap(source, { resizeWidth: 32, resizeHeight: 32 });
          const id = this.idCounter++; const elements = Array.isArray(targetElements) ? targetElements : [targetElements];
          this.callbacks.set(id, { elements, isInstant }); this.worker.postMessage({ id, bitmap }, [bitmap]);
        } catch (e) { console.debug('Failed to extract color', e); }
      }
      static extractFromUrl(url, targetElements) {
        const elements = Array.isArray(targetElements) ? targetElements : [targetElements];
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload = () => { elements.forEach(el => el && el.style.removeProperty('--bg-image')); this.extract(img, targetElements, true); };
        img.onerror = () => { elements.forEach(el => { if (el) { el.style.setProperty('--bg-image', `url('${url}')`); el.style.removeProperty('--grad-start'); el.style.removeProperty('--grad-end'); } }); };
        img.src = url;
      }
      static destroy() {
        if (this.worker) { this.worker.terminate(); this.worker = null; }
        if (this.workerBlobUrl) { URL.revokeObjectURL(this.workerBlobUrl); this.workerBlobUrl = null; }
        this.callbacks.clear(); this.idCounter = 0;
      }
    }

    class StoryDataAdapter {
      constructor(config) { 
        this.apiUrl = config.API_URL || null; 
        this.headers = config.API_HEADERS || {}; 
        this.page = 1; this.hasMore = true; this.isLoading = false; 
        this.abortController = null; // Instansiasi AbortController
      }
      
      async getStories() {
        if (this.isLoading || !this.hasMore) return [];
        
        // PATCH: Batalkan request sebelumnya jika masih berjalan
        if (this.abortController) this.abortController.abort();
        this.abortController = new AbortController();
        
        this.isLoading = true;
        
        const fetchPromise = Promise.try(async () => {
           if (!this.apiUrl) {
             const data = await this._getMockStories(this.page);
             if (this.page >= 3) this.hasMore = false;
             this.page++; return data;
           }
           const response = await fetch(`${this.apiUrl}?page=${this.page}`, { 
             headers: this.headers, priority: 'high', signal: this.abortController.signal 
           });
           if (!response.ok) throw new Error('API request failed');
           const result = await response.json();
           this.hasMore = result.meta ? result.meta.hasMore : (result.data.length > 0);
           this.page++; return this._normalizeData(result.data);
        });

        return fetchPromise.catch(err => {
           if (err.name === 'AbortError') {
             console.debug('Fetch API dibatalkan karena navigasi cepat.');
             return [];
           }
           const isGenuineError = typeof Error.isError === 'function' ? Error.isError(err) : err instanceof Error;
           console.error('Fetch error:', isGenuineError ? err.message : err);
           return [];
        }).finally(() => {
           this.isLoading = false;
        });
      }
      
      async sendAction(endpoint, payload) {
        if (!this.apiUrl) return new Promise(resolve => setTimeout(() => resolve({ success: true }), 300));
        try {
          const response = await fetch(`${this.apiUrl}/${endpoint}`, { method: 'POST', headers: { 'Content-Type': 'application/json', ...this.headers }, body: JSON.stringify(payload), keepalive: true });
          return await response.json();
        } catch (err) { return { success: false, error: err }; }
      }
      async toggleLike(mediaId, emoji) { return this.sendAction('like', { mediaId, emoji }); }
      async removeLike(mediaId) { return this.sendAction('unlike', { mediaId }); }
      async sendAnalytics(mediaId, durationMs) { return this.sendAction('analytics', { mediaId, durationMs }); }
      _normalizeData(data) { return data; }
      async _getMockStories(pageIndicator) {
        return new Promise(resolve => setTimeout(() => {
          resolve([
            { id: `vid_${pageIndicator}_1`, format: 'reels', type: 'youtube', url: 'https://www.youtube.com/watch?v=lxSM-MYJsA8', categories: ['Engineering', 'Showcase'], title: `Arsitektur Modern ${pageIndicator}`, meta: 'NextGen Systems • 2 Jam yang lalu', excerpt: 'Menjelajahi batas-batas infrastruktur modern.', content: '<p>Penjelasan mendalam mengenai <strong>integritas struktural</strong>.</p>' },
            { id: `vid_${pageIndicator}_2`, format: 'story', title: `Update Produk ${pageIndicator} 📸`, meta: 'Template Factory • Baru saja', categories: ['Release', 'Features'], content: '<p>Komponen terbaru siap digunakan.</p>', items: [ { id: `sub_${pageIndicator}_2a`, type: 'image', url: 'https://images.unsplash.com/photo-1682687220742-aba13b6e50ba?q=80&w=1080&auto=format&fit=crop', thumbnail: 'https://images.unsplash.com/photo-1682687220742-aba13b6e50ba?q=80&w=200&auto=format&fit=crop', isVertical: false, duration: 7, excerpt: 'Slide 1: Resolusi visual sejernih kristal.' }, { id: `sub_${pageIndicator}_2b`, type: 'youtube', url: 'https://www.youtube.com/shorts/Km5xz7NKqlA', excerpt: 'Slide 2: Uji coba konten dinamis berdurasi pendek.' }, { id: `sub_${pageIndicator}_2c`, type: 'video', url: 'https://videos.pexels.com/video-files/36753182/15576383_1440_2560_30fps.mp4', excerpt: 'Slide 3: Pengiriman format MP4 native dengan framerate tinggi.', thumbnailFit: 'contain', thumbnail: 'https://images.pexels.com/videos/36753182/pexels-photo-36753182.jpeg?auto=compress&cs=tinysrgb&w=800&loading=lazy' } ] },
            { id: `vid_${pageIndicator}_3`, format: 'reels', type: 'video', url: 'https://media.w3.org/2010/05/bunny/trailer.mp4', categories: ['Cinematic', 'HTML5 Native'], thumbnail: 'https://upload.wikimedia.org/wikipedia/commons/thumb/0/0c/ElephantsDreamPoster.jpg/960px-ElephantsDreamPoster.jpg', isVertical: false, title: `Render Sinematik ${pageIndicator} 🎬`, meta: 'Chronos Grid • 5 Menit yang lalu', excerpt: 'Lanskap luar biasa dari perpaduan waktu.', content: '<p>Muatan MP4 asli diproses secara langsung ke layar.</p>' }
          ]);
        }, 800));
      }
    }

    const UI_FSM_CONFIG = {
      IDLE: { transitions: { START_TRANSITION: 'TRANSITIONING', OPEN_CONTEXT: 'CONTEXT_OPEN' } },
      TRANSITIONING: { transitions: { END_TRANSITION: 'IDLE' } },
      SCRUBBING: { transitions: { END_SCRUB: 'IDLE' } },
      CONTEXT_OPEN: { transitions: { CLOSE_CONTEXT: 'IDLE' } }
    };

    class ApplicationState {
      constructor(config, appEvents) {
        this.config = config; this.appEvents = appEvents; this.prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        
        const savedState = this.loadState();
        this.isGlobalMuted = typeof savedState.isGlobalMuted === 'boolean' ? savedState.isGlobalMuted : true;
        const parsedVolume = Number(savedState.volume);
        this.volume = (!isNaN(parsedVolume) && parsedVolume >= 0 && parsedVolume <= 100) ? parsedVolume : this.config.DEFAULT_VOLUME;
        this.savedVolume = this.volume;
        
        this.currentVideoIndex = typeof savedState.currentVideoIndex === 'number' ? savedState.currentVideoIndex : 0;
        this.currentSubIndex = 0;
        
        this.playlist = []; this.userInteracted = false; this.isApiReady = false; this.wasPlayingBeforeHidden = false; this.errorCount = 0;
        this.currentMedia = null; this.currentAmbient = null; this.timers = { crossfade: null, loading: null }; this.currentUser = MOCK_USER;
        this.watchStartTime = null; this.adapter = new StoryDataAdapter(this.config); this.isSeeking = false; this.targetSeekTime = 0;
        this.fsm = new StateMachine('IDLE', UI_FSM_CONFIG); this.isOffScreen = false; this.lastNavDirection = 1; this.isEcoMode = false; this.ignoreNextTap = false; 
        
        return new Proxy(this, {
          set: (target, property, value) => {
            const oldValue = target[property]; target[property] = value;
            if (oldValue !== value) {
              if (['volume', 'isGlobalMuted', 'savedVolume', 'currentVideoIndex'].includes(property)) {
                const isForceMuteByBrowser = property === 'isGlobalMuted' && !target.userInteracted;
                if (!isForceMuteByBrowser) target.saveState();
                if (property === 'volume' || property === 'isGlobalMuted') target.appEvents.emit('UI:SYNC_VOLUME');
              }
            }
            return true;
          }
        });
      }
      
      async fetchPlaylist() { try { const data = await this.adapter.getStories(); this.playlist = data; return true; } catch (error) { return false; } }
      loadState() { try { const raw = window.localStorage.getItem(this.config.STORAGE_KEY); return raw ? JSON.parse(raw) : {}; } catch(e) { return {}; } }
      saveState() {
        clearTimeout(this._saveTimer);
        this._saveTimer = setTimeout(() => {
          try { window.localStorage.setItem(this.config.STORAGE_KEY, JSON.stringify({ isGlobalMuted: this.isGlobalMuted, volume: this.volume, savedVolume: this.savedVolume, currentVideoIndex: this.currentVideoIndex })); } catch(e) {}
        }, 500);
      }
      getActiveMediaData() { const group = this.playlist[this.currentVideoIndex]; return (group?.items) ? group.items[this.currentSubIndex] : group; }
    }

    const ThumbnailResolver = {
      cache: new Map(), pendingCallbacks: new Map(),
      resolve(data, callback) {
        if (!data) return callback(null);
        const cacheKey = data.type === 'youtube' ? MediaUtils.parseYouTubeData(data.url).videoId : data.url;
        if (this.cache.has(cacheKey)) {
          const cachedValue = this.cache.get(cacheKey);
          if (cachedValue === 'loading') return this.pendingCallbacks.get(cacheKey).push(callback);
          this.cache.delete(cacheKey); this.cache.set(cacheKey, cachedValue); return callback(cachedValue);
        }
        if (this.cache.size >= 50) {
          let deletedCount = 0;
          for (const key of this.cache.keys()) {
            if (this.cache.get(key) !== 'loading') { this.cache.delete(key); deletedCount++; if (deletedCount >= 10) break; }
          }
        }
        this.cache.set(cacheKey, 'loading'); this.pendingCallbacks.set(cacheKey, [callback]);
        const onResolve = (resultUrl) => {
          this.cache.set(cacheKey, resultUrl); const callbacks = this.pendingCallbacks.get(cacheKey) || []; callbacks.forEach(cb => cb(resultUrl)); this.pendingCallbacks.delete(cacheKey);
        };
        if (data.type === 'youtube') {
          const img = new Image(); 
          const fallbackUrl = `https://i.ytimg.com/vi/${cacheKey}/hqdefault.jpg`; 
          const maxResUrl = `https://i.ytimg.com/vi/${cacheKey}/maxresdefault.jpg`;
          
          img.src = maxResUrl;
          img.decode().then(() => {
              onResolve(img.naturalWidth > 120 ? maxResUrl : fallbackUrl);
          }).catch(() => {
              onResolve(fallbackUrl);
          });
          
          setTimeout(() => { if (this.cache.get(cacheKey) === 'loading') onResolve(fallbackUrl); }, 5000); 
        } else if (data.type === 'video') { onResolve(data.thumbnail || null); } else { onResolve(data.thumbnail || data.url || null); }
      }
    };

    class HardwareAwarenessManager {
      static async init(state, appEvents) {
        this.state = state; this.appEvents = appEvents; this.checkStatus();
        if ('connection' in navigator) navigator.connection.addEventListener('change', () => this.checkStatus());
        if ('getBattery' in navigator) {
          try { const battery = await navigator.getBattery(); battery.addEventListener('levelchange', () => this.checkStatus(battery)); battery.addEventListener('chargingchange', () => this.checkStatus(battery)); this.checkStatus(battery); } catch(e) {}
        }
      }
      static checkStatus(battery = null) {
        let isEco = false;
        if ('connection' in navigator) { const conn = navigator.connection; if (conn.saveData || ['slow-2g', '2g', '3g'].includes(conn.effectiveType)) isEco = true; }
        if (battery) { if (!battery.charging && battery.level <= 0.20) isEco = true; }
        if (navigator.hardwareConcurrency && navigator.hardwareConcurrency < 4) isEco = true;
        if (this.state.isEcoMode !== isEco) {
          this.state.isEcoMode = isEco;
          const root = document.querySelector(DOM_SELECTORS.ROOT); if (root) root.classList.toggle('is-eco-mode', isEco);
          if (isEco) ToastService.show(this.state.config.locale.batterySaving || 'Mode Hemat Daya Aktif 🔋');
        }
      }
    }

    class MemoryNetworkManager {
      static activeObjectURLs = new Set(); static preloadedNodes = new Map();
      static init() {}
      
      // PATCH: Menerima parameter currentSubIndex
      static syncVirtualWindow(playlist, currentIndex, currentSubIndex, config) {
        if ('connection' in navigator && (navigator.connection.saveData || ['slow-2g', '2g', '3g'].includes(navigator.connection.effectiveType))) return;
        
        const windowSize = config.VIRTUAL_WINDOW_SIZE || 2; 
        const keysToKeep = new Set();

        // Fungsi Helper untuk Mendaftarkan Preload Media
        const preloadItem = (item) => {
          if (!item) return;
          if (item.type !== 'youtube') keysToKeep.add(item.url);
          if (item.thumbnail) keysToKeep.add(item.thumbnail);

          if (item.type === 'video' && !this.preloadedNodes.has('video_cache_' + item.url)) {
            const preloader = document.createElement('video'); preloader.preload = 'auto'; preloader.muted = true; preloader.playsInline = true; preloader.src = item.url; preloader.style.display = 'none';
            document.body.appendChild(preloader); this.preloadedNodes.set('video_cache_' + item.url, preloader);
          }
          if (item.type !== 'youtube' && item.type !== 'video' && !this.preloadedNodes.has(item.url)) {
            const link = document.createElement('link'); link.rel = 'preload'; link.as = 'image'; link.href = item.url;
            link.fetchPriority = 'low'; // PATCH: Jangan rebutan bandwidth!
            document.head.appendChild(link); this.preloadedNodes.set(item.url, link);
          }
          if (item.thumbnail && !this.preloadedNodes.has(item.thumbnail)) {
            const img = new Image(); 
            img.fetchPriority = 'low'; // PATCH
            img.src = item.thumbnail; 
            this.preloadedNodes.set(item.thumbnail, img);
          }
          if (item.type === 'video') keysToKeep.add('video_cache_' + item.url);
        };

        // 1. PRIORITAS UTAMA: Preload segmen SELANJUTNYA dalam Story yang sedang aktif
        const currentGroup = playlist[currentIndex];
        if (currentGroup && currentGroup.items) {
            preloadItem(currentGroup.items[currentSubIndex]); // Keep segmen saat ini
            if (currentSubIndex + 1 < currentGroup.items.length) {
                preloadItem(currentGroup.items[currentSubIndex + 1]); // Preload segmen selanjutnya
            }
        } else {
            preloadItem(currentGroup);
        }

        // 2. PRIORITAS KEDUA: Preload cover/item pertama dari Story sebelum & sesudahnya (Swipe)
        const minIndex = Math.max(0, currentIndex - windowSize); 
        const maxIndex = Math.min(playlist.length - 1, currentIndex + windowSize);

        for (let i = minIndex; i <= maxIndex; i++) {
          if (i === currentIndex) continue; // Sudah diproses di atas
          const item = playlist[i].items ? playlist[i].items[0] : playlist[i];
          preloadItem(item);
        }

        // Cleanup: Buang media yang sudah keluar dari jangkauan (Hemat RAM)
        for (const key of this.preloadedNodes.keys()) {
          if (!keysToKeep.has(key)) {
            const node = this.preloadedNodes.get(key);
            if (node instanceof HTMLLinkElement) node.remove(); 
            else if (node instanceof HTMLImageElement) node.src = ''; 
            else if (node instanceof HTMLVideoElement) { node.removeAttribute('src'); node.load(); node.remove(); }
            this.preloadedNodes.delete(key);
          }
        }
      }
    }

    class MediaPool {
      static videoPool = []; static MAX_POOL = 3;
      
      static getVideoElement() {
        if (this.videoPool.length > 0) return this.videoPool.pop();
        const video = document.createElement('video'); video.playsInline = true; video.crossOrigin = 'anonymous'; video.preload = 'auto'; return video;
      }
      
      static releaseVideoElement(video) {
        if (!video) return;
        try { video.pause(); video.removeAttribute('src'); video.load(); } catch(e) {}
        const cleanVideo = video.cloneNode(false);
        if (video.parentNode) video.parentNode.replaceChild(cleanVideo, video);
        if (this.videoPool.length < this.MAX_POOL) this.videoPool.push(cleanVideo); else cleanVideo.remove();
      }
      
      static clear() { 
        this.videoPool.forEach(video => { video.removeAttribute('src'); video.load(); video.remove(); }); 
        this.videoPool = []; 
      }
    }

    class BaseMediaHandler {
      constructor(config) { this.container = config.container; this.data = config.data; this.callbacks = config.callbacks || {}; this.isAmbient = config.isAmbient || false; this.appEvents = config.appEvents; this.state = config.state; this.isDestroyed = false; }
      load() {} play() {} pause() {} mute() {} unMute() {} seek(offset) { this.seekTo(this.getCurrentTime() + offset); } seekTo(time) {} getCurrentTime() { return 0; } getDuration() { return 0; } getLoadedFraction() { return 0; } setPlaybackRate(rate) {} isMuted() { return true; } setVolume(level) {} getState() { return MEDIA_STATE.UNSTARTED; }
      destroy() { this.isDestroyed = true; if (this.container) { while(this.container.firstChild) this.container.firstChild.remove(); } }
      emitStateChange(state) { if (this.callbacks.onStateChange) this.callbacks.onStateChange(state); }
    }

    class YouTubeMediaHandler extends BaseMediaHandler {
      constructor(config) { super(config); }
      
      load() {
        if (typeof YT === 'undefined' || !YT.Player) {
          let retries = 0;
          const checkInterval = setInterval(() => {
            if (this.isDestroyed) { clearInterval(checkInterval); return; }
            if (typeof YT !== 'undefined' && YT.Player) { clearInterval(checkInterval); if (!this.isDestroyed) this.load(); }
            if (++retries > 50) { clearInterval(checkInterval); if (!this.isDestroyed && this.callbacks.onError) this.callbacks.onError(null, "Gagal memuat YouTube API"); }
          }, 100); return;
        }

        // Buat container iframe baru (Tidak menggunakan pool)
        this.ytContainer = document.createElement('div');
        this.ytContainer.style.cssText = 'inline-size: 100%; block-size: 100%; pointer-events: none;';
        const inner = document.createElement('div');
        this.ytContainer.appendChild(inner);
        this.container.appendChild(this.ytContainer);

        const { videoId, isShort } = MediaUtils.parseYouTubeData(this.data.url);

        this.player = new YT.Player(inner, {
          videoId: videoId,
          playerVars: { autoplay: 1, controls: 0, loop: 0, mute: 1, modestbranding: 1, iv_load_policy: 3, rel: 0, playsinline: 1 },
          events: {
            onReady: (event) => {
              if (this.isDestroyed || !this.player) return;
              if (this.isAmbient || this.state.isGlobalMuted) { event.target.mute(); } else { event.target.unMute(); event.target.setVolume(this.state.volume); }
              const iframe = event.target.getIframe(); if (iframe) { iframe.setAttribute('tabindex', '-1'); iframe.style.objectFit = (isShort || this.data.isVertical) ? 'cover' : 'contain'; }
              if (this.callbacks.onReady) this.callbacks.onReady(event);
            },
            onStateChange: (event) => {
              if (this.isDestroyed || !this.callbacks.onStateChange) return;
              const stateMapping = { [YT.PlayerState.PLAYING]: MEDIA_STATE.PLAYING, [YT.PlayerState.PAUSED]: MEDIA_STATE.PAUSED, [YT.PlayerState.BUFFERING]: MEDIA_STATE.BUFFERING, [YT.PlayerState.ENDED]: MEDIA_STATE.ENDED };
              this.callbacks.onStateChange(stateMapping[event.data] ?? MEDIA_STATE.UNSTARTED);
            },
            onError: (event) => {
              if (this.isDestroyed || !this.callbacks.onError) return;
              let customMessage = null;
              if (event.data === 101 || event.data === 150) customMessage = "Pemilik video menonaktifkan pemutaran di situs eksternal."; else if (event.data === 2) customMessage = "ID Video tidak valid atau telah dihapus.";
              this.callbacks.onError(event, customMessage);
            }
          }
        });

        // PATCH: Failsafe Timer (Penyelamat jika YouTube nyangkut di "Buffering")
        this.failsafeTimer = setTimeout(() => {
          if (this.isDestroyed || !this.player) return;
          const state = typeof this.player.getPlayerState === 'function' ? this.player.getPlayerState() : -1;
          // Jika dalam 8 detik tidak masuk ke Playing atau Paused, paksa UI lepas dari loading
          if (state !== YT.PlayerState.PLAYING && state !== YT.PlayerState.PAUSED) {
            console.warn("YouTube API memakan waktu terlalu lama. Membuka kunci UI.");
            this.emitStateChange(MEDIA_STATE.PAUSED); 
            ToastService.show("Video lambat memuat. Coba tekan Play manual.");
          }
        }, 8000);
      }
      
      play() {
        if (navigator.userActivation && !navigator.userActivation.hasBeenActive && !this.isAmbient && !this.state.isGlobalMuted) { this.mute(); this.state.isGlobalMuted = true; }
        if (!this.isAmbient && !this.state.userInteracted && !this.state.isGlobalMuted) { this.mute(); this.state.isGlobalMuted = true; }
        if (typeof this.player?.playVideo === 'function') this.player.playVideo();
        
        clearTimeout(this.autoplayCheckTimer);
        this.autoplayCheckTimer = setTimeout(() => {
          if (this.isDestroyed) return; 
          const state = typeof this.player?.getPlayerState === 'function' ? this.player.getPlayerState() : -1; 
          if (state === -1 || state === 5) this.emitStateChange(MEDIA_STATE.PAUSED);
        }, this.state.config.AUTOPLAY_CHECK_MS);
      }
      
      pause() { if (typeof this.player?.pauseVideo === 'function') this.player.pauseVideo(); } 
      mute() { if (typeof this.player?.mute === 'function') this.player.mute(); } 
      unMute() { if (typeof this.player?.unMute === 'function') this.player.unMute(); } 
      seekTo(time) { if (typeof this.player?.seekTo === 'function') this.player.seekTo(time, true); } 
      getCurrentTime() { return typeof this.player?.getCurrentTime === 'function' ? this.player.getCurrentTime() : 0; } 
      getDuration() { return typeof this.player?.getDuration === 'function' ? this.player.getDuration() : 0; } 
      getLoadedFraction() { return typeof this.player?.getVideoLoadedFraction === 'function' ? this.player.getVideoLoadedFraction() : 0; } 
      setPlaybackRate(rate) { if (typeof this.player?.setPlaybackRate === 'function') this.player.setPlaybackRate(rate); } 
      isMuted() { return typeof this.player?.isMuted === 'function' ? this.player.isMuted() : true; } 
      setVolume(level) { if (typeof this.player?.setVolume === 'function') this.player.setVolume(level); }
      
      getState() { 
        if (!this.player || typeof this.player.getPlayerState !== 'function') return MEDIA_STATE.UNSTARTED;
        const stateMapping = { [YT.PlayerState.PLAYING]: MEDIA_STATE.PLAYING, [YT.PlayerState.PAUSED]: MEDIA_STATE.PAUSED, [YT.PlayerState.BUFFERING]: MEDIA_STATE.BUFFERING, [YT.PlayerState.ENDED]: MEDIA_STATE.ENDED }; 
        return stateMapping[this.player.getPlayerState()] ?? MEDIA_STATE.UNSTARTED; 
      }
      
      destroy() { 
        clearTimeout(this.autoplayCheckTimer); 
        clearTimeout(this.failsafeTimer);
        
        // Hancurkan instansiasi player dengan benar untuk mencegah memory leak
        if (this.player) { 
           try { if (typeof this.player.destroy === 'function') this.player.destroy(); } catch (e) {} 
           this.player = null; 
        } 
        if (this.ytContainer) {
           this.ytContainer.remove();
           this.ytContainer = null;
        }
        super.destroy(); 
      }
    }

    class ImageMediaHandler extends BaseMediaHandler {
      constructor(config) { super(config); this.duration = this.data.duration || 5; this.currentTime = 0; this.animationFrameTimer = null; this.lastTickTime = 0; this.playbackState = MEDIA_STATE.UNSTARTED; }
      async load() {
        this.imageElement = new Image(); this.imageElement.draggable = false; this.imageElement.crossOrigin = 'anonymous'; this.imageElement.style.cssText = `inline-size: 100%; block-size: 100%; object-fit: ${this.data.isVertical ? 'cover' : 'contain'}; pointer-events: none;`; this.imageElement.src = this.data.url;
        try { await this.imageElement.decode(); this.handleSuccess(); } catch (e) { this.handleError(); }
      }
      handleSuccess() {
        if (this.isDestroyed) return; this.container.appendChild(this.imageElement); this.playbackState = MEDIA_STATE.PAUSED;
        if (!this.isAmbient && !this.state.isEcoMode) {
          const targets = []; if (this.container.parentElement) targets.push(this.container.parentElement); const ambient = document.querySelector('.js-ambient-container'); if (ambient) targets.push(ambient);
          DominantColorService.extract(this.imageElement, targets);
        }
        if (this.callbacks.onReady) this.callbacks.onReady({ target: this });
      }
      handleError() {
        if (this.isDestroyed) return;
        if (this.data.thumbnail && this.imageElement.src !== this.data.thumbnail) { this.imageElement.src = this.data.thumbnail; this.container.appendChild(this.imageElement); } 
        else { this.playbackState = MEDIA_STATE.ENDED; this.emitStateChange(this.playbackState); if (this.callbacks.onError) this.callbacks.onError(); }
      }
      animationTick() {
        if (this.playbackState !== MEDIA_STATE.PLAYING || this.isDestroyed) return;
        const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
        const deltaSeconds = Math.min((now - this.lastTickTime) / 1000, 0.1); this.currentTime += deltaSeconds; this.lastTickTime = now;
        if (this.currentTime >= this.duration) { this.currentTime = this.duration; this.playbackState = MEDIA_STATE.ENDED; this.emitStateChange(this.playbackState); } 
        else { this.animationFrameTimer = requestAnimationFrame(() => this.animationTick()); }
      }
      play() { if (this.playbackState === MEDIA_STATE.PLAYING) return; if (this.currentTime >= this.duration) this.currentTime = 0; this.playbackState = MEDIA_STATE.PLAYING; this.lastTickTime = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now(); this.emitStateChange(this.playbackState); this.animationTick(); }
      pause() { this.playbackState = MEDIA_STATE.PAUSED; cancelAnimationFrame(this.animationFrameTimer); this.emitStateChange(this.playbackState); }
      seekTo(time) { this.currentTime = Math.max(0, Math.min(time, this.duration)); } getCurrentTime() { return this.currentTime; } getDuration() { return this.duration; } getLoadedFraction() { return 1; } getState() { return this.playbackState; }
      destroy() { cancelAnimationFrame(this.animationFrameTimer); if (this.imageElement) { this.imageElement.src = ''; this.imageElement.remove(); this.imageElement = null; } super.destroy(); }
    }

    class HTML5VideoMediaHandler extends BaseMediaHandler {
      #rvfcId = null; #lastColorTime = 0;
      constructor(config) { super(config); }
      #extractColors() {
        if (!this.videoElement || this.videoElement.readyState < 3 || this.isDestroyed || this.isAmbient) return;
        const targets = []; if (this.container.parentElement) targets.push(this.container.parentElement); const ambientLayer = document.querySelector('.js-ambient-container'); if (ambientLayer) targets.push(ambientLayer);
        DominantColorService.extract(this.videoElement, targets);
      }
      #startColorThief() {
        if (this.isAmbient || this.#rvfcId || !this.videoElement.requestVideoFrameCallback || this.state.isEcoMode) return;
        const step = (now) => {
          if (this.isDestroyed || this.videoElement.paused) { this.#rvfcId = null; return; }
          if (now - this.#lastColorTime > 800) { this.#extractColors(); this.#lastColorTime = now; }
          this.#rvfcId = this.videoElement.requestVideoFrameCallback(step);
        };
        this.#rvfcId = this.videoElement.requestVideoFrameCallback(step);
      }
      #stopColorThief() { if (this.#rvfcId && this.videoElement && this.videoElement.cancelVideoFrameCallback) { this.videoElement.cancelVideoFrameCallback(this.#rvfcId); this.#rvfcId = null; } }
      load() {
        this.videoElement = MediaPool.getVideoElement(); this.videoElement.src = this.data.url; this.videoElement.style.cssText = `inline-size: 100%; block-size: 100%; object-fit: ${this.data.isVertical ? 'cover' : 'contain'};`; this.videoElement.muted = this.isAmbient || this.state.isGlobalMuted; this.videoElement.volume = this.state.volume / 100; this.abortController = new AbortController(); this.container.appendChild(this.videoElement); this.attachEvents();
      }
      attachEvents() {
        const signal = this.abortController.signal; let hasFiredPlaying = false; let isBufferLocked = false; let bufferCheckInterval = null;
        const firePlaying = () => { if (!this.isDestroyed && !hasFiredPlaying && !isBufferLocked) { hasFiredPlaying = true; this.emitStateChange(MEDIA_STATE.PLAYING); } };
        
        this.videoElement.addEventListener('loadedmetadata', () => { if (!this.isDestroyed && this.callbacks.onReady) this.callbacks.onReady({ target: this }); }, { signal });
        this.videoElement.addEventListener('playing', () => { if (isBufferLocked) return; if (this.videoElement.readyState >= 3) firePlaying(); }, { signal });
        this.videoElement.addEventListener('timeupdate', () => { if (!hasFiredPlaying && this.videoElement.currentTime > 0.05 && this.videoElement.readyState >= 3 && !isBufferLocked) firePlaying(); }, { signal });
        this.videoElement.addEventListener('pause', () => { if (isBufferLocked) return; hasFiredPlaying = false; if (!this.isDestroyed) this.emitStateChange(MEDIA_STATE.PAUSED); }, { signal });
        
        this.videoElement.addEventListener('waiting', () => {
