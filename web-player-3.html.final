              if (this.isDestroyed || !this.videoElement) { clearInterval(bufferCheckInterval); return; }
              const b = this.videoElement.buffered; const ct = this.videoElement.currentTime; const duration = this.videoElement.duration;
              if (b.length > 0) {
                 const bufferEnd = b.end(b.length - 1); const bufferGap = bufferEnd - ct;
                 if (bufferGap > 2.5 || bufferEnd >= duration - 0.5) { clearInterval(bufferCheckInterval); isBufferLocked = false; this.videoElement.play().catch(()=>{}); } 
                 else { if (!this.videoElement.paused) this.videoElement.pause(); }
              }
            }, 250);
          }
        }, { signal });
        
        this.videoElement.addEventListener('seeking', () => { hasFiredPlaying = false; if (!this.isDestroyed) this.emitStateChange(MEDIA_STATE.BUFFERING); }, { signal });
        this.videoElement.addEventListener('seeked', () => { if (!this.isDestroyed && !this.videoElement.paused && this.videoElement.readyState >= 3 && !isBufferLocked) firePlaying(); }, { signal });
        this.videoElement.addEventListener('ended', () => { hasFiredPlaying = false; if (!this.isDestroyed) this.emitStateChange(MEDIA_STATE.ENDED); }, { signal });
        this.videoElement.addEventListener('error', (event) => { if (!this.isDestroyed && this.callbacks.onError) this.callbacks.onError(event); }, { signal });
      }
      play() {
        if (navigator.userActivation && !navigator.userActivation.hasBeenActive && !this.isAmbient && !this.state.isGlobalMuted) { this.mute(); this.state.isGlobalMuted = true; }
        const playPromise = this.videoElement?.play();
        if (playPromise !== undefined) {
          playPromise.then(() => { if (this.isDestroyed && this.videoElement) { this.videoElement.pause(); } else { this.#startColorThief(); } }).catch(error => {
            if (error.name === 'NotAllowedError' && !this.isAmbient) { this.mute(); this.videoElement?.play().catch((e)=>{}); this.state.isGlobalMuted = true; } else { this.emitStateChange(MEDIA_STATE.PAUSED); }
          });
        }
      }
      pause() { this.#stopColorThief(); this.videoElement?.pause(); } mute() { if (this.videoElement) this.videoElement.muted = true; } unMute() { if (this.videoElement) this.videoElement.muted = false; } seekTo(time) { if (this.videoElement) this.videoElement.currentTime = time; } getCurrentTime() { return this.videoElement?.currentTime || 0; } getDuration() { return this.videoElement?.duration || 0; }
      getLoadedFraction() { if (!this.videoElement || !this.videoElement.duration) return 0; const b = this.videoElement.buffered; return b.length > 0 ? b.end(b.length - 1) / this.videoElement.duration : 0; }
      setPlaybackRate(rate) { if (this.videoElement) this.videoElement.playbackRate = rate; } isMuted() { return this.videoElement?.muted || false; } setVolume(level) { if (this.videoElement) this.videoElement.volume = level / 100; }
      getState() { if (!this.videoElement) return MEDIA_STATE.UNSTARTED; if (this.videoElement.ended) return MEDIA_STATE.ENDED; if (this.videoElement.paused) return MEDIA_STATE.PAUSED; if (this.videoElement.readyState < 3) return MEDIA_STATE.BUFFERING; return MEDIA_STATE.PLAYING; }
      destroy() { this.#stopColorThief(); if (this.abortController) { this.abortController.abort(); this.abortController = null; } if (this.videoElement) { MediaPool.releaseVideoElement(this.videoElement); this.videoElement = null; } super.destroy(); }
    }

    class MediaFactory {
      static create(config) {
        switch (config.data.type) { case 'youtube': return new YouTubeMediaHandler(config); case 'image': return new ImageMediaHandler(config); case 'video': return new HTML5VideoMediaHandler(config); default: return null; }
      }
    }

    class UIManager {
      constructor(state, appEvents) {
        this.state = state; this.appEvents = appEvents; this.activeProgressFill = null; this.activeBufferFill = null; this.cachedAmbientMedia = null; this.animFrameId = null; this.lastSyncCheck = 0; this.flashTimeout = null; this.focusTrapHandler = null; this.previousFocusElement = null; this.lastReactionTime = 0; this._lastVolIconState = '';
        this.dom = {
          volumeSlider: DOMHelper.select(DOM_SELECTORS.VOLUME_SLIDER), btnMute: DOMHelper.select(DOM_SELECTORS.BTN_MUTE), progressWrapper: DOMHelper.select(DOM_SELECTORS.PROGRESS_WRAPPER), storyContainer: DOMHelper.select(DOM_SELECTORS.STORY_CONTAINER), btnPlay: DOMHelper.select(DOM_SELECTORS.BTN_PLAY), thumbOverlay: DOMHelper.select(DOM_SELECTORS.THUMBNAIL_OVERLAY), ambientMedia: DOMHelper.select(DOM_SELECTORS.AMBIENT_MEDIA), ambientWrapper: DOMHelper.select(DOM_SELECTORS.AMBIENT_WRAPPER), mainMedia: DOMHelper.select(DOM_SELECTORS.MAIN_MEDIA), centerPlayIcon: DOMHelper.select(DOM_SELECTORS.CENTER_PLAY_ICON), centerReaction: DOMHelper.select(DOM_SELECTORS.CENTER_REACTION), reactionWrapper: DOMHelper.select(DOM_SELECTORS.REACTION_WRAPPER), reactionContainer: DOMHelper.select(DOM_SELECTORS.REACTION_CONTAINER), btnReaction: DOMHelper.select(DOM_SELECTORS.BTN_REACTION)
        };
        this.setupEventSubscriptions();
        if (this.dom.volumeSlider) { this.dom.volumeSlider.addEventListener('input', (e) => this.updateVolumeFromSlider(e), { passive: true }); }
        const volWrapper = DOMHelper.select('.js-volume-wrapper');
        if (volWrapper) { volWrapper.addEventListener('mouseleave', () => { if (this.dom.volumeSlider && document.activeElement === this.dom.volumeSlider) { this.dom.volumeSlider.blur(); } }, { passive: true }); }
      }
      
      setupEventSubscriptions() {
        this.appEvents.on('UI:SYNC_VOLUME', () => this.syncVolumeUI()); 
        this.appEvents.on('UI:RENDER_CORE', (payload) => this.renderCoreUI(payload)); 
        this.appEvents.on('UI:RESET_STATE', () => this.resetVideoStateUI()); 
        this.appEvents.on('MEDIA:STATE_CHANGE', (mediaState) => this.handleMediaStateChange(mediaState)); 
        this.appEvents.on('UI:FLASH_ICON', (icon) => this.flashIcon(icon)); 
        this.appEvents.on('UI:SHOW_RIPPLE', (data) => this.showRipple(data.side, data.text)); 
        this.appEvents.on('UI:TOGGLE_MUTE', () => this.toggleMute()); 
        this.appEvents.on('UI:TOGGLE_CONTEXT', (isOpen) => this.toggleContext(isOpen)); 
        this.appEvents.on('UI:TRIGGER_REACTION', (payload) => this.triggerReaction(payload)); 
        this.appEvents.on('UI:TOGGLE_REACTION_MENU', () => this.toggleReactionMenu());
        
        this.initMagneticButtons();
        this.initAmbientParallax();
      }

      initMagneticButtons() {
        if (window.matchMedia('(hover: none)').matches || this.state.prefersReducedMotion) return;
        const buttons = document.querySelectorAll('.fab-wrapper, .reaction-option-btn, .story-excerpt');
        
        buttons.forEach(btn => {
          const inner = btn.querySelector('.fab-inner');
          const isWideButton = btn.classList.contains('story-excerpt'); 
          
          btn.addEventListener('pointermove', (e) => {
            const rect = btn.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            
            const pullStrength = isWideButton ? 0.05 : 0.3; 
            const scaleStrength = isWideButton ? 1.01 : 1.1; 
            
            btn.style.transition = 'transform 0.1s ease-out';
            btn.style.transform = `translate(${x * pullStrength}px, ${y * pullStrength}px) scale(${scaleStrength})`;
            
            if (inner) {
              inner.style.transition = 'transform 0.1s ease-out';
              inner.style.transform = `translate(${x * (pullStrength / 2)}px, ${y * (pullStrength / 2)}px)`;
            }
          }, { passive: true });
          
          btn.addEventListener('pointerleave', () => {
            btn.style.transition = ''; 
            btn.style.transform = ''; 
            if (inner) {
              inner.style.transition = '';
              inner.style.transform = '';
            }
          }, { passive: true });
        });
      }

      initAmbientParallax() {
        if (window.matchMedia('(hover: none)').matches || this.state.prefersReducedMotion || this.state.isEcoMode) return;
        window.addEventListener('pointermove', (e) => {
          if (!this.dom.ambientWrapper || this.state.currentMedia?.getState() !== MEDIA_STATE.PLAYING) return;
          const x = (e.clientX / window.innerWidth - 0.5) * -30; 
          const y = (e.clientY / window.innerHeight - 0.5) * -30;
          requestAnimationFrame(() => {
            this.dom.ambientWrapper.style.transform = `translate3d(${x}px, ${y}px, 0) scale(3)`;
          });
        }, { passive: true });
      }
      
      updateMetaTags(mediaData, groupData) {
        const title = mediaData?.title || groupData?.title || this.state.config.locale.noTitle; const desc = mediaData?.excerpt || groupData?.excerpt || 'Checkout this immersive story!'; let imgUrl = mediaData?.thumbnail || mediaData?.url;
        if (mediaData?.type === 'youtube') { const ytData = MediaUtils.parseYouTubeData(mediaData.url); imgUrl = `https://i.ytimg.com/vi/${ytData.videoId}/maxresdefault.jpg`; }
        const setMeta = (property, content) => { let tag = document.querySelector(`meta[property="${property}"]`); if (!tag) { tag = document.createElement('meta'); tag.setAttribute('property', property); document.head.appendChild(tag); } if (content) tag.setAttribute('content', content); };
        setMeta('og:title', title); setMeta('og:description', desc); setMeta('og:image', imgUrl); setMeta('og:url', window.location.href);
      }
      
      syncVolumeUI() {
        UISoundFX.isUIMuted = this.state.isGlobalMuted || this.state.volume === 0;
        if (this.dom.volumeSlider) { const val = this.state.isGlobalMuted ? 0 : this.state.volume; this.dom.volumeSlider.value = val; this.dom.volumeSlider.style.setProperty('--vol', `${val}%`); this.dom.volumeSlider.setAttribute('aria-valuenow', val); }
        if (this.dom.btnMute) {
          let targetIconState = '', targetIconSvg = '';
          if (this.state.isGlobalMuted || this.state.volume === 0) { targetIconState = 'mute'; targetIconSvg = UI_ICONS.mute; this.dom.btnMute.setAttribute('aria-label', this.state.config.locale.unmuteAudio); this.dom.btnMute.setAttribute('aria-pressed', 'true'); } 
          else { targetIconState = this.state.volume < 50 ? 'low' : 'high'; targetIconSvg = this.state.volume < 50 ? UI_ICONS.volumeLow : UI_ICONS.volumeHigh; this.dom.btnMute.setAttribute('aria-label', this.state.config.locale.muteAudio); this.dom.btnMute.setAttribute('aria-pressed', 'false'); }
          if (this._lastVolIconState !== targetIconState) { IconHelper.update(this.dom.btnMute, targetIconSvg); this._lastVolIconState = targetIconState; }
        }
      }
      
      /* NEW PATCH: Render Core UI dipisah menjadi method yang lebih modular dan memanggil Custom Templating jika ada */
      renderCoreUI({ groupData, mediaData, renderIndex, renderSubIndex }) {
        if (this.dom.storyContainer) {
          this.dom.storyContainer.classList.add('is-loading'); this.dom.storyContainer.classList.remove('has-started');
          if (groupData.format === 'story' || (groupData.items && groupData.items.length > 1)) { this.dom.storyContainer.classList.add('is-story-format'); } 
          else { this.dom.storyContainer.classList.remove('is-story-format'); }
        }
        this.renderProgressBars(groupData); this.syncVolumeUI(); 
        
        this.renderExcerptAndContext(mediaData, groupData);
        this.renderCustomActions(mediaData, groupData);
        
        this.updateThumbnailsAndBackgrounds(mediaData, renderIndex, renderSubIndex); this.updateLikeState(mediaData); this.updateMetaTags(mediaData, groupData);
      }
      
      renderExcerptAndContext(mediaData, groupData) {
        const displayTitle = mediaData?.title || groupData?.title || this.state.config.locale.noTitle;
        document.title = displayTitle ? `${displayTitle} - NextGen Story` : 'NextGen Story';

        const excerptBtn = DOMHelper.select('.js-btn-open-context');
        if (excerptBtn) {
          if (this.state.config.renderExcerpt) {
            const customHTML = this.state.config.renderExcerpt(mediaData, groupData);
            excerptBtn.innerHTML = ttPolicy ? ttPolicy.createHTML(customHTML) : customHTML;
          } else {
            this.updateDefaultExcerpt(excerptBtn, mediaData, groupData, displayTitle);
          }
        }

        const dynamicAreas = DOMHelper.selectAll('.story-dynamic-area');
        dynamicAreas.forEach(area => {
          if (this.state.config.renderContext) {
            const customHTML = this.state.config.renderContext(mediaData, groupData);
            area.innerHTML = ttPolicy ? ttPolicy.createHTML(customHTML) : customHTML;
          } else {
            this.updateDefaultContext(area, mediaData, groupData, displayTitle);
          }
        });
      }

      updateDefaultExcerpt(btnEl, mediaData, groupData, displayTitle) {
        const displayCategories = mediaData?.categories || groupData?.categories || [];
        const displayExcerpt = mediaData?.excerpt ?? groupData?.excerpt ?? '';
        const hasDetailContent = (mediaData?.content || groupData?.content) ? true : false;

        if (!btnEl.querySelector('.story-excerpt__title')) {
           btnEl.innerHTML = ttPolicy ? ttPolicy.createHTML('<div class="story-excerpt__badges"></div><span class="story-excerpt__title"></span><div class="story-excerpt__text"></div>') : '<div class="story-excerpt__badges"></div><span class="story-excerpt__title"></span><div class="story-excerpt__text"></div>';
        }

        const badgeContainer = btnEl.querySelector('.story-excerpt__badges');
        if (badgeContainer) {
          badgeContainer.innerHTML = '';
          displayCategories.forEach(cat => {
            const span = document.createElement('span'); span.className = 'story-badge-item'; span.innerText = cat;
            badgeContainer.appendChild(span);
          });
        }

        const titleEl = btnEl.querySelector('.story-excerpt__title');
        if (titleEl) titleEl.innerText = displayTitle;

        const textEl = btnEl.querySelector('.story-excerpt__text');
        if (textEl) {
          const rawExcerpt = displayExcerpt.trim();
          const sanitizedExcerpt = DOMHelper.sanitizeHTML(rawExcerpt);
          
          if (rawExcerpt === '' && hasDetailContent) { 
            textEl.innerHTML = ttPolicy ? ttPolicy.createHTML(`<span class="story-read-more" style="margin-inline-start: 0;">${this.state.config.locale.readMore}</span>`) : `<span class="story-read-more" style="margin-inline-start: 0;">${this.state.config.locale.readMore}</span>`; 
          } else if (rawExcerpt === '') { 
            textEl.innerHTML = ''; 
          } else {
            textEl.innerHTML = ttPolicy ? ttPolicy.createHTML(sanitizedExcerpt) : sanitizedExcerpt;
            if (hasDetailContent) {
              requestAnimationFrame(() => { 
                if (textEl.scrollHeight <= textEl.clientHeight && !textEl.innerHTML.includes('story-read-more')) { 
                  const readMoreStr = sanitizedExcerpt + `<span class="story-read-more"> ...</span>`; 
                  textEl.innerHTML = ttPolicy ? ttPolicy.createHTML(readMoreStr) : readMoreStr; 
                } 
              });
            }
          }
        }
      }

      updateDefaultContext(area, mediaData, groupData, displayTitle) {
        let view = area.querySelector('.story-view');
        if (!view) {
          const template = document.querySelector('.js-story-template');
          if (template) { area.appendChild(template.content.cloneNode(true)); view = area.querySelector('.story-view'); }
        }
        if (!view) return;

        const displayMeta = mediaData?.meta || groupData?.meta || this.state.config.locale.noInfo;
        const displayCategories = mediaData?.categories || groupData?.categories || [];
        const displayContent = mediaData?.content || groupData?.content || '';

        const badgeContainer = view.querySelector('.story-view__badges');
        if (badgeContainer) {
          badgeContainer.innerHTML = '';
          displayCategories.forEach(cat => {
            const span = document.createElement('span'); span.className = 'story-badge-item'; span.innerText = cat;
            badgeContainer.appendChild(span);
          });
        }

        const titleEl = view.querySelector('.story-view__title');
        if (titleEl) titleEl.innerText = displayTitle;
        const metaEl = view.querySelector('.js-story-meta');
        if (metaEl) metaEl.innerText = displayMeta;
        const contentEl = view.querySelector('.story-body__cms-content');
        if (contentEl) contentEl.innerHTML = DOMHelper.sanitizeHTML(displayContent);
      }

      renderCustomActions(mediaData, groupData) {
         if (!this.state.config.renderActions) return;
         const actionContainer = DOMHelper.select('.story-player-actions');
         if (actionContainer) {
            const customActionsHTML = this.state.config.renderActions(mediaData, groupData);
            actionContainer.innerHTML = ttPolicy ? ttPolicy.createHTML(customActionsHTML) : customActionsHTML;
            if (window.lucide && window.lucide.createIcons) window.lucide.createIcons({ root: actionContainer });
         }
      }

      updateLikeState(mediaData) {
        const reaction = this.state.currentUser.reactions.get(mediaData.id); const fabIcon = this.dom.btnReaction?.querySelector('.fab-inner');
        if (fabIcon) {
          if (reaction) { fabIcon.classList.add('is-liked'); IconHelper.update(fabIcon, `<span style="font-size: 1.25rem; font-style: normal; line-height: 1; display: inline-block;">${reaction}</span>`); } 
          else { fabIcon.classList.remove('is-liked'); IconHelper.update(fabIcon, UI_ICONS.heart); }
        }
      }
      
      renderProgressBars(groupData) {
        if (!this.dom.progressWrapper) return;
        const count = groupData.items ? groupData.items.length : 1; this.dom.progressWrapper.innerHTML = '';
        for (let i = 0; i < count; i++) {
          const bar = document.createElement('div'); bar.className = 'story-progress-bar';
          if (i < this.state.currentSubIndex) bar.classList.add('is-viewed'); else if (i === this.state.currentSubIndex) bar.classList.add('is-current'); else bar.classList.add('is-upcoming');
          const bufferFill = document.createElement('div'); bufferFill.className = 'story-progress-bar__buffer'; bufferFill.setAttribute('data-buffer-index', i.toString()); bufferFill.style.transform = i < this.state.currentSubIndex ? 'scaleX(1)' : 'scaleX(0)';
          const fill = document.createElement('div'); fill.className = 'story-progress-bar__fill'; fill.setAttribute('data-progress-index', i.toString()); fill.style.transform = i < this.state.currentSubIndex ? 'scaleX(1)' : 'scaleX(0)';
          bar.appendChild(bufferFill); bar.appendChild(fill); this.dom.progressWrapper.appendChild(bar);
        }
      }
      
      updateThumbnailsAndBackgrounds(mediaData, renderIndex, renderSubIndex) {
        const isShort = (mediaData.type === 'youtube' && MediaUtils.parseYouTubeData(mediaData.url).isShort) || mediaData.isVertical === true;
        const objectFitStyle = mediaData.thumbnailFit ? mediaData.thumbnailFit : (isShort ? 'cover' : 'contain');
        ThumbnailResolver.resolve(mediaData, (url) => {
          if (!url || this.state.currentVideoIndex !== renderIndex || this.state.currentSubIndex !== renderSubIndex) return;
          const storyWrapper = DOMHelper.select('.story-video-wrapper'); const targetElements = [];
          if (storyWrapper) targetElements.push(storyWrapper); if (this.dom.ambientWrapper) targetElements.push(this.dom.ambientWrapper);
          if (!this.state.isEcoMode) { DominantColorService.extractFromUrl(url, targetElements); }
          if (this.dom.thumbOverlay) { this.dom.thumbOverlay.src = url; this.dom.thumbOverlay.style.objectFit = objectFitStyle; this.dom.thumbOverlay.style.display = ''; this.dom.thumbOverlay.style.transition = 'none'; this.dom.thumbOverlay.style.opacity = '1'; }
          if (this.dom.ambientWrapper) { this.dom.ambientWrapper.classList.toggle('is-breathing', mediaData.type === 'image' && !this.state.isEcoMode); }
        });
      }
      
      handleMediaStateChange(mediaState) {
        if (mediaState === MEDIA_STATE.PLAYING) {
          clearTimeout(this.state.timers.loading);
          if (this.dom.mainMedia) { this.dom.mainMedia.style.transition = 'opacity 0.4s ease-in'; this.dom.mainMedia.style.opacity = '1'; }
          if (this.dom.btnPlay) { const icon = this.dom.btnPlay.querySelector('.fab-inner'); if (icon) IconHelper.update(icon, UI_ICONS.pause); this.dom.btnPlay.setAttribute('aria-pressed', 'true'); }
          if (this.dom.storyContainer) { this.dom.storyContainer.classList.add('has-started', 'show-ui'); this.dom.storyContainer.classList.remove('is-paused', 'is-loading'); }
          if (this.dom.thumbOverlay && this.dom.thumbOverlay.style.opacity !== '0') { this.dom.thumbOverlay.style.transition = 'opacity 0.3s ease-out'; this.dom.thumbOverlay.style.opacity = '0'; }
          if (this.state.currentAmbient && this.state.currentMedia && !this.state.isEcoMode) { if (this.dom.ambientMedia) { this.dom.ambientMedia.style.transition = 'opacity 0.8s ease-in'; this.dom.ambientMedia.style.opacity = '0.8'; } }
          this.startProgressBar(); A11yAnnouncer.speak(this.state.config.locale.videoPlaying);
        } else if (mediaState === MEDIA_STATE.PAUSED) {
          if (this.dom.btnPlay) { const icon = this.dom.btnPlay.querySelector('.fab-inner'); if (icon) IconHelper.update(icon, UI_ICONS.play); this.dom.btnPlay.setAttribute('aria-pressed', 'false'); }
          if (this.dom.storyContainer) { this.dom.storyContainer.classList.add('is-paused', 'has-started', 'show-ui'); this.dom.storyContainer.classList.remove('is-loading'); }
          this.stopProgressBar(); A11yAnnouncer.speak(this.state.config.locale.videoPaused);
        } else if (mediaState === MEDIA_STATE.BUFFERING) {
          clearTimeout(this.state.timers.loading); this.state.timers.loading = setTimeout(() => { if (this.dom.storyContainer) this.dom.storyContainer.classList.add('is-loading'); }, 350);
          if (!this.state.isSeeking) { this.stopProgressBar(); } else { this.startProgressBar(); }
        } else if (mediaState === MEDIA_STATE.ENDED) {
          this.stopProgressBar();
          if (this.dom.btnPlay && this.state.playlist[this.state.currentVideoIndex]?.format === 'story') {
            const icon = this.dom.btnPlay.querySelector('.fab-inner'); if (icon) IconHelper.update(icon, UI_ICONS.play); this.dom.btnPlay.setAttribute('aria-pressed', 'false'); if (this.dom.storyContainer) this.dom.storyContainer.classList.add('is-paused');
          }
        }
      }
      
      loopProgress() {
        const currentState = this.state.currentMedia?.getState();
        if (currentState === MEDIA_STATE.PLAYING || this.state.isSeeking) {
          const duration = this.state.currentMedia.getDuration(); const currentTime = this.state.currentMedia.getCurrentTime(); let displayTime = currentTime;
          if (this.state.isSeeking) { displayTime = this.state.targetSeekTime; if (Math.abs(currentTime - this.state.targetSeekTime) < 1.0 && currentState === MEDIA_STATE.PLAYING) { this.state.isSeeking = false; } }
          if (duration > 0 && this.activeProgressFill) { this.activeProgressFill.style.transform = `scaleX(${displayTime / duration})`; }
          if (this.activeBufferFill && typeof this.state.currentMedia.getLoadedFraction === 'function') { const loaded = this.state.currentMedia.getLoadedFraction(); this.activeBufferFill.style.transform = `scaleX(${loaded})`; }
          if (this.state.currentAmbient && !this.state.isEcoMode) {
            const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
            if (now - this.lastSyncCheck > 500) {
              const diff = Math.abs(currentTime - this.state.currentAmbient.getCurrentTime());
              if (diff > 1.5 && !this.state.isSeeking) {
                if (this.cachedAmbientMedia) this.cachedAmbientMedia.style.opacity = '0';
                this.state.currentAmbient.seekTo(currentTime);
                setTimeout(() => { if (this.cachedAmbientMedia && this.state.currentMedia?.getState() === MEDIA_STATE.PLAYING) { this.cachedAmbientMedia.style.opacity = '0.8'; } }, 400);
              }
              this.lastSyncCheck = now;
            }
          }
          if ('mediaSession' in navigator && !this.state.isSeeking && duration > 0) {
            const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
            if (!this.lastMediaSync || now - this.lastMediaSync > 1000) {
              try { navigator.mediaSession.setPositionState({ duration: duration, playbackRate: this.state.currentMedia?.videoElement?.playbackRate || 1, position: currentTime }); } catch (e) {} this.lastMediaSync = now;
            }
          }
          this.animFrameId = requestAnimationFrame(() => this.loopProgress());
        } else { this.animFrameId = null; }
      }
      
      startProgressBar() { cancelAnimationFrame(this.animFrameId); this.activeProgressFill = DOMHelper.select(`[data-progress-index="${this.state.currentSubIndex}"]`); this.activeBufferFill = DOMHelper.select(`[data-buffer-index="${this.state.currentSubIndex}"]`); this.cachedAmbientMedia = DOMHelper.select(DOM_SELECTORS.AMBIENT_MEDIA); this.animFrameId = requestAnimationFrame(() => this.loopProgress()); }
      stopProgressBar() { cancelAnimationFrame(this.animFrameId); }
      
      flashIcon(iconString) {
        this.hideSteadyIcon(); void this.dom.centerPlayIcon?.offsetWidth;
        if (this.dom.centerPlayIcon) { IconHelper.update(this.dom.centerPlayIcon, iconString); this.dom.centerPlayIcon.className = 'story-center-play js-center-play is-flashing'; clearTimeout(this.flashTimeout); this.flashTimeout = setTimeout(() => this.dom.centerPlayIcon.classList.remove('is-flashing'), 500); }
      }
      hideSteadyIcon() { if (this.dom.centerPlayIcon) this.dom.centerPlayIcon.classList.remove('is-steady'); }
      
      showRipple(side, htmlContent) {
        if (this.state.prefersReducedMotion || this.state.isEcoMode) return;
        const element = DOMHelper.select(`.js-ripple-${side}`); 
        const textElement = DOMHelper.select(`.js-ripple-text-${side}`);
        if (!element || !textElement) return;

        textElement.innerHTML = typeof ttPolicy !== 'undefined' && ttPolicy ? ttPolicy.createHTML(htmlContent) : htmlContent;
        if (window.lucide && window.lucide.createIcons) window.lucide.createIcons({ root: textElement });

        element.classList.remove('is-animating', 'is-steady'); 
        void element.offsetWidth; 
        element.classList.add('is-animating'); 
        HapticsEngine.medium(); 
        element.onanimationend = () => element.classList.remove('is-animating');
      }
      
      resetVideoStateUI() {
        clearTimeout(this.state.timers.crossfade); this.stopProgressBar(); this.closeReactionMenu(); this.hideSteadyIcon();
        DOMHelper.select('.js-ripple-left')?.classList.remove('is-animating', 'is-steady'); DOMHelper.select('.js-ripple-right')?.classList.remove('is-animating', 'is-steady');
        if (this.dom.reactionContainer) this.dom.reactionContainer.innerHTML = ''; this.dom.centerReaction?.classList.remove('is-animating'); this.dom.centerPlayIcon?.classList.remove('is-flashing'); DOMHelper.root.classList.remove('is-gesture-active');
        if (this.dom.storyContainer) { this.dom.storyContainer.classList.remove('show-ui', 'has-started', 'is-paused'); this.dom.storyContainer.classList.add('is-loading'); }
        if (this.dom.btnPlay) { const icon = this.dom.btnPlay.querySelector('.fab-inner'); if (icon) IconHelper.update(icon, UI_ICONS.pause); this.dom.btnPlay.setAttribute('aria-pressed', 'false'); }
        if (this.dom.thumbOverlay) { this.dom.thumbOverlay.style.transition = 'none'; this.dom.thumbOverlay.style.opacity = '0'; this.dom.thumbOverlay.removeAttribute('src'); this.dom.thumbOverlay.style.objectFit = ''; }
        
        const errorOverlay = DOMHelper.select(DOM_SELECTORS.ERROR_OVERLAY);
        if (errorOverlay) errorOverlay.classList.remove('is-visible');

        /* PATCH: Kembalikan tampilan elemen UI bawah untuk video selanjutnya */
        if (this.dom.progressWrapper) this.dom.progressWrapper.style.display = '';
        const excerptBtn = DOMHelper.select('.js-btn-open-context');
        if (excerptBtn) excerptBtn.style.display = '';
        const playerActions = DOMHelper.select('.story-player-actions');
        if (playerActions) playerActions.style.display = '';

        const storyWrapper = DOMHelper.select('.story-video-wrapper'); if (storyWrapper) { storyWrapper.style.removeProperty('--grad-start'); storyWrapper.style.removeProperty('--grad-end'); storyWrapper.style.removeProperty('--bg-image'); }
        if (this.dom.ambientWrapper) { this.dom.ambientWrapper.style.removeProperty('--grad-start'); this.dom.ambientWrapper.style.removeProperty('--grad-end'); this.dom.ambientWrapper.style.removeProperty('--bg-image'); this.dom.ambientWrapper.classList.remove('is-breathing'); }
        [this.dom.mainMedia, this.dom.ambientMedia].forEach(element => { if (element) { element.style.transition = 'none'; element.style.opacity = '0'; element.style.transform = 'translateX(0) scale(1)'; element.innerHTML = ''; requestAnimationFrame(() => { element.style.transition = 'opacity 0.4s ease-in'; }); } });
        const sheetContent = DOMHelper.select(DOM_SELECTORS.SHEET_CONTENT); if (sheetContent) { sheetContent.style.transition = 'none'; sheetContent.style.transform = `translate3d(0, 100dvh, 0)`; sheetContent.style.setProperty('--sheet-y', '0px'); sheetContent.classList.remove('is-full-sheet', 'is-entering'); }
        const popupContent = DOMHelper.select('.story-popup__content'); if (popupContent) { popupContent.classList.remove('is-entering'); popupContent.style.removeProperty('--exit-translate-x'); }
      }
      
      getActiveContext() { return window.innerWidth >= 1280 ? DOMHelper.select('.js-story-card') : window.innerWidth >= 768 ? DOMHelper.select('.js-story-popup') : DOMHelper.select('.js-story-sheet'); }
      
      toggleContext(openState) {
        if (openState && !this.state.fsm.dispatch('OPEN_CONTEXT')) return; if (!openState && !this.state.fsm.dispatch('CLOSE_CONTEXT')) return;
        const contextElement = this.getActiveContext(); if (!contextElement) return;
        
        /* NEW PATCH: Lifecycle Hook onContextOpened */
        if (openState && this.state.config.onContextOpened) {
          const mediaData = this.state.getActiveMediaData();
          this.state.config.onContextOpened(mediaData);
        }
        
        const executeToggle = () => {
          DOMHelper.root.classList.toggle('is-ui-open', openState); DOMHelper.root.classList.remove('is-gesture-active');
          const feed = DOMHelper.select(DOM_SELECTORS.FEED); const targetContentPopup = contextElement.querySelector('.story-popup__content');
          
          if (openState) {
            UISoundFX.play('swoosh_up'); this.previousFocusElement = document.activeElement;
            if (contextElement.tagName === 'DIALOG') { if (!contextElement.open) contextElement.showModal(); contextElement.oncancel = (e) => { e.preventDefault(); this.appEvents.emit('UI:TOGGLE_CONTEXT', false); }; } 
            else { contextElement.classList.add('is-active'); }
            if (targetContentPopup && !this.state.prefersReducedMotion && window.innerWidth >= 768) { targetContentPopup.classList.add('is-entering'); setTimeout(() => targetContentPopup.classList.remove('is-entering'), 350); }
            if (window.innerWidth < 1280 && feed) feed.setAttribute('inert', '');
            if (window.innerWidth < 1280 && window.innerWidth >= 768) this.appEvents.emit('PLAYER:FORCE_PAUSE');
            if (window.innerWidth < 768 && contextElement.classList.contains('story-sheet')) { this.appEvents.emit('SHEET:SET_INITIAL'); this.appEvents.emit('SHEET:ANIMATE_TO', { state: 'half' }); }
            this.closeReactionMenu(); A11yAnnouncer.speak(this.state.config.locale.detailsOpened); setTimeout(() => {
               const titleEl = contextElement.querySelector('.story-view__title');
               const closeBtn = contextElement.querySelector('.story-close-btn');
               if (titleEl) {
                 titleEl.setAttribute('tabindex', '-1');
                 titleEl.focus();
               } else if (closeBtn) {
                 closeBtn.focus();
               }
            }, 150);
            this.focusTrapHandler = (e) => this.handleFocusTrap(e, contextElement); document.addEventListener('keydown', this.focusTrapHandler);
          } else {
            UISoundFX.play('swoosh_down');
            if (this.focusTrapHandler) { document.removeEventListener('keydown', this.focusTrapHandler); this.focusTrapHandler = null; }
            if (targetContentPopup) targetContentPopup.classList.remove('is-entering');
            if (window.innerWidth < 768 && contextElement.classList.contains('story-sheet')) {
              this.appEvents.emit('SHEET:ANIMATE_TO', { state: 'hidden', onComplete: () => { contextElement.close(); if (feed) feed.removeAttribute('inert'); } });
            } else {
              const popup = DOMHelper.select('.js-story-popup');
              if (popup?.open) { popup.classList.add('is-exiting'); setTimeout(() => { popup.classList.remove('is-exiting'); popup.style.removeProperty('--exit-translate-x'); popup.close(); if (feed) feed.removeAttribute('inert'); }, 300); }
              DOMHelper.select('.js-story-card')?.classList.remove('is-active'); if (feed) feed.removeAttribute('inert');
            }
            if (window.innerWidth < 1280) this.appEvents.emit('PLAYER:FORCE_PLAY');
            A11yAnnouncer.speak(this.state.config.locale.detailsClosed);
            if (this.previousFocusElement) { this.previousFocusElement.focus(); } else { DOMHelper.select(DOM_SELECTORS.BTN_OPEN_CONTEXT)?.focus(); }
          }
          HapticsEngine.light();
        }; executeToggle();
      }
      
      handleFocusTrap(e, container) {
        if (e.key !== 'Tab') return;
        const focusableSelectors = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'; const focusableElements = container.querySelectorAll(focusableSelectors); const elementsArray = Array.from(focusableElements).filter(el => !el.hasAttribute('disabled') && el.getAttribute('aria-hidden') !== 'true' && el.offsetParent !== null);
        if (elementsArray.length === 0) return; const firstElement = elementsArray[0], lastElement = elementsArray[elementsArray.length - 1];
        if (e.shiftKey) { if (document.activeElement === firstElement || document.activeElement === container) { e.preventDefault(); lastElement.focus(); } } 
        else { if (document.activeElement === lastElement) { e.preventDefault(); firstElement.focus(); } }
      }
      
      toggleMute() {
        if (this.state.isGlobalMuted || this.state.volume === 0) { this.state.volume = this.state.savedVolume > 0 ? this.state.savedVolume : 100; this.state.isGlobalMuted = false; MediaUtils.rampUpVolume(this.state.currentMedia, this.state.volume); A11yAnnouncer.speak(this.state.config.locale.unmuteAudio); } 
        else { this.state.savedVolume = this.state.volume; this.state.isGlobalMuted = true; this.state.currentMedia?.mute?.(); A11yAnnouncer.speak(this.state.config.locale.muteAudio); } HapticsEngine.light();
      }
      
      updateVolumeFromSlider(event) {
        const val = parseInt(event.target.value, 10);
        if (val === 0) { this.state.volume = 0; this.state.isGlobalMuted = true; this.state.currentMedia?.mute?.(); } 
        else { this.state.volume = val; this.state.savedVolume = val; if (this.state.isGlobalMuted) { this.state.isGlobalMuted = false; this.state.currentMedia?.unMute?.(); } this.state.currentMedia?.setVolume?.(val); }
        A11yAnnouncer.speak(`${this.state.config.locale.volume} ${val}%`);
      }
      
      toggleReactionMenu() {
        const wrapper = this.dom.reactionWrapper; if (!wrapper) return; const isActive = !wrapper.classList.contains('is-active');
        FluidBounds.animate(wrapper, () => { wrapper.classList.toggle('is-active', isActive); this.dom.btnReaction?.setAttribute('aria-expanded', isActive); });
      }
      
      closeReactionMenu() {
        if(this.dom.reactionWrapper && this.dom.reactionWrapper.classList.contains('is-active')) {
          FluidBounds.animate(this.dom.reactionWrapper, () => { this.dom.reactionWrapper.classList.remove('is-active'); this.dom.btnReaction?.setAttribute('aria-expanded', 'false'); });
        }
      }
      
      triggerReaction(payload) {
        const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
        if (now - this.lastReactionTime < 300) return; this.lastReactionTime = now;
        const emojiStr = typeof payload === 'string' ? payload : payload.emoji; 
        const isDoubleTap = typeof payload === 'object' ? payload.isDoubleTap : false; 
        let isRemoving = false; 
        const mediaData = this.state.getActiveMediaData();
        
        if (mediaData && mediaData.id) {
          const previousReaction = this.state.currentUser.reactions.get(mediaData.id);
          const newReaction = isDoubleTap ? emojiStr : (previousReaction === emojiStr ? undefined : emojiStr);

          if (newReaction) {
            this.state.currentUser.reactions.set(mediaData.id, newReaction); A11yAnnouncer.speak(`Bereaksi dengan ${newReaction}`);
          } else {
            this.state.currentUser.reactions.delete(mediaData.id); A11yAnnouncer.speak(`Menghapus reaksi`); isRemoving = true;
          }
          this.updateLikeState(mediaData);

          /* NEW PATCH: Lifecycle Hook onReactionTriggered */
          if (this.state.config.onReactionTriggered) {
             this.state.config.onReactionTriggered(newReaction || null, mediaData.id);
          }

          this.state.adapter.toggleLike(mediaData.id, newReaction).then(response => {
             if (!response.success) {
                console.warn("Gagal menyimpan reaksi, mengembalikan UI.");
                if (previousReaction) { this.state.currentUser.reactions.set(mediaData.id, previousReaction); } 
                else { this.state.currentUser.reactions.delete(mediaData.id); }
                this.updateLikeState(mediaData);
             }
          });
        }
        
        if (isDoubleTap) {
          const centerNode = this.dom.centerReaction;
          if (this.dom.btnReaction && !isRemoving) { this.dom.btnReaction.style.transform = 'scale(1.3)'; setTimeout(() => { this.dom.btnReaction.style.transform = ''; }, 150); }
          if (centerNode && !isRemoving) {
            const tilt = Math.floor(Math.random() * 30) - 15; centerNode.style.setProperty('--tilt', `${tilt}deg`); const htmlStr = `<span style="display: inline-block;">${emojiStr}</span>`;
            centerNode.innerHTML = ttPolicy ? ttPolicy.createHTML(htmlStr) : htmlStr; centerNode.classList.remove('is-animating'); void centerNode.offsetWidth; centerNode.classList.add('is-animating');
            centerNode.onanimationend = () => { centerNode.classList.remove('is-animating'); centerNode.onanimationend = null; }; UISoundFX.play('pop', 0.5);
          }
          this.closeReactionMenu();
        } else {
          if (isRemoving) { this.closeReactionMenu(); return; } if (this.dom.reactionContainer && this.dom.reactionContainer.childElementCount > 30) return; if (this.state.prefersReducedMotion) { HapticsEngine.heavy(); this.closeReactionMenu(); return; }
          const fragment = document.createDocumentFragment(); const particleCount = this.state.isEcoMode ? 3 : 15;
          for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div'); const depth = Math.random(); particle.className = 'particle'; particle.innerText = emojiStr;
            particle.style.cssText = `--x: ${70 + (Math.random() * 20)}%; --size: calc(clamp(1rem, 0.8rem + 2vmin, 2rem) * ${depth * 0.8 + 0.6}); --blur: ${depth < 0.2 ? '3px' : '0px'}; --z: ${depth > 0.5 ? 20 : 1}; --duration: ${2000 + Math.random() * 800}ms; --delay: ${Math.random() * 100}ms; --rotation: ${(Math.random() - 0.5) * 120}deg; --drift: ${(Math.random() - 0.5) * 100}px;`;
            particle.onanimationend = () => particle.remove(); fragment.appendChild(particle);
          }
          if (this.dom.reactionContainer) this.dom.reactionContainer.appendChild(fragment); HapticsEngine.heavy(); this.closeReactionMenu();
        }
      }
    }

    class PlayerManager {
      constructor(state, uiManager, appEvents) { this.state = state; this.uiManager = uiManager; this.appEvents = appEvents; this.lastInteractionTime = 0; this.setupEventSubscriptions(); }
      setupEventSubscriptions() {
        this.appEvents.on('PLAYER:TOGGLE_PLAY', () => this.togglePlayPause()); this.appEvents.on('PLAYER:FORCE_PLAY', () => { this.state.currentMedia?.play(); this.state.currentAmbient?.play(); }); this.appEvents.on('PLAYER:FORCE_PAUSE', () => { this.state.currentMedia?.pause(); this.state.currentAmbient?.pause(); }); this.appEvents.on('PLAYER:SEEK', (offset) => this.seekVideo(offset)); this.appEvents.on('PLAYER:NEXT', () => this.navigateNext()); this.appEvents.on('PLAYER:PREV', () => this.navigatePrev()); this.appEvents.on('PLAYER:SWITCH_VIDEO', (step) => this.switchVideo(step)); this.appEvents.on('PLAYER:JUMP_SUB', (index) => this.jumpToSub(index));
      }
      jumpToSub(targetIndex) {
        if (this.state.fsm.getState() === 'TRANSITIONING' || targetIndex === this.state.currentSubIndex) return;
        const groupData = this.state.playlist[this.state.currentVideoIndex]; const maxIndex = groupData.items ? groupData.items.length - 1 : 0; if (targetIndex < 0 || targetIndex > maxIndex) return;
        const direction = targetIndex > this.state.currentSubIndex ? 1 : -1;
        this.triggerTransition(() => { this.state.currentSubIndex = targetIndex; this.appEvents.emit('UI:RESET_STATE'); this.updateVideoCore(); }, direction);
      }
      handleMediaStateChange(mediaState) {
        if (mediaState === MEDIA_STATE.PLAYING) {
          clearTimeout(this.state.timers.loading); WakeLockManager.request();
          if (!this.state.watchStartTime) this.state.watchStartTime = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
          if (this.state.currentAmbient && this.state.currentMedia && !this.state.isEcoMode) { this.state.currentAmbient.seekTo(this.state.currentMedia.getCurrentTime()); this.state.currentAmbient.play(); }
        } else if (mediaState === MEDIA_STATE.PAUSED) {
          clearTimeout(this.state.timers.loading); WakeLockManager.release(); this.state.currentAmbient?.pause();
        } else if (mediaState === MEDIA_STATE.BUFFERING) {
          this.state.currentAmbient?.pause();
        } else if (mediaState === MEDIA_STATE.ENDED) {
          clearTimeout(this.state.timers.loading); WakeLockManager.release();
          const isContextOpen = this.state.fsm.getState() === 'CONTEXT_OPEN'; const group = this.state.playlist[this.state.currentVideoIndex]; const isMulti = group && group.items && group.items.length > 1; const count = isMulti ? group.items.length : 1;
          
          if (isContextOpen) {
            this.state.currentMedia?.seekTo(0); this.state.currentMedia?.play();
            if (!this.state.isEcoMode) { this.state.currentAmbient?.seekTo(0); this.state.currentAmbient?.play(); }
            this.appEvents.emit('MEDIA:STATE_CHANGE', MEDIA_STATE.PLAYING); return;
          }
          if (isMulti && this.state.currentSubIndex < count - 1) { this.navigateNext(); } 
          else if (this.state.currentVideoIndex < this.state.playlist.length - 1) { this.switchVideo(1); } 
          else { this.playBumpEffect('right'); this.state.currentMedia?.pause(); }
        }
        this.appEvents.emit('MEDIA:STATE_CHANGE', mediaState);
      }
      updateMediaSession(mediaData, groupData) {
        if ('mediaSession' in navigator) {
          const title = mediaData.title || groupData.title || 'NextGen Story'; const artist = mediaData.meta || groupData.meta || 'Premium Edition'; let artworkUrl = mediaData.thumbnail || mediaData.url;
          if (mediaData.type === 'youtube') { const ytData = MediaUtils.parseYouTubeData(mediaData.url); artworkUrl = `https://i.ytimg.com/vi/${ytData.videoId}/maxresdefault.jpg`; }
          navigator.mediaSession.metadata = new MediaMetadata({ title: title, artist: artist, artwork: [ { src: artworkUrl, sizes: '512x512', type: 'image/jpeg' }, { src: artworkUrl, sizes: '256x256', type: 'image/jpeg' } ] });
          try { navigator.mediaSession.setActionHandler('play', () => this.appEvents.emit('PLAYER:FORCE_PLAY')); navigator.mediaSession.setActionHandler('pause', () => this.appEvents.emit('PLAYER:FORCE_PAUSE')); navigator.mediaSession.setActionHandler('previoustrack', () => this.appEvents.emit('PLAYER:PREV')); navigator.mediaSession.setActionHandler('nexttrack', () => this.appEvents.emit('PLAYER:NEXT')); } catch (e) {}
        }
      }
      updateVideoCore() {
        if (!this.state.isApiReady || this.state.playlist.length === 0) return; const groupData = this.state.playlist[this.state.currentVideoIndex]; if (!groupData) return; const mediaData = this.state.getActiveMediaData();
        
        if (this.state.config.onStoryChange) {
           this.state.config.onStoryChange(this.state.currentVideoIndex, this.state.currentSubIndex, mediaData);
        }

        this.appEvents.emit('UI:RENDER_CORE', { groupData, mediaData, renderIndex: this.state.currentVideoIndex, renderSubIndex: this.state.currentSubIndex });
        if (this.state.currentMedia) this.state.currentMedia.destroy(); if (this.state.currentAmbient) this.state.currentAmbient.destroy();
        
        const mainContainer = DOMHelper.select(DOM_SELECTORS.MAIN_MEDIA), ambientContainer = DOMHelper.select(DOM_SELECTORS.AMBIENT_MEDIA);
        const mainConfig = {
          container: mainContainer, data: mediaData,
          callbacks: {
            onReady: () => { DOMHelper.root.classList.add('is-ready'); this.state.errorCount = 0; DOMHelper.select(DOM_SELECTORS.ERROR_OVERLAY)?.classList.remove('is-visible'); if (!document.hidden) this.state.currentMedia.play(); else this.state.wasPlayingBeforeHidden = true; },
            onStateChange: (mediaState) => this.handleMediaStateChange(mediaState),
            onError: (errEvent, customMsg) => this.handleMediaError(mediaData, customMsg)
          }, isAmbient: false, appEvents: this.appEvents, state: this.state
        };
        this.state.currentMedia = MediaFactory.create(mainConfig);
        
        if (window.innerWidth >= 768 && ambientContainer && !this.state.isEcoMode) {
          const ambientConfig = { container: ambientContainer, data: mediaData, callbacks: { onReady: () => { if (!document.hidden) this.state.currentAmbient.play(); } }, isAmbient: true, appEvents: this.appEvents, state: this.state };
          this.state.currentAmbient = MediaFactory.create(ambientConfig); this.state.currentAmbient?.load();
        }
        this.state.currentMedia?.load(); this.updateURLState(mediaData, groupData); this.updateMediaSession(mediaData, groupData); this.checkNavigationState();
        
        // PATCH: Teruskan parameter this.state.currentSubIndex ke sinkronisasi memori
        window.requestIdleCallback(() => { 
          MemoryNetworkManager.syncVirtualWindow(
            this.state.playlist, 
            this.state.currentVideoIndex, 
            this.state.currentSubIndex, 
            this.state.config
          ); 
        });
      }
      handleMediaError(mediaData, customMsg) {
        const btnRetry = DOMHelper.select(DOM_SELECTORS.ERROR_RETRY), 
              overlay = DOMHelper.select(DOM_SELECTORS.ERROR_OVERLAY), 
              title = DOMHelper.select(DOM_SELECTORS.ERROR_TITLE), 
              desc = DOMHelper.select(DOM_SELECTORS.ERROR_DESC);
        
        const container = DOMHelper.select(DOM_SELECTORS.STORY_CONTAINER);
        if (container) {
          container.classList.remove('is-loading');
          container.classList.add('show-ui'); 
        }

        /* PATCH: Sembunyikan elemen UI bawah saat terjadi error */
        if (this.uiManager.dom.progressWrapper) this.uiManager.dom.progressWrapper.style.display = 'none';
        const excerptBtn = DOMHelper.select('.js-btn-open-context');
        if (excerptBtn) excerptBtn.style.display = 'none';
        const playerActions = DOMHelper.select('.story-player-actions');
        if (playerActions) playerActions.style.display = 'none';

        DOMHelper.root.classList.add('is-ready');
        this.uiManager.stopProgressBar();

        if (customMsg) {
          if (title) title.innerText = this.state.config.locale.accessDenied; if (desc) desc.innerText = customMsg;
          if (btnRetry) { 
             btnRetry.innerText = this.state.config.locale.openInYouTube; 
             btnRetry.onclick = () => { 
                try { const safeUrl = new URL(mediaData.url); if (safeUrl.protocol === 'http:' || safeUrl.protocol === 'https:') window.open(safeUrl.href, '_blank', 'noopener,noreferrer'); } catch(e){} 
             }; 
          }
        } else if (!navigator.onLine) {
          if (title) title.innerText = this.state.config.locale.connectionLost; if (desc) desc.innerText = this.state.config.locale.checkNetwork;
          if (btnRetry) { 
             btnRetry.innerText = this.state.config.locale.tryAgain; 
             btnRetry.onclick = () => { overlay?.classList.remove('is-visible'); this.updateVideoCore(); } 
          } 
        } else {
          if (title) title.innerText = this.state.config.locale.videoUnavailable; if (desc) desc.innerText = this.state.config.locale.mediaFailed;
          if (btnRetry) { 
             btnRetry.innerText = this.state.config.locale.skip; 
             btnRetry.onclick = () => { 
                overlay?.classList.remove('is-visible');
                this.switchVideo(this.state.lastNavDirection > 0 ? 1 : -1); 
             }; 
          } 
        }
        
        overlay?.classList.add('is-visible');
      }
      updateURLState(mediaData, groupData) {
        let urlId; if (mediaData.type === 'youtube') { urlId = MediaUtils.parseYouTubeData(mediaData.url).videoId; } else { const displayTitle = mediaData.title || groupData.title; urlId = MediaUtils.slugify(displayTitle || 'story'); if (groupData.items && groupData.items.length > 1) urlId += `-${this.state.currentSubIndex + 1}`; }
        const newUrl = `${window.location.protocol}//${window.location.host}${window.location.pathname}?v=${urlId}`; window.history.replaceState({ index: this.state.currentVideoIndex, subIndex: this.state.currentSubIndex }, '', newUrl);
      }
      checkNavigationState() {
        const prevBtn = DOMHelper.select(DOM_SELECTORS.BTN_PREV), nextBtn = DOMHelper.select(DOM_SELECTORS.BTN_NEXT); const isFirst = this.state.currentVideoIndex === 0 && this.state.currentSubIndex === 0; const isLast = this.state.currentVideoIndex === this.state.playlist.length - 1 && (!this.state.playlist.at(-1).items || this.state.currentSubIndex === this.state.playlist.at(-1).items.length - 1);
        if (prevBtn) { prevBtn.classList.toggle('is-disabled', isFirst); prevBtn.disabled = isFirst; } if (nextBtn) { nextBtn.classList.toggle('is-disabled', isLast); nextBtn.disabled = isLast; }
      }
      triggerTransition(callback, direction = 0) {
        const now = Temporal.Now.instant().epochMilliseconds;
        if (!this.state.fsm.dispatch('START_TRANSITION') || (now - this.lastInteractionTime < 400)) return; this.lastInteractionTime = now;
        if (this.state.prefersReducedMotion || this.state.isEcoMode) { callback(); this.state.fsm.dispatch('END_TRANSITION'); return; }
        const mainMedia = DOMHelper.select(DOM_SELECTORS.MAIN_MEDIA);
        if (mainMedia) {
          mainMedia.style.transition = 'opacity 0.25s var(--ease-out), transform 0.3s var(--ease-spring), filter 0.25s var(--ease-out)'; mainMedia.style.opacity = '0'; mainMedia.style.filter = 'blur(4px) brightness(0.8)';
          if (direction !== 0) { mainMedia.style.transform = `translateX(${direction * -30}px) scale(0.92) rotateY(${direction * 5}deg)`; } else { mainMedia.style.transform = 'scale(0.92)'; }
        }
        setTimeout(() => {
          callback();
          if (mainMedia) {
            mainMedia.style.transition = 'none';
            if (direction !== 0) { mainMedia.style.transform = `translateX(${direction * 30}px) scale(1.05) rotateY(${direction * -5}deg)`; } else { mainMedia.style.transform = 'scale(1.05)'; }
            mainMedia.style.opacity = '0'; mainMedia.style.filter = 'blur(4px) brightness(1.2)'; void mainMedia.offsetWidth;
            mainMedia.style.transition = 'opacity 0.3s var(--ease-out), transform 0.45s var(--ease-spring), filter 0.3s var(--ease-out)'; mainMedia.style.opacity = '1'; mainMedia.style.filter = 'blur(0px) brightness(1)'; mainMedia.style.transform = 'translateX(0) scale(1) rotateY(0deg)';
          }
          setTimeout(() => { this.state.fsm.dispatch('END_TRANSITION'); }, 350);
        }, 250);
      }
      seekVideo(offsetSeconds) {
        if (!this.state.currentMedia) return; const duration = this.state.currentMedia.getDuration(); if (!duration) return;
        const newTime = Math.max(0, Math.min(this.state.currentMedia.getCurrentTime() + offsetSeconds, duration)); this.state.isSeeking = true; this.state.targetSeekTime = newTime; this.state.currentMedia.seekTo(newTime); if (this.state.currentAmbient) this.state.currentAmbient.seekTo(newTime);
      }
      playBumpEffect(direction) {
        const mediaContainer = DOMHelper.select(DOM_SELECTORS.MAIN_MEDIA); if (!mediaContainer || this.state.prefersReducedMotion) return; HapticsEngine.light();
        const className = direction === 'left' ? 'is-bumping-left' : 'is-bumping-right'; mediaContainer.classList.remove('is-bumping-left', 'is-bumping-right'); void mediaContainer.offsetWidth; mediaContainer.classList.add(className);
        mediaContainer.onanimationend = () => { mediaContainer.classList.remove(className); mediaContainer.onanimationend = null; };
      }
      switchVideo(stepOffset) {
        const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
        if (this.state.fsm.getState() === 'TRANSITIONING' || (now - this.lastInteractionTime < 500)) return; this.lastInteractionTime = now; this.state.lastNavDirection = stepOffset > 0 ? 1 : -1;
        if (this.state.fsm.getState() === 'CONTEXT_OPEN') { this.appEvents.emit('UI:TOGGLE_CONTEXT', false); }
        if (this.state.watchStartTime) { 
           const durationWatched = now - this.state.watchStartTime; 
           const currentMedia = this.state.getActiveMediaData(); 
           if(currentMedia) this.state.adapter.sendAnalytics(currentMedia.id, durationWatched); 
           this.state.watchStartTime = null; 
        }
        const newIndex = this.state.currentVideoIndex + stepOffset; const feed = DOMHelper.select(DOM_SELECTORS.FEED); const slots = feed ? feed.querySelectorAll('.story-slot') : [];
        if (slots[newIndex]) { this.state.fsm.dispatch('START_TRANSITION'); slots[newIndex].scrollIntoView({ behavior: (this.state.prefersReducedMotion || this.state.isEcoMode) ? 'auto' : 'smooth', block: 'center' }); setTimeout(() => { this.state.fsm.dispatch('END_TRANSITION'); }, 600); } else { this.appEvents.emit('APP:CLOSE'); }
      }
