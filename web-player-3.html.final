          this.sheetVelocity = velocity; 
          
          const step = () => {
            const force = (target - this.sheetY) * stiffness; this.sheetVelocity = (this.sheetVelocity + force) * damping; this.sheetY += this.sheetVelocity; 
            const sheet = DOMHelper.select('.story-sheet__content');
            
            if (sheet) { sheet.style.transition = 'none'; sheet.style.transform = `translate3d(0, ${this.sheetY}px, 0)`; sheet.style.setProperty('--sheet-y', `${Math.max(0, this.sheetY)}px`); }
            
            if (Math.abs(this.sheetVelocity) < 0.5 && Math.abs(target - this.sheetY) < 0.5) {
