        this.initDragSheet(); 
        this.initRubberBand(); 
        this.initPopupSwipe(); 
        
        this.initiOSScrollGuard();
      }
      
      forceClearScreenGestures() {
        const s = this.screenState;
        if (!s) return;
        clearTimeout(s.longPressTimer);
        clearTimeout(s.singleTapTimer);
        clearTimeout(s.tapResetTimer);
        
        if (s.isLongPressActive) {
          s.isLongPressActive = false;
          DOMHelper.root.classList.remove('is-gesture-active');
          DOMHelper.root.removeAttribute('data-action');
          DOMHelper.select('.js-speed-badge')?.classList.remove('is-visible');
        }
        s.startX = 0; s.isSwiping = false; s.tapCount = 0; s.cumulativeSeek = 0;
      }

      initiOSScrollGuard() {
        const bodies = DOMHelper.selectAll('.story-body');
        bodies.forEach(body => {
          body.addEventListener('touchstart', function() {
            const top = body.scrollTop;
            const totalScroll = body.scrollHeight;
            const currentScroll = top + body.offsetHeight;
            if (top === 0) {
              body.scrollTop = 1;
            } else if (currentScroll === totalScroll) {
              body.scrollTop = top - 1;
            }
          }, { passive: true });
        });
      }
      
      initProgressBarGestures() {
