    class GestureManager {
      constructor(state, appEvents) { 
        this.state = state; this.appEvents = appEvents; 
        this.gestureState = { isPinching: false, pinchJustEnded: false, isDragging: false, startY: 0, currentY: 0, stopScrubCallback: null, wasCleanMode: false }; 
        
