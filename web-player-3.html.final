            DOMHelper.root.classList.add('is-gesture-active'); DOMHelper.root.setAttribute('data-action', 'pinch');
            const mediaContainer = DOMHelper.select(DOM_SELECTORS.MAIN_MEDIA); mediaElement = mediaContainer?.firstElementChild;
