          const speedText = s.holdAction === 'forward' ? '2x' : '0.5x';
          const contentHtml = `<div style="display: flex; align-items: center; gap: 4px;"><i data-lucide="${iconName}" style="width: 1.2em; height: 1.2em;"></i> <span style="font-size: 1rem;">${speedText}</span></div>`;
          
          this.state.currentMedia?.setPlaybackRate(rate); 
          if (this.state.currentAmbient) this.state.currentAmbient.setPlaybackRate(rate); 
          
          this.appEvents.emit('UI:SHOW_RIPPLE', { side: s.holdAction === 'forward' ? 'right' : 'left', text: contentHtml }); 
          
