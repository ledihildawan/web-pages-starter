      initDragSheet() {
        let dragController = null, startY = 0, lastY = 0, lastTime = 0, dragRaf = null;
        const dialog = DOMHelper.select('#story-sheet-dialog'); 
        
        const move = (event) => {
          if (!this.gestureState.isDragging || window.innerWidth >= 768) return;
          
          const y = event.touches ? event.touches[0].clientY : event.clientY; 
          const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now(); 
          const deltaTime = now - lastTime;
          
          if (deltaTime > 0) this.sheetVelocity = ((y - lastY) / deltaTime) * 16;
          let deltaY = y - lastY; 
          
          const scrollableArea = event.target.closest('.story-body'); 
