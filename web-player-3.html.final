              sheet.style.setProperty('--sheet-y', `${Math.max(0, this.sheetY)}px`); 
              
              if (dialog) {
                 const vh = window.innerHeight;
                 const progress = Math.max(0, Math.min(1, 1 - (this.sheetY / (vh * 0.7))));
                 dialog.style.setProperty('--bg-opacity', progress.toFixed(3));
              }
            } 
          });
        };
        
        const end = () => {
          if (!this.gestureState.isDragging || window.innerWidth >= 768) return;
          this.gestureState.isDragging = false; 
          
          const sheet = DOMHelper.select('.story-sheet__content'); 
          if (sheet) sheet.classList.remove('is-dragging');
          if (dialog) {
             dialog.classList.remove('is-dragging-backdrop');
             dialog.style.removeProperty('--bg-opacity'); 
          }

          if (dragController) { dragController.abort(); dragController = null; }
          
          const vh = window.innerHeight; 
          const projectedY = this.sheetY + (this.sheetVelocity * 18); 
          let targetState = 'half';
          
          if (this.sheetVelocity > 20) targetState = 'hidden';
          else if (this.sheetVelocity < -20) targetState = 'full';
          else if (projectedY < vh * 0.25) targetState = 'full'; 
          else if (projectedY > vh * 0.6) targetState = 'hidden';
          
          if (targetState === 'hidden') this.appEvents.emit('UI:TOGGLE_CONTEXT', false); 
          else this.appEvents.emit('SHEET:ANIMATE_TO', { state: targetState, velocity: this.sheetVelocity });
        };
        
        const start = (event) => {
          if (this.gestureState.isPinching || window.innerWidth >= 768) return;
          
          const scrollableArea = event.target.closest('.story-body'); 
          if (scrollableArea && scrollableArea.scrollTop > 0) return;
          
          startY = event.touches ? event.touches[0].clientY : event.clientY; 
          lastY = startY; 
          lastTime = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now(); 
          this.sheetVelocity = 0; 
          this.gestureState.isDragging = true; 
          cancelAnimationFrame(this.springAnimId);
          
          const sheet = DOMHelper.select(DOM_SELECTORS.SHEET_CONTENT); 
          if (sheet) { sheet.classList.add('is-dragging'); sheet.style.transition = 'none'; }
          if (dialog) { dialog.classList.add('is-dragging-backdrop'); } 
          
          dragController = new AbortController(); 
          const opts = { signal: dragController.signal }, optsPassive = { passive: false, signal: dragController.signal };
          
          window.addEventListener('touchmove', move, optsPassive);
          window.addEventListener('touchend', end, opts);
          window.addEventListener('touchcancel', end, opts);
          window.addEventListener('pointermove', move, optsPassive);
          window.addEventListener('pointerup', end, opts);
        };
        
        EventRegistry.add(document, 'touchstart', (e) => { if(e.target.closest(DOM_SELECTORS.SHEET_CONTENT)) start(e); }, { passive: true }, 'app');
        EventRegistry.add(document, 'mousedown', (e) => { if(e.target.closest(DOM_SELECTORS.SHEET_CONTENT)) start(e); }, { passive: true }, 'app');
      }
      
      initPopupSwipe() {
        let popupStartX = 0, popupCurrentX = 0, popupDragging = false, swipeRaf = null;
        EventRegistry.add(document, 'pointerdown', (e) => {
          const popup = e.target.closest('.story-popup__content'); if (!popup || e.target.closest('.story-body')) return;
          popupStartX = e.clientX; popupDragging = true; popup.style.transition = 'none';
        }, { passive: true }, 'app');
        EventRegistry.add(window, 'pointermove', (e) => {
          if (!popupDragging) return; popupCurrentX = e.clientX - popupStartX;
          if (swipeRaf) cancelAnimationFrame(swipeRaf);
          swipeRaf = requestAnimationFrame(() => { const popup = DOMHelper.select('.story-popup__content'); if(popup) popup.style.transform = `translate3d(${popupCurrentX}px, 0, 0) scale(0.98)`; });
        }, { passive: true }, 'app');
        EventRegistry.add(window, 'pointerup', (e) => {
          if (!popupDragging) return; popupDragging = false; const popup = DOMHelper.select('.story-popup__content'); if(!popup) return;
          if (Math.abs(popupCurrentX) > 100) { popup.style.setProperty('--exit-translate-x', `${Math.sign(popupCurrentX) * 100}vw`); this.appEvents.emit('UI:TOGGLE_CONTEXT', false); } 
          else { popup.style.transition = 'transform 0.25s var(--ease-out)'; popup.style.transform = `translate3d(0, 0, 0) scale(1)`; } popupCurrentX = 0;
        }, { passive: true }, 'app');
      }
      
      initRubberBand() {
        let startY = 0, isPulling = false, lastDelta = 0, startTime = 0, rubberRaf = null;
        const threshold = 80; 
        
        const topIndicator = DOMHelper.select('.js-pull-top');
        const bottomIndicator = DOMHelper.select('.js-pull-bottom');
        const topText = topIndicator?.querySelector('.pull-indicator__text');
        const bottomText = bottomIndicator?.querySelector('.pull-indicator__text');

        const applyRubberBand = (distance, dimension) => { return (1.0 - (1.0 / ((distance * 0.55 / dimension) + 1.0))) * dimension; };
        
        EventRegistry.add(document, 'touchstart', (e) => {
          const feed = e.target.closest(DOM_SELECTORS.FEED);
          if (!feed || (e.touches && e.touches.length > 1) || this.gestureState.isPinching || e.target.closest('.story-progress-bar-wrapper, .story-top-actions, .story-player-actions')) return;
          const isAtTop = feed.scrollTop <= 0, isAtBottom = Math.ceil(feed.scrollTop + feed.clientHeight) >= feed.scrollHeight - 5;
          if (isAtTop || isAtBottom) { startY = e.touches[0].clientY; startTime = performance.now(); isPulling = true; feed.style.transition = 'none'; lastDelta = 0; }
        }, { passive: true }, 'app');
        
        EventRegistry.add(document, 'touchmove', (e) => {
          const feed = DOMHelper.select(DOM_SELECTORS.FEED); if (!isPulling || !feed) return;
          const deltaY = e.touches[0].clientY - startY, dimension = window.innerHeight; 
          const isAtTop = feed.scrollTop <= 0, isAtBottom = Math.ceil(feed.scrollTop + feed.clientHeight) >= feed.scrollHeight - 5;
          let targetY = 0;
          
          if (isAtTop && deltaY > 0) { 
            if (e.cancelable) e.preventDefault(); lastDelta = deltaY; targetY = applyRubberBand(deltaY, dimension); 
            if (topIndicator) {
              const ratio = Math.min(lastDelta / threshold, 1.2);
              topIndicator.classList.add('is-visible');
              topIndicator.style.transform = `translateX(-50%) translateY(${targetY * 0.2}px) scale(${0.8 + (ratio * 0.2)})`;
              
              if (lastDelta >= threshold) {
                topIndicator.classList.add('is-ready');
                if (topText) topText.innerText = this.state.config.locale.pullToClose;
                if (!this.state.prefersReducedMotion && !topIndicator.dataset.hapticFired) { HapticsEngine.light(); topIndicator.dataset.hapticFired = 'true'; }
              } else {
                topIndicator.classList.remove('is-ready');
                if (topText) topText.innerText = this.state.config.locale.pullDown;
                topIndicator.dataset.hapticFired = '';
              }
            }
          } 
          else if (isAtBottom && deltaY < 0) { 
            if (e.cancelable) e.preventDefault(); lastDelta = deltaY; targetY = applyRubberBand(Math.abs(deltaY), dimension) * -1; 
            if (bottomIndicator) {
              const ratio = Math.min(Math.abs(lastDelta) / threshold, 1.2);
              bottomIndicator.classList.add('is-visible');
              bottomIndicator.style.transform = `translateX(-50%) translateY(${targetY * 0.2}px) scale(${0.8 + (ratio * 0.2)})`;
              
              if (Math.abs(lastDelta) >= threshold) {
                bottomIndicator.classList.add('is-ready');
                if (bottomText) bottomText.innerText = this.state.config.locale.pullToClose;
                if (!this.state.prefersReducedMotion && !bottomIndicator.dataset.hapticFired) { HapticsEngine.light(); bottomIndicator.dataset.hapticFired = 'true'; }
              } else {
                bottomIndicator.classList.remove('is-ready');
                if (bottomText) bottomText.innerText = this.state.config.locale.pullUp;
                bottomIndicator.dataset.hapticFired = '';
              }
            }
          } 
          else { lastDelta = 0; return; }
          
          if (rubberRaf) cancelAnimationFrame(rubberRaf); rubberRaf = requestAnimationFrame(() => { feed.style.transform = `translate3d(0, ${targetY}px, 0)`; });
        }, { passive: false }, 'app');
        
        const endPull = () => {
          const feed = DOMHelper.select(DOM_SELECTORS.FEED);
          if (isPulling && feed) {
            isPulling = false; const timeElapsed = performance.now() - startTime, velocity = Math.abs(lastDelta) / timeElapsed;
            [topIndicator, bottomIndicator].forEach(ind => {
              if (ind) { ind.classList.remove('is-visible', 'is-ready'); ind.style.transform = 'translateX(-50%) scale(0.8)'; ind.dataset.hapticFired = ''; }
            });
            if (Math.abs(lastDelta) >= threshold || (velocity > 0.4 && Math.abs(lastDelta) > 30)) { this.appEvents.emit('APP:CLOSE'); return; }
            feed.style.transition = this.state.prefersReducedMotion ? 'none' : 'transform 0.4s var(--ease-spring)'; feed.style.transform = 'translate3d(0, 0, 0)'; lastDelta = 0;
          }
        };
        EventRegistry.add(document, 'touchend', endPull, { passive: true }, 'app'); EventRegistry.add(document, 'touchcancel', endPull, { passive: true }, 'app');
      }
    }

    const ViewComponents = {
      AmbientLayer: () => `
        <div class="ambient-layer js-ambient-container" aria-hidden="true">
          <div class="media-container ambient-media-container js-ambient-media"></div>
        </div>
      `,

      Loader: () => `
        <div class="story-loader" aria-hidden="true">
          <div class="story-loader__spinner-simple"></div>
          <div class="story-loader__spinner-complex">
            <div class="story-loader__container">
              <div class="story-loader__rotator">
                <div class="story-loader__left"><div class="story-loader__circle"></div></div>
                <div class="story-loader__right"><div class="story-loader__circle"></div></div>
              </div>
            </div>
          </div>
        </div>
      `,

      ErrorOverlay: () => `
        <div class="story-error-overlay js-error-overlay" role="alert" aria-live="assertive">
          <div class="error-content">
            <span class="error-icon" aria-hidden="true">⚠️</span>
            <h3 class="error-title js-error-title">Koneksi Terputus</h3>
            <p class="error-desc js-error-desc">Gagal memuat media kualitas tinggi.</p>
            <button type="button" class="error-retry-btn js-error-retry">Coba Lagi</button>
          </div>
        </div>
      `,

      MainMedia: () => `
        <figure class="story-video-wrapper">
          <img class="thumbnail-overlay js-thumbnail-overlay" alt="" aria-hidden="true" src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='1' height='1'/%3E" loading="lazy" />
          <div class="media-container main-media-container js-main-media"></div>
        </figure>
      `,

      InteractiveUI: () => `
        <div class="reaction-container-layer js-reaction-container" aria-hidden="true"></div>
        <div class="speed-badge js-speed-badge"></div>
        <div class="story-center-play js-center-play" aria-hidden="true"></div>
        <div class="story-center-reaction js-center-reaction" aria-hidden="true"></div>
        
        <div class="ripple-edge ripple-edge--left js-ripple-left"><div class="ripple-edge__capsule js-ripple-text-left"></div></div>
        <div class="ripple-edge ripple-edge--right js-ripple-right"><div class="ripple-edge__capsule js-ripple-text-right"></div></div>
        
        <div class="story-gesture-layer js-gesture-layer">
          <div class="gesture-zone gesture-zone--left" data-action="rewind" role="button" tabindex="-1"></div>
          <div class="gesture-zone gesture-zone--center" data-action="playpause" role="button" tabindex="-1"></div>
          <div class="gesture-zone gesture-zone--right" data-action="forward" role="button" tabindex="-1"></div>
        </div>
        
        <div class="story-progress-bar-wrapper js-progress-wrapper" role="progressbar"></div>
        
        <header class="story-top-actions">
          <button type="button" class="fab-wrapper js-btn-play" aria-label="Pause Video" aria-pressed="false" title="Play/Pause (Spasi atau K)" aria-keyshortcuts="Space k">
            <span class="fab-inner"></span>
          </button>
          <div class="volume-wrapper js-volume-wrapper">
            <div class="volume-inner">
              <button type="button" class="volume-btn js-btn-mute" aria-label="Unmute Audio" aria-pressed="true" title="Mute/Unmute (M)" aria-keyshortcuts="m"></button>
              <div class="volume-slider-box">
                <input type="range" class="volume-slider js-volume-slider" aria-label="Adjust Volume" min="0" max="100" value="0" title="Atur Volume (- / +)">
              </div>
            </div>
          </div>
        </header>
        
        <div class="story-mobile-top-actions">
          <button type="button" class="fab-wrapper fullscreen-fab js-btn-clean" aria-label="Layar Penuh" title="Layar Penuh (F)" aria-keyshortcuts="f">
            <span class="fab-inner"><i data-lucide="maximize-2"></i></span>
          </button>
          <button type="button" class="fab-wrapper js-btn-close story-close-mobile" aria-label="Tutup" title="Tutup">
            <span class="fab-inner"><i data-lucide="x"></i></span>
          </button>
        </div>
        
        <button type="button" class="story-excerpt js-btn-open-context" aria-label="Buka Detail" title="Info / Detail (I)" aria-keyshortcuts="i">
          <div class="story-excerpt__badges"></div>
          <span class="story-excerpt__title">Media Title</span>
          <div class="story-excerpt__text">Brief description...</div>
        </button>
        
        <aside class="story-player-actions">
          <div class="reaction-wrapper js-reaction-wrapper">
            <div class="reaction-options">
              <button type="button" class="reaction-option-btn" data-reaction="❤️">❤️</button>
              <button type="button" class="reaction-option-btn" data-reaction="😂">😂</button>
              <button type="button" class="reaction-option-btn" data-reaction="🔥">🔥</button>
              <button type="button" class="reaction-option-btn" data-reaction="😮">😮</button>
              <button type="button" class="reaction-option-btn" data-reaction="👏">👏</button>
            </div>
            <button type="button" class="fab-wrapper js-btn-reaction" aria-label="Beri Reaksi" aria-expanded="false" title="Suka (L)" aria-keyshortcuts="l">
              <span class="fab-inner"><i data-lucide="heart"></i></span>
            </button>
          </div>
          <button type="button" class="fab-wrapper share-fab js-btn-share" aria-label="Bagikan" title="Bagikan (S)" aria-keyshortcuts="s">
            <span class="fab-inner"><i data-lucide="share-2"></i></span>
          </button>
        </aside>
      `,

      DesktopNavigation: () => `
        <nav class="desktop-controls-wrapper">
          <div class="desktop-top-actions">
            <button type="button" class="fab-wrapper fullscreen-fab js-btn-clean" aria-label="Layar Penuh" title="Layar Penuh (F)" aria-keyshortcuts="f">
              <span class="fab-inner"><i data-lucide="maximize-2"></i></span>
            </button>
            <button type="button" class="fab-wrapper story-close-player js-btn-close" aria-label="Tutup" title="Tutup Player (Esc)" aria-keyshortcuts="Escape">
              <span class="fab-inner"><i data-lucide="x"></i></span>
            </button>
          </div>
          <div class="external-nav-group">
            <button type="button" class="fab-wrapper external-nav-btn js-btn-prev" aria-label="Sebelumnya" title="Video Sebelumnya (Panah Atas)" aria-keyshortcuts="ArrowUp">
              <span class="fab-inner"><i data-lucide="chevron-up"></i></span>
            </button>
            <button type="button" class="fab-wrapper external-nav-btn js-btn-next" aria-label="Selanjutnya" title="Video Selanjutnya (Panah Bawah)" aria-keyshortcuts="ArrowDown">
              <span class="fab-inner"><i data-lucide="chevron-down"></i></span>
            </button>
          </div>
        </nav>
      `,

      ContextPanels: () => `
        <aside class="story-card js-story-card" aria-label="Detailed Information">
          <button type="button" class="fab-wrapper story-close-btn" aria-label="Tutup"><span class="fab-inner"><i data-lucide="x"></i></span></button>
          <div class="story-dynamic-area"></div>
        </aside>
        
        <dialog id="story-sheet-dialog" class="story-sheet js-story-sheet" aria-label="Detailed Information">
          <div class="story-sheet__content">
            <div class="story-sheet__handle-wrapper js-sheet-handle"><div class="story-sheet__handle"></div></div>
            <button type="button" class="fab-wrapper story-close-btn" aria-label="Tutup" style="display: none;"></button>
            <div class="story-dynamic-area"></div>
          </div>
        </dialog>
        
        <dialog class="story-popup js-story-popup" aria-label="Detailed Information">
          <div class="story-popup__content">
            <button type="button" class="fab-wrapper story-close-btn" aria-label="Tutup"><span class="fab-inner"><i data-lucide="x"></i></span></button>
            <div class="story-dynamic-area"></div>
          </div>
        </dialog>
      `,

      DynamicTemplate: () => `
        <template class="js-story-template">
          <div class="story-view is-active">
            <header class="story-header">
              <div class="story-view__badges"></div>
              <h3 class="story-view__title" tabindex="-1">Dynamic Title</h3>
              <span class="story-view__meta js-story-meta">Information • Metadata</span>
            </header>
            <section class="story-body" tabindex="0">
              <div class="story-body__cms-content"></div>
            </section>
          </div>
        </template>
      `
    };

    class NextGenStory {
      constructor(userConfig = {}) {
        const finalConfig = { ...DEFAULT_CONFIG, ...userConfig };
        this.appEvents = new EventBus();
        this.state = new ApplicationState(finalConfig, this.appEvents);
        this.injectDOM();
        this.uiManager = new UIManager(this.state, this.appEvents);
        this.playerManager = new PlayerManager(this.state, this.uiManager, this.appEvents);
        this.gestureManager = new GestureManager(this.state, this.appEvents);
        this.isProgrammaticScroll = false; this.observers = [];
        
        this.appEvents.on('APP:CLOSE', () => this.destroy());
        this.uiManager.syncVolumeUI();
        this.appEvents.on('MEDIA:STATE_CHANGE', (state) => { if (state === MEDIA_STATE.PLAYING) this.resetIdleTimer(); });
      }
      
      injectDOM() {
        if (document.querySelector('.js-layout-wrapper')) return;
        
        const masterTemplateStr = `
          <div class="sr-only js-a11y" aria-live="polite" aria-atomic="true"></div>
          <main class="layout-wrapper js-layout-wrapper" tabindex="-1">
            <div class="pull-indicator pull-indicator--top js-pull-top" aria-hidden="true">
              <div class="pull-indicator__icon"><i data-lucide="arrow-down"></i></div>
              <span class="pull-indicator__text">${this.state.config.locale.pullDown}</span>
            </div>
            <div class="pull-indicator pull-indicator--bottom js-pull-bottom" aria-hidden="true">
              <div class="pull-indicator__icon"><i data-lucide="arrow-up"></i></div>
              <span class="pull-indicator__text">${this.state.config.locale.pullUp}</span>
            </div>
            
            <div class="story-feed js-story-feed" aria-label="Media Feed" role="region"></div>
            
            <article class="story-container js-story-container is-loading" style="display: none;">
              ${ViewComponents.AmbientLayer()}
              
              <div class="story-viewport">
                ${ViewComponents.Loader()}
                ${ViewComponents.ErrorOverlay()}
                ${ViewComponents.MainMedia()}
                ${ViewComponents.InteractiveUI()}
              </div>
            </article>

            ${ViewComponents.ContextPanels()}
            ${ViewComponents.DesktopNavigation()}
          </main>
          
          ${ViewComponents.DynamicTemplate()}
        `;
        
        const targetContainer = this.state.config.target ? document.querySelector(this.state.config.target) : document.body;
        
        if (targetContainer) {
          const tempDiv = document.createElement('div'); 
          tempDiv.innerHTML = ttPolicy ? ttPolicy.createHTML(masterTemplateStr) : masterTemplateStr;
          while(tempDiv.firstChild) { targetContainer.appendChild(tempDiv.firstChild); }
          const layoutNode = document.querySelector('.js-layout-wrapper'); 
          if(layoutNode) layoutNode.style.cssText = "position: fixed; inset: 0; z-index: 99999; display: none;";
        }
      }
      
      async initialize() {
        if (typeof window.DOMPurify === 'undefined') {
          const dpScript = document.createElement('script'); dpScript.src = 'https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.6/purify.min.js'; document.head.appendChild(dpScript);
          const lcScript = document.createElement('script'); lcScript.src = 'https://unpkg.com/lucide@0.344.0'; document.head.appendChild(lcScript);
          await new Promise(resolve => { let loaded = 0; const check = () => { loaded++; if (loaded === 2) resolve(); }; dpScript.onload = check; lcScript.onload = check; });
        }
        await HardwareAwarenessManager.init(this.state, this.appEvents); MemoryNetworkManager.init();
        const layoutNode = document.querySelector('.js-layout-wrapper'); if(layoutNode) layoutNode.style.display = 'block';
        const fetched = await this.state.fetchPlaylist();
        if (!fetched || this.state.playlist.length === 0) { ToastService.show(this.state.config.locale.failedToLoad); return false; }
        
        this.initCoreEventListeners(); 
        
        // PATCH: Cek apakah user mendarat di video terakhir, jika ya, fetch halaman berikutnya!
        this.fetchMoreIfNeeded();
        
        return true;
      }

      /* PATCH: Method Reusable untuk Fetch API Pagination */
      fetchMoreIfNeeded() {
        if (this.state.currentVideoIndex >= this.state.playlist.length - 2 && !this.state.adapter.isLoading && this.state.adapter.hasMore) {
          this.state.adapter.getStories().then(newItems => {
            if (newItems.length === 0) return; 
            const currentLength = this.state.playlist.length; 
            this.state.playlist.push(...newItems);
            
            const feed = DOMHelper.select(DOM_SELECTORS.FEED);
            if (feed) {
              newItems.forEach((_, i) => { 
                const slot = document.createElement('div'); 
                slot.className = 'story-slot'; 
                slot.dataset.index = currentLength + i; 
                feed.appendChild(slot); 
                // Observe elemen baru yang ditambahkan
                if (this.feedObserver) this.feedObserver.observe(slot); 
              });
              this.updateVirtualization(this.state.currentVideoIndex);
              // Pastikan tombol Prev/Next mendeteksi penambahan data
              this.playerManager.checkNavigationState(); 
            }
          });
        }
      }
      
      initCoreEventListeners() {
        EventRegistry.add(document, 'pointerdown', (event) => {
          const target = event.target; if (target.closest('.fab-wrapper, .reaction-option-btn, .volume-wrapper, .story-excerpt, .story-badge-item')) { const xRatio = event.clientX / window.innerWidth; UISoundFX.play('pop', xRatio); }
        }, { passive: true }, 'app');
        ['click', 'touchstart', 'keydown', 'pointerdown'].forEach(evt => EventRegistry.add(window, evt, () => { this.state.userInteracted = true; UISoundFX.init(); }, { once: true, passive: true }, 'app'));
        this.resolveInitialURL(); this.initScrollSnap(); this.attachGlobalKeyBindings(); this.attachGlobalClickBindings(); this.attachWindowBindings(); this.initOffScreenThrottling();
        if (window.lucide && document.querySelector('.js-layout-wrapper')) { window.lucide.createIcons({ root: document.querySelector('.js-layout-wrapper') }); }
      }
      
      resolveInitialURL() {
        if (this.state.config.startIndex !== undefined) { this.state.currentVideoIndex = this.state.config.startIndex; this.state.currentSubIndex = 0; return; }
        if (window.history.state && window.history.state.index !== undefined) { this.state.currentVideoIndex = window.history.state.index; this.state.currentSubIndex = window.history.state.subIndex || 0; return; }
        const urlV = new URLSearchParams(window.location.search).get('v');
        if (urlV) {
          let foundIndex = -1, foundSubIndex = 0;
          for (let i = 0; i < this.state.playlist.length; i++) {
            const group = this.state.playlist[i];
            if (group.items) {
              for (let j = 0; j < group.items.length; j++) {
                const item = group.items[j], title = item.title || group.title || 'story', itemSlug = item.type === 'youtube' ? MediaUtils.parseYouTubeData(item.url).videoId : MediaUtils.slugify(title) + `-${j + 1}`;
                if (itemSlug === urlV) { foundIndex = i; foundSubIndex = j; break; }
              }
            } else { let itemSlug = group.type === 'youtube' ? MediaUtils.parseYouTubeData(group.url).videoId : MediaUtils.slugify(group.title || 'story'); if (itemSlug === urlV) { foundIndex = i; break; } }
            if (foundIndex > -1) break;
          }
          if (foundIndex > -1) { this.state.currentVideoIndex = foundIndex; this.state.currentSubIndex = foundSubIndex; return; }
        }
      }
      
      initScrollSnap() {
        const feed = DOMHelper.select(DOM_SELECTORS.FEED), playerContainer = DOMHelper.select(DOM_SELECTORS.STORY_CONTAINER);
        playerContainer.style.display = ''; feed.innerHTML = '';
        this.state.playlist.forEach((item, index) => { const slot = document.createElement('div'); slot.className = 'story-slot'; slot.dataset.index = index; feed.appendChild(slot); });
        
        const slots = feed.querySelectorAll('.story-slot');
        if (slots[this.state.currentVideoIndex]) {
          this.isProgrammaticScroll = true; slots[this.state.currentVideoIndex].appendChild(playerContainer); feed.scrollTop = slots[this.state.currentVideoIndex].offsetTop;
          setTimeout(() => { this.isProgrammaticScroll = false; }, 800);
        }
        this.updateVirtualization(this.state.currentVideoIndex);
        
        let targetIndex = this.state.currentVideoIndex;
        const observer = new IntersectionObserver((entries) => { 
          entries.forEach(entry => { 
            if (entry.isIntersecting && entry.intersectionRatio >= 0.55) {
              if (!this.isProgrammaticScroll) {
                targetIndex = parseInt(entry.target.dataset.index, 10); 
              }
            }
          }); 
        }, { root: feed, threshold: [0.55] });
        
        slots.forEach(slot => observer.observe(slot)); 
        this.observers.push(observer);
        this.feedObserver = observer; // Simpan referensi ke property class
        
        let isTouching = false; let scrollTimeout;
        feed.addEventListener('touchstart', () => { isTouching = true; }, { passive: true });
        feed.addEventListener('scroll', () => {
          if (isTouching && !this.isProgrammaticScroll) {
            feed.classList.add('is-dragging');
            if (this.state.currentMedia && !this.state.isGlobalMuted) { this.state.currentMedia.setVolume(this.state.volume * 0.3); }
          }
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => { if (feed.classList.contains('is-dragging')) { feed.classList.remove('is-dragging'); processScrollEnd(); } }, 150);
        }, { passive: true });
        feed.addEventListener('touchend', () => { isTouching = false; }, { passive: true });
        
        const processScrollEnd = () => {
          feed.classList.remove('is-dragging');
          
          const wasProgrammatic = this.isProgrammaticScroll;
          this.isProgrammaticScroll = false;
          
          if (wasProgrammatic || this.state.currentVideoIndex === targetIndex) {
             if (this.state.currentMedia && !this.state.isGlobalMuted) { this.state.currentMedia.setVolume(this.state.volume); } return;
          }
          if (!this.state.prefersReducedMotion && !this.state.isEcoMode) { HapticsEngine.medium(); UISoundFX.play('tick', 0.5); }
          
          this.state.lastNavDirection = targetIndex > this.state.currentVideoIndex ? 1 : -1; this.state.currentVideoIndex = targetIndex; this.state.currentSubIndex = 0;
          
          // PATCH: Panggil ulang method fetch!
          this.fetchMoreIfNeeded();
          
          if (this.gestureManager.gestureState.stopScrubCallback) this.gestureManager.gestureState.stopScrubCallback();
          this.appEvents.emit('UI:RESET_STATE');
          
          requestAnimationFrame(() => {
            const newSlot = feed.querySelector(`.story-slot[data-index="${this.state.currentVideoIndex}"]`);
            if(newSlot) newSlot.appendChild(playerContainer);
            this.updateVirtualization(this.state.currentVideoIndex); this.playerManager.updateVideoCore();
            const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); if (rootLayer) rootLayer.focus({ preventScroll: true });
          });
        };
        feed.addEventListener('scrollend', processScrollEnd, { passive: true });
      }
      
      initOffScreenThrottling() {
        const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); if (!rootLayer) return;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) {
              this.state.isOffScreen = true;
              if (this.state.currentMedia?.getState() === MEDIA_STATE.PLAYING) { this.state.wasPlayingBeforeHidden = true; this.appEvents.emit('PLAYER:FORCE_PAUSE'); }
              this.uiManager.stopProgressBar(); DominantColorService.destroy();
            } else {
              this.state.isOffScreen = false;
              if (this.state.wasPlayingBeforeHidden && !this.uiManager.isContextOpen) { this.appEvents.emit('PLAYER:FORCE_PLAY'); this.state.wasPlayingBeforeHidden = false; }
            }
          });
        }, { threshold: 0.1 });
        observer.observe(rootLayer); this.observers.push(observer);
      }
      
      updateVirtualization(currentIndex) {
        const feed = DOMHelper.select(DOM_SELECTORS.FEED), slots = feed.querySelectorAll('.story-slot'), playerContainer = DOMHelper.select(DOM_SELECTORS.STORY_CONTAINER);
        slots.forEach((slot) => {
          const slotIndex = parseInt(slot.dataset.index, 10); const isInsideWindow = Math.abs(slotIndex - currentIndex) <= this.state.config.VIRTUAL_WINDOW_SIZE;
          if (isInsideWindow) {
            if (!slot.querySelector('.story-dummy-card') && slot !== playerContainer.parentElement) {
              const groupData = this.state.playlist[slotIndex]; if (!groupData) return;
              const dummyCard = document.createElement('div'); dummyCard.className = 'story-dummy-card'; slot.appendChild(dummyCard);
              const coverData = groupData.items ? groupData.items[0] : groupData;
              ThumbnailResolver.resolve(coverData, (url) => {
                if (url && slot.contains(dummyCard)) {
                  const isShortMedia = (coverData.type === 'youtube' && MediaUtils.parseYouTubeData(coverData.url).isShort) || coverData.isVertical === true;
                  dummyCard.style.setProperty('--peek-img', `url(${url})`); dummyCard.style.setProperty('--peek-fit', isShortMedia ? 'cover' : 'contain');
                  if (!this.state.isEcoMode) { DominantColorService.extractFromUrl(url, dummyCard); }
                }
              });
            }
          } else if (slot !== playerContainer.parentElement) {
            const dummy = slot.querySelector('.story-dummy-card'); if(dummy) { dummy.style.backgroundImage = 'none'; dummy.style.removeProperty('--peek-img'); } slot.innerHTML = '';
          }
        });
      }
      
      attachGlobalKeyBindings() {
        let kbCumulativeSeek = 0; let kbSeekTimer = null; let kbDirection = null;
        EventRegistry.add(document, 'keydown', (event) => {
          if (['INPUT', 'TEXTAREA'].includes(event.target.tagName)) return;
          const isContextOpen = this.uiManager.getActiveContext()?.classList.contains('is-active') || this.uiManager.getActiveContext()?.open;
          if (event.key === 'Escape') {
            if (isContextOpen) { this.appEvents.emit('UI:TOGGLE_CONTEXT', false); } else if (document.fullscreenElement) { document.exitFullscreen().catch(()=>{}); } else { this.appEvents.emit('APP:CLOSE'); } return;
          }
          if (isContextOpen || this.state.fsm.getState() === 'TRANSITIONING') return;
          
          const groupData = this.state.playlist[this.state.currentVideoIndex]; const isMulti = groupData.items && groupData.items.length > 1; const isReady = DOMHelper.select(DOM_SELECTORS.STORY_CONTAINER)?.classList.contains('has-started');
          
          const keyActions = {
            Space: () => { event.preventDefault(); this.appEvents.emit('PLAYER:TOGGLE_PLAY'); }, KeyK: () => this.appEvents.emit('PLAYER:TOGGLE_PLAY'), ArrowDown: () => { event.preventDefault(); this.appEvents.emit('PLAYER:SWITCH_VIDEO', 1); }, ArrowUp: () => { event.preventDefault(); this.appEvents.emit('PLAYER:SWITCH_VIDEO', -1); },
            ArrowRight: () => {
              if (groupData.format === 'story' || isMulti) this.appEvents.emit('PLAYER:NEXT');
              else if (isReady) {
                if (kbDirection !== 'right') kbCumulativeSeek = 0; kbDirection = 'right'; kbCumulativeSeek += 10;
                const contentHtml = `<div style="display: flex; align-items: center; gap: 4px;"><i data-lucide="fast-forward" style="width: 1.2em; height: 1.2em;"></i> <span>${kbCumulativeSeek}s</span></div>`;
                this.appEvents.emit('UI:SHOW_RIPPLE', {side: 'right', text: contentHtml});
                clearTimeout(kbSeekTimer); kbSeekTimer = setTimeout(() => { this.appEvents.emit('PLAYER:SEEK', kbCumulativeSeek); kbCumulativeSeek = 0; }, 400);
              }
            },
            ArrowLeft: () => {
              if (groupData.format === 'story' || isMulti) this.appEvents.emit('PLAYER:PREV');
              else if (isReady) {
                if (kbDirection !== 'left') kbCumulativeSeek = 0; kbDirection = 'left'; kbCumulativeSeek += 10;
                const contentHtml = `<div style="display: flex; align-items: center; gap: 4px;"><i data-lucide="rewind" style="width: 1.2em; height: 1.2em;"></i> <span>${kbCumulativeSeek}s</span></div>`;
                this.appEvents.emit('UI:SHOW_RIPPLE', {side: 'left', text: contentHtml});
                clearTimeout(kbSeekTimer); kbSeekTimer = setTimeout(() => { this.appEvents.emit('PLAYER:SEEK', -kbCumulativeSeek); kbCumulativeSeek = 0; }, 400);
              }
            },
            KeyM: () => this.appEvents.emit('UI:TOGGLE_MUTE'),
            Minus: () => { const currentVol = this.state.volume; const newVol = Math.max(0, currentVol - 10); if (this.uiManager.dom.volumeSlider) { this.uiManager.dom.volumeSlider.value = newVol; this.uiManager.dom.volumeSlider.dispatchEvent(new Event('input')); } },
            Equal: () => { const currentVol = this.state.volume; const newVol = Math.min(100, currentVol + 10); if (this.uiManager.dom.volumeSlider) { this.uiManager.dom.volumeSlider.value = newVol; this.uiManager.dom.volumeSlider.dispatchEvent(new Event('input')); } },
            KeyF: () => {
              this.uiManager.closeReactionMenu(); const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); const btnInners = document.querySelectorAll('.js-btn-clean .fab-inner'); 
              if (!rootLayer) return;
              const isFullscreenNow = document.fullscreenElement || rootLayer.classList.contains('is-fullscreen');
              if (!isFullscreenNow) { 
                const requestFS = rootLayer.requestFullscreen;
                if (requestFS && !/iPhone|iPad|iPod/i.test(navigator.userAgent)) { requestFS.call(rootLayer).catch(() => { rootLayer.classList.add('is-fullscreen'); this.resetIdleTimer(); }); } else { rootLayer.classList.add('is-fullscreen'); this.resetIdleTimer(); }
                btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="minimize-2"></i>'));
              } else { 
                const exitFS = document.exitFullscreen;
                if (exitFS && document.fullscreenElement) { exitFS.call(document).catch(() => {}); } else { rootLayer.classList.remove('is-fullscreen', 'is-idle'); clearTimeout(this.interactionIdleTimer); }
                btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="maximize-2"></i>'));
              }
            },
            KeyI: () => this.appEvents.emit('UI:TOGGLE_CONTEXT', true),
            KeyL: () => { if (isReady) { const mediaData = this.state.getActiveMediaData(); const currentReaction = this.state.currentUser.reactions.get(mediaData?.id) || '❤️'; this.appEvents.emit('UI:TRIGGER_REACTION', { emoji: currentReaction, isDoubleTap: false }); } },
            KeyS: () => { const shareBtn = DOMHelper.select(DOM_SELECTORS.BTN_SHARE); if (shareBtn) shareBtn.click(); }
          };
          
          if (keyActions[event.code]) { keyActions[event.code](); } else if (/^[0-9]$/.test(event.key) && isReady) {
            const percentage = parseInt(event.key, 10) / 10; const duration = this.state.currentMedia?.getDuration();
            if (duration > 0) {
              const targetTime = duration * percentage; this.state.currentMedia.seekTo(targetTime); if (this.state.currentAmbient) this.state.currentAmbient.seekTo(targetTime);
              const side = percentage >= 0.5 ? 'right' : 'left'; 
              const iconName = percentage >= 0.5 ? 'fast-forward' : 'rewind';
              const contentHtml = `<div style="display: flex; align-items: center; gap: 4px;"><i data-lucide="${iconName}" style="width: 1.2em; height: 1.2em;"></i> <span>${percentage * 100}%</span></div>`;
              this.appEvents.emit('UI:SHOW_RIPPLE', { side: side, text: contentHtml });
            }
          }
        }, {}, 'app');
      }
      
      attachGlobalClickBindings() {
        const btnReaction = DOMHelper.select(DOM_SELECTORS.BTN_REACTION); const reactionWrapper = DOMHelper.select(DOM_SELECTORS.REACTION_WRAPPER); let reactionPressTimer;
        if (btnReaction) {
          btnReaction.addEventListener('pointerdown', (e) => {
            if (e.pointerType === 'mouse' && e.button !== 0) return;
            reactionPressTimer = setTimeout(() => { this.appEvents.emit('UI:TOGGLE_REACTION_MENU'); HapticsEngine.medium(); }, 300);
          }, { passive: true });
          const clearReactionTimer = () => clearTimeout(reactionPressTimer);
          btnReaction.addEventListener('pointerup', clearReactionTimer, { passive: true }); btnReaction.addEventListener('pointercancel', clearReactionTimer, { passive: true });
          btnReaction.addEventListener('click', (e) => {
            clearReactionTimer(); const mediaData = this.state.getActiveMediaData(); const currentReaction = this.state.currentUser.reactions.get(mediaData?.id) || '❤️';
            this.appEvents.emit('UI:TRIGGER_REACTION', { emoji: currentReaction, isDoubleTap: false });
          });
        }
        if (reactionWrapper) {
          reactionWrapper.addEventListener('mouseenter', () => { if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) reactionWrapper.classList.add('is-active'); }, { passive: true });
          reactionWrapper.addEventListener('mouseleave', () => { if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) this.uiManager.closeReactionMenu(); }, { passive: true });
        }
        
        EventRegistry.add(document, 'click', async (event) => {
          if (this.state.ignoreNextTap) { event.preventDefault(); event.stopPropagation(); return; }
          const target = event.target;
          if (target.closest(DOM_SELECTORS.VOLUME_SLIDER)) return;
          if (target.nodeName === 'DIALOG' || target.closest('.story-close-btn, .overlay-backdrop')) return this.appEvents.emit('UI:TOGGLE_CONTEXT', false);
          if (target.closest('.reaction-option-btn')) return this.appEvents.emit('UI:TRIGGER_REACTION', { emoji: target.closest('.reaction-option-btn').dataset.reaction, isDoubleTap: false });
          
          const dummyClick = target.closest('.story-dummy-card');
          if (dummyClick && !dummyClick.closest('.story-slot').classList.contains('is-active')) {
            dummyClick.parentElement.scrollIntoView({ behavior: (this.state.prefersReducedMotion || this.state.isEcoMode) ? 'auto' : 'smooth', block: 'center' }); return;
          }
          
          const actionMap = {
            [DOM_SELECTORS.BTN_PLAY]: () => this.appEvents.emit('PLAYER:TOGGLE_PLAY'),
            [DOM_SELECTORS.BTN_MUTE]: () => this.appEvents.emit('UI:TOGGLE_MUTE'),
            [DOM_SELECTORS.BTN_PREV]: () => { if (!target.closest('.is-disabled')) this.appEvents.emit('PLAYER:SWITCH_VIDEO', -1); },
            [DOM_SELECTORS.BTN_NEXT]: () => { if (!target.closest('.is-disabled')) this.appEvents.emit('PLAYER:SWITCH_VIDEO', 1); },
            [DOM_SELECTORS.BTN_CLOSE]: () => this.appEvents.emit('APP:CLOSE'),
            [DOM_SELECTORS.BTN_OPEN_CONTEXT]: () => this.appEvents.emit('UI:TOGGLE_CONTEXT', true),
            [DOM_SELECTORS.BTN_CLEAN]: () => {
              this.uiManager.closeReactionMenu(); const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); const btnInners = document.querySelectorAll('.js-btn-clean .fab-inner'); 
              if (!rootLayer) return;
              const isFullscreenNow = document.fullscreenElement || rootLayer.classList.contains('is-fullscreen');
              if (!isFullscreenNow) { 
                const requestFS = rootLayer.requestFullscreen;
                if (requestFS && !/iPhone|iPad|iPod/i.test(navigator.userAgent)) { requestFS.call(rootLayer).catch(() => { rootLayer.classList.add('is-fullscreen'); this.resetIdleTimer(); }); } else { rootLayer.classList.add('is-fullscreen'); this.resetIdleTimer(); }
                btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="minimize-2"></i>'));
              } else { 
                const exitFS = document.exitFullscreen;
                if (exitFS && document.fullscreenElement) { exitFS.call(document).catch(() => {}); } else { rootLayer.classList.remove('is-fullscreen', 'is-idle'); clearTimeout(this.interactionIdleTimer); }
                btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="maximize-2"></i>'));
              }
            },
            [DOM_SELECTORS.BTN_SHARE]: async () => {
              const currentUrl = window.location.href; const groupData = this.state.playlist[this.state.currentVideoIndex]; const activeData = (groupData.items) ? groupData.items[this.state.currentSubIndex] : groupData;
              const shareData = { title: document.title, text: activeData.excerpt || groupData.excerpt || 'Checkout this immersive story!', url: currentUrl };
              try { if (navigator.canShare && navigator.canShare(shareData)) { await navigator.share(shareData); } else { await navigator.clipboard.writeText(currentUrl); ToastService.show(this.state.config.locale.copiedToClipboard); } } catch (err) { if (err.name !== 'AbortError') ToastService.show(this.state.config.locale.failedToShare); }
            }
          };
          for (let selector in actionMap) { if (target.closest(selector)) return actionMap[selector](event); }
          if (this.uiManager.dom.reactionWrapper && !this.uiManager.dom.reactionWrapper.contains(target) && !target.closest(DOM_SELECTORS.BTN_REACTION)) { this.uiManager.closeReactionMenu(); }
        }, {}, 'app');
      }
      
      resetIdleTimer() {
        const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); if (!rootLayer) return false;
        const wasIdle = rootLayer.classList.contains('is-idle'); rootLayer.classList.remove('is-idle'); clearTimeout(this.interactionIdleTimer);
        if (this.state.currentMedia?.getState() === MEDIA_STATE.PLAYING && !this.uiManager.isContextOpen) {
           const isFullscreen = document.fullscreenElement || rootLayer.classList.contains('is-fullscreen');
           if (isFullscreen) { this.interactionIdleTimer = setTimeout(() => { if(rootLayer) rootLayer.classList.add('is-idle'); }, 2500); }
        }
        return wasIdle;
      }

      attachWindowBindings() {
        EventRegistry.add(document, 'fullscreenchange', () => {
          this.isProgrammaticScroll = true;
          clearTimeout(this.fsLockTimer);
          this.fsLockTimer = setTimeout(() => { this.isProgrammaticScroll = false; }, 800);

          const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); const btnInners = document.querySelectorAll('.js-btn-clean .fab-inner');
          if (!document.fullscreenElement) { if(rootLayer) rootLayer.classList.remove('is-fullscreen', 'is-idle'); btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="maximize-2"></i>')); } 
          else { if(rootLayer) rootLayer.classList.add('is-fullscreen'); btnInners.forEach(inner => IconHelper.update(inner, '<i data-lucide="minimize-2"></i>')); }
        }, {}, 'app');
        EventRegistry.add(window, 'offline', () => ToastService.show(this.state.config.locale.internetDisconnected), {}, 'app');
        EventRegistry.add(window, 'online', () => { ToastService.show(this.state.config.locale.internetRestored); if (DOMHelper.select(DOM_SELECTORS.ERROR_OVERLAY)?.classList.contains('is-visible')) { this.playerManager.updateVideoCore(); } }, {}, 'app');
        EventRegistry.add(window, 'popstate', (event) => {
          if (event.state && typeof event.state.index === 'number') {
            if (this.state.fsm.getState() === 'TRANSITIONING') return;
            this.state.currentVideoIndex = event.state.index; this.state.currentSubIndex = event.state.subIndex || 0;
            if (this.gestureManager.gestureState.stopScrubCallback) this.gestureManager.gestureState.stopScrubCallback();
            this.appEvents.emit('UI:RESET_STATE'); this.playerManager.updateVideoCore();
          } else {
            const val = new URLSearchParams(window.location.search).get('v');
            if (val) {
              let foundIndex = val.startsWith('item_') ? parseInt(val.replace('item_',''), 10) : this.state.playlist.findIndex(item => item.type === 'youtube' && MediaUtils.parseYouTubeData(item.url).videoId === val);
              if (foundIndex > -1 && foundIndex !== this.state.currentVideoIndex && foundIndex < this.state.playlist.length) {
                if (this.state.fsm.getState() === 'TRANSITIONING') return;
                this.state.currentVideoIndex = foundIndex; this.state.currentSubIndex = 0;
                if (this.gestureManager.gestureState.stopScrubCallback) this.gestureManager.gestureState.stopScrubCallback();
                this.appEvents.emit('UI:RESET_STATE'); this.playerManager.updateVideoCore();
              }
            }
          }
        }, {}, 'app');
        
        const feed = DOMHelper.select(DOM_SELECTORS.FEED);
        if (feed && window.ResizeObserver) {
          let resizeDebounce; let lastHeight = window.innerHeight;
          const resizeObserver = new ResizeObserver(() => {
            clearTimeout(resizeDebounce);
            resizeDebounce = setTimeout(() => {
              const currentHeight = window.innerHeight; const heightDiff = Math.abs(currentHeight - lastHeight) / lastHeight; lastHeight = currentHeight;
              if (heightDiff < 0.15) return;
              const slots = feed.querySelectorAll('.story-slot');
              if (slots[this.state.currentVideoIndex] && this.state.fsm.getState() !== 'TRANSITIONING') {
                this.isProgrammaticScroll = true; slots[this.state.currentVideoIndex].scrollIntoView({ block: 'center' }); setTimeout(() => { this.isProgrammaticScroll = false; }, 300);
              }
              if (window.innerWidth < 768 && this.state.currentAmbient) { this.state.currentAmbient.destroy(); this.state.currentAmbient = null; } 
              else if (window.innerWidth >= 768 && !this.state.currentAmbient && this.state.currentMedia && !this.state.isEcoMode) {
                const ambientContainer = DOMHelper.select(DOM_SELECTORS.AMBIENT_MEDIA); const data = this.state.getActiveMediaData();
                this.state.currentAmbient = MediaFactory.create({
                  container: ambientContainer, data: data, callbacks: { onReady: () => { this.state.currentAmbient.seekTo(this.state.currentMedia.getCurrentTime()); if (this.state.currentMedia.getState() === MEDIA_STATE.PLAYING) this.state.currentAmbient.play(); } }, isAmbient: true, appEvents: this.appEvents, state: this.state
                });
                this.state.currentAmbient.load();
              }
            }, 150);
          });
          resizeObserver.observe(feed); this.observers.push(resizeObserver);
        }
        
        EventRegistry.add(document, 'visibilitychange', () => {
          if (document.hidden) {
            this.state.wasPlayingBeforeHidden = (this.state.currentMedia?.getState() === MEDIA_STATE.PLAYING);
            if (this.state.wasPlayingBeforeHidden) { this.appEvents.emit('PLAYER:FORCE_PAUSE'); this.appEvents.emit('UI:FLASH_ICON', ''); }
            WakeLockManager.release();
            if (UISoundFX.ctx && UISoundFX.ctx.state === 'running') UISoundFX.ctx.suspend();
          } else {
            if (this.state.wasPlayingBeforeHidden && !this.uiManager.isContextOpen && !document.hidden) { this.appEvents.emit('PLAYER:FORCE_PLAY'); this.state.wasPlayingBeforeHidden = false; }
            if (UISoundFX.ctx && UISoundFX.ctx.state === 'suspended') UISoundFX.ctx.resume();
          }
        }, { passive: true }, 'app');
        EventRegistry.add(document, 'pointermove', () => this.resetIdleTimer(), { passive: true }, 'app');
        EventRegistry.add(document, 'pointerdown', (e) => { if (e.pointerType === 'touch' && this.resetIdleTimer()) { this.state.ignoreNextTap = true; setTimeout(() => { this.state.ignoreNextTap = false; }, 400); } }, { passive: true }, 'app');
        EventRegistry.add(document, 'mouseleave', () => {
             const rootLayer = document.querySelector(DOM_SELECTORS.ROOT); const isFullscreen = document.fullscreenElement || rootLayer?.classList.contains('is-fullscreen');
             if(rootLayer && isFullscreen && this.state.currentMedia?.getState() === MEDIA_STATE.PLAYING) { rootLayer.classList.add('is-idle'); } clearTimeout(this.interactionIdleTimer);
        }, { passive: true }, 'app');

        window.addEventListener('orientationchange', () => {
          setTimeout(() => { const currentFeed = DOMHelper.select(DOM_SELECTORS.FEED); if (currentFeed) { const slots = currentFeed.querySelectorAll('.story-slot'); if (slots[this.state.currentVideoIndex]) { slots[this.state.currentVideoIndex].scrollIntoView({ block: 'center' }); } } }, 150);
        });
      }
      
      destroy() {
        if (document.fullscreenElement) document.exitFullscreen().catch(()=>{});
        const executeDestroy = () => {
          const layout = document.querySelector(DOM_SELECTORS.ROOT); if (layout) layout.classList.add('is-closing');
          if (this.state.watchStartTime) {
            const now = typeof Temporal !== 'undefined' ? Temporal.Now.instant().epochMilliseconds : Date.now();
            const durationWatched = now - this.state.watchStartTime; const currentMedia = this.state.getActiveMediaData();
            if (currentMedia) this.state.adapter.sendAnalytics(currentMedia.id, durationWatched); this.state.watchStartTime = null;
          }
          this.appEvents.emit('PLAYER:FORCE_PAUSE'); WakeLockManager.release();
          if ('mediaSession' in navigator) { navigator.mediaSession.metadata = null; navigator.mediaSession.playbackState = 'none'; }
          EventRegistry.clear('app'); 
          
          // PATCH: Garbage Collection Observer secara eksplisit
          if (this.feedObserver) {
             this.feedObserver.disconnect();
             this.feedObserver = null;
          }
          this.observers.forEach(obs => obs.disconnect()); 
          this.observers = [];
          
          try { this.state.currentMedia?.destroy(); } catch (e) {} try { this.state.currentAmbient?.destroy(); } catch (e) {}
          this.state.currentMedia = null; this.state.currentAmbient = null; this.state.playlist = [];
          window.history.replaceState({}, '', window.location.pathname); const metaTheme = document.getElementById('meta-theme-color'); if (metaTheme) metaTheme.setAttribute('content', '#0f0f11');
          DominantColorService.destroy(); MediaPool.clear(); document.querySelectorAll('.story-video-wrapper, img').forEach(el => el.classList.remove('is-transitioning-hero')); setTimeout(() => { if (layout) layout.remove(); }, 600);
        };
        
        if (document.startViewTransition && !this.state.prefersReducedMotion && !this.state.isEcoMode) {
          const activeRingImg = document.querySelector(`.story-ring-wrapper[data-index="${this.state.currentVideoIndex}"] img`), targetMedia = document.querySelector('.story-video-wrapper');
          if (activeRingImg) activeRingImg.classList.add('is-transitioning-hero'); if (targetMedia) targetMedia.classList.add('is-transitioning-hero');
          document.startViewTransition(() => executeDestroy());
        } else { executeDestroy(); }
      }
    }
    
    window.NextGenStory = NextGenStory;
  </script>

  <script id="demo-js">
    document.addEventListener('DOMContentLoaded', () => {
      const storyIds = ['vid_1_1', 'vid_1_2', 'vid_1_3'];
      let activeStoryInstance = null;
      const storyRings = document.querySelectorAll('.story-ring-wrapper');
      
      storyRings.forEach((ring) => {
        ring.addEventListener('click', async () => {
          if (document.querySelector('.js-layout-wrapper')) return;
          const imgElement = ring.querySelector('img'),
                index = parseInt(ring.getAttribute('data-index'), 10),
                targetId = storyIds[index];
                
          window.history.pushState({ index: index, subIndex: 0 }, '', `?v=${targetId}`);
          if (activeStoryInstance) activeStoryInstance.destroy();
          
          const executeLaunch = async () => {
            if (imgElement) imgElement.classList.remove('is-transitioning-hero');
            activeStoryInstance = new NextGenStory({ startIndex: index });
            const isReady = await activeStoryInstance.initialize();                                             
            if (isReady) {
              activeStoryInstance.state.isApiReady = true;
              const targetMedia = document.querySelector('.story-video-wrapper');
              if (targetMedia && !activeStoryInstance.state.prefersReducedMotion && !activeStoryInstance.state.isEcoMode) {
                  targetMedia.classList.add('is-transitioning-hero');
              }
              activeStoryInstance.playerManager.updateVideoCore();
              setTimeout(() => {
                if (targetMedia) targetMedia.classList.remove('is-transitioning-hero');
              }, 600);
            }
          };
          
          const launchStory = async () => {
            if (!document.startViewTransition || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              executeLaunch();
              return;
            }
            if (imgElement) imgElement.classList.add('is-transitioning-hero');
            document.startViewTransition(() => executeLaunch());
          };
          
          if (window.YT && window.YT.Player) {
            launchStory();
          } else {
            window.ytCallbacks = [launchStory]; 
            if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
              const scriptTag = document.createElement('script');
              scriptTag.src = 'https://www.youtube.com/iframe_api';
              scriptTag.async = true;
              document.head.appendChild(scriptTag);
              window.onYouTubeIframeAPIReady = () => {
                window.ytCallbacks.forEach(cb => cb());
                window.ytCallbacks = [];
              };
            }
          }
        });
        
        ring.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            ring.click();
          }
        });
      });
    });
  </script>
</body>
</html>