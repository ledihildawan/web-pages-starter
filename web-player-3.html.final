        if (groupData.format === 'story' || isMulti) {
          if (this.state.currentSubIndex < subCount - 1) { this.triggerTransition(() => { this.state.currentSubIndex++; this.appEvents.emit('UI:RESET_STATE'); this.updateVideoCore(); }, 1); } 
          else if (this.state.currentVideoIndex >= this.state.playlist.length - 1) { this.playBumpEffect('right'); } else { this.switchVideo(1); }
        } else if (this.state.currentVideoIndex >= this.state.playlist.length - 1) { this.playBumpEffect('right'); } else { this.switchVideo(1); }
