# =============================================================================
# General environment (shared across all stages)
# =============================================================================
# This file is loaded FIRST. Stage-specific files (.env.{stage}) are loaded
# AFTER and override values defined here. Stage pipeline:
# dev → qa → uat → preprod → prod
# Copy this file to .env and adjust values.
#
# PRIVATE_ prefix = server-only (NOT exposed to browser bundle, prefix stripped).
# No prefix = browser-safe (public by default, like TypeScript class members).
# =============================================================================

# --- Server ---
PORT=8888
HOST=0.0.0.0

# --- Build ---
MINIFY=true
BUILD_PREVIEW=false
PRETTY_HTML=false
LIGHTHOUSE_OUTPUT_DIR=./reports
SITEMAP_DEFAULT_PRIORITY=0.7
SITEMAP_DEFAULT_CHANGEFREQ=weekly
