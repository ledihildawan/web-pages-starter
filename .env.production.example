# =============================================================================
# Production environment
# =============================================================================
# Copy this file to .env.production and adjust values.
# =============================================================================

# --- Server ---
# NODE_ENV=production

# --- Client ---
# SITE_URL=https://your-actual-domain.com
# BASE_PATH=/  # Subpath for GitHub Pages (e.g. /repo-name/). Defaults to /

# --- Optional ---
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# MINIFY=false
# MINIFY_HTML=false
# BUILD_PREVIEW=true
# NODE_BINARY=node
# RSBUILD_RUNTIME=bun
