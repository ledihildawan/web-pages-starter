# =============================================================================
# Production environment (STAGE=prod)
# =============================================================================
# Stage-specific overrides for .env (general). Stage pipeline:
# dev → qa → uat → preprod → prod
# All values are required (no defaults in schema).
# Copy .env.example to .env first, then this file to .env.prod.
# =============================================================================

STAGE=prod
NODE_ENV=production
SITE_URL=https://your-actual-domain.com
BASE_PATH=/

# Optional
NGROK_AUTHTOKEN=
NODE_BINARY=
RSBUILD_RUNTIME=
