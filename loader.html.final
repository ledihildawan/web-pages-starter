<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="A versatile collection of pure CSS Unicode Braille loading animations.">
  <title>Unicode Braille Animations ⠿ | Pure CSS Library</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* =========================================
       CSS RESET & BASE
       ========================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -moz-text-size-adjust: none; -webkit-text-size-adjust: none; text-size-adjust: none; }
    body { min-height: 100vh; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    img, picture, video, canvas, svg { display: block; max-width: 100%; }
    input, button, textarea, select { font: inherit; outline: none; border: none; background: transparent; }
    p, h1, h2, h3, h4, h5, h6 { overflow-wrap: break-word; }
    a { text-decoration: none; color: inherit; }
    ul, ol { list-style: none; }

    /* =========================================
       DESIGN SYSTEM: TOKENS & TAXONOMY
       ========================================= */
    :root {
      /* --- 1. SPACING & PROPORTIONS --- */
      --w-max: 80rem;
      --px-mob: 1.25rem; --px-tab: 2rem; --px-desk: 3rem;
      --radius-sm: 0.5rem; --radius-md: 1.25rem; --radius-full: 9999px;

      /* --- 2. COLOR PRIMITIVES (OKLCH) --- */
      --clr-core-white: oklch(100% 0 0);
      --clr-core-black: oklch(0% 0 0);
      
      /* Modern Geist/Onyx Neutral Scale (Ultra-low chroma, sleek cool-gray) */
      --clr-neutral-50:  oklch(98.5% 0.002 250);
      --clr-neutral-100: oklch(96% 0.005 250);
      --clr-neutral-200: oklch(90% 0.005 250);
      --clr-neutral-700: oklch(35% 0.01 250);
      --clr-neutral-800: oklch(25% 0.01 250);
      --clr-neutral-900: oklch(17% 0.01 250);
      --clr-neutral-950: oklch(13% 0.01 250);
      
      /* High-Chroma Modern Accent (Electric Cobalt / Indigo) */
      --clr-accent-500: oklch(65% 0.22 255);
      
      /* Vibrant Status (Neon Emerald) */
      --clr-status-success: oklch(70% 0.16 150);

      /* --- 3. COLOR SEMANTICS (LIGHT/DARK AWARE) --- */
      color-scheme: light dark;
      
      /* Backgrounds */
      --bg-canvas: light-dark(var(--clr-neutral-50), var(--clr-neutral-950));
      --bg-surface: light-dark(var(--clr-core-white), var(--clr-neutral-900));
      --bg-surface-elevated: light-dark(var(--clr-neutral-50), var(--clr-neutral-800));
      
      /* Typography */
      --text-primary: light-dark(var(--clr-neutral-950), var(--clr-core-white));
      --text-secondary: light-dark(var(--clr-neutral-700), var(--clr-neutral-200));
      --text-accent: var(--clr-accent-500);
      --text-success: var(--clr-status-success);
      
      /* Borders */
      --border-subtle: color-mix(in oklch, var(--text-primary) 10%, transparent);
      --border-strong: color-mix(in oklch, var(--text-primary) 25%, transparent);
      --border-accent: color-mix(in oklch, var(--clr-accent-500) 40%, transparent);
      --border-success: color-mix(in oklch, var(--clr-status-success) 40%, transparent);

      /* --- 4. SURFACE FX & GLASSMORPHISM --- */
      --glass-surface: color-mix(in oklch, var(--bg-surface) 60%, transparent);
      --glass-surface-hover: color-mix(in oklch, var(--bg-surface) 80%, transparent);
      --glass-highlight: inset 0 1px 0 0 color-mix(in oklch, var(--clr-core-white) 15%, transparent);
      
      --shadow-base: 0 8px 24px -4px color-mix(in oklch, var(--clr-core-black) 8%, transparent);
      --shadow-hover: 0 20px 40px -8px color-mix(in oklch, var(--clr-core-black) 15%, transparent);
      
      /* Atmospheric Gradients */
      --ambient-primary: light-dark(oklch(85% 0.1 240 / 0.5), oklch(35% 0.15 255 / 0.4));
      --ambient-secondary: light-dark(oklch(85% 0.1 280 / 0.5), oklch(30% 0.15 280 / 0.4));
      --bg-grid-pattern: color-mix(in oklch, var(--text-primary) 4%, transparent);

      /* --- 5. COMPONENT TOKENS (BRAILLE LOADER) --- */
      --loader-shimmer-base: light-dark(
        color-mix(in oklch, var(--clr-core-white) 75%, var(--clr-neutral-950)), 
        color-mix(in oklch, var(--clr-neutral-800) 60%, var(--clr-core-white))
      );
      --loader-shimmer-peak: var(--text-primary);
      --loader-glow-color: light-dark(
        color-mix(in oklch, var(--clr-neutral-950) 30%, transparent), 
        var(--clr-core-white)
      );
      --loader-glow-sm: light-dark(0.125rem, 0.375rem);
      --loader-glow-lg: light-dark(0.25rem, 0.625rem);

      /* --- 6. MOTION & PHYSICS --- */
      --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
      --ease-smooth: cubic-bezier(0.22, 1, 0.36, 1);
      --dur-fast: 0.2s;
      --dur-base: 0.4s;
      --dur-slow: 0.8s;
    }

    [data-theme="light"] { color-scheme: light; }
    [data-theme="dark"] { color-scheme: dark; }

    /* =========================================
       GLOBAL STYLES
       ========================================= */
    *:focus-visible { 
      outline: 2px solid var(--clr-accent-500); 
      outline-offset: 4px; 
      transition: outline-offset var(--dur-fast) var(--ease-spring); 
    }

    body { 
      display: flex; flex-direction: column; 
      background-color: var(--bg-canvas); 
      background-image: radial-gradient(var(--bg-grid-pattern) 1px, transparent 1px); 
      background-size: 1.5rem 1.5rem; 
      color: var(--text-secondary); 
      font-family: 'Inter', system-ui, -apple-system, sans-serif; 
      text-rendering: optimizeLegibility; 
      transition: background-color var(--dur-base) ease, color var(--dur-base) ease; 
      position: relative; z-index: 0; overflow-x: hidden; 
    }
    
    body::before, body::after { 
      content: ""; position: fixed; border-radius: 50%; filter: blur(100px); z-index: -1; pointer-events: none; transition: background 0.6s ease; 
    }
    body::before { inset-block-start: -10%; inset-inline-start: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, var(--ambient-primary) 0%, color-mix(in oklch, var(--ambient-primary) 60%, transparent) 30%, color-mix(in oklch, var(--ambient-primary) 20%, transparent) 55%, transparent 70%); }
    body::after { inset-block-end: -10%; inset-inline-end: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, var(--ambient-secondary) 0%, color-mix(in oklch, var(--ambient-secondary) 60%, transparent) 30%, color-mix(in oklch, var(--ambient-secondary) 20%, transparent) 55%, transparent 70%); }
    .hide-mobile { display: none; }

    /* =========================================
       COMPONENTS
       ========================================= */
    
    /* Page Loader */
    #page-loader { position: fixed; inset: 0; z-index: 99999; background: var(--bg-canvas); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.5rem; transition: opacity 0.6s var(--ease-smooth), visibility 0.6s; }
    #page-loader .loader-text { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.2em; color: var(--text-secondary); text-transform: uppercase; }
    #page-loader .braille-loader { font-size: 3.5rem; color: var(--text-primary); }
    body.loaded #page-loader { opacity: 0; visibility: hidden; pointer-events: none; transform: scale(1.05); }

    /* Navbar */
    .navbar { position: fixed; inset-block-start: 1rem; inset-inline-start: 50%; transform: translateX(-50%); width: calc(100% - (var(--px-mob) * 2)); max-width: calc(var(--w-max) - (var(--px-mob) * 2)); block-size: 3.5rem; display: flex; align-items: center; justify-content: space-between; padding-inline: 1.25rem; background: color-mix(in oklch, var(--bg-canvas) 60%, transparent); backdrop-filter: blur(16px) saturate(180%); -webkit-backdrop-filter: blur(16px) saturate(180%); border: 1px solid var(--border-subtle); border-radius: var(--radius-full); box-shadow: var(--shadow-base); z-index: 1000; transition: all var(--dur-base) var(--ease-smooth); }
    .navbar-logo { font-size: 0.9375rem; font-weight: 600; letter-spacing: 0.03125em; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem; white-space: nowrap; }
    .navbar-logo span.icon { font-size: 1.3em; line-height: 1; color: var(--text-primary); }
    .badge { font-size: 0.625rem; padding: 0.25rem 0.75rem; border-radius: var(--radius-full); border: 1px solid var(--border-subtle); background: var(--glass-surface); color: var(--text-secondary); font-weight: 500; }
    .nav-actions { display: flex; align-items: center; gap: 1rem; }
    
    /* Icon Links */
    .github-link { color: var(--text-secondary); display: flex; align-items: center; justify-content: center; padding: 0.375rem; border-radius: 50%; transition: all var(--dur-base) var(--ease-spring); }
    .github-link:hover, .github-link:focus-visible { color: var(--text-primary); transform: scale(1.15); background: color-mix(in oklch, var(--text-primary) 10%, transparent); }
    .github-link svg { width: 1.25rem; height: 1.25rem; }

    /* Theme Toggle */
    .theme-toggle { position: relative; display: flex; background: var(--glass-surface); border: 1px solid var(--border-subtle); border-radius: var(--radius-full); padding: 0.25rem; gap: 0.125rem; backdrop-filter: blur(8px); }
    .theme-toggle::before { content: ""; position: absolute; inset-block-start: 0.25rem; inset-inline-start: 0.25rem; width: 2.5rem; height: 1.75rem; border-radius: 1rem; background: var(--text-primary); transition: transform 0.5s var(--ease-spring); z-index: 0; will-change: transform; }
    .theme-toggle[data-active="light"]::before { transform: translateX(0); }
    .theme-toggle[data-active="system"]::before { transform: translateX(2.625rem); }
    .theme-toggle[data-active="dark"]::before { transform: translateX(5.25rem); }
    .theme-btn { position: relative; z-index: 1; color: var(--text-secondary); cursor: pointer; border-radius: 1rem; width: 2.5rem; height: 1.75rem; display: flex; align-items: center; justify-content: center; transition: color 0.3s ease; }
    .theme-btn:hover:not(.active), .theme-btn:focus-visible:not(.active) { color: var(--text-primary); }
    .theme-btn.active { color: var(--bg-canvas); }
    .theme-btn svg { width: 1.125rem; height: 1.125rem; pointer-events: none; }

    /* Layout Content */
    .main-content { padding-block: 8rem 4rem; width: 100%; max-width: var(--w-max); padding-inline: var(--px-mob); flex-grow: 1; margin-inline: auto; position: relative; z-index: 1; }
    .header-section { text-align: center; margin-block-end: 4.5rem; animation: slideUpFade var(--dur-slow) var(--ease-smooth) forwards; }
    .header-section h1 { font-size: 2.25rem; letter-spacing: -0.03125em; margin-block-end: 0.5rem; font-weight: 800; line-height: 1.2; text-wrap: balance; background: linear-gradient(135deg, var(--text-primary) 0%, color-mix(in oklch, var(--text-primary) 70%, var(--clr-accent-500)) 50%, var(--clr-neutral-700) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .header-section p { font-size: 1.05rem; max-width: 37.5rem; margin-inline: auto; text-wrap: pretty; color: var(--text-secondary); }

    /* Grid & Cards */
    .grid-container { display: grid; grid-template-columns: 1fr; gap: 1.25rem; perspective: 1000px; }
    .card { cursor: pointer; position: relative; overflow: hidden; background: linear-gradient(145deg, var(--glass-surface) 0%, color-mix(in oklch, var(--glass-surface) 50%, transparent) 50%, color-mix(in oklch, var(--bg-surface) 10%, transparent) 100%); backdrop-filter: blur(16px) saturate(180%); -webkit-backdrop-filter: blur(16px) saturate(180%); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: 1.5rem; min-block-size: 12.5rem; display: flex; flex-direction: column; align-items: center; box-shadow: var(--glass-highlight), var(--shadow-base); transition: transform 0.5s var(--ease-spring), border-color var(--dur-base) var(--ease-smooth), box-shadow 0.5s var(--ease-spring), background-color var(--dur-base); outline: none; will-change: transform, border-color; animation: slideUpFade var(--dur-slow) var(--ease-smooth) backwards; }
    @keyframes slideUpFade { from { opacity: 0; transform: translateY(2rem) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

    .card::before { content: ""; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(circle at 50% -20%, var(--text-primary) 0%, color-mix(in oklch, var(--text-primary) 50%, transparent) 30%, color-mix(in oklch, var(--text-primary) 15%, transparent) 50%, transparent 65%); opacity: 0; transition: opacity 0.5s var(--ease-smooth); z-index: 0; will-change: opacity; }
    .card * { position: relative; z-index: 1; }
    .card:active { transform: translateY(0) scale(0.96); transition: transform var(--dur-fast) var(--ease-spring); } 
    .card:hover, .card:focus-visible { border-color: var(--border-strong); transform: translateY(-0.375rem); box-shadow: inset 0 1px 0 0 color-mix(in oklch, var(--clr-core-white) 25%, transparent), var(--shadow-hover); }
    .card:hover::before, .card:focus-visible::before { opacity: 0.08; }
    .card:hover .card-title, .card:focus-visible .card-title { color: var(--text-primary); border-color: var(--border-strong); background: color-mix(in oklch, var(--text-primary) 5%, transparent); }
    .card:hover .spinner-wrapper, .card:focus-visible .spinner-wrapper { transform: scale(1.05); }
    .card:hover .copy-hint, .card:focus-visible .copy-hint { opacity: 1; transform: translateY(0); }
    
    .card.copied { border-color: var(--border-success); background: linear-gradient(145deg, color-mix(in oklch, var(--clr-status-success) 5%, var(--glass-surface)) 0%, color-mix(in oklch, var(--glass-surface) 50%, transparent) 50%, color-mix(in oklch, var(--bg-surface) 10%, transparent) 100%); }
    .card.copied .card-title { color: var(--text-success); border-color: var(--border-success); background: color-mix(in oklch, var(--clr-status-success) 10%, transparent); }
    .card.copied .copy-hint { color: var(--text-success); }
    .card.copied .icon-copy { opacity: 0; transform: scale(0.5) rotate(-15deg); }
    .card.copied .icon-check { opacity: 1; transform: scale(1) rotate(0deg); }

    .card-title { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600; color: var(--text-secondary); margin-block-end: auto; padding: 0.5rem 1rem; border: 1px solid transparent; border-radius: var(--radius-full); transition: all var(--dur-base) var(--ease-spring); position: relative; z-index: 2; pointer-events: none; will-change: background-color, border-color, color; }
    .spinner-wrapper { width: 100%; flex-grow: 1; display: flex; align-items: center; justify-content: center; font-size: 3rem; padding-block-end: 1.5rem; transition: transform 0.5s var(--ease-spring); pointer-events: none; will-change: transform; }
    .copy-hint { position: absolute; inset-block-end: 1.25rem; font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.05em; color: var(--text-secondary); opacity: 0; transform: translateY(0.625rem); transition: all var(--dur-base) var(--ease-spring); display: flex; align-items: center; gap: 0.5rem; pointer-events: none; }
    
    .icon-wrapper { position: relative; width: 1.125rem; height: 1.125rem; display: flex; align-items: center; justify-content: center; }
    .icon-wrapper svg { position: absolute; width: 100%; height: 100%; transition: all 0.5s var(--ease-spring); will-change: transform, opacity; }
    .icon-check { opacity: 0; transform: scale(0.5) rotate(15deg); }

    /* Toast */
    #toast { position: fixed; inset-block-end: 2rem; inset-inline-start: 50%; transform: translateX(-50%) translateY(8rem) scale(0.9); background: var(--text-primary); color: var(--bg-canvas); padding: 0.75rem 1.5rem; border-radius: var(--radius-full); font-weight: 600; font-size: 0.875rem; letter-spacing: 0.03125em; opacity: 0; transition: all 0.6s var(--ease-spring); z-index: 9999; pointer-events: none; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap; box-shadow: 0 10px 40px -10px color-mix(in oklch, var(--clr-core-black) 40%, transparent); will-change: transform, opacity; }
    #toast.show { transform: translateX(-50%) translateY(0) scale(1); opacity: 1; }
    #toast svg { width: 1.125rem; height: 1.125rem; color: var(--text-success); }
    
    /* Footer */
    .footer { margin-block-start: auto; padding-block: 2rem; padding-inline: var(--px-mob); border-block-start: 1px solid var(--border-subtle); position: relative; z-index: 1; background: linear-gradient(180deg, transparent 0%, color-mix(in oklch, var(--clr-neutral-900) 2%, transparent) 40%, color-mix(in oklch, var(--clr-neutral-900) 5%, transparent) 70%, color-mix(in oklch, var(--clr-neutral-900) 10%, transparent) 100%); }
    .footer-content { max-width: calc(var(--w-max) - (var(--px-mob) * 2)); margin-inline: auto; display: flex; align-items: center; justify-content: center; text-align: center; }
    .footer-copyright { font-size: 0.875rem; color: var(--text-secondary); }
    .footer-copyright a { color: var(--text-primary); font-weight: 600; transition: color 0.3s var(--ease-smooth); }
    .footer-copyright a:hover, .footer-copyright a:focus-visible { color: var(--text-accent); text-decoration: underline; text-underline-offset: 4px; }

    /* Media Queries */
    @media (width >= 40rem) { 
      .hide-mobile { display: inline; } 
      .navbar { inset-block-start: 1.5rem; width: calc(100% - (var(--px-tab) * 2)); max-width: calc(var(--w-max) - (var(--px-tab) * 2)); } 
      .navbar-logo { font-size: 1rem; } 
      .nav-actions { gap: 1.5rem; } 
      .main-content { padding-block: 10rem 5rem; padding-inline: var(--px-tab); } 
      .header-section h1 { font-size: 3rem; } 
      .grid-container { grid-template-columns: repeat(auto-fit, minmax(16.25rem, 1fr)); gap: 1.5rem; } 
      .footer { padding-inline: var(--px-tab); }
      .footer-content { max-width: calc(var(--w-max) - (var(--px-tab) * 2)); }
    }
    @media (width >= 64rem) { 
      .navbar { inset-block-start: 2rem; width: calc(100% - (var(--px-desk) * 2)); max-width: calc(var(--w-max) - (var(--px-desk) * 2)); } 
      .main-content { padding-block: 12rem 6.25rem; padding-inline: var(--px-desk); } 
      .header-section { margin-block-end: 6rem; } 
      .header-section h1 { font-size: 3.5rem; letter-spacing: -0.05em; } 
      .grid-container { grid-template-columns: repeat(auto-fit, minmax(17.5rem, 1fr)); gap: 1.75rem; } 
      #toast { inset-block-end: 2.5rem; } 
      .footer { padding-inline: var(--px-desk); }
      .footer-content { max-width: calc(var(--w-max) - (var(--px-desk) * 2)); }
    }

    @media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; } }

    /* =========================================
       BRAILLE SPINNER ENGINE
       ========================================= */
    .braille-loader { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .braille-loader::after { display: inline-block; white-space: pre; background: linear-gradient(90deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-base) 70%, var(--loader-shimmer-peak)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-base) 70%, var(--loader-shimmer-peak)) 75%, var(--loader-shimmer-base) 100%); background-size: 200% auto; color: transparent; -webkit-background-clip: text; background-clip: text; will-change: background-position, filter, opacity; pointer-events: none; }

    @keyframes l-swp { 0% { background-position: 200% center; filter: brightness(.7); } 50% { filter: brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color)); } 100% { background-position: -200% center; filter: brightness(.7); } }
    @keyframes l-swp-diag { 0% { background-position: 200% 200%; filter: brightness(.7); } 50% { filter: brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color)); } 100% { background-position: -200% -200%; filter: brightness(.7); } }
    @keyframes l-swp-y-dn { 0% { background-position: center -200%; filter: brightness(.7); } 50% { filter: brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color)); } 100% { background-position: center 200%; filter: brightness(.7); } }
    @keyframes l-swp-y-up { 0% { background-position: center 200%; filter: brightness(.7); } 50% { filter: brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color)); } 100% { background-position: center -200%; filter: brightness(.7); } }
    @keyframes l-brt-sync { 0%, 100% { opacity: .3; filter: drop-shadow(0 0 0 transparent) brightness(.6); background-position: 200% center; } 45%, 55% { opacity: 1; filter: drop-shadow(0 0 var(--loader-glow-lg) var(--loader-glow-color)) brightness(1.4); background-position: 50% center; } }
    @keyframes l-pls-sync { 0%, 50%, 100% { opacity: .3; filter: drop-shadow(0 0 0 transparent) brightness(.8); background-position: 200% center; } 18% { opacity: 1; filter: drop-shadow(0 0 var(--loader-glow-lg) var(--loader-glow-color)) brightness(1.5) contrast(1.2); background-position: 50% center; } 34% { background-position: -100% center; } }
    @keyframes l-glc-sync { 0%, 60%, 100% { filter: contrast(1) brightness(.8) drop-shadow(0 0 0 transparent); } 12%, 18%, 45%, 85%, 90% { filter: contrast(3) brightness(1.8) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color)); } }

    .spinner-cascade::after { background: linear-gradient(135deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 75%, var(--loader-shimmer-base) 100%); background-size: 200% 200%; -webkit-background-clip: text; content: "⠁⠀⠀⠀"; animation: sp-csc 1.1s step-end infinite, l-swp-diag 1.1s linear infinite; }
    @keyframes sp-csc{0%,100%{content:"⠁⠀⠀⠀"}7.1%{content:"⠋⠀⠀⠀"}14.2%{content:"⠞⠁⠀⠀"}21.4%{content:"⡴⠋⠀⠀"}28.5%{content:"⣠⠞⠁⠀"}35.7%{content:"⢀⡴⠋⠀"}42.8%{content:"⠀⣠⠞⠁"}50%{content:"⠀⢀⡴⠋"}57.1%{content:"⠀⠀⣠⠞"}64.2%{content:"⠀⠀⢀⡴"}71.4%{content:"⠀⠀⠀⣠"}78.5%{content:"⠀⠀⠀⢀"}85.7%,92.8%{content:"⠀⠀⠀⠀"}}
    .spinner-wave::after { content: "⠑⢄⠔⠑"; animation: sp-wav 0.8s step-end infinite, l-swp 0.8s linear infinite; }
    @keyframes sp-wav{0%,100%{content:"⠑⢄⠔⠑"}12.5%{content:"⠊⠆⢄⠊"}25%{content:"⠢⠑⢄⠢"}37.5%{content:"⢄⠢⠑⢄"}50%{content:"⠔⢄⠢⠔"}62.5%{content:"⠒⠔⢄⠒"}75%{content:"⠆⠒⠔⠆"}87.5%{content:"⠁⠆⠒⠁"}}
    .spinner-helix::after { content: "⢁⠦⠔⡈"; animation: sp-hlx 0.6s step-end infinite, l-swp 0.6s ease-in-out infinite alternate; }
    @keyframes sp-hlx{0%,100%{content:"⢁⠦⠔⡈"}16.6%{content:"⠦⠔⡈⠔"}33.3%{content:"⠔⡈⠔⠦"}50%{content:"⡈⠔⠦⢁"}66.6%{content:"⠔⠦⢁⠦"}83.3%{content:"⠦⢁⠦⠔"}}
    .spinner-rain::after { background: linear-gradient(180deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 75%, var(--loader-shimmer-base) 100%); background-size: 100% 200%; -webkit-background-clip: text; content: "⠁⠄⠂⡀"; animation: sp-ran 0.7s step-end infinite, l-swp-y-dn 0.7s linear infinite; }
    @keyframes sp-ran{0%,100%{content:"⠁⠄⠂⡀"}12.5%{content:"⠊⡀⠌⠀"}25%{content:"⠔⠈⡐⠁"}37.5%{content:"⡀⠑⠡⠊"}50%{content:"⠡⠢⢂⠔"}62.5%{content:"⢂⢄⠄⡠"}75%{content:"⠄⡀⡀⢀"}87.5%{content:"⡀⠀⠁⠁"}}
    .spinner-breathe::after { content: "⠀"; animation: sp-brt 2.2s step-end infinite, l-brt-sync 2.2s ease-in-out infinite; }
    @keyframes sp-brt{0%{content:"⠀"}8%{content:"⠁"}15%{content:"⠑"}21%{content:"⠕"}26%{content:"⢕"}30%{content:"⢝"}34%{content:"⢟"}38%{content:"⢿"}45%,55%{content:"⣿"}62%{content:"⢿"}66%{content:"⢟"}70%{content:"⢝"}74%{content:"⢕"}79%{content:"⠕"}85%{content:"⠑"}92%{content:"⠁"}100%{content:"⠀"}}
    .spinner-diagonal::after { background: linear-gradient(135deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 75%, var(--loader-shimmer-base) 100%); background-size: 200% 200%; -webkit-background-clip: text; content: "⠀⠀"; animation: sp-dgl 1.12s step-end infinite, l-swp-diag 1.12s linear infinite; }
    @keyframes sp-dgl{0%,100%{content:"⠀⠀"}7.1%{content:"⠁⠀"}14.2%{content:"⠋⠀"}21.4%{content:"⠟⠁"}28.5%{content:"⡿⠋"}35.7%{content:"⣿⠟"}42.8%{content:"⣿⡿"}50%{content:"⣿⣿"}57.1%{content:"⣾⣿"}64.2%{content:"⣴⣿"}71.4%{content:"⣠⣾"}78.5%{content:"⢀⣴"}85.7%{content:"⠀⣠"}92.8%{content:"⠀⢀"}}
    .spinner-pulse::after { content: "⠀⠶⠀"; animation: sp-pls 1.4s step-end infinite, l-pls-sync 1.4s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes sp-pls{0%,100%{content:"⠀⠶⠀"}10%{content:"⠰⣿⠆"}18%{content:"⢾⣿⡷"}26%{content:"⢾⣉⡷"}34%{content:"⣏⣉⣹"}42%{content:"⡁⠀⢈"}50%{content:"⠀⠶⠀"}}
    .spinner-snake::after { content: "⣁⠀⠀"; animation: sp-snk 1.2s step-end infinite, l-swp 0.6s ease-in-out infinite alternate; }
    @keyframes sp-snk{0%{content:"⣁⠀⠀"}6.25%{content:"⡉⠀⠀"}12.5%{content:"⠉⠀⠁"}18.75%{content:"⠈⠀⠉"}25%{content:"⠀⠀⠙"}31.25%{content:"⠀⠀⠚"}37.5%{content:"⠐⠀⠒"}43.75%{content:"⠒⠀⠂"}50%{content:"⠖⠀⠀"}56.25%{content:"⠦⠀⠀"}62.5%{content:"⠤⠀⠄"}68.75%{content:"⠠⠀⠤"}75%{content:"⠀⠀⢤"}81.25%{content:"⠀⠀⣠"}87.5%{content:"⢀⠀⣀"}93.75%{content:"⣀⠀⡀"}100%{content:"⣁⠀⠀"}}
    .spinner-glitch::after { content: "⢕⢕⢕"; animation: sp-glc 0.8s step-end infinite, l-glc-sync 0.8s step-end infinite; }
    @keyframes sp-glc{0%,60%,100%{content:"⢕⢕⢕"}12%,85%{content:"⡪⡪⡪"}18%,90%{content:"⢊⠔⡡"}45%{content:"⡡⢊⠔"}}
    .spinner-columns::after { background: linear-gradient(0deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 75%, var(--loader-shimmer-base) 100%); background-size: 100% 200%; -webkit-background-clip: text; content: "⠀⠀⠀"; animation: sp-col 1.8s step-end infinite, l-swp-y-up 1.8s linear infinite; }
    @keyframes sp-col{0%,100%{content:"⠀⠀⠀"}4%{content:"⡀⠀⠀"}8%{content:"⡄⠀⠀"}12%{content:"⡆⠀⠀"}16%{content:"⡇⠀⠀"}20%{content:"⣇⠀⠀"}24%{content:"⣧⠀⠀"}28%{content:"⣷⠀⠀"}32%{content:"⣿⠀⠀"}36%{content:"⣿⡀⠀"}40%{content:"⣿⡄⠀"}44%{content:"⣿⡆⠀"}48%{content:"⣿⡇⠀"}52%{content:"⣿⣇⠀"}56%{content:"⣿⣧⠀"}60%{content:"⣿⣷⠀"}64%{content:"⣿⣿⠀"}68%{content:"⣿⣿⡀"}72%{content:"⣿⣿⡄"}76%{content:"⣿⣿⡆"}80%{content:"⣿⣿⡇"}84%{content:"⣿⣿⣇"}88%{content:"⣿⣿⣧"}92%{content:"⣿⣿⣷"}96%{content:"⣿⣿⣿"}}
    .spinner-scan::after { content: "⣿⠀⠀⠀"; animation: sp-scn 0.6s step-end infinite alternate, l-swp 0.6s linear infinite alternate; }
    @keyframes sp-scn{0%{content:"⣿⠀⠀⠀"}16.6%{content:"⢸⡇⠀⠀"}33.3%{content:"⠀⣿⠀⠀"}50%{content:"⠀⢸⡇⠀"}66.6%{content:"⠀⠀⣿⠀"}83.3%{content:"⠀⠀⢸⡇"}100%{content:"⠀⠀⠀⣿"}}
    .spinner-sweep::after { background: linear-gradient(0deg, var(--loader-shimmer-base) 0%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 25%, var(--loader-shimmer-peak) 50%, color-mix(in oklch, var(--loader-shimmer-peak) 30%, var(--loader-shimmer-base)) 75%, var(--loader-shimmer-base) 100%); background-size: 100% 200%; -webkit-background-clip: text; content: "⠀⠀⠀"; animation: sp-swp 1.4s step-end infinite, l-swp-y-up 0.7s ease-in-out infinite alternate; }
    @keyframes sp-swp{0%{content:"⠀⠀⠀"}12.5%{content:"⣀⠀⣀"}25%{content:"⣤⠀⣤"}37.5%{content:"⣶⠀⣶"}50%{content:"⣿⠀⣿"}62.5%{content:"⣶⠀⣶"}75%{content:"⣤⠀⣤"}87.5%{content:"⣀⠀⣀"}100%{content:"⠀⠀⠀"}}
    .spinner-orbit::after { content: "⠉"; animation: sp-orb 0.6s step-end infinite, l-swp 0.6s linear infinite; }
    @keyframes sp-orb{0%{content:"⠉"}12.5%{content:"⠘"}25%{content:"⠰"}37.5%{content:"⢠"}50%{content:"⣀"}62.5%{content:"⡄"}75%{content:"⠆"}87.5%{content:"⠃"}100%{content:"⠉"}}
    .spinner-sparkle::after { content: "⠀⠁⠀⠂"; animation: sp-spr 0.5s step-end infinite, l-glc-sync 0.5s step-end infinite; }
    @keyframes sp-spr{0%,90%,100%{content:"⠀⠁⠀⠂"}10%{content:"⠠⠀⢀⠀"}20%{content:"⠀⠐⠉⠁"}30%{content:"⠁⠂⠀⠐"}40%{content:"⠑⠊⠔⠢"}50%{content:"⠀⢀⠠⠀"}60%{content:"⠂⠀⠁⠀"}70%{content:"⠐⠀⠐⠀"}80%{content:"⢀⠠⠑⠊"}}
    .spinner-basic::after { content: "⠋"; animation: sp-bsc 0.8s step-end infinite, l-swp 0.8s linear infinite; }
    @keyframes sp-bsc{0%{content:"⠋"}10%{content:"⠙"}20%{content:"⠹"}30%{content:"⠸"}40%{content:"⠼"}50%{content:"⠴"}60%{content:"⠦"}70%{content:"⠧"}80%{content:"⠇"}90%{content:"⠏"}100%{content:"⠋"}}
    body.tab-inactive .braille-loader::after { animation-play-state: paused !important; }
  </style>
</head>
<body>
  <div id="page-loader" aria-hidden="true">
    <span class="braille-loader spinner-pulse"></span>
    <span class="loader-text">Initializing</span>
  </div>

  <nav class="navbar">
    <div class="navbar-logo">
      <span class="hide-mobile">Unicode&nbsp;</span>Braille 
      <span class="icon">⠿</span> 
      <span class="badge">v1.0</span>
    </div>
    <div class="nav-actions">
      <div class="theme-toggle" data-active="system" role="radiogroup" aria-label="Theme preference" tabindex="0">
        <button class="theme-btn" data-set-theme="light" aria-label="Light mode" role="radio" tabindex="-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        </button>
        <button class="theme-btn active" data-set-theme="system" aria-label="System mode" role="radio" tabindex="-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
        </button>
        <button class="theme-btn" data-set-theme="dark" aria-label="Dark mode" role="radio" tabindex="-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </div>
      <a href="https://github.com/ledihildawan/unicode-braille-animations" target="_blank" class="github-link" aria-label="GitHub Repository">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
    </div>
  </nav>

  <main class="main-content">
    <section class="header-section">
      <h1>Unicode Braille Animations ⠿</h1>
      <p>A seamless collection of pure CSS loading indicators built entirely with Unicode Braille characters. Lightweight, accessible, infinitely scalable, and copy-paste ready.</p>
    </section>

    <section class="grid-container" id="cards-grid">
      <div class="card" data-snippet="spinner-cascade" data-name="Cascade Drop" role="button" tabindex="0"><div class="card-title">Cascade Drop</div><div class="spinner-wrapper"><span class="braille-loader spinner-cascade" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-wave" data-name="Ripple Wave" role="button" tabindex="0"><div class="card-title">Ripple Wave</div><div class="spinner-wrapper"><span class="braille-loader spinner-wave" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-helix" data-name="Twin Helix" role="button" tabindex="0"><div class="card-title">Twin Helix</div><div class="spinner-wrapper"><span class="braille-loader spinner-helix" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-rain" data-name="Matrix Rain" role="button" tabindex="0"><div class="card-title">Matrix Rain</div><div class="spinner-wrapper"><span class="braille-loader spinner-rain" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-breathe" data-name="Breathing Focus" role="button" tabindex="0"><div class="card-title">Breathing Focus</div><div class="spinner-wrapper"><span class="braille-loader spinner-breathe" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-diagonal" data-name="Diagonal Wipe" role="button" tabindex="0"><div class="card-title">Diagonal Wipe</div><div class="spinner-wrapper"><span class="braille-loader spinner-diagonal" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-pulse" data-name="Core Pulse" role="button" tabindex="0"><div class="card-title">Core Pulse</div><div class="spinner-wrapper"><span class="braille-loader spinner-pulse" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-snake" data-name="Slithering Snake" role="button" tabindex="0"><div class="card-title">Slithering Snake</div><div class="spinner-wrapper"><span class="braille-loader spinner-snake" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-glitch" data-name="Static Glitch" role="button" tabindex="0"><div class="card-title">Static Glitch</div><div class="spinner-wrapper"><span class="braille-loader spinner-glitch" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-columns" data-name="Rising Columns" role="button" tabindex="0"><div class="card-title">Rising Columns</div><div class="spinner-wrapper"><span class="braille-loader spinner-columns" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-scan" data-name="Radar Scan" role="button" tabindex="0"><div class="card-title">Radar Scan</div><div class="spinner-wrapper"><span class="braille-loader spinner-scan" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-sweep" data-name="Fill Sweep" role="button" tabindex="0"><div class="card-title">Fill Sweep</div><div class="spinner-wrapper"><span class="braille-loader spinner-sweep" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-orbit" data-name="Satellite Orbit" role="button" tabindex="0"><div class="card-title">Satellite Orbit</div><div class="spinner-wrapper"><span class="braille-loader spinner-orbit" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-sparkle" data-name="Stardust Sparkle" role="button" tabindex="0"><div class="card-title">Stardust Sparkle</div><div class="spinner-wrapper"><span class="braille-loader spinner-sparkle" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
      <div class="card" data-snippet="spinner-basic" data-name="Classic Spinner" role="button" tabindex="0"><div class="card-title">Classic Spinner</div><div class="spinner-wrapper"><span class="braille-loader spinner-basic" aria-hidden="true"></span></div><div class="copy-hint"><div class="icon-wrapper"><svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg><svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span>Copy</span></div></div>
