  <div id="toast" role="status" aria-live="polite">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> <span>Copied to clipboard!</span>
  </div>

  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    
    function playUiSound(type) {
      if (prefersReducedMotion.matches) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      if (type === 'pop') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(600, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(300, audioCtx.currentTime + 0.1);
        gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
        osc.start(); osc.stop(audioCtx.currentTime + 0.1);
      } else if (type === 'switch') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(400, audioCtx.currentTime);
        osc.frequency.linearRampToValueAtTime(600, audioCtx.currentTime + 0.05);
        gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
        gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
        osc.start(); osc.stop(audioCtx.currentTime + 0.05);
      }
    }

    function triggerHaptic() {
      if (!prefersReducedMotion.matches && navigator.vibrate) navigator.vibrate(50);
    }

    window.addEventListener('load', () => {
      if (!prefersReducedMotion.matches) {
        document.querySelectorAll('.card').forEach((el, i) => { el.style.animationDelay = `${i * 0.04}s`; });
      }
      setTimeout(() => document.body.classList.add('loaded'), 600);
    });

    const htmlEl = document.documentElement;
    const themeToggle = document.querySelector('.theme-toggle');
    const themeBtns = document.querySelectorAll('[data-set-theme]');
    let currentThemeIndex = 0;
    const themes = ['light', 'system', 'dark'];
    
    function applyTheme(theme) {
      themeBtns.forEach(btn => btn.classList.remove('active'));
      const activeBtn = document.querySelector(`[data-set-theme="${theme}"]`);
      if (activeBtn) activeBtn.classList.add('active');
      theme === 'system' ? htmlEl.removeAttribute('data-theme') : htmlEl.setAttribute('data-theme', theme);
      localStorage.setItem('braille-ui-theme', theme);
      themeToggle.setAttribute('data-active', theme);
      currentThemeIndex = themes.indexOf(theme);
    }

    themeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        playUiSound('switch');
        triggerHaptic();
        applyTheme(btn.getAttribute('data-set-theme'));
      });
    });

    themeToggle.addEventListener('keydown', e => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        const next = (currentThemeIndex + 1) % themes.length;
        playUiSound('switch'); triggerHaptic(); applyTheme(themes[next]);
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        const prev = (currentThemeIndex - 1 + themes.length) % themes.length;
        playUiSound('switch'); triggerHaptic(); applyTheme(themes[prev]);
      }
    });
    
    applyTheme(localStorage.getItem('braille-ui-theme') || 'system');

    let toastTimeout;
    
    // JS Stringified CSS for the standalone copied component
    // These variables are specifically generated to make the loader standalone if pasted anywhere else
    const baseLoaderCSS=`:root{--loader-shimmer-base:#3f3f46;--loader-shimmer-peak:#fff;--loader-glow-lg:0.5rem;--loader-glow-sm:0.25rem;--loader-glow-color:#fff}.braille-loader::after{display:inline-block;white-space:pre;background:linear-gradient(90deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-base) 70%,var(--loader-shimmer-peak)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-base) 70%,var(--loader-shimmer-peak)) 75%,var(--loader-shimmer-base) 100%);background-size:200% auto;color:transparent;-webkit-background-clip:text;background-clip:text;will-change:background-position,filter,opacity;pointer-events:none}`;
    
    const lightSyncEngines={'l-swp':`@keyframes l-swp{0%{background-position:200% center;filter:brightness(.7)}50%{filter:brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color))}100%{background-position:-200% center;filter:brightness(.7)}}`,'l-swp-diag':`@keyframes l-swp-diag{0%{background-position:200% 200%;filter:brightness(.7)}50%{filter:brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color))}100%{background-position:-200% -200%;filter:brightness(.7)}}`,'l-swp-y-dn':`@keyframes l-swp-y-dn{0%{background-position:center -200%;filter:brightness(.7)}50%{filter:brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color))}100%{background-position:center 200%;filter:brightness(.7)}}`,'l-swp-y-up':`@keyframes l-swp-y-up{0%{background-position:center 200%;filter:brightness(.7)}50%{filter:brightness(1.3) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color))}100%{background-position:center -200%;filter:brightness(.7)}}`,'l-brt-sync':`@keyframes l-brt-sync{0%,100%{opacity:.3;filter:drop-shadow(0 0 0 transparent) brightness(.6);background-position:200% center}45%,55%{opacity:1;filter:drop-shadow(0 0 var(--loader-glow-lg) var(--loader-glow-color)) brightness(1.4);background-position:50% center}}`,'l-pls-sync':`@keyframes l-pls-sync{0%,50%,100%{opacity:.3;filter:drop-shadow(0 0 0 transparent) brightness(.8);background-position:200% center}18%{opacity:1;filter:drop-shadow(0 0 var(--loader-glow-lg) var(--loader-glow-color)) brightness(1.5) contrast(1.2);background-position:50% center}34%{background-position:-100% center}}`,'l-glc-sync':`@keyframes l-glc-sync{0%,60%,100%{filter:contrast(1) brightness(.8) drop-shadow(0 0 0 transparent)}12%,18%,45%,85%,90%{filter:contrast(3) brightness(1.8) drop-shadow(0 0 var(--loader-glow-sm) var(--loader-glow-color))}}`};
    const cssSnippets={'spinner-cascade':{code:`.spinner-cascade::after{background:linear-gradient(135deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 75%,var(--loader-shimmer-base) 100%);background-size:200% 200%;-webkit-background-clip:text;content:"⠁⠀⠀⠀";animation:sp-csc 1.1s step-end infinite,l-swp-diag 1.1s linear infinite}\n@keyframes sp-csc{0%,100%{content:"⠁⠀⠀⠀"}7.1%{content:"⠋⠀⠀⠀"}14.2%{content:"⠞⠁⠀⠀"}21.4%{content:"⡴⠋⠀⠀"}28.5%{content:"⣠⠞⠁⠀"}35.7%{content:"⢀⡴⠋⠀"}42.8%{content:"⠀⣠⠞⠁"}50%{content:"⠀⢀⡴⠋"}57.1%{content:"⠀⠀⣠⠞"}64.2%{content:"⠀⠀⢀⡴"}71.4%{content:"⠀⠀⠀⣠"}78.5%{content:"⠀⠀⠀⢀"}85.7%,92.8%{content:"⠀⠀⠀⠀"}}`,sync:'l-swp-diag'},'spinner-wave':{code:`.spinner-wave::after{content:"⠑⢄⠔⠑";animation:sp-wav .8s step-end infinite,l-swp .8s linear infinite}\n@keyframes sp-wav{0%,100%{content:"⠑⢄⠔⠑"}12.5%{content:"⠊⠆⢄⠊"}25%{content:"⠢⠑⢄⠢"}37.5%{content:"⢄⠢⠑⢄"}50%{content:"⠔⢄⠢⠔"}62.5%{content:"⠒⠔⢄⠒"}75%{content:"⠆⠒⠔⠆"}87.5%{content:"⠁⠆⠒⠁"}}`,sync:'l-swp'},'spinner-helix':{code:`.spinner-helix::after{content:"⢁⠦⠔⡈";animation:sp-hlx .6s step-end infinite,l-swp .6s ease-in-out infinite alternate}\n@keyframes sp-hlx{0%,100%{content:"⢁⠦⠔⡈"}16.6%{content:"⠦⠔⡈⠔"}33.3%{content:"⠔⡈⠔⠦"}50%{content:"⡈⠔⠦⢁"}66.6%{content:"⠔⠦⢁⠦"}83.3%{content:"⠦⢁⠦⠔"}}`,sync:'l-swp'},'spinner-rain':{code:`.spinner-rain::after{background:linear-gradient(180deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 75%,var(--loader-shimmer-base) 100%);background-size:100% 200%;-webkit-background-clip:text;content:"⠁⠄⠂⡀";animation:sp-ran .7s step-end infinite,l-swp-y-dn .7s linear infinite}\n@keyframes sp-ran{0%,100%{content:"⠁⠄⠂⡀"}12.5%{content:"⠊⡀⠌⠀"}25%{content:"⠔⠈⡐⠁"}37.5%{content:"⡀⠑⠡⠊"}50%{content:"⠡⠢⢂⠔"}62.5%{content:"⢂⢄⠄⡠"}75%{content:"⠄⡀⡀⢀"}87.5%{content:"⡀⠀⠁⠁"}}`,sync:'l-swp-y-dn'},'spinner-breathe':{code:`.spinner-breathe::after{content:"⠀";animation:sp-brt 2.2s step-end infinite,l-brt-sync 2.2s ease-in-out infinite}\n@keyframes sp-brt{0%{content:"⠀"}8%{content:"⠁"}15%{content:"⠑"}21%{content:"⠕"}26%{content:"⢕"}30%{content:"⢝"}34%{content:"⢟"}38%{content:"⢿"}45%,55%{content:"⣿"}62%{content:"⢿"}66%{content:"⢟"}70%{content:"⢝"}74%{content:"⢕"}79%{content:"⠕"}85%{content:"⠑"}92%{content:"⠁"}100%{content:"⠀"}}`,sync:'l-brt-sync'},'spinner-diagonal':{code:`.spinner-diagonal::after{background:linear-gradient(135deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 75%,var(--loader-shimmer-base) 100%);background-size:200% 200%;-webkit-background-clip:text;content:"⠀⠀";animation:sp-dgl 1.12s step-end infinite,l-swp-diag 1.12s linear infinite}\n@keyframes sp-dgl{0%,100%{content:"⠀⠀"}7.1%{content:"⠁⠀"}14.2%{content:"⠋⠀"}21.4%{content:"⠟⠁"}28.5%{content:"⡿⠋"}35.7%{content:"⣿⠟"}42.8%{content:"⣿⡿"}50%{content:"⣿⣿"}57.1%{content:"⣾⣿"}64.2%{content:"⣴⣿"}71.4%{content:"⣠⣾"}78.5%{content:"⢀⣴"}85.7%{content:"⠀⣠"}92.8%{content:"⠀⢀"}}`,sync:'l-swp-diag'},'spinner-pulse':{code:`.spinner-pulse::after{content:"⠀⠶⠀";animation:sp-pls 1.4s step-end infinite,l-pls-sync 1.4s cubic-bezier(.4,0,.6,1) infinite}\n@keyframes sp-pls{0%,100%{content:"⠀⠶⠀"}10%{content:"⠰⣿⠆"}18%{content:"⢾⣿⡷"}26%{content:"⢾⣉⡷"}34%{content:"⣏⣉⣹"}42%{content:"⡁⠀⢈"}50%{content:"⠀⠶⠀"}}`,sync:'l-pls-sync'},'spinner-snake':{code:`.spinner-snake::after{content:"⣁⠀⠀";animation:sp-snk 1.2s step-end infinite,l-swp .6s ease-in-out infinite alternate}\n@keyframes sp-snk{0%{content:"⣁⠀⠀"}6.25%{content:"⡉⠀⠀"}12.5%{content:"⠉⠀⠁"}18.75%{content:"⠈⠀⠉"}25%{content:"⠀⠀⠙"}31.25%{content:"⠀⠀⠚"}37.5%{content:"⠐⠀⠒"}43.75%{content:"⠒⠀⠂"}50%{content:"⠖⠀⠀"}56.25%{content:"⠦⠀⠀"}62.5%{content:"⠤⠀⠄"}68.75%{content:"⠠⠀⠤"}75%{content:"⠀⠀⢤"}81.25%{content:"⠀⠀⣠"}87.5%{content:"⢀⠀⣀"}93.75%{content:"⣀⠀⡀"}100%{content:"⣁⠀⠀"}}`,sync:'l-swp'},'spinner-glitch':{code:`.spinner-glitch::after{content:"⢕⢕⢕";animation:sp-glc .8s step-end infinite,l-glc-sync .8s step-end infinite}\n@keyframes sp-glc{0%,60%,100%{content:"⢕⢕⢕"}12%,85%{content:"⡪⡪⡪"}18%,90%{content:"⢊⠔⡡"}45%{content:"⡡⢊⠔"}}`,sync:'l-glc-sync'},'spinner-columns':{code:`.spinner-columns::after{background:linear-gradient(0deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 75%,var(--loader-shimmer-base) 100%);background-size:100% 200%;-webkit-background-clip:text;content:"⠀⠀⠀";animation:sp-col 1.8s step-end infinite,l-swp-y-up 1.8s linear infinite}\n@keyframes sp-col{0%,100%{content:"⠀⠀⠀"}4%{content:"⡀⠀⠀"}8%{content:"⡄⠀⠀"}12%{content:"⡆⠀⠀"}16%{content:"⡇⠀⠀"}20%{content:"⣇⠀⠀"}24%{content:"⣧⠀⠀"}28%{content:"⣷⠀⠀"}32%{content:"⣿⠀⠀"}36%{content:"⣿⡀⠀"}40%{content:"⣿⡄⠀"}44%{content:"⣿⡆⠀"}48%{content:"⣿⡇⠀"}52%{content:"⣿⣇⠀"}56%{content:"⣿⣧⠀"}60%{content:"⣿⣷⠀"}64%{content:"⣿⣿⠀"}68%{content:"⣿⣿⡀"}72%{content:"⣿⣿⡄"}76%{content:"⣿⣿⡆"}80%{content:"⣿⣿⡇"}84%{content:"⣿⣿⣇"}88%{content:"⣿⣿⣧"}92%{content:"⣿⣿⣷"}96%{content:"⣿⣿⣿"}}`,sync:'l-swp-y-up'},'spinner-scan':{code:`.spinner-scan::after{content:"⣿⠀⠀⠀";animation:sp-scn .6s step-end infinite alternate,l-swp .6s linear infinite alternate}\n@keyframes sp-scn{0%{content:"⣿⠀⠀⠀"}16.6%{content:"⢸⡇⠀⠀"}33.3%{content:"⠀⣿⠀⠀"}50%{content:"⠀⢸⡇⠀"}66.6%{content:"⠀⠀⣿⠀"}83.3%{content:"⠀⠀⢸⡇"}100%{content:"⠀⠀⠀⣿"}}`,sync:'l-swp'},'spinner-sweep':{code:`.spinner-sweep::after{background:linear-gradient(0deg,var(--loader-shimmer-base) 0%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 25%,var(--loader-shimmer-peak) 50%,color-mix(in oklch,var(--loader-shimmer-peak) 30%,var(--loader-shimmer-base)) 75%,var(--loader-shimmer-base) 100%);background-size:100% 200%;-webkit-background-clip:text;content:"⠀⠀⠀";animation:sp-swp 1.4s step-end infinite,l-swp-y-up .7s ease-in-out infinite alternate}\n@keyframes sp-swp{0%{content:"⠀⠀⠀"}12.5%{content:"⣀⠀⣀"}25%{content:"⣤⠀⣤"}37.5%{content:"⣶⠀⣶"}50%{content:"⣿⠀⣿"}62.5%{content:"⣶⠀⣶"}75%{content:"⣤⠀⣤"}87.5%{content:"⣀⠀⣀"}100%{content:"⠀⠀⠀"}}`,sync:'l-swp-y-up'},'spinner-orbit':{code:`.spinner-orbit::after{content:"⠉";animation:sp-orb .6s step-end infinite,l-swp .6s linear infinite}\n@keyframes sp-orb{0%{content:"⠉"}12.5%{content:"⠘"}25%{content:"⠰"}37.5%{content:"⢠"}50%{content:"⣀"}62.5%{content:"⡄"}75%{content:"⠆"}87.5%{content:"⠃"}100%{content:"⠉"}}`,sync:'l-swp'},'spinner-sparkle':{code:`.spinner-sparkle::after{content:"⠀⠁⠀⠂";animation:sp-spr .5s step-end infinite,l-glc-sync .5s step-end infinite}\n@keyframes sp-spr{0%,90%,100%{content:"⠀⠁⠀⠂"}10%{content:"⠠⠀⢀⠀"}20%{content:"⠀⠐⠉⠁"}30%{content:"⠁⠂⠀⠐"}40%{content:"⠑⠊⠔⠢"}50%{content:"⠀⢀⠠⠀"}60%{content:"⠂⠀⠁⠀"}70%{content:"⠐⠀⠐⠀"}80%{content:"⢀⠠⠑⠊"}}`,sync:'l-glc-sync'},'spinner-basic':{code:`.spinner-basic::after{content:"⠋";animation:sp-bsc .8s step-end infinite,l-swp .8s linear infinite}\n@keyframes sp-bsc{0%{content:"⠋"}10%{content:"⠙"}20%{content:"⠹"}30%{content:"⠸"}40%{content:"⠼"}50%{content:"⠴"}60%{content:"⠦"}70%{content:"⠧"}80%{content:"⠇"}90%{content:"⠏"}100%{content:"⠋"}}`,sync:'l-swp'}};
    
    document.getElementById('cards-grid').addEventListener('click', e => {
      const card = e.target.closest('.card');
      if (!card) return;
      playUiSound('pop');
      triggerHaptic();
      card.classList.add('copied');
      setTimeout(() => card.classList.remove('copied'), 2000);

      const { snippet: className, name: displayName } = card.dataset;
      const snippetData = cssSnippets[className];
      const fullCode = `\n<span class="braille-loader ${className}" role="status" aria-label="Loading"></span>\n\n\n<style>\n${baseLoaderCSS}\n${lightSyncEngines[snippetData.sync]}\n${snippetData.code}\n</style>`;
      
      navigator.clipboard.writeText(fullCode).then(() => {
        const toast = document.getElementById('toast');
        toast.querySelector('span').innerText = `${displayName} Snippet Copied!`;
        if (toastTimeout) clearTimeout(toastTimeout);
        toast.classList.add('show');
        toastTimeout = setTimeout(() => toast.classList.remove('show'), 2500);
      });
    });

    document.getElementById('cards-grid').addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); e.target.closest('.card')?.click(); }
    });
    
    document.addEventListener("visibilitychange", () => {
      if (!prefersReducedMotion.matches) document.body.classList.toggle("tab-inactive", document.hidden);
    });
  </script>
</body>
</html>